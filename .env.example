# Extense website — environment variables
#
# Copy this to .env (for local dev) or .env.production (for deploy) and fill
# in real values. Vars prefixed PUBLIC_ are exposed to client-side code.

# Formspree endpoint for /contact form submissions.
# Set up: create a Formspree account, create a form, set destination email
# to contactus@ex-tense.co, copy the form action URL here.
# Format: https://formspree.io/f/{form_id}
PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/REPLACE_WITH_FORM_ID

# Site URL (used by RSS feed, sitemap, canonical URLs).
# Production: https://www.ex-tense.co
# Vercel preview: leave unset to fall back to Astro.site config
PUBLIC_SITE_URL=https://www.ex-tense.co
