<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE map PUBLIC "-//OASIS//DTD DITA Map//EN" "map.dtd">
<map id="part02-dtd-validation">
  <title>Part 2: Document Type Definitions (DTD)</title>
  <topicmeta>
    <shortdesc>Schema validation with DTDs: element declarations, attribute definitions, entities,
      and the difference between well-formed and valid XML.</shortdesc>
    <othermeta name="difficulty" content="beginner"/>
    <othermeta name="learningObjectives"
      content="Write DTD element and attribute declarations; validate XML against DTDs; use entities"/>
  </topicmeta>
  <topicref href="../topics/part02-dtd/ch05-what-is-dtd.dita">
    <topicmeta>
      <navtitle>What Is a DTD?</navtitle>
      <shortdesc>Why schemas exist, well-formed vs. valid XML, and how DTDs define document structure.</shortdesc>
    </topicmeta>
  </topicref>
  <topicref href="../topics/part02-dtd/ch06-dtd-element-declarations.dita">
    <topicmeta>
      <navtitle>DTD Element Declarations</navtitle>
      <shortdesc>Declaring elements with sequences, choices, occurrence indicators, and mixed content.</shortdesc>
    </topicmeta>
  </topicref>
  <topicref href="../topics/part02-dtd/ch07-dtd-attributes-entities.dita">
    <topicmeta>
      <navtitle>DTD Attributes and Entities</navtitle>
      <shortdesc>Attribute types, default behaviors, general entities, parameter entities, and DTD limitations.</shortdesc>
    </topicmeta>
  </topicref>
  <topicref href="../topics/part02-dtd/dtd-syntax-reference.dita">
    <topicmeta>
      <navtitle>DTD Quick Reference</navtitle>
      <shortdesc>Concise reference for DTD element, attribute, and entity declaration syntax.</shortdesc>
    </topicmeta>
  </topicref>
</map>
