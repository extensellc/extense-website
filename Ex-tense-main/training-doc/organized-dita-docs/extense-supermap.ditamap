  <topicmeta>
    <metadata>
      <othermeta name="learningObjectives"
                 content="Master DITA from content strategy through advanced development, then make content AI-ready for chatbots and RAG pipelines."/>
    </metadata>
  </topicmeta>

  <frontmatter>
    <topicref href="topics/frontmatter/preface.dita"/>
    <booklists><toc/></booklists>
  </frontmatter>

  <!-- ═══════════════════════════════════════════════════════════════
       PART SUBMAPS — Progressive Learning Path
       ═══════════════════════════════════════════════════════════════ -->

  <!-- Part I — Why Intelligent Content Matters (beginner) -->
  <part navtitle="Why Intelligent Content Matters">
    <topicmeta>
      <shortdesc>Understand why unstructured content fails AI, what intelligent content is, and how to measure readiness</shortdesc>
    </topicmeta>
    <mapref href="submaps/part01-why-intelligent-content.ditamap"/>
  </part>

  <!-- Part II — Content Preparation (beginner) -->
  <part navtitle="Content Preparation">
    <topicmeta>
      <shortdesc>Install the toolkit, configure your editor, and understand DITA fundamentals</shortdesc>
    </topicmeta>
    <mapref href="submaps/part02-content-preparation.ditamap"/>
  </part>

  <!-- Part III — Authoring DITA Content (intermediate) -->
  <part navtitle="Authoring DITA Content">
    <topicmeta>
      <shortdesc>Write your first project, master topic types, and learn reuse and variant management</shortdesc>
    </topicmeta>
    <mapref href="submaps/part03-authoring-dita-content.ditamap"/>
  </part>

  <!-- Part IV — Information Architecture (intermediate) -->
  <part navtitle="Information Architecture">
    <topicmeta>
      <shortdesc>Design topic hierarchies, define controlled vocabulary, and build progressive maps</shortdesc>
    </topicmeta>
    <mapref href="submaps/part04-information-architecture.ditamap"/>
  </part>

  <!-- Part V — Making Content Intelligent (intermediate) -->
  <part navtitle="Making Content Intelligent">
    <topicmeta>
      <shortdesc>Add AI-ready metadata, migrate from markdown, and apply machine-addressable authoring practices</shortdesc>
    </topicmeta>
    <mapref href="submaps/part05-making-content-intelligent.ditamap"/>
  </part>

  <!-- Part VI — Publishing & Automation (intermediate) -->
  <part navtitle="Publishing &amp; Automation">
    <topicmeta>
      <shortdesc>Build HTML5, PDF, and multi-channel deliverables from enriched DITA source</shortdesc>
    </topicmeta>
    <mapref href="submaps/part06-publishing-automation.ditamap"/>
  </part>

  <!-- Part VII — DITA-OT Development (advanced, developer only) -->
  <part navtitle="DITA-OT Development" audience="developer">
    <topicmeta>
      <shortdesc>DITA-OT architecture, plugin creation, Docker containers, and CI/CD pipelines</shortdesc>
    </topicmeta>
    <mapref href="submaps/part07-dita-ot-development.ditamap"/>
  </part>

  <!-- Part VIII — Advanced XSLT Customization (advanced, developer only;
       ditaval-filtering-variants.dita is audience="all" in the submap
       so writers retain that one topic) -->
  <part navtitle="Advanced XSLT Customization" audience="developer">
    <topicmeta>
      <shortdesc>Hands-on labs — build a complete HTML5 customization plugin from scratch</shortdesc>
    </topicmeta>
    <mapref href="submaps/part08-xslt-customization.ditamap"/>
  </part>

  <!-- Part IX — AI Pipeline & Chatbot Integration (advanced, developer only) -->
  <part navtitle="AI Pipeline &amp; Chatbot Integration" audience="developer">
    <topicmeta>
      <shortdesc>Connect enriched DITA content to RAG pipelines, vector stores, and chatbot delivery</shortdesc>
    </topicmeta>
    <mapref href="submaps/part09-ai-pipeline-integration.ditamap"/>
  </part>

  <!-- Part X — Benefits, Utilization & Impact (beginner) -->
  <part navtitle="Benefits, Utilization &amp; Impact">
    <topicmeta>
      <shortdesc>Measure ROI, leverage every intelligent feature, and understand the full impact</shortdesc>
    </topicmeta>
    <mapref href="submaps/part10-benefits-utilization-impact.ditamap"/>
  </part>

