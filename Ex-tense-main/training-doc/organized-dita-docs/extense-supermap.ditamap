    <publisherinformation>
      <published><completed><year>2026</year></completed></published>
    </publisherinformation>
    <critdates>
      <created date="2026-02-10"/>
    </critdates>
    <bookrights>
      <copyrfirst><year>2026</year></copyrfirst>
      <bookowner><organization>Extense LLC</organization></bookowner>
    </bookrights>
  </bookmeta>

