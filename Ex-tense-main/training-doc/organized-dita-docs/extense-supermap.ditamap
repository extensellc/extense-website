<bookmap id="extense-supermap" xml:lang="en-US">

  <booktitle>
    <mainbooktitle>DITA Training Guide: From First Topic to AI-Powered Delivery</mainbooktitle>
    <booktitlealt>A Progressive Learning Path — Content Strategy, Authoring, Development, and Intelligent Delivery</booktitlealt>
  </booktitle>

  <bookmeta>
    <authorinformation>
      <organizationinfo>
        <namedetails>
          <organizationnamedetails>
            <organizationname>Extense LLC</organizationname>
          </organizationnamedetails>
        </namedetails>
      </organizationinfo>
