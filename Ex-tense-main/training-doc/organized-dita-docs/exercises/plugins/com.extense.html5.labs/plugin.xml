<?xml version="1.0" encoding="UTF-8"?>
<!--
  Starter plug-in for XSLT Customization Labs
  
  This plug-in provides a skeleton that Lab 1-5 build upon progressively.
  Install into your DITA-OT plugins/ directory and run: dita install
  
  Extension points used:
    dita.xsl.html5      — HTML5 topic XSLT overrides
    dita.xsl.html5.toc  — HTML5 TOC/navigation overrides
-->
<plugin id="com.extense.html5.labs" version="1.0.0">
  <require plugin="org.dita.html5"/>

  <!-- Lab 1-3: Topic transform overrides (callouts, step anchors, meta) -->
  <feature extension="dita.xsl.html5" file="xsl/html5/override.xsl"/>

  <!-- Lab 4: TOC/navigation overrides (collapsible sidebar) -->
  <feature extension="dita.xsl.html5.toc" file="xsl/toc/toc-override.xsl"/>
</plugin>
