<?xml version="1.0" encoding="UTF-8"?>
<!--
  Extense LLC — Branded PDF Plugin
  Customizes the DITA-OT PDF2 output with Extense LLC branding:
  navy/gold/green palette, branded cover page, headers & footers.
-->
<plugin id="com.extense.pdf.branded" version="1.0.0">
  <require plugin="org.dita.pdf2"/>

  <!-- Override XSL-FO attribute sets (colors, fonts, spacing) -->
  <feature extension="dita.xsl.xslfo" file="cfg/fo/attrs/custom.xsl"/>

  <!-- Override XSL-FO templates (cover page, headers, footers) -->
  <feature extension="dita.xsl.xslfo" file="cfg/fo/xsl/custom.xsl"/>
</plugin>
