<reference id="xslt-troubleshooting" xml:lang="en-US">
  <title>Troubleshooting</title>
  <shortdesc>Common issues and solutions for sidebar TOC, chunking, XSL overrides, external links, and post-upgrade breakages.</shortdesc>
  <prolog>
    <author>Extense LLC</author>
    <critdates>
      <created date="2026-02-10"/>
    </critdates>
    <metadata>
      <keywords>
        <indexterm>Troubleshooting</indexterm><indexterm>Sidebar TOC missing</indexterm><indexterm>Chunking</indexterm><indexterm>XSL overrides</indexterm>
