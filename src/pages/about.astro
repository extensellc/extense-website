---
/*
  /about — load-bearing identity page.

  Spec ref: EXTENSE_DESIGN_BRIEF.md §8

  The canonical definitional treatment of the 5-phase methodology, the only
  page displaying the full five-stat outcome record, the firm's growth
  narrative, the aggregate team framing (the only place that lives, given
  no-individuals-featured choice), and the certifications block at depth.

  Section order (identity-first):
    1. TopNav (BaseLayout)
    2. Hero (Hero.universal — uses Phase 1 canonical positioning sentence verbatim)
    3. 5-phase methodology, definitional framing (DocumentRow.entry × 5)
    4. Full five-stat outcome record (StatBlock.five)
    5. Aggregate team framing
    6. Founding and growth (brief, compressed padding)
    7. Certifications at depth (DocumentRow.entry × N) with procurement context
    8. CTAModule (general toggle preset)
    9. Footer (BaseLayout)

  Phase 4 directives:
    - Hero copy uses the canonical positioning sentence verbatim
    - Aggregate team section copy bar set higher than other body copy
    - Certifications copy includes procurement context per badge
*/

import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/site/Hero.astro";
import DocumentRow from "../components/site/DocumentRow.astro";
import StatBlock from "../components/site/StatBlock.astro";
import CompactList from "../components/site/CompactList.astro";
import CTAModule from "../components/site/CTAModule.astro";

const methodologyPhases = [
  {
    phase: "Discovery",
    body: "We don't move past Discovery until the constraints that would otherwise sink a content model have surfaced. That includes interviewing the people who will produce, edit, and consume the content, auditing what exists today, and mapping the use cases the system has to support. The goal isn't to gather requirements; it's to find the constraints the architecture has to obey.",
  },
  {
    phase: "Architecture",
    body: "The architecture is the leverage point. Schema design, taxonomy, metadata strategy, and reuse decisions made here determine what's possible in every downstream phase. We design against the use cases Discovery surfaced, not against generic structured-content principles. The architecture has to work for this client's content, not for a textbook example of DITA.",
  },
  {
    phase: "Migration",
    body: "Migration is recovery, not transcription. The conversion engine identifies reusable assets in legacy content and lifts them into the target schema; what isn't recoverable gets retired or rewritten with intent. We design the QA harness before the first batch runs — failing migrations fail because the validation strategy was an afterthought.",
  },
  {
    phase: "Implementation",
    body: "Implementation makes the architecture operational across the toolchain — CCMS configuration, publishing pipelines, integration points. The discipline at this phase is to resist scope expansion: every feature added during implementation is a feature the team has to maintain afterward. We deliver the smallest implementation that runs.",
  },
  {
    phase: "Enablement",
    body: "Enablement runs through every phase, not at the end. Discovery teaches the practitioner how the program works. Architecture documentation becomes the team's runbook. Migration training transitions authors. CCMS rollout becomes the operating manual. The handover isn't a phase — it's a discipline applied throughout.",
  },
];

const fullOutcomeRecord = [
  {
    number: "60%",
    label: "Faster publishing",
    context: "From quarterly batches to per-merge releases.",
  },
  {
    number: "72%",
    label: "Translation savings",
    context: "Single-source reuse cuts localization volume.",
  },
  {
    number: "45%",
    label: "Content reuse rate",
    context: "Average across migrations from unstructured legacy formats.",
  },
  {
    number: "90%",
    label: "Fewer support tickets",
    context: "Architecture quality measured in escalation volume.",
  },
  {
    number: "85%",
    label: "RAG retrieval precision",
    context: "Floor delivered across deployed AI pipelines.",
  },
];

const practiceAreas = [
  {
    label: "DITA architects",
    description: "Practicing across DITA 1.3 specializations, custom DTDs and constraints, taxonomy and subject scheme design. Versions 5.0 / 6.0 of S1000D for defense and aerospace-adjacent programs.",
  },
  {
    label: "S1000D specialists",
    description: "Issue 5.0 / 6.0 conformance work for defense primes and federal civilian agencies. Data module design, CSDB integration, IETM/IETP publishing.",
  },
  {
    label: "CCMS implementers",
    description: "Hands-on implementation experience across IXIASOFT, Heretto, Paligo, and Tridion Docs. Multi-platform fluency that's rare in this market — and informed opinions about which platform fits which problem.",
  },
  {
    label: "Conversion engineers",
    description: "XSLT 2.0 / 3.0 pipelines, custom converters, off-the-shelf tools where appropriate. QA harnesses designed before production conversion runs, not after.",
  },
  {
    label: "Publishing engineers",
    description: "DITA-OT customization, branded PDF (XSL-FO), responsive HTML5, S1000D IETP output, CI/CD integration with Jenkins / GitHub Actions / Azure DevOps. Containerized builds for reproducibility.",
  },
  {
    label: "AI / retrieval-engineering practitioners",
    description: "Chunking strategy, metadata schema, retrieval evaluation. Specialization in regulated-industry RAG where precision matters more than recall.",
  },
];

const certifications = [
  {
    heading: "SBA 8(a) Certified",
    body: "Sole-source eligibility for federal contracts up to $4.5M (services) without competitive bid. Set-aside competition with other 8(a) firms. Simplified acquisition procedures across all federal agencies. The program has a defined duration; we participate within those bounds.",
  },
  {
    heading: "Woman-Owned Small Business (WOSB)",
    body: "WOSB set-aside eligibility on contracts in WOSB-designated NAICS codes. Contracting officers may restrict competition to WOSB firms when appropriate. Recognized in private-sector supplier-diversity programs.",
  },
  {
    heading: "Minority-Owned Business Enterprise (MBE)",
    body: "Recognized in federal supplier-diversity programs and in Fortune 500 partner-tier diversity tracking. Relevant for prime/sub teaming on federal contracts; a credential many enterprise programs explicitly value.",
  },
  {
    heading: "Sole-source eligible",
    body: "Through the 8(a) program, federal agencies can award sole-source contracts to Extense up to threshold limits without competitive procedures. Accelerates procurement timelines for agencies with established justification frameworks.",
  },
];
---

<BaseLayout
  title="About Extense LLC"
  description="Extense LLC is an XML content engineering firm for organizations whose documentation has to be right. Founded 2012 in Maryland. SBA 8(a) certified, woman-owned, minority-owned. The canonical record of who we are, how we work, and what we deliver."
>
  <Hero
    variant="universal"
    title="Extense LLC is an XML content engineering firm for organizations whose documentation has to be right."
    subdeck="Federal agencies, Fortune 500 manufacturers, life sciences companies, financial institutions, and defense contractors. Founded 2012. SBA 8(a) certified, woman-owned, minority-owned — sole-source eligible for federal contracts."
  />

  <section class="about-section about-section--methodology" aria-labelledby="methodology-heading">
    <div class="container-prose about-section__inner">
      <h2 id="methodology-heading" class="about-section__heading">How we work.</h2>
      <p class="about-section__intro">
        Five phases. Same shape on every engagement. The tone here is definitional — what each phase <em>is</em> in our practice, not what activities happen during it.
      </p>
      <div class="about-section__rows">
        {methodologyPhases.map((p) => (
          <DocumentRow variant="entry" heading={p.phase} body={p.body} headingLevel={3} />
        ))}
      </div>
    </div>
  </section>

  <section class="about-section about-section--full-stats" aria-label="Full outcome record">
    <div class="container-data about-section__inner">
      <p class="about-section__stats-frame">
        Five outcome metrics across our engagements. The full record — only displayed here.
      </p>
      <StatBlock variant="five" stats={fullOutcomeRecord} />
    </div>
  </section>

  <section class="about-section about-section--team" aria-labelledby="team-heading">
    <div class="container-prose about-section__inner">
      <h2 id="team-heading" class="about-section__heading">The practice.</h2>
      <p class="about-section__team-intro">
        Extense is a small firm of practitioners who have shipped structured-content systems for federal agencies, Fortune 500 manufacturers, life sciences companies, financial institutions, and defense contractors. We don't feature individual team members on this site — the work is the work, and clients evaluate firms by what those firms have shipped, not by team-page photography. The composition we describe below is what's behind every engagement.
      </p>
      <CompactList items={practiceAreas} />
    </div>
  </section>

  <section class="about-section about-section--founding" aria-labelledby="founding-heading">
    <div class="container-prose about-section__inner">
      <h2 id="founding-heading" class="about-section__heading">Founded 2012.</h2>
      <div class="about-section__founding-prose">
        <p>
          Extense was founded as a two-person XML consulting practice in Maryland — formed around the observation that structured content engineering required a different kind of firm than the documentation industry was producing. The early engagements were federal: DITA work for civilian agencies, publishing-automation projects that turned manual production cycles into single-source pipelines.
        </p>
        <p>
          The firm grew alongside the maturity of the structured-content market. SBA 8(a) certification opened sole-source eligibility for federal work. CCMS implementations across enterprise platforms became a practice line. Fortune 500 commercial engagements followed in regulated industries. Most recently, AI-readiness — the content-engineering work that makes RAG retrieval accurate in regulated workloads — became a fourth pillar.
        </p>
        <p>
          The shape of the firm today: small, specialized, full-stack. Information architecture through CI/CD publishing through retrieval engineering, owned in a single team rather than handed off across vendors.
        </p>
      </div>
    </div>
  </section>

  <section class="about-section about-section--certifications" aria-labelledby="certifications-heading">
    <div class="container-prose about-section__inner">
      <h2 id="certifications-heading" class="about-section__heading">Certifications and set-asides.</h2>
      <p class="about-section__certs-intro">
        Each credential below names what it enables in procurement, not just the badge.
      </p>
      <div class="about-section__rows">
        {certifications.map((c) => (
          <DocumentRow variant="entry" heading={c.heading} body={c.body} headingLevel={3} />
        ))}
      </div>
    </div>
  </section>

  <CTAModule
    audience="general"
    body="Submit a 20-page sample. We'll return conversion feasibility, content recovery rate, and engineering effort within two business days. The analysis is the basis for any further engagement, with no obligation to proceed."
  />
</BaseLayout>

<style>
  .about-section {
    padding-top: var(--section-pad-default);
    padding-bottom: var(--section-pad-default);
  }

  @media (max-width: 767px) {
    .about-section {
      padding-top: var(--space-16);
      padding-bottom: var(--space-16);
    }
  }

  /* Founding / growth section: compressed padding signals 'identity, not history' */
  .about-section--founding {
    padding-top: var(--section-pad-compressed);
    padding-bottom: var(--section-pad-compressed);
  }

  @media (max-width: 767px) {
    .about-section--founding {
      padding-top: var(--space-12);
      padding-bottom: var(--space-12);
    }
  }

  .about-section__heading {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin-bottom: var(--space-8);
    text-wrap: balance;
  }

  .about-section__intro,
  .about-section__team-intro,
  .about-section__certs-intro {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-12);
    text-wrap: pretty;
  }

  .about-section__intro em,
  .about-section__team-intro em {
    font-style: italic;
  }

  .about-section__rows {
    /* DocumentRow handles its own spacing */
  }

  .about-section__stats-frame {
    text-align: center;
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    max-width: var(--container-prose);
    margin-left: auto;
    margin-right: auto;
    margin-bottom: var(--space-16);
    text-wrap: pretty;
  }

  .about-section__founding-prose p {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    text-wrap: pretty;
  }

  .about-section__founding-prose p + p {
    margin-top: var(--space-4);
  }
</style>
