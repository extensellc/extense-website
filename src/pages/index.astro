---
/*
  / — homepage. Reframed 2026: solution-led, cognitive-flow order.

  Section order (full rationale in docs/reframe-2026/home.md):
    1.  Hero (HomeHero) — solution-forward H1 + outcome sub-deck
    2.  Service Pillars (7) — the offer
    3.  Trust badges — credentials
    4.  Logo marquee — proof
    5.  Content Ops Stack — capability layers
    6.  Content Engineering Lifecycle — workflow stages
    7.  CTA (CTAModule) — mid-page Sample Content Assessment
    8.  Why Choose Extense — differentiators + pipeline + toolchain
    9.  Industries — 5 sector cards
    10. Footer (BaseLayout)

  Persistent "Free Assessment" CTA lives in TopNav (sitewide).
  Locked constraints still apply: no transformation verbs; stat numbers never amber.

  Removed in the reframe: cost-of-being-wrong failure modes (problem-education),
  the 4-pillar capabilities row (replaced by the 7 service pillars), the standalone
  60/72/85 StatBlock (numbers now live in the hero sub-deck), and the public/private
  AudiencePivotCard (replaced by the 5 industry cards).
*/

import BaseLayout from "../layouts/BaseLayout.astro";
import HomeHero from "../components/site/HomeHero.astro";
import ServicePillars from "../components/site/ServicePillars.astro";
import TrustBadges from "../components/site/TrustBadges.astro";
import LogoBench from "../components/site/LogoBench.astro";
import ContentOpsStack from "../components/site/ContentOpsStack.astro";
import ContentLifecycle from "../components/site/ContentLifecycle.astro";
import CTAModule from "../components/site/CTAModule.astro";
import WhyChoose from "../components/site/WhyChoose.astro";
import HomeIndustries from "../components/site/HomeIndustries.astro";
---

<BaseLayout
  title="Content Engineering"
  description="Extense LLC is a content engineering firm for organizations whose documentation has to be right — federal agencies, Fortune 500 manufacturers, life sciences companies, financial institutions, and defense contractors."
>
  <HomeHero />

  <ServicePillars />

  <TrustBadges />

  <section class="home-section home-section--logos" aria-label="Client proof">
    <LogoBench
      variant="full"
      eyebrow="Trusted by Government Agencies, Fortune 500 Companies, & Non-Profit Organizations"
    />
  </section>

  <ContentOpsStack />

  <ContentLifecycle />

  <CTAModule
    audience="general"
    body="Submit a 20-page sample. We'll return conversion feasibility, content recovery rate, and engineering effort within two business days. The analysis is the basis for any further engagement, with no obligation to proceed."
  />

  <WhyChoose />

  <HomeIndustries />
</BaseLayout>

<style>
  /* Only the logo-marquee section is composed inline here; every other section
     is a self-contained component with its own padding + hairline divider.
     Extra top padding so the marquee doesn't read as crowded against the trust
     badges strip directly above it. */
  .home-section--logos {
    padding-top: calc(var(--section-pad-default) + var(--space-12));
    padding-bottom: var(--section-pad-default);
  }
  @media (max-width: 767px) {
    .home-section--logos {
      padding-top: var(--space-20);
      padding-bottom: var(--space-16);
    }
  }
</style>
