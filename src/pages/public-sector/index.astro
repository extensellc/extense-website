---
/*
  /public-sector — federal capability-statement landing page.

  Spec ref: EXTENSE_DESIGN_BRIEF.md §8

  Section order (verification-first — federal procurement officers verify before they evaluate):
    1. TopNav (BaseLayout)
    2. Hero (Hero.identifying) — declarative identity, no aspiration verbs
    3. CapabilityStrip — NAICS / CAGE / UEI (no contract vehicles per Phase 3 verification)
    4. PDFDownloadButton — capability statement PDF
    5. LogoBench.federal — 3 logos: IRS, U.S. House, U.S. District Courts
    6. Certifications block (DocumentRow.entry × N) — 8(a), WOSB, MBE with procurement context
    7. Past performance (DocumentRow.entry × 4–6) — agency + general work description
    8. Four pillars (PillarCard × 4) — federal copy register
    9. Cost-of-being-wrong (DocumentRow.failureMode × 1) — S1000D/stop-work
    10. CTAModule (Sample Content Assessment, public-sector audience preset)
    11. Footer (BaseLayout)
*/

import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/site/Hero.astro";
import CapabilityStrip from "../../components/site/CapabilityStrip.astro";
import PDFDownloadButton from "../../components/site/PDFDownloadButton.astro";
import LogoBench from "../../components/site/LogoBench.astro";
import DocumentRow from "../../components/site/DocumentRow.astro";
import PillarCard from "../../components/site/PillarCard.astro";
import CTAModule from "../../components/site/CTAModule.astro";

const certifications = [
  {
    heading: "SBA 8(a) Certified",
    body: "Sole-source eligibility for federal contracts up to $4.5M (services) without competitive bid. Set-aside competition with other 8(a) firms. Simplified acquisition procedures across all federal agencies.",
  },
  {
    heading: "Woman-Owned Small Business (WOSB)",
    body: "WOSB set-aside eligibility on contracts in WOSB-designated NAICS codes. Contracting officers may restrict competition to WOSB firms when appropriate.",
  },
  {
    heading: "Minority-Owned Business Enterprise (MBE)",
    body: "Recognized in federal supplier-diversity programs and in private-sector partner-tier diversity tracking — relevant for prime/sub teaming on federal contracts.",
  },
  {
    heading: "Sole-Source Eligible",
    body: "Through the 8(a) program, federal agencies can award sole-source contracts to Extense up to threshold limits without competitive procedures, accelerating procurement timelines.",
  },
];

// Past performance — agency name + general (non-specific) description of work only.
// NDA constraints prevent disclosure of contract numbers, periods of performance,
// contract values, or specific scope details.
const pastPerformance = [
  {
    heading: "Internal Revenue Service",
    body: "Structured content engineering and publishing engagement — DITA-based architecture and CCMS-driven workflows for taxpayer-facing and internal documentation programs.",
  },
  {
    heading: "U.S. House of Representatives",
    body: "Legislative and administrative documentation engineering — content modeling, taxonomy, and publishing automation supporting institutional knowledge and constituent-facing materials.",
  },
  {
    heading: "U.S. District Courts",
    body: "Court documentation systems engagement — structured content design, migration, and publishing workflow supporting administrative operations across federal court districts.",
  },
];

const federalPillars = [
  {
    pillar: "ia" as const,
    name: "Information Architecture",
    scope: "Schema design and taxonomy for compliance documentation: Section 508, agency publishing standards, S1000D data module specifications.",
    href: "/capabilities/information-architecture",
  },
  {
    pillar: "migration" as const,
    name: "Content Migration",
    scope: "Recovery of legacy estates — agency content from FrameMaker, Word, and unstructured XML into clean DITA or S1000D for downstream automation.",
    href: "/capabilities/content-migration",
  },
  {
    pillar: "ccms" as const,
    name: "CCMS & Publishing",
    scope: "Implementation on procurement-friendly CCMS platforms (IXIASOFT, Heretto, Paligo, Tridion). CI/CD publishing for civilian and defense documentation programs.",
    href: "/capabilities/ccms-and-publishing",
  },
  {
    pillar: "ai-ready" as const,
    name: "AI-Ready Content",
    scope: "Records-management modernization — chunking, metadata, and retrieval architecture for agency RAG initiatives over policy and regulation libraries.",
    href: "/capabilities/ai-ready-content",
  },
];
---

<BaseLayout
  title="Public Sector — Federal Capability Statement"
  description="Extense LLC capability statement for federal agencies and contractors. SBA 8(a) certified, sole-source eligible. Past performance with the IRS, the U.S. House of Representatives, and the U.S. District Courts."
>
  <Hero
    variant="identifying"
    title="Extense LLC. SBA 8(a) certified XML content engineering firm."
    subdeck="Federal documentation engineering — civilian agency content modernization, defense maintenance documentation, S1000D conformance, IETM development. Founded 2012. Sole-source eligible through the 8(a) program."
  />

  <CapabilityStrip />

  <PDFDownloadButton
    href="/capability-statement.pdf"
    label="Download capability statement"
  />

  <section class="pub-section pub-section--logos" aria-label="Federal client proof">
    <LogoBench variant="federal" eyebrow="Federal Past Performance" />
  </section>

  <section class="pub-section pub-section--certs" aria-labelledby="certs-heading">
    <div class="container-prose pub-section__inner">
      <h2 id="certs-heading" class="pub-section__heading">Federal certifications and set-asides.</h2>
      <div class="pub-section__rows">
        {certifications.map((c) => (
          <DocumentRow variant="entry" heading={c.heading} body={c.body} headingLevel={3} />
        ))}
      </div>
    </div>
  </section>

  <section class="pub-section pub-section--past-perf" aria-labelledby="past-perf-heading">
    <div class="container-prose pub-section__inner">
      <h2 id="past-perf-heading" class="pub-section__heading">Past performance.</h2>
      <p class="pub-section__note">
        Federal engagements held under non-disclosure constraints. Detailed scope, contract identifiers, and outcome specifics available under appropriate procurement and NDA channels.
      </p>
      <div class="pub-section__rows">
        {pastPerformance.map((p) => (
          <DocumentRow variant="entry" heading={p.heading} body={p.body} headingLevel={3} />
        ))}
      </div>
    </div>
  </section>

  <section class="pub-section pub-section--pillars" aria-labelledby="pillars-heading">
    <div class="container-data pub-section__inner">
      <h2 id="pillars-heading" class="pub-section__heading">Capabilities for federal engagements.</h2>
      <div class="pub-section__pillar-grid">
        {federalPillars.map((p) => (
          <PillarCard pillar={p.pillar} name={p.name} scope={p.scope} href={p.href} />
        ))}
      </div>
    </div>
  </section>

  <section class="pub-section pub-section--failure" aria-labelledby="failure-heading">
    <div class="container-prose pub-section__inner">
      <h2 id="failure-heading" class="pub-section__heading">When defense documentation goes wrong.</h2>
      <DocumentRow
        variant="failureMode"
        eyebrow="DEFENSE / S1000D"
        heading="An S1000D conformance failure triggers a stop-work order."
        body="Payment halts. The contract goes to risk. Cure-notice procedures begin. Data modules have to be reauthored before delivery resumes — and the program slips on a dependency the prime didn't engineer in."
        headingLevel={3}
      />
    </div>
  </section>

  <CTAModule
    audience="public-sector"
    body="Submit a 20-page sample. We'll return conversion feasibility, content recovery rate, and engineering effort within two business days. The analysis is the basis for any future RFP response or sole-source justification, with no obligation to proceed."
  />
</BaseLayout>

<style>
  .pub-section {
    padding-top: var(--section-pad-default);
    padding-bottom: var(--section-pad-default);
  }

  @media (max-width: 767px) {
    .pub-section {
      padding-top: var(--space-16);
      padding-bottom: var(--space-16);
    }
  }

  .pub-section__heading {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin-bottom: var(--space-12);
    text-wrap: balance;
  }

  .pub-section__note {
    font-size: var(--text-body-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin-top: calc(var(--space-12) * -1);
    margin-bottom: var(--space-12);
    font-style: italic;
    text-wrap: pretty;
    max-width: 60ch;
  }

  .pub-section__rows {
    /* DocumentRow handles its own spacing */
  }

  .pub-section__pillar-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
  }

  @media (min-width: 600px) {
    .pub-section__pillar-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-8);
    }
  }

  @media (min-width: 1024px) {
    .pub-section__pillar-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-8);
    }
  }
</style>
