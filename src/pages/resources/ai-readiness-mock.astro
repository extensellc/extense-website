---
/*
  TEMP — Hero side-visual mockups for /resources/ai-readiness.
  Two candidate concepts (A: score arc, B: 7-dim spokes) laid out
  vertically for in-browser comparison. Delete this file after selection.

  Route: /resources/ai-readiness-mock
*/
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="AI-Readiness — Hero visual mockups"
  description="Temporary mockup page; delete after selection."
>
  <div class="container-page airm-wrap">
    <header class="airm-page-head">
      <p class="airm-eyebrow">TEMP · MOCKUPS</p>
      <h1 class="airm-page-h1">AI-Readiness — hero side-visual candidates</h1>
      <p class="airm-page-intro">
        Two concepts for the upper-right hero slot on
        <code>/resources/ai-readiness</code> (replacing the current
        <code>ScorecardDimensionCard</code> side panel). Each sized to
        fit beside the H1 + subdeck at desktop (viewBox ~480×220 or
        ~480×260).
      </p>
    </header>

    {/* ───────────── CONCEPT A — Score arc ───────────── */}
    <section class="airm-mock">
      <header class="airm-mock__head">
        <p class="airm-mock__tag">CONCEPT A</p>
        <h2 class="airm-mock__title">Score arc · 0 → 14</h2>
        <p class="airm-mock__desc">
          Horizontal scale 0–14 with a muted "baseline" dot at 3 and an
          amber "target" dot at 10, connecting amber line between.
          Renders the scorecard's core promise — measurable improvement
          — in one glance.
        </p>
      </header>
      <div class="airm-svg-frame">
        <svg
          class="airm-svg drawn"
          viewBox="0 0 480 220"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
          role="presentation"
        >
          <g class="corner">
            <path d="M 12 22 L 12 12 L 22 12" />
            <path d="M 458 12 L 468 12 L 468 22" />
            <path d="M 12 198 L 12 208 L 22 208" />
            <path d="M 458 208 L 468 208 L 468 198" />
          </g>

          <text class="chrome" x="24" y="30">in :: readiness.scored</text>
          <text class="chrome label--muted" x="24" y="46">15-POINT SCALE · 0 → 14</text>

          {/* Axis line */}
          <line class="axis" x1="30" y1="120" x2="450" y2="120" />

          {/* 15 tick marks at integer positions (x = 30 + i*30) */}
          {Array.from({ length: 15 }).map((_, i) => {
            const x = 30 + i * 30;
            const isAnchor = i === 0 || i === 14;
            return (
              <g>
                <line class={isAnchor ? "tick tick--strong" : "tick"} x1={x} y1="114" x2={x} y2="126" />
                <text class="tick-num" x={x} y="142" text-anchor="middle">{i}</text>
              </g>
            );
          })}

          {/* Amber arc/line from baseline (3) to target (10) */}
          <path class="flow-conn" d="M120 120 L330 120" />

          {/* Baseline dot at x=120 (tick 3) */}
          <circle class="dot dot--baseline" cx="120" cy="120" r="7" />
          <text class="dot-label dot-label--muted" x="120" y="172" text-anchor="middle">BASELINE</text>
          <text class="dot-value dot-value--muted" x="120" y="190" text-anchor="middle">3</text>

          {/* Target dot at x=330 (tick 10) */}
          <circle class="dot dot--target" cx="330" cy="120" r="9" />
          <text class="dot-label dot-label--accent" x="330" y="172" text-anchor="middle">TARGET</text>
          <text class="dot-value dot-value--accent" x="330" y="190" text-anchor="middle">10</text>

          {/* "+7 measured" chip on the arc */}
          <rect class="node node--custom" x="195" y="90" width="120" height="22" rx="3" />
          <text class="node-label node-label--custom" x="255" y="106" text-anchor="middle">+7 measured</text>

          {/* Bottom chrome */}
          <line class="chrome-rule" x1="24" y1="200" x2="456" y2="200" />
          <rect class="build-dot" x="172" y="207" width="6" height="6" />
          <text class="chrome chrome--strong" x="186" y="213">FIG. 01</text>
          <text class="chrome" x="236" y="213">/</text>
          <text class="chrome chrome--strong" x="244" y="213">readiness.scored</text>
          <text class="chrome chrome--strong" x="456" y="213" text-anchor="end">0 → 14</text>
        </svg>
      </div>
    </section>

    {/* ───────────── CONCEPT B — 7-dim spokes ───────────── */}
    <section class="airm-mock">
      <header class="airm-mock__head">
        <p class="airm-mock__tag">CONCEPT B</p>
        <h2 class="airm-mock__title">7-dimension spokes</h2>
        <p class="airm-mock__desc">
          Central amber <code>extense.readiness</code> chip with 7
          numbered dots radiating outward, each labeled with an
          abbreviated dimension name. Captures "7 dimensions, scored
          together."
        </p>
      </header>
      <div class="airm-svg-frame">
        <svg
          class="airm-svg drawn"
          viewBox="0 0 480 260"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
          role="presentation"
        >
          <g class="corner">
            <path d="M 12 22 L 12 12 L 22 12" />
            <path d="M 458 12 L 468 12 L 468 22" />
            <path d="M 12 238 L 12 248 L 22 248" />
            <path d="M 458 248 L 468 248 L 468 238" />
          </g>

          <text class="chrome" x="24" y="30">in :: readiness.dimensions</text>

          {/* 7 spokes — straight amber lines from chip center to each dot.
              Center at (240, 130). Dots at angle_i = i * 360/7 from top.
              Dot positions (radius 80):
                01 (0°)     → (240, 50)
                02 (51.4°)  → (302, 80)
                03 (102.9°) → (318, 148)
                04 (154.3°) → (275, 202)
                05 (205.7°) → (205, 202)
                06 (257.1°) → (162, 148)
                07 (308.6°) → (178, 80) */}
          <line class="spoke" x1="240" y1="130" x2="240" y2="50"  />
          <line class="spoke" x1="240" y1="130" x2="302" y2="80"  />
          <line class="spoke" x1="240" y1="130" x2="318" y2="148" />
          <line class="spoke" x1="240" y1="130" x2="275" y2="202" />
          <line class="spoke" x1="240" y1="130" x2="205" y2="202" />
          <line class="spoke" x1="240" y1="130" x2="162" y2="148" />
          <line class="spoke" x1="240" y1="130" x2="178" y2="80"  />

          {/* 7 dimension dots + numbers + abbreviated labels */}
          {/* 01 top */}
          <circle class="dot dot--target" cx="240" cy="50" r="6" />
          <text class="toc-num" x="240" y="38" text-anchor="middle">01</text>
          <text class="dim-label" x="240" y="24" text-anchor="middle">TYPING</text>
          {/* 02 top-right */}
          <circle class="dot dot--target" cx="302" cy="80" r="6" />
          <text class="toc-num" x="318" y="76" text-anchor="start">02</text>
          <text class="dim-label" x="318" y="64" text-anchor="start">META</text>
          {/* 03 right */}
          <circle class="dot dot--target" cx="318" cy="148" r="6" />
          <text class="toc-num" x="336" y="146" text-anchor="start">03</text>
          <text class="dim-label" x="336" y="158" text-anchor="start">IDS</text>
          {/* 04 bottom-right */}
          <circle class="dot dot--target" cx="275" cy="202" r="6" />
          <text class="toc-num" x="284" y="216" text-anchor="start">04</text>
          <text class="dim-label" x="284" y="228" text-anchor="start">VOCAB</text>
          {/* 05 bottom-left */}
          <circle class="dot dot--target" cx="205" cy="202" r="6" />
          <text class="toc-num" x="196" y="216" text-anchor="end">05</text>
          <text class="dim-label" x="196" y="228" text-anchor="end">MARKUP</text>
          {/* 06 left */}
          <circle class="dot dot--target" cx="162" cy="148" r="6" />
          <text class="toc-num" x="144" y="146" text-anchor="end">06</text>
          <text class="dim-label" x="144" y="158" text-anchor="end">REUSE</text>
          {/* 07 top-left */}
          <circle class="dot dot--target" cx="178" cy="80" r="6" />
          <text class="toc-num" x="162" y="76" text-anchor="end">07</text>
          <text class="dim-label" x="162" y="64" text-anchor="end">OUTPUT</text>

          {/* Central chip */}
          <rect class="node node--custom" x="170" y="116" width="140" height="28" rx="3" />
          <text class="node-label node-label--custom" x="240" y="135" text-anchor="middle">extense.readiness</text>

          {/* Bottom chrome */}
          <line class="chrome-rule" x1="24" y1="238" x2="456" y2="238" />
          <rect class="build-dot" x="172" y="245" width="6" height="6" />
          <text class="chrome chrome--strong" x="186" y="251">FIG. 01</text>
          <text class="chrome" x="236" y="251">/</text>
          <text class="chrome chrome--strong" x="244" y="251">readiness.dimensions</text>
          <text class="chrome chrome--strong" x="456" y="251" text-anchor="end">7 + 1</text>
        </svg>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  /* ─── Page chrome ─── */
  .airm-wrap {
    padding-top: var(--space-12);
    padding-bottom: var(--space-24);
  }
  .airm-page-head {
    margin-bottom: var(--space-16);
    max-width: 80ch;
  }
  .airm-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent-primary-pressed);
    margin: 0 0 var(--space-3) 0;
  }
  .airm-page-h1 {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-4) 0;
    text-wrap: balance;
  }
  .airm-page-intro {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin: 0;
    text-wrap: pretty;
  }
  .airm-page-intro code,
  .airm-mock__desc code {
    font-family: var(--font-mono);
    font-size: 0.92em;
    color: var(--color-text-primary);
    background-color: var(--color-surface-band);
    padding: 0 var(--space-1);
  }

  /* ─── Mock section ─── */
  .airm-mock {
    margin-bottom: var(--space-16);
    border-top: var(--border-hairline);
    padding-top: var(--space-12);
  }
  .airm-mock__head {
    margin-bottom: var(--space-8);
    max-width: 80ch;
  }
  .airm-mock__tag {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent-primary-pressed);
    margin: 0 0 var(--space-2) 0;
  }
  .airm-mock__title {
    font-family: var(--font-display);
    font-size: var(--text-display-md);
    font-weight: var(--weight-medium);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-3) 0;
    line-height: var(--leading-snug);
  }
  .airm-mock__desc {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin: 0;
    text-wrap: pretty;
  }
  .airm-svg-frame {
    background-color: var(--color-page-bg);
    border: var(--border-hairline);
    padding: var(--space-6);
    max-width: 560px;
  }

  /* ─── Shared SVG styling (document-grade idiom) ─── */
  .airm-svg {
    width: 100%;
    height: auto;
    color: var(--color-text-primary);
    overflow: visible;
    display: block;
    shape-rendering: geometricPrecision;
  }
  .airm-svg .chrome {
    font-family: var(--font-mono);
    font-size: 9px;
    fill: var(--color-text-muted);
    letter-spacing: 0.06em;
  }
  .airm-svg .chrome--strong {
    fill: var(--color-text-primary);
    font-weight: var(--weight-medium);
  }
  .airm-svg .label--muted {
    fill: var(--color-text-secondary);
  }
  .airm-svg .corner {
    stroke: var(--color-accent-primary-hover);
    stroke-width: 1.25;
    fill: none;
  }
  .airm-svg .chrome-rule {
    stroke: var(--color-border-subtle);
    stroke-width: 1;
  }
  .airm-svg .build-dot {
    fill: var(--color-accent-primary-hover);
    stroke: none;
  }
  .airm-svg .node {
    fill: var(--color-page-bg);
    stroke: var(--color-text-primary);
    stroke-width: 1.5;
    vector-effect: non-scaling-stroke;
  }
  .airm-svg .node--custom {
    fill: #fef3c7;
    stroke: var(--color-accent-primary);
  }
  .airm-svg .node-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: var(--weight-medium);
    fill: var(--color-text-primary);
    letter-spacing: 0.02em;
  }
  .airm-svg .node-label--custom {
    fill: var(--color-accent-primary-pressed);
  }
  .airm-svg .flow-conn {
    stroke: var(--color-accent-primary-hover);
    stroke-width: 2.5;
    fill: none;
    vector-effect: non-scaling-stroke;
  }
  .airm-svg .spoke {
    stroke: var(--color-accent-primary-hover);
    stroke-width: 1.5;
    vector-effect: non-scaling-stroke;
  }

  /* Axis (concept A) */
  .airm-svg .axis {
    stroke: var(--color-text-primary);
    stroke-width: 1;
  }
  .airm-svg .tick {
    stroke: var(--color-text-muted);
    stroke-width: 1;
  }
  .airm-svg .tick--strong {
    stroke: var(--color-text-primary);
    stroke-width: 1.5;
  }
  .airm-svg .tick-num {
    font-family: var(--font-mono);
    font-size: 9px;
    fill: var(--color-text-secondary);
  }

  /* Dots (both concepts) */
  .airm-svg .dot--baseline {
    fill: var(--color-page-bg);
    stroke: var(--color-text-muted);
    stroke-width: 2;
  }
  .airm-svg .dot--target {
    fill: var(--color-accent-primary);
    stroke: var(--color-accent-primary-pressed);
    stroke-width: 2;
  }
  .airm-svg .dot-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: var(--weight-semibold);
    letter-spacing: 0.12em;
  }
  .airm-svg .dot-label--muted {
    fill: var(--color-text-secondary);
  }
  .airm-svg .dot-label--accent {
    fill: var(--color-accent-primary-pressed);
  }
  .airm-svg .dot-value {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: var(--weight-medium);
  }
  .airm-svg .dot-value--muted {
    fill: var(--color-text-secondary);
  }
  .airm-svg .dot-value--accent {
    fill: var(--color-accent-primary-pressed);
  }

  /* Numbered/labeled spokes (concept B) */
  .airm-svg .toc-num {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: var(--weight-semibold);
    fill: var(--color-accent-primary-pressed);
    letter-spacing: 0.04em;
  }
  .airm-svg .dim-label {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: var(--weight-medium);
    fill: var(--color-text-secondary);
    letter-spacing: 0.08em;
  }
</style>
