<script>
  function setupPaHero() {
    const svg = document.getElementById("pa-hero-flow");
    if (svg) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              svg.classList.add("drawn");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15 }
      );
      observer.observe(svg);
    }
  }

  function setupPaStats() {
    const band = document.querySelector(".pa-stats");
    if (!band) return;
    band.classList.add("pa-stats--armed");
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            band.classList.add("in-view");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.3 }
    );
    observer.observe(band);
  }

  function setupPa() {
    setupPaHero();
    setupPaStats();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupPa);
  } else {
    setupPa();
  }
  document.addEventListener("astro:page-load", setupPa);
</script>
