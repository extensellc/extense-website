        </g>
        <path class="flow-conn" style="--d: 480ms" d="M140 71 L208 96 M203 92 L208 96 L202 100" />
        <path class="flow-conn" style="--d: 620ms" d="M308 104 L378 78 M373 78 L378 78 L377 83" />
        <g class="fx" style="--d: 700ms">
          <rect class="node node--custom" x="380" y="58" width="120" height="26" rx="3" />
