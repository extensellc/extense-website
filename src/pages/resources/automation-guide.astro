        <g class="corner fx" style="--d: 0ms">
          <path d="M 12 22 L 12 12 L 22 12" />
          <path d="M 498 12 L 508 12 L 508 22" />
          <path d="M 12 218 L 12 228 L 22 228" />
          <path d="M 498 228 L 508 228 L 508 218" />
        </g>

        <text class="chrome fx" x="24" y="28" style="--d: 80ms">in :: build.gated</text>

        {/* section labels */}
        <text class="chrome label--accent fx" x="80" y="46" text-anchor="middle" style="--d: 140ms">COMMITS</text>
        <text class="chrome label--accent fx" x="260" y="46" text-anchor="middle" style="--d: 200ms">GATE</text>
        <text class="chrome label--accent fx" x="440" y="46" text-anchor="middle" style="--d: 260ms">RESULT</text>

        {/* central validation gate */}
        <g class="fx" style="--d: 320ms">
          <rect class="node node--custom" x="212" y="92" width="96" height="36" rx="3" />
          <text class="node-label node-label--custom" x="260" y="108" text-anchor="middle">validate</text>
          <text class="node-sub node-sub--custom" x="260" y="120" text-anchor="middle">gate</text>
        </g>

        {/* top row: valid commit -> shipped */}
        <g class="fx" style="--d: 400ms">
          <rect class="node" x="20" y="58" width="120" height="26" rx="3" />
