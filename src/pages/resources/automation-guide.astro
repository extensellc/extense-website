          <path class="conn--blocked" d="M312 124 L360 150" />
          <rect class="node node--rot" x="380" y="156" width="120" height="26" rx="3" />
          <text class="node-label node-label--muted" x="440" y="173" text-anchor="middle">blocked</text>
        </g>
        <line class="strike" x1="386" y1="169" x2="494" y2="169" style="--d: 880ms" />

        {/* bottom chrome */}
