---
/*
  /resources/migration-playbook — practitioner playbook for DITA migration.

  Section order:
    1. Hero (universal, with MigrationLifecycleCard side panel — static)
    2. Framing prose — names the principle and the 2M+ pages context
    3. AnimatedDivider
    4. The five disciplines (vertical entries — like AI Readiness phases)
    5. AnimatedDivider
    6. Source formats covered (typographic 3-col mono grid)
    7. AnimatedDivider
    8. Field rules from the practice (horizontal-row, like Decisions section)
    9. AnimatedDivider
   10. CTAModule (general)
*/

import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/site/Hero.astro";
import CTAModule from "../../components/site/CTAModule.astro";
import AnimatedDivider from "../../components/site/AnimatedDivider.astro";

/* Hero side-visual data — Option C (recovery before/after). 10 source
   pages on the left with 4 marked ROT (struck-through); 6 typed DITA
   topics on the right. Renders the H1 thesis 'migration is recovery,
   not transcription' as a single image. */
const sourcePages = Array.from({ length: 10 }).map((_, i) => {
  const rotIndexes = new Set([1, 4, 6, 9]);
  return {
    label: `page-${String(i + 1).padStart(2, "0")}.docx`,
    isRot: rotIndexes.has(i),
  };
});

const recoveredTopics = [
  { label: "topic-01 · concept" },
  { label: "topic-02 · task" },
  { label: "topic-03 · task" },
  { label: "topic-04 · reference" },
  { label: "topic-05 · concept" },
  { label: "topic-06 · task" },
];

/* Migration Lifecycle 5-stage strip data — sits between Phase 1 and the
   Source Formats section, mirroring the old page's lifecycle row. */
const lifecycleStages = [
  { number: "01", name: "Audit",   body: "Catalog the corpus. Delete ROT before anything converts." },
  { number: "02", name: "Map",     body: "Define topic types, taxonomy, and metadata before mapping styles." },
  { number: "03", name: "Convert", body: "Run the refined engine across the full corpus in one pass." },
  { number: "04", name: "Refine",  body: "Deduplicate, enrich, and resolve the structural exceptions." },
  { number: "05", name: "Publish", body: "Validate outputs against the use cases that defined the architecture." },
];

interface Discipline {
  number: string;
  name: string;
  stage: string;
  body: string;
}

const disciplines: Discipline[] = [
  {
    number: "01",
    name: "Content audit",
    stage: "Audit",
    body: "Catalog everything before converting anything. Count topics, count formats, identify duplicates, surface ROT — redundant, obsolete, trivial content that should not survive into the target system. Migration teams routinely move 40% dead content into a new CCMS, where it costs money to convert, money to maintain, and reduces retrieval signal downstream. The audit is the only opportunity to delete that content with the team's authorization intact.",
  },
  {
    number: "02",
    name: "Information architecture",
    stage: "Map",
    body: "Define topic types — concept, task, reference, troubleshooting — before scoping conversion rules. Define the metadata strategy and the controlled vocabulary before mapping a single style. The conversion engine cannot guess the right type from source markup; it follows rules that someone defined deliberately. Skipping IA means the conversion produces structured-garbage-out from unstructured-garbage-in — the type system is empty of meaning.",
  },
  {
    number: "03",
    name: "Pilot migration",
    stage: "Map → Convert",
    body: "Take fifty representative pages — chosen to span the difficult patterns in the source corpus, not the easy ones. Run them through the conversion manually or via script. Inspect every output for type fidelity, structural validity, and metadata coverage. Refine the conversion rules. Re-run. This pilot cycle prevents the most expensive migration failure: discovering a structural defect after running 50,000 pages through the wrong rule set.",
  },
  {
    number: "04",
    name: "Batch conversion",
    stage: "Convert",
    body: "Feed the full corpus through the refined engine. Context-based pattern matching distinguishes 'numbered steps in a task' from 'numbered lists in a reference topic' — a distinction that style-mapping tools cannot reach. The engine handles row-and-column-spanning tables, FrameMaker equations to MathML, embedded drawings to SVG, and the structurally awkward constructs that defeat lift-and-shift conversion.",
  },
  {
    number: "05",
    name: "Deduplication & enrichment",
    stage: "Refine",
    body: "After conversion, run exact-topic deduplication across the entire collection. Identify redundant topics and consolidate them into reusable warehouse topics that downstream content can conref. Inject metadata, keys, conref targets, and taxonomy attributes during the conversion pass — not after. Enriching post-conversion means inspecting every topic by hand; enriching during conversion lets the rule engine carry the load.",
  },
];

const sourceFormats = [
  "Microsoft Word",
  "FrameMaker",
  "InDesign",
  "RoboHelp",
  "MadCap Flare",
  "DocBook",
  "HTML",
  "Markdown",
  "AuthorIT",
  "Confluence",
  "SGML",
  "Excel",
  "PDF (OCR)",
];

interface FieldRule {
  rule: string;
  why: string;
}

const fieldRules: FieldRule[] = [
  {
    rule: "Delete ROT first.",
    why: "Redundant, obsolete, and trivial content should never reach the conversion engine. Teams routinely migrate 40% dead content — that content costs money to convert, money to maintain, and reduces retrieval signal downstream. ROT is identified during audit and gets removed before anything else moves.",
  },
  {
    rule: "Pilot with fifty pages. Not five. Not five hundred.",
    why: "Five pages don't give statistical significance — defects don't surface until the long tail. Five hundred pages mean weeks of conversion work before the first structural defect is caught. Fifty pages is the empirically validated sweet spot — large enough to expose the difficult patterns, small enough that re-running the pilot is cheap.",
  },
  {
    rule: "Don't fix formatting in source.",
    why: "Source cleanup is wasted effort — the formatting won't survive conversion, and the conversion engine doesn't depend on it. Fix typography and styling in DITA stylesheets after conversion, where the fix lives permanently and applies across the corpus, not just to the file someone happened to clean up.",
  },
  {
    rule: "Convert all languages simultaneously.",
    why: "Migrating English first and 'doing translations later' breaks TM (translation memory) alignment between source and target. The localization team ends up reconciling drift that didn't exist before migration. Run all locales through the same conversion engine in the same pass — the TM stays coherent.",
  },
];
---

<BaseLayout
  title="Migration Playbook — Extense LLC"
  description="A practitioner's playbook for moving content from Word, FrameMaker, MadCap, RoboHelp, AuthorIT and other unstructured legacy formats into typed, validated DITA. Five disciplines, the migration lifecycle, source-format coverage, and field rules from two million pages of practice."
>
  <Hero
    variant="universal"
    title="The Ultimate DITA Migration Playbook"
    subdeck="Don't just copy-paste — transform. A practitioner playbook for moving content from unstructured legacy formats (Word, FrameMaker, MadCap, RoboHelp, AuthorIT) into typed, validated DITA. Migration is recovery, not transcription — the disciplines, the lifecycle, and the field rules drawn from the practice."
    subdeckMaxWidth="540px"
  >
    <div class="mp-hero-visual">
      <svg
        class="mp-hero-flow"
        id="mp-hero-flow"
        viewBox="0 0 520 260"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        role="presentation"
      >
        {/* corner reg marks */}
        <g class="corner fx" style="--d: 0ms">
          <path d="M 12 22 L 12 12 L 22 12" />
          <path d="M 498 12 L 508 12 L 508 22" />
          <path d="M 12 238 L 12 248 L 22 248" />
          <path d="M 498 248 L 508 248 L 508 238" />
        </g>

        <text class="chrome fx" x="24" y="30" style="--d: 80ms">in :: corpus.recovered</text>

        {/* Section labels above each side */}
        <text class="chrome label--muted fx" x="80" y="60" text-anchor="middle" style="--d: 160ms">SOURCE · 10 PAGES</text>
        <text class="chrome label--accent fx" x="440" y="60" text-anchor="middle" style="--d: 220ms">RECOVERED · 6 TOPICS</text>

        {/* Left stack — 10 source pages, 4 marked ROT (struck-through) */}
        {sourcePages.map((p, i) => {
          const y = 76 + i * 14;
          const delay = 280 + i * 40;
          return (
            <g class="fx" style={`--d: ${delay}ms`}>
              <rect class={p.isRot ? "page-row page-row--rot" : "page-row"} x="20" y={y} width="124" height="11" />
              <text class={p.isRot ? "page-label page-label--rot" : "page-label"} x="26" y={y + 8}>{p.isRot ? `${p.label} · ROT` : p.label}</text>
            </g>
          );
        })}

        {/* Strikethroughs over the 4 ROT rows (drawn) */}
        {sourcePages.map((p, i) => {
          if (!p.isRot) return null;
          const y = 76 + i * 14;
          // strike sequence among the 4 ROT pages: order them 0..3 by appearance
          const rotOrder = sourcePages.filter((sp) => sp.isRot).indexOf(p);
          const strikeDelay = 720 + rotOrder * 40;
          return (
            <line class="strike" x1="20" y1={y + 5.5} x2="144" y2={y + 5.5} style={`--d: ${strikeDelay}ms`} />
          );
        })}

        {/* Center: amber arrow + recover chip */}
        <path class="flow-conn" style="--d: 880ms" d="M148 140 L380 140 M375 135 L380 140 L375 145" />

        <g class="fx" style="--d: 980ms">
          <rect class="node node--custom" x="200" y="128" width="128" height="24" rx="3" />
          <text class="node-label node-label--custom" x="264" y="144" text-anchor="middle">↻ extense.recover</text>
        </g>

        {/* Right stack — 6 typed DITA topics, amber-bordered */}
        {recoveredTopics.map((t, i) => {
          const y = 92 + i * 18;
          const delay = 1080 + i * 60;
          return (
            <g class="fx" style={`--d: ${delay}ms`}>
              <rect class="page-row page-row--custom" x="380" y={y} width="120" height="14" />
              <text class="page-label page-label--custom" x="386" y={y + 10}>{t.label}</text>
            </g>
          );
        })}

        {/* Bottom chrome */}
        <g class="fx" style="--d: 1440ms">
          <line class="chrome-rule" x1="24" y1="220" x2="496" y2="220" />
          <rect class="build-dot" x="172" y="227" width="6" height="6" />
          <text class="chrome chrome--strong" x="186" y="233">FIG. 01</text>
          <text class="chrome" x="236" y="233">/</text>
          <text class="chrome chrome--strong" x="244" y="233">corpus.recovered</text>
          <text class="chrome chrome--strong" x="496" y="233" text-anchor="end">10 → 6 + 4 ROT</text>
        </g>
      </svg>
    </div>
  </Hero>

  <AnimatedDivider />

  <section class="mp-section mp-section--framing" aria-labelledby="framing-heading">
    <div class="container-prose mp-section__inner">
      <h2 id="framing-heading" class="mp-section__heading">Why migration is recovery.</h2>
      <div class="mp-framing">
        <p>
          A migration that copy-pastes source content into a new schema is not a migration — it's a lift-and-shift. The schema gets populated; the structural problems in the source travel intact into the target. The new system inherits the same redundancies, the same broken navigation, the same ungoverned metadata. Two years later, the team is asking why the CCMS investment didn't pay off.
        </p>
        <p>
          Migration is recovery, not transcription. The conversion engine identifies reusable assets in legacy content and lifts them into the target schema; what isn't recoverable gets retired or rewritten with intent. The QA harness is designed before the first batch runs — failing migrations fail because the validation strategy was an afterthought. The architecture decisions get made before the conversion rules, not after.
        </p>
        <p>
          The playbook below codifies the disciplines, the lifecycle, and the field rules — patterns drawn from two million pages of migration work across federal, defense, life sciences, and enterprise commercial engagements. None of it is theory; all of it is what a migration team has to do, not just what they have to know.
        </p>
      </div>
    </div>
  </section>

  <AnimatedDivider />

  {/* ───────── Phase 1 — Analysis & Strategy (disciplines 01–03) ───────── */}
  <section class="mp-section mp-section--disciplines" aria-labelledby="phase1-heading">
    <div class="container-prose mp-section__inner">
      <p class="mp-phase__eyebrow">Phase 1</p>
      <h2 id="phase1-heading" class="mp-section__heading">Analysis & strategy.</h2>
      <p class="mp-section__lead">
        Three disciplines that take you from corpus to architecture. Skip them and you migrate dead weight into a new system.
      </p>

      <ol class="mp-disciplines">
        {disciplines.slice(0, 3).map((d) => (
          <li class="mp-discipline">
            <span class="mp-discipline__num" aria-hidden="true">{d.number}</span>
            <div class="mp-discipline__body">
              <p class="mp-discipline__stage">Lifecycle stage · {d.stage}</p>
              <h3 class="mp-discipline__name">{d.name}</h3>
              <p class="mp-discipline__text">{d.body}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <AnimatedDivider />

  {/* ───────── The Migration Lifecycle — 5-card strip between phases ───────── */}
  <section class="mp-section mp-section--lifecycle" aria-labelledby="lifecycle-heading">
    <div class="container-data mp-section__inner">
      <h2 id="lifecycle-heading" class="mp-section__heading">The migration lifecycle.</h2>
      <p class="mp-section__lead">
        Five stages that sit underneath the disciplines. The disciplines are <em>what</em> a migration team does; the lifecycle is <em>where</em> in the program each one applies.
      </p>

      <ol class="mp-lifecycle">
        {lifecycleStages.map((s, i) => (
          <>
            <li class="mp-lifecycle__card">
              <span class="mp-lifecycle__num">{s.number}</span>
              <h3 class="mp-lifecycle__name">{s.name}</h3>
              <p class="mp-lifecycle__body">{s.body}</p>
            </li>
            {i < lifecycleStages.length - 1 && (
              <li class="mp-lifecycle__arrow" aria-hidden="true">
                <svg viewBox="0 0 32 16" class="mp-lifecycle__arrow-svg" aria-hidden="true">
                  <path class="mp-lifecycle__arrow-path" d="M 0 8 L 28 8 M 24 4 L 28 8 L 24 12" />
                </svg>
              </li>
            )}
          </>
        ))}
      </ol>
    </div>
  </section>

  <AnimatedDivider />

  <section class="mp-section mp-section--formats" aria-labelledby="formats-heading">
    <div class="container-prose mp-section__inner">
      <h2 id="formats-heading" class="mp-section__heading">Source formats covered.</h2>
      <p class="mp-section__lead">
        The conversion engine handles thirteen named source formats. Conversion rules differ by format — Word's style-driven model is not the same problem as FrameMaker's structural conditions or RoboHelp's compiled output — and each has named patterns the engine recognizes.
      </p>

      <p class="mp-formats__eyebrow">Formats</p>
      <hr class="mp-rule" />
      <ul class="mp-formats">
        {sourceFormats.map((f) => (
          <li class="mp-format">{f}</li>
        ))}
      </ul>
      <hr class="mp-rule" />
    </div>
  </section>

  <AnimatedDivider />

  {/* ───────── Phase 2 — Conversion & Enrichment (disciplines 04–05) ───────── */}
  <section class="mp-section mp-section--disciplines" aria-labelledby="phase2-heading">
    <div class="container-prose mp-section__inner">
      <p class="mp-phase__eyebrow">Phase 2</p>
      <h2 id="phase2-heading" class="mp-section__heading">Conversion & enrichment.</h2>
      <p class="mp-section__lead">
        Two disciplines that take you from converted content to enriched, validated DITA — the part where the architecture pays off.
      </p>

      <ol class="mp-disciplines">
        {disciplines.slice(3).map((d) => (
          <li class="mp-discipline">
            <span class="mp-discipline__num" aria-hidden="true">{d.number}</span>
            <div class="mp-discipline__body">
              <p class="mp-discipline__stage">Lifecycle stage · {d.stage}</p>
              <h3 class="mp-discipline__name">{d.name}</h3>
              <p class="mp-discipline__text">{d.body}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <AnimatedDivider />

  <section class="mp-section mp-section--rules" aria-labelledby="rules-heading">
    <div class="container-data mp-section__inner">
      <h2 id="rules-heading" class="mp-section__heading">Field rules from the practice.</h2>
      <p class="mp-section__lead">
        Four positions taken — backed by named failure modes and measured costs. None of these are stylistic; all of them are reasoning a migration team has to apply, not just remember.
      </p>

      <ol class="mp-rules">
        {fieldRules.map((r, i) => (
          <li class="mp-rule-row">
            <span class="mp-rule-row__num" aria-hidden="true">{String(i + 1).padStart(2, "0")}</span>
            <p class="mp-rule-row__rule">{r.rule}</p>
            <p class="mp-rule-row__why">
              <span class="mp-rule-row__why-tag">Why:</span> {r.why}
            </p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <AnimatedDivider />

  <CTAModule
    audience="general"
    body="Submit a 20-page sample document. We'll return conversion feasibility, expected content recovery rate, ROT estimate, and engineering effort within two business days. The analysis is the basis for any further engagement, with no obligation to proceed."
  />
</BaseLayout>

<style>
  /* ─── Section spacing ─── */
  .mp-section {
    padding-top: var(--space-16);
    padding-bottom: var(--space-16);
  }

  @media (min-width: 768px) {
    .mp-section {
      padding-top: var(--space-20);
      padding-bottom: var(--space-20);
    }
  }

  .mp-section__heading {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-6) 0;
    text-wrap: balance;
  }

  .mp-section__lead {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    line-height: var(--leading-normal);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-12) 0;
    text-wrap: pretty;
    max-width: 65ch;
  }

  .mp-section__visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .mp-rule {
    border: 0;
    border-top: var(--border-hairline);
    margin: 0;
  }

  /* ─── Framing prose ─── */
  .mp-framing {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .mp-framing p {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    line-height: var(--leading-normal);
    color: var(--color-text-secondary);
    margin: 0;
    text-wrap: pretty;
  }

  /* ─── Phase eyebrow (above Phase 1 / Phase 2 headings) ─── */
  .mp-phase__eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: var(--weight-semibold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent-primary-pressed);
    margin: 0 0 var(--space-3) 0;
  }

  /* ─── Migration Lifecycle 5-card strip (between Phase 1 and Source Formats) ─── */
  .mp-lifecycle {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }
  @media (min-width: 1024px) {
    .mp-lifecycle {
      grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr auto 1fr;
      align-items: stretch;
      gap: var(--space-3);
    }
  }
  .mp-lifecycle__card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-5) var(--space-5) var(--space-6);
    border: var(--border-hairline);
    background-color: var(--color-page-bg);
  }
  .mp-lifecycle__num {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: var(--weight-semibold);
    letter-spacing: 0.12em;
    color: var(--color-accent-primary-pressed);
  }
  .mp-lifecycle__name {
    font-family: var(--font-display);
    font-size: var(--text-display-sm);
    font-weight: var(--weight-medium);
    line-height: var(--leading-snug);
    color: var(--color-text-primary);
    margin: 0;
    text-wrap: balance;
  }
  .mp-lifecycle__body {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    line-height: var(--leading-normal);
    color: var(--color-text-secondary);
    margin: 0;
    text-wrap: pretty;
  }
  .mp-lifecycle__arrow {
    display: none;
    align-self: center;
    color: var(--color-accent-primary-hover);
  }
  @media (min-width: 1024px) {
    .mp-lifecycle__arrow {
      display: flex;
      justify-content: center;
      align-items: center;
    }
  }
  .mp-lifecycle__arrow-svg {
    width: 32px;
    height: 16px;
    color: currentColor;
    overflow: visible;
    display: block;
  }
  .mp-lifecycle__arrow-path {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
    stroke-linecap: square;
    vector-effect: non-scaling-stroke;
  }

  /* ─── The five disciplines (vertical entries) ─── */
  .mp-disciplines {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .mp-discipline {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: var(--space-4);
    padding: var(--space-8) 0;
    border-top: var(--border-hairline);
  }

  @media (min-width: 768px) {
    .mp-discipline {
      grid-template-columns: 64px 1fr;
      gap: var(--space-6);
    }
  }

  .mp-discipline:last-child {
    border-bottom: var(--border-hairline);
  }

  .mp-discipline__num {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: var(--weight-regular);
    line-height: 1;
    color: #fcd34d;
    font-feature-settings: "tnum";
    padding-top: 2px;
  }

  @media (min-width: 768px) {
    .mp-discipline__num {
      font-size: 36px;
    }
  }

  .mp-discipline__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .mp-discipline__stage {
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0;
  }

  .mp-discipline__name {
    font-family: var(--font-display);
    font-size: var(--text-display-sm);
    font-weight: var(--weight-regular);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin: 0;
    text-wrap: balance;
  }

  .mp-discipline__text {
    font-family: var(--font-body);
    font-size: var(--text-body);
    line-height: var(--leading-normal);
    color: var(--color-text-secondary);
    margin: 0;
    text-wrap: pretty;
  }

  /* ─── Source formats (3-col mono grid) ─── */
  .mp-formats__eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-4) 0;
  }

  .mp-formats {
    list-style: none;
    margin: 0;
    padding: var(--space-6) 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3) var(--space-8);
  }

  @media (min-width: 640px) {
    .mp-formats {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1024px) {
    .mp-formats {
      grid-template-columns: 1fr 1fr 1fr;
    }
  }

  .mp-format {
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.4;
    color: var(--color-text-primary);
    padding: var(--space-2) 0;
    border-bottom: var(--border-hairline);
  }

  /* ─── Field rules (horizontal-row layout) ─── */
  .mp-rules {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .mp-rule-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
    padding: var(--space-8) 0;
    border-top: var(--border-hairline);
  }

  .mp-rule-row:last-child {
    border-bottom: var(--border-hairline);
  }

  @media (min-width: 768px) {
    .mp-rule-row {
      grid-template-columns: 48px 1fr;
      grid-template-rows: auto auto;
      gap: var(--space-2) var(--space-6);
      align-items: start;
    }

    .mp-rule-row__num {
      grid-row: 1 / -1;
      grid-column: 1;
    }

    .mp-rule-row__rule,
    .mp-rule-row__why {
      grid-column: 2;
    }
  }

  @media (min-width: 1024px) {
    .mp-rule-row {
      grid-template-columns: 48px minmax(0, 1fr) minmax(0, 1.8fr);
      grid-template-rows: auto;
      gap: var(--space-8);
      padding: var(--space-12) 0;
      align-items: start;
    }

    .mp-rule-row__num {
      grid-row: 1;
      grid-column: 1;
    }

    .mp-rule-row__rule {
      grid-row: 1;
      grid-column: 2;
    }

    .mp-rule-row__why {
      grid-row: 1;
      grid-column: 3;
    }
  }

  .mp-rule-row__num {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: var(--weight-regular);
    line-height: 1;
    color: #fcd34d;
    font-feature-settings: "tnum";
    padding-top: 2px;
    margin: 0;
  }

  .mp-rule-row__rule {
    font-family: var(--font-display);
    font-size: var(--text-display-sm);
    font-weight: var(--weight-regular);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin: 0;
    text-wrap: balance;
  }

  .mp-rule-row__why {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    line-height: var(--leading-normal);
    color: var(--color-text-secondary);
    margin: 0;
    text-wrap: pretty;
  }

  .mp-rule-row__why-tag {
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-right: var(--space-2);
  }

  /* ─── Hero side-visual: recovery before/after SVG (document-grade idiom) ─── */
  .mp-hero-visual {
    width: 100%;
    display: flex;
    justify-content: center;
  }
  @media (max-width: 1023px) {
    .mp-hero-visual {
      margin-top: var(--space-12);
      justify-content: flex-start;
    }
  }
  .mp-hero-flow {
    /* width: 520px (not 100%) — the Hero component's .hero__side is
       flex: 0 0 auto, so 'width: 100%' has no definite parent size and
       the SVG falls back to its intrinsic ~300px. Use an explicit width
       capped by max-width: 100% for narrow viewports. */
    width: 520px;
    max-width: 100%;
    height: auto;
    color: var(--color-text-primary);
    overflow: visible;
    display: block;
    shape-rendering: geometricPrecision;
  }
  .mp-hero-flow .chrome {
    font-family: var(--font-mono);
    font-size: 9px;
    fill: var(--color-text-muted);
    letter-spacing: 0.06em;
    user-select: none;
  }
  .mp-hero-flow .chrome--strong {
    fill: var(--color-text-primary);
    font-weight: var(--weight-medium);
  }
  .mp-hero-flow .label--muted {
    fill: var(--color-text-secondary);
  }
  .mp-hero-flow .label--accent {
    fill: var(--color-accent-primary-pressed);
  }
  .mp-hero-flow .corner {
    stroke: var(--color-accent-primary-hover);
    stroke-width: 1.25;
    fill: none;
  }
  .mp-hero-flow .chrome-rule {
    stroke: var(--color-border-subtle);
    stroke-width: 1;
  }
  .mp-hero-flow .build-dot {
    fill: var(--color-accent-primary-hover);
    stroke: none;
  }
  .mp-hero-flow .node {
    fill: var(--color-page-bg);
    stroke: var(--color-text-primary);
    stroke-width: 1.5;
    vector-effect: non-scaling-stroke;
  }
  .mp-hero-flow .node--custom {
    fill: #fef3c7;
    stroke: var(--color-accent-primary);
  }
  .mp-hero-flow .node-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: var(--weight-medium);
    fill: var(--color-text-primary);
    letter-spacing: 0.02em;
  }
  .mp-hero-flow .node-label--custom {
    fill: var(--color-accent-primary-pressed);
  }
  .mp-hero-flow .page-row {
    fill: var(--color-page-bg);
    stroke: var(--color-border-subtle);
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
  }
  .mp-hero-flow .page-row--rot {
    fill: var(--color-surface-elevated);
    stroke: var(--color-border-subtle);
  }
  .mp-hero-flow .page-row--custom {
    fill: #fef3c7;
    stroke: var(--color-accent-primary);
    stroke-width: 1;
  }
  .mp-hero-flow .page-label {
    font-family: var(--font-mono);
    font-size: 7px;
    fill: var(--color-text-primary);
    letter-spacing: 0.02em;
  }
  .mp-hero-flow .page-label--rot {
    fill: var(--color-text-muted);
  }
  .mp-hero-flow .page-label--custom {
    fill: var(--color-accent-primary-pressed);
  }

  /* Strikethroughs over ROT rows — draw with stroke-dasharray */
  .mp-hero-flow .strike {
    stroke: var(--color-text-muted);
    stroke-width: 0.75;
    vector-effect: non-scaling-stroke;
    stroke-dasharray: 130;
    stroke-dashoffset: 130;
  }
  .mp-hero-flow.drawn .strike {
    animation: mp-hero-strike 400ms ease-out forwards;
    animation-delay: var(--d, 0ms);
  }

  /* Center flow connector — draw with stroke-dasharray */
  .mp-hero-flow .flow-conn {
    stroke: var(--color-accent-primary-hover);
    stroke-width: 1.5;
    fill: none;
    vector-effect: non-scaling-stroke;
    stroke-dasharray: 240;
    stroke-dashoffset: 240;
  }
  .mp-hero-flow.drawn .flow-conn {
    animation: mp-hero-draw 620ms ease-out forwards;
    animation-delay: var(--d, 0ms);
  }

  /* fx fade-in for all other layered groups */
  .mp-hero-flow .fx {
    opacity: 0;
  }
  .mp-hero-flow.drawn .fx {
    animation: mp-hero-fade 360ms ease-out forwards;
    animation-delay: var(--d, 0ms);
  }
  @keyframes mp-hero-fade {
    to { opacity: 1; }
  }
  @keyframes mp-hero-draw {
    to { stroke-dashoffset: 0; }
  }
  @keyframes mp-hero-strike {
    to { stroke-dashoffset: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .mp-hero-flow .fx {
      opacity: 1 !important;
      animation: none !important;
    }
    .mp-hero-flow .flow-conn,
    .mp-hero-flow .strike {
      stroke-dashoffset: 0 !important;
      animation: none !important;
    }
  }
</style>

<script>
  function setupMpHero() {
    const svg = document.getElementById("mp-hero-flow");
    if (!svg) return;
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            svg.classList.add("drawn");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );
    observer.observe(svg);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupMpHero);
  } else {
    setupMpHero();
  }
  document.addEventListener("astro:page-load", setupMpHero);
</script>
