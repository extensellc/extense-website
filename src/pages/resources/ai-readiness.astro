---
/*
  /resources/ai-readiness — practitioner guide, redesigned.

  See docs/reframe-2026/ai-readiness.md for the locked wireframe + decisions.

  Section order:
    S1 Hero — H1 + subdeck (left) + compact score-arc SVG (right)
    S2 Why this matters — 3 rail-rows (banded)
    S3 The 7-dimension scorecard — 6 cards 3-col + 1 wide card
    S4 Interpret your score — 4-row rubric
    S5 Preparation roadmap — 5-card horizontal strip + inline typical timeline (banded)
    S6 What AI-ready content looks like — 3 sub-sections (metadata · chunking · vocabulary)
    S7 Output: chatbot-ready JSONL — 3-file row table (banded)
    S8 CTAModule

  Page-local CSS prefix: air-
*/

import BaseLayout from "../../layouts/BaseLayout.astro";
import CTAModule from "../../components/site/CTAModule.astro";

interface Dimension {
  number: string;
  name: string;
  question: string;
  why: string;
  scores: { level: "0" | "1" | "2"; body: string }[];
}

const dimensions: Dimension[] = [
  {
    number: "01",
    name: "Content typing",
    question: "Is every document formally typed — concept, task, reference, troubleshooting — or is everything a generic 'page'?",
    why: "AI intent routing depends on type. 'What is X?' → concept. 'How do I X?' → task. 'List of X' → reference. Without types, the AI cannot match question intent to answer format.",
    scores: [
      { level: "0", body: "Everything is a generic document" },
      { level: "1", body: "Some documents have informal categories" },
      { level: "2", body: "Every topic is formally typed with semantic structure" },
    ],
  },
  {
    number: "02",
    name: "Metadata coverage",
    question: "Does every topic have machine-readable metadata — audience, difficulty, domain, intent, duration?",
    why: "Metadata enables filtering. Without it, the AI retrieves beginner content for experts, developer docs for writers, and overview content when the user needs a step-by-step procedure.",
    scores: [
      { level: "0", body: "No metadata (or only title and date)" },
      { level: "1", body: "Some topics have partial metadata" },
      { level: "2", body: "Every topic has 5+ controlled metadata fields" },
    ],
  },
  {
    number: "03",
    name: "Section addressability",
    question: "Does every major section have a stable, unique ID?",
    why: "Vector stores chunk content at section boundaries. Without IDs, chunks break at arbitrary points — mid-sentence, mid-procedure, mid-table. The AI retrieves fragments instead of complete answers.",
    scores: [
      { level: "0", body: "No section IDs" },
      { level: "1", body: "Some sections have IDs" },
      { level: "2", body: "Every section has a stable, meaningful ID" },
    ],
  },
  {
    number: "04",
    name: "Vocabulary control",
    question: "Are metadata values drawn from a controlled vocabulary, or is it free-text tagging?",
    why: "Free-text tags produce inconsistency: 'dev', 'developer', 'software engineer', 'eng' all mean the same thing. AI filters break when vocabulary is uncontrolled. A subject scheme or taxonomy enforces consistency.",
    scores: [
      { level: "0", body: "Free-text or no tagging" },
      { level: "1", body: "Informal guidelines for tagging" },
      { level: "2", body: "Formal taxonomy enforced by schema" },
    ],
  },
  {
    number: "05",
    name: "Semantic markup richness",
    question: "Do topics use semantic elements — shortdesc, prereqs, steps, result, tables, notes — or is everything paragraphs?",
    why: "Semantic elements tell the AI the role of each block. A <shortdesc> becomes the chatbot's one-line answer. <steps> become numbered instructions. <prereq> tells the AI what the user needs before starting.",
    scores: [
      { level: "0", body: "Paragraphs only" },
      { level: "1", body: "Some semantic elements used" },
      { level: "2", body: "Full semantic markup throughout" },
    ],
  },
  {
    number: "06",
    name: "Reuse architecture",
    question: "Is content reused via conref / keyref / transclusion, or duplicated by copy-paste?",
    why: "Copy-paste duplication means the AI retrieves multiple slightly-different versions of the same content. Users see conflicting answers. Proper reuse means one authoritative source — one answer.",
    scores: [
      { level: "0", body: "Copy-paste duplication" },
      { level: "1", body: "Some shared components" },
      { level: "2", body: "Systematic reuse via conref / keyref" },
    ],
  },
  {
    number: "07",
    name: "Output pipeline maturity",
    question: "Can the pipeline produce HTML, PDF, JSON, and chatbot-ready JSONL from a single source automatically?",
    why: "AI pipelines consume JSON / JSONL — not PDF. If your publishing pipeline only produces PDF and HTML, you need a separate export step for AI ingestion. A mature pipeline includes chatbot-ready output as a first-class format.",
    scores: [
      { level: "0", body: "Manual export to 1-2 formats" },
      { level: "1", body: "Automated build to HTML + PDF" },
      { level: "2", body: "Automated multi-format including JSON / JSONL for AI" },
    ],
  },
];

const whyCards = [
  {
    label: "The problem",
    body: "Most enterprise content sits in unstructured formats — Word, PDF, wiki pages, Markdown. When that lands in a vector store, the AI treats every paragraph as undifferentiated text. It can't distinguish a safety warning from a marketing blurb, a step-by-step procedure from a concept explanation, or a beginner topic from an expert reference.",
  },
  {
    label: "The cost of inaction",
    body: "Organizations that deploy chatbots on unstructured content see retrieval precision around 25–35%. Users get wrong answers, lose trust, and escalate to human support. Worse, AI hallucinations fill gaps where metadata should have guided the system — and a hallucinated citation is materially worse than a missed one.",
  },
  {
    label: "The opportunity",
    body: "Content that is semantically typed, metadata-enriched, and section-addressable delivers 85%+ retrieval precision. The AI knows what each piece of content is, who it's for, and when to surface it. That's the difference between a chatbot that guesses and one that answers — and it's an engineering problem, not a model-selection problem.",
  },
];

const interpretation = [
  { range: "0 – 4",   meaning: "AI will treat your content as plain text. Chatbot answers will be imprecise, often wrong. This is where most organizations start." },
  { range: "5 – 7",   meaning: "Partial readiness. Some AI features work, but gaps in metadata or structure cause retrieval failures for edge cases." },
  { range: "8 – 10",  meaning: "Production-ready. AI can filter, route, chunk, and cite your content precisely. This is where our clients end up." },
  { range: "11 – 14", meaning: "Best-in-class. Full semantic markup, enforced taxonomy, multi-format output including JSONL — your content is an organizational asset, not just documentation." },
];

const roadmap = [
  {
    phase: "Audit & baseline",
    body: "Score your current content on the seven dimensions above. Identify the biggest gaps. Inventory content by type, volume, language, and update frequency.",
    deliverable: "Content audit report with AI-readiness score and gap analysis.",
  },
  {
    phase: "Structure & type",
    body: "Convert content to a typed format (DITA concept / task / reference, or equivalent). Split monolithic documents into focused single-purpose topics. Add section IDs to every major block.",
    deliverable: "Typed, modular topics with section-level addressability.",
  },
  {
    phase: "Enrich metadata",
    body: "Define a controlled vocabulary (subject scheme or taxonomy) with facets for audience, difficulty, content domain, content intent. Apply metadata to every topic via batch tooling — not manual entry.",
    deliverable: "100% metadata coverage with enforced vocabulary.",
  },
  {
    phase: "Build the pipeline",
    body: "Configure the publishing toolchain to produce chatbot-ready output alongside traditional formats. JSONL export with section-aware chunking, metadata inheritance, and glossary extraction.",
    deliverable: "Automated build producing HTML5, PDF, and JSONL from a single source.",
  },
  {
    phase: "Integrate & validate",
    body: "Connect the JSONL output to your vector store and chatbot. Configure metadata filters for intent routing and audience matching. Run retrieval tests with real user queries.",
    deliverable: "Working AI retrieval with measured precision rate.",
  },
];

const timelineRows = [
  { scale: "Small corpus",  range: "50 – 200 topics",    duration: "4 – 8 weeks through all 5 phases." },
  { scale: "Medium corpus", range: "200 – 1,000 topics", duration: "8 – 16 weeks, often with phases 2 and 3 running in parallel batches." },
  { scale: "Large corpus",  range: "1,000+ topics",      duration: "3 – 6 months, phased rollout by product line or content domain." },
];

const metadataExamples = [
  {
    label: "Audience filtering",
    body: "A developer asks 'How do I create a custom plugin?' — the AI filters for audience=developer and intent=how-to, skipping the manager-level overview of the same feature. Without metadata, both would be returned with equal rank.",
  },
  {
    label: "Difficulty matching",
    body: "A beginner asks 'What is DITA?' — the AI returns the difficulty=beginner concept topic, not the advanced architecture reference. The right answer at the right level prevents overwhelm and helpdesk escalation.",
  },
  {
    label: "Intent routing",
    body: "'What is X?' routes to concepts. 'How do I X?' routes to tasks. 'Show me the parameters' routes to reference tables. Topic typing plus intent metadata makes this automatic — no prompt engineering required.",
  },
];

const outputFiles = [
  { name: "chunks.jsonl",         purpose: "One JSON object per section. Ready for vector store embedding. Metadata fields enable filtered retrieval." },
  { name: "glossary-index.json",  purpose: "Term definitions with synonyms. Enables the chatbot to resolve terminology and expand queries." },
  { name: "content-manifest.json", purpose: "Topic inventory with metadata. Used for corpus validation, coverage analysis, and pipeline health checks." },
];
---

<BaseLayout
  title="AI-Readiness Guide — Extense LLC"
  description="A practitioner guide to making content AI-ready: a seven-dimension scorecard, a five-phase preparation roadmap, and worked examples of what AI-ready DITA, metadata, and JSONL output actually look like."
>
  {/* ───────── S1 — Hero ───────── */}
  <section class="air-section air-section--hero" aria-labelledby="air-hero-heading">
    <div class="container-page air-section__inner">
      <div class="air-hero__top">
        <div class="air-hero__lead">
          <h1 id="air-hero-heading" class="air-hero__title">AI-readiness is a content engineering problem.</h1>
          <p class="air-hero__subdeck">
            Retrieval precision is upstream of model selection. A practitioner guide to the seven dimensions of content engineering that determine whether your AI pipeline returns the right answer or the closest keyword match.
          </p>
        </div>

        <div class="air-hero__aside">
          <svg
            class="air-hero-flow"
            id="air-hero-flow"
            viewBox="0 0 480 220"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
            role="presentation"
          >
            <g class="corner fx" style="--d: 0ms">
              <path d="M 12 22 L 12 12 L 22 12" />
              <path d="M 458 12 L 468 12 L 468 22" />
              <path d="M 12 198 L 12 208 L 22 208" />
              <path d="M 458 208 L 468 208 L 468 198" />
            </g>

            <text class="chrome fx" x="24" y="30" style="--d: 80ms">in :: readiness.scored</text>
            <text class="chrome label--muted fx" x="24" y="46" style="--d: 160ms">15-POINT SCALE · 0 → 14</text>

            {/* Axis line */}
            <line class="axis fx" x1="30" y1="120" x2="450" y2="120" style="--d: 240ms" />

            {/* 15 tick marks at integer positions (x = 30 + i*30) */}
            {Array.from({ length: 15 }).map((_, i) => {
              const x = 30 + i * 30;
              const isAnchor = i === 0 || i === 14;
              const delay = 320 + i * 30;
              return (
                <g class="fx" style={`--d: ${delay}ms`}>
                  <line class={isAnchor ? "tick tick--strong" : "tick"} x1={x} y1="114" x2={x} y2="126" />
                  <text class="tick-num" x={x} y="142" text-anchor="middle">{i}</text>
                </g>
              );
            })}

            {/* Amber arc/line from baseline (3) to target (10), drawn */}
            <path class="flow-conn" style="--d: 820ms" d="M120 120 L330 120" />

            {/* Baseline dot at x=120 (tick 3) */}
            <g class="fx" style="--d: 940ms">
              <circle class="dot dot--baseline" cx="120" cy="120" r="7" />
              <text class="dot-label dot-label--muted" x="120" y="172" text-anchor="middle">BASELINE</text>
              <text class="dot-value dot-value--muted" x="120" y="190" text-anchor="middle">3</text>
            </g>

            {/* Target dot at x=330 (tick 10) */}
            <g class="fx" style="--d: 1060ms">
              <circle class="dot dot--target" cx="330" cy="120" r="9" />
              <text class="dot-label dot-label--accent" x="330" y="172" text-anchor="middle">TARGET</text>
              <text class="dot-value dot-value--accent" x="330" y="190" text-anchor="middle">10</text>
            </g>

            {/* "+7 measured" chip on the arc */}
            <g class="fx" style="--d: 1180ms">
              <rect class="node node--custom" x="195" y="90" width="120" height="22" rx="3" />
              <text class="node-label node-label--custom" x="255" y="106" text-anchor="middle">+7 measured</text>
            </g>

            {/* Bottom chrome */}
            <g class="fx" style="--d: 1320ms">
              <line class="chrome-rule" x1="24" y1="200" x2="456" y2="200" />
              <rect class="build-dot" x="172" y="207" width="6" height="6" />
              <text class="chrome chrome--strong" x="186" y="213">FIG. 01</text>
              <text class="chrome" x="236" y="213">/</text>
              <text class="chrome chrome--strong" x="244" y="213">readiness.scored</text>
              <text class="chrome chrome--strong" x="456" y="213" text-anchor="end">0 → 14</text>
            </g>
          </svg>
        </div>
      </div>
    </div>
  </section>

  {/* ───────── S2 — Why this matters ───────── */}
  <section class="air-section air-section--band" aria-labelledby="air-why-heading">
    <div class="container-page air-section__inner">
      <div class="air-heading-block">
        <h2 id="air-why-heading" class="air-heading">Why AI-readiness matters.</h2>
        <p class="air-intro">
          Most enterprise content sits in unstructured formats. When it lands in a vector store, the AI treats every paragraph as undifferentiated text.
        </p>
      </div>

      <ol class="air-why">
        {whyCards.map((card) => (
          <li class="air-rail-row">
            <p class="air-rail-row__label">{card.label}</p>
            <p class="air-rail-row__body">{card.body}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  {/* ───────── S3 — The 7-dimension scorecard ───────── */}
  <section class="air-section" aria-labelledby="air-scorecard-heading">
    <div class="container-page air-section__inner">
      <div class="air-heading-block">
        <h2 id="air-scorecard-heading" class="air-heading">The seven-dimension scorecard.</h2>
        <p class="air-intro">
          Rate your content on each dimension below: 0, 1, or 2 points. Total range is 0–14. Sum your score and consult the interpretation rubric below.
        </p>
      </div>

      <ol class="air-dim-grid">
        {dimensions.slice(0, 6).map((d) => (
          <li class="air-dim-card">
            <header class="air-dim-card__head">
              <span class="air-dim-card__num">{d.number}</span>
              <p class="air-dim-card__name">{d.name}</p>
            </header>
            <p class="air-dim-card__question">{d.question}</p>
            <div class="air-dim-card__why">
              <p class="air-dim-card__sub-label">Why it matters</p>
              <p class="air-dim-card__sub-body">{d.why}</p>
            </div>
            <div class="air-dim-card__scoring">
              <p class="air-dim-card__sub-label">Scoring</p>
              <ul class="air-dim-card__scores">
                {d.scores.map((s) => (
                  <li class="air-score">
                    <span class="air-score__num">{s.level}</span>
                    <span class="air-score__body">{s.body}</span>
                  </li>
                ))}
              </ul>
            </div>
          </li>
        ))}
      </ol>

      {/* Dimension 07 — full-width card matching the old page layout */}
      <article class="air-dim-card air-dim-card--wide">
        <header class="air-dim-card__head">
          <span class="air-dim-card__num">{dimensions[6].number}</span>
          <p class="air-dim-card__name">{dimensions[6].name}</p>
        </header>
        <div class="air-dim-card__wide-grid">
          <p class="air-dim-card__question">{dimensions[6].question}</p>
          <div class="air-dim-card__why">
            <p class="air-dim-card__sub-label">Why it matters</p>
            <p class="air-dim-card__sub-body">{dimensions[6].why}</p>
          </div>
          <div class="air-dim-card__scoring">
            <p class="air-dim-card__sub-label">Scoring</p>
            <ul class="air-dim-card__scores">
              {dimensions[6].scores.map((s) => (
                <li class="air-score">
                  <span class="air-score__num">{s.level}</span>
                  <span class="air-score__body">{s.body}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </article>
    </div>
  </section>

  {/* ───────── S4 — Interpret your score ───────── */}
  <section class="air-section" aria-labelledby="air-interpret-heading">
    <div class="container-page air-section__inner">
      <div class="air-heading-block">
        <h2 id="air-interpret-heading" class="air-heading">Interpret your score.</h2>
      </div>

      <dl class="air-interpret">
        {interpretation.map((row) => (
          <div class="air-rail-row air-rail-row--interpret">
            <dt class="air-rail-row__label air-interpret__range">{row.range}</dt>
            <dd class="air-rail-row__body">{row.meaning}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  {/* ───────── S5 — The preparation roadmap (banded) ───────── */}
  <section class="air-section air-section--band" aria-labelledby="air-roadmap-heading">
    <div class="container-page air-section__inner">
      <div class="air-heading-block">
        <h2 id="air-roadmap-heading" class="air-heading">The preparation roadmap.</h2>
        <p class="air-intro">
          Five phases to take content from unstructured to AI-ready. Each phase builds on the previous one; skipping the foundation phases is the most common way these programs fail.
        </p>
      </div>

      <ol class="air-strip">
        {roadmap.map((r, i) => (
          <>
            <li class="air-strip__card">
              <span class="air-strip__num">{String(i + 1).padStart(2, "0")}</span>
              <h3 class="air-strip__name">{r.phase}</h3>
              <p class="air-strip__body">{r.body}</p>
              <p class="air-strip__deliverable">
                <span class="air-strip__deliverable-tag">Deliverable:</span> {r.deliverable}
              </p>
            </li>
            {i < roadmap.length - 1 && (
              <li class="air-strip__arrow" aria-hidden="true">
                <svg viewBox="0 0 32 16" class="air-strip__arrow-svg" aria-hidden="true">
                  <path class="air-strip__arrow-path" d="M 0 8 L 28 8 M 24 4 L 28 8 L 24 12" />
                </svg>
              </li>
            )}
          </>
        ))}
      </ol>

      {/* Inline timeline addendum */}
      <div class="air-timeline">
        <p class="air-timeline__eyebrow">Typical timeline</p>
        <dl class="air-timeline__rows">
          {timelineRows.map((t) => (
            <div class="air-rail-row air-rail-row--timeline">
              <dt class="air-rail-row__label air-timeline__scale">
                <span class="air-timeline__scale-name">{t.scale}</span>
                <span class="air-timeline__scale-range">{t.range}</span>
              </dt>
              <dd class="air-rail-row__body">{t.duration}</dd>
            </div>
          ))}
        </dl>
      </div>
    </div>
  </section>

  {/* ───────── S6 — What AI-ready content looks like ───────── */}
  <section class="air-section" aria-labelledby="air-examples-heading">
    <div class="container-page air-section__inner">
      <div class="air-heading-block">
        <h2 id="air-examples-heading" class="air-heading">What AI-ready content looks like.</h2>
        <p class="air-intro">
          Concrete examples of the transformations the scorecard measures. Each pair shows the failure mode at score 0 and the working pattern at score 2.
        </p>
      </div>

      <div class="air-examples">
        {/* Sub-section: metadata filtering — 3 rail-rows */}
        <div class="air-example-group">
          <p class="air-example-group__label">Metadata that AI systems can filter</p>
          <ul class="air-example-group__rows">
            {metadataExamples.map((e) => (
              <li class="air-rail-row air-rail-row--example">
                <p class="air-rail-row__label">{e.label}</p>
                <p class="air-rail-row__body">{e.body}</p>
              </li>
            ))}
          </ul>
        </div>

        {/* Sub-section: section-aware chunking — 2-col before/after */}
        <div class="air-example-group">
          <p class="air-example-group__label">Section-aware chunking</p>
          <div class="air-ba-grid">
            <article class="air-ba">
              <p class="air-ba__label">Without section IDs</p>
              <p class="air-ba__body">A 2,000-word topic gets split into three chunks of ~667 words each. Chunk 2 starts mid-paragraph, references "the step above" (which is now in Chunk 1), and includes half a table. The AI retrieves Chunk 2 and the user sees a fragment that doesn't make sense.</p>
            </article>
            <article class="air-ba">
              <p class="air-ba__label">With section IDs</p>
              <p class="air-ba__body">The same topic has five sections, each with a stable ID and self-contained heading. Chunking happens at section boundaries. Each chunk is a complete, citable unit. The AI retrieves the exact section, and the user sees a coherent answer with a deep-link back to source.</p>
            </article>
          </div>
        </div>

        {/* Sub-section: controlled vocabulary vs free-text — 2-col before/after */}
        <div class="air-example-group">
          <p class="air-example-group__label">Controlled vocabulary vs. free-text tags</p>
          <div class="air-ba-grid">
            <article class="air-ba">
              <p class="air-ba__label">Free-text chaos</p>
              <p class="air-ba__body">Topic A is tagged "developer". Topic B is tagged "dev". Topic C is tagged "software engineer". Topic D has no audience tag. A filter for <code>audience=developer</code> returns only Topic A — missing 75% of relevant content. The chatbot appears to have knowledge gaps that don't actually exist.</p>
            </article>
            <article class="air-ba">
              <p class="air-ba__label">Controlled vocabulary</p>
              <p class="air-ba__body">A DITA subject scheme defines exactly seven valid audience values: <em>technical-writer, developer, build-engineer, manager, localization-specialist, editor, all</em>. Validation rejects any other value. The same filter returns 100% of relevant content — zero false negatives.</p>
            </article>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ───────── S7 — Output: chatbot-ready JSONL (banded) ───────── */}
  <section class="air-section air-section--band" aria-labelledby="air-output-heading">
    <div class="container-page air-section__inner">
      <div class="air-heading-block">
        <h2 id="air-output-heading" class="air-heading">Output: chatbot-ready JSONL.</h2>
        <p class="air-intro">
          Each section becomes a JSONL record with the text content, topic title, section heading, topic type (concept / task / reference), all metadata fields, the section ID for deep-linking, and the parent map path for breadcrumb context. A glossary index maps terms to definitions with synonyms. A content manifest provides a searchable index of all topics.
        </p>
      </div>

      <dl class="air-output">
        {outputFiles.map((f) => (
          <div class="air-rail-row air-rail-row--output">
            <dt class="air-rail-row__label air-output__name">{f.name}</dt>
            <dd class="air-rail-row__body">{f.purpose}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <CTAModule
    audience="general"
    body="Submit a 20-topic sample. We'll score it on all seven dimensions, return a gap analysis with recommended next steps, and indicate the engineering effort required to reach production-grade retrieval. No obligation to proceed."
  />
</BaseLayout>

<style>
  /* ─── Section shell ─── */
  .air-section {
    padding-top: var(--space-12);
    padding-bottom: var(--space-12);
    border-top: var(--border-hairline);
  }
  .air-section--hero {
    padding-top: var(--space-16);
    padding-bottom: var(--space-12);
    border-top: 0;
  }
  @media (min-width: 768px) {
    .air-section--hero {
      padding-top: var(--space-20);
    }
  }
  .air-section--band {
    background-color: var(--color-surface-band);
  }
  @media (max-width: 767px) {
    .air-section {
      padding-top: var(--space-8);
      padding-bottom: var(--space-8);
    }
  }

  .air-heading-block {
    margin-bottom: var(--space-10);
    max-width: 80ch;
  }
  .air-heading {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
