---
/*
  /resources/ai-readiness — practitioner guide to making content AI-ready.

  Section order:
    1. Hero (universal, with ScorecardDimensionCard side panel — static)
    2. Framing prose — names the asymmetry
    3. AnimatedDivider
    4. The 7-Dimension Scorecard (two-column grid: 4 + 3)
    5. Interpret your score (4-row rubric)
    6. AnimatedDivider
    7. The Preparation Roadmap (5 vertical phases + typical timeline)
    8. AnimatedDivider
    9. What AI-Ready Content Looks Like (3 sub-sections: metadata filtering,
       section-aware chunking, controlled vocabulary)
   10. Output: chatbot-ready JSONL (3-file schema)
   11. AnimatedDivider
   12. CTAModule (general)
*/

import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/site/Hero.astro";
import ScorecardDimensionCard from "../../components/site/ScorecardDimensionCard.astro";
import CTAModule from "../../components/site/CTAModule.astro";
import AnimatedDivider from "../../components/site/AnimatedDivider.astro";

interface Dimension {
  number: string;
  name: string;
  question: string;
  why: string;
  scores: { level: "0" | "1" | "2"; body: string }[];
}

const dimensions: Dimension[] = [
  {
    number: "01",
    name: "Content typing",
    question: "Is every document formally typed — concept, task, reference, troubleshooting — or is everything a generic 'page'?",
    why: "AI intent routing depends on type. 'What is X?' → concept. 'How do I X?' → task. 'List of X' → reference. Without types, the AI cannot match question intent to answer format.",
    scores: [
      { level: "0", body: "Everything is a generic document" },
      { level: "1", body: "Some documents have informal categories" },
      { level: "2", body: "Every topic is formally typed with semantic structure" },
    ],
  },
  {
    number: "02",
    name: "Metadata coverage",
    question: "Does every topic have machine-readable metadata — audience, difficulty, domain, intent, duration?",
    why: "Metadata enables filtering. Without it, the AI retrieves beginner content for experts, developer docs for writers, and overview content when the user needs a step-by-step procedure.",
    scores: [
      { level: "0", body: "No metadata (or only title and date)" },
      { level: "1", body: "Some topics have partial metadata" },
      { level: "2", body: "Every topic has 5+ controlled metadata fields" },
    ],
  },
  {
    number: "03",
    name: "Section addressability",
    question: "Does every major section have a stable, unique ID?",
    why: "Vector stores chunk content at section boundaries. Without IDs, chunks break at arbitrary points — mid-sentence, mid-procedure, mid-table. The AI retrieves fragments instead of complete answers.",
    scores: [
      { level: "0", body: "No section IDs" },
      { level: "1", body: "Some sections have IDs" },
      { level: "2", body: "Every section has a stable, meaningful ID" },
    ],
  },
  {
    number: "04",
    name: "Vocabulary control",
    question: "Are metadata values drawn from a controlled vocabulary, or is it free-text tagging?",
    why: "Free-text tags produce inconsistency: 'dev', 'developer', 'software engineer', 'eng' all mean the same thing. AI filters break when vocabulary is uncontrolled. A subject scheme or taxonomy enforces consistency.",
    scores: [
      { level: "0", body: "Free-text or no tagging" },
      { level: "1", body: "Informal guidelines for tagging" },
      { level: "2", body: "Formal taxonomy enforced by schema" },
    ],
  },
  {
    number: "05",
    name: "Semantic markup richness",
    question: "Do topics use semantic elements — shortdesc, prereqs, steps, result, tables, notes — or is everything paragraphs?",
    why: "Semantic elements tell the AI the role of each block. A <shortdesc> becomes the chatbot's one-line answer. <steps> become numbered instructions. <prereq> tells the AI what the user needs before starting.",
    scores: [
      { level: "0", body: "Paragraphs only" },
      { level: "1", body: "Some semantic elements used" },
      { level: "2", body: "Full semantic markup throughout" },
    ],
  },
  {
    number: "06",
    name: "Reuse architecture",
    question: "Is content reused via conref / keyref / transclusion, or duplicated by copy-paste?",
    why: "Copy-paste duplication means the AI retrieves multiple slightly-different versions of the same content. Users see conflicting answers. Proper reuse means one authoritative source — one answer.",
    scores: [
      { level: "0", body: "Copy-paste duplication" },
      { level: "1", body: "Some shared components" },
      { level: "2", body: "Systematic reuse via conref / keyref" },
    ],
  },
  {
    number: "07",
    name: "Output pipeline maturity",
    question: "Can the pipeline produce HTML, PDF, JSON, and chatbot-ready JSONL from a single source automatically?",
    why: "AI pipelines consume JSON / JSONL — not PDF. If your publishing pipeline only produces PDF and HTML, you need a separate export step for AI ingestion. A mature pipeline includes chatbot-ready output as a first-class format.",
    scores: [
      { level: "0", body: "Manual export to 1-2 formats" },
      { level: "1", body: "Automated build to HTML + PDF" },
      { level: "2", body: "Automated multi-format including JSON / JSONL for AI" },
    ],
  },
];

const interpretation = [
  { range: "0 – 4",   meaning: "AI will treat your content as plain text. Chatbot answers will be imprecise, often wrong. This is where most organizations start." },
  { range: "5 – 7",   meaning: "Partial readiness. Some AI features work, but gaps in metadata or structure cause retrieval failures for edge cases." },
  { range: "8 – 10",  meaning: "Production-ready. AI can filter, route, chunk, and cite your content precisely. This is where our clients end up." },
  { range: "11 – 14", meaning: "Best-in-class. Full semantic markup, enforced taxonomy, multi-format output including JSONL — your content is an organizational asset, not just documentation." },
];

const roadmap = [
  {
    phase: "Audit & baseline",
    body: "Score your current content on the seven dimensions above. Identify the biggest gaps. Inventory content by type, volume, language, and update frequency. This baseline is what every improvement will be measured against.",
    deliverable: "Content audit report with AI-readiness score and gap analysis.",
  },
  {
    phase: "Structure & type",
    body: "Convert content to a typed format (DITA concept / task / reference, or equivalent). Split monolithic documents into focused single-purpose topics. Add section IDs to every major block. This is the foundation — without it, nothing downstream works.",
    deliverable: "Typed, modular topics with section-level addressability.",
  },
  {
    phase: "Enrich metadata",
    body: "Define a controlled vocabulary (subject scheme or taxonomy) with facets for audience, difficulty, content domain, content intent, and any organization-specific dimensions. Apply metadata to every topic via batch tooling — not manual entry.",
    deliverable: "100% metadata coverage with enforced vocabulary.",
  },
  {
    phase: "Build the pipeline",
    body: "Configure the publishing toolchain to produce chatbot-ready output alongside traditional formats. JSONL export with section-aware chunking, metadata inheritance, and glossary extraction. Test the chunks against sample queries.",
    deliverable: "Automated build producing HTML5, PDF, and JSONL from a single source.",
  },
  {
    phase: "Integrate & validate",
    body: "Connect the JSONL output to your vector store and chatbot. Configure metadata filters for intent routing and audience matching. Run retrieval tests with real user queries. Measure precision and iterate on vocabulary and chunking strategy.",
    deliverable: "Working AI retrieval with measured precision rate.",
  },
];

const timelineRows = [
  {
    scale: "Small corpus",
    range: "50 – 200 topics",
    duration: "4 – 8 weeks through all 5 phases.",
  },
  {
    scale: "Medium corpus",
    range: "200 – 1,000 topics",
    duration: "8 – 16 weeks, often with phases 2 and 3 running in parallel batches.",
  },
  {
    scale: "Large corpus",
    range: "1,000+ topics",
    duration: "3 – 6 months, phased rollout by product line or content domain. Automation tooling (enrich-metadata.py, dita-to-chatbot-json.py) is critical at this scale.",
  },
];

const metadataExamples = [
  {
    label: "Audience filtering",
    body: "A developer asks 'How do I create a custom plugin?' — the AI filters for audience=developer and intent=how-to, skipping the manager-level overview of the same feature. Without metadata, both would be returned with equal rank.",
  },
  {
    label: "Difficulty matching",
    body: "A beginner asks 'What is DITA?' — the AI returns the difficulty=beginner concept topic, not the advanced architecture reference. The right answer at the right level prevents overwhelm and helpdesk escalation.",
  },
  {
    label: "Intent routing",
    body: "'What is X?' routes to concepts. 'How do I X?' routes to tasks. 'Show me the parameters' routes to reference tables. Topic typing plus intent metadata makes this automatic — no prompt engineering required.",
  },
];

const outputFiles = [
  {
    name: "chunks.jsonl",
    purpose: "One JSON object per section. Ready for vector store embedding. Metadata fields enable filtered retrieval.",
  },
  {
    name: "glossary-index.json",
    purpose: "Term definitions with synonyms. Enables the chatbot to resolve terminology and expand queries.",
  },
  {
    name: "content-manifest.json",
    purpose: "Topic inventory with metadata. Used for corpus validation, coverage analysis, and pipeline health checks.",
  },
];
---

<BaseLayout
  title="AI-Readiness Guide — Extense LLC"
  description="A practitioner guide to making content AI-ready: a seven-dimension scorecard, a five-phase preparation roadmap, and worked examples of what AI-ready DITA, metadata, and JSONL output actually look like."
>
  <Hero
    variant="universal"
    title="AI-readiness is a content engineering problem."
    subdeck="Retrieval precision is upstream of model selection. A practitioner guide to the seven dimensions of content engineering that determine whether your AI pipeline returns the right answer or the closest keyword match."
  >
    <ScorecardDimensionCard
      number="01"
      total="07"
      dimension={dimensions[0].name}
      question={dimensions[0].question}
      scores={dimensions[0].scores}
    />
  </Hero>

  <AnimatedDivider />

  <section class="air-section air-section--framing" aria-labelledby="framing-heading">
    <div class="container-prose air-section__inner">
      <h2 id="framing-heading" class="air-section__heading">Why AI-readiness matters.</h2>
      <div class="air-framing">
        <p>
          Most enterprise content sits in unstructured formats — Word, PDF, wiki pages, Markdown. When that content gets ingested into a vector store, the AI treats every paragraph as undifferentiated text. It can't distinguish a worked example from a marketing blurb, a step-by-step procedure from a concept explanation, or a beginner topic from an expert reference.
        </p>
        <p>
          The failure shows up downstream as retrieval precision in the 25–35% range. Users get wrong answers, lose trust, and escalate to human support. Worse, AI hallucinations fill gaps where metadata should have guided the system. The asymmetry that matters in regulated workloads: a hallucinated citation is materially worse than a missed one. The missed result gets escalated; the hallucinated citation gets followed.
        </p>
        <p>
          Content that is semantically typed, metadata-enriched, and section-addressable delivers production-grade retrieval precision because the AI knows what each piece of content is, who it's for, and when to surface it. That's the difference between a chatbot that guesses and one that answers — and it's an engineering problem, not a model selection problem.
        </p>
      </div>
    </div>
  </section>

  <AnimatedDivider />

  <section class="air-section air-section--scorecard" aria-labelledby="scorecard-heading">
    <div class="container-data air-section__inner">
      <h2 id="scorecard-heading" class="air-section__heading">The seven-dimension scorecard.</h2>
      <p class="air-section__lead">
        Rate your content on each dimension below: 0, 1, or 2 points. Total range is 0–14. Sum your score and consult the interpretation rubric at the end. Honest self-scoring is the prerequisite for an honest baseline.
      </p>

      <ol class="air-grid">
        {dimensions.map((d) => (
          <li class="air-dim">
            <span class="air-dim__num" aria-hidden="true">{d.number}</span>
            <p class="air-dim__name">{d.name}</p>
            <div class="air-dim__col air-dim__col--question">
              <p class="air-dim__question">{d.question}</p>
            </div>
            <div class="air-dim__col air-dim__col--why">
              <p class="air-dim__why-label">Why it matters</p>
              <p class="air-dim__why">{d.why}</p>
            </div>
            <div class="air-dim__col air-dim__col--scoring">
              <p class="air-dim__scoring-label">Scoring</p>
              <ul class="air-dim__scores">
                {d.scores.map((s) => (
                  <li class="air-score">
                    <span class="air-score__num">{s.level}</span>
                    <span class="air-score__body">{s.body}</span>
                  </li>
                ))}
              </ul>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="air-section air-section--interpret" aria-labelledby="interpret-heading">
    <div class="container-prose air-section__inner">
      <h2 id="interpret-heading" class="air-section__heading">Interpret your score.</h2>
      <dl class="air-interpret">
        {interpretation.map((row) => (
          <div class="air-interpret__row">
            <dt class="air-interpret__range">{row.range}</dt>
            <dd class="air-interpret__meaning">{row.meaning}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <AnimatedDivider />

  <section class="air-section air-section--roadmap" aria-labelledby="roadmap-heading">
    <div class="container-prose air-section__inner">
      <h2 id="roadmap-heading" class="air-section__heading">The preparation roadmap.</h2>
      <p class="air-section__lead">
        Five phases to take content from unstructured to AI-ready. Each phase builds on the previous one; skipping the foundation phases is the most common way these programs fail.
      </p>

      <ol class="air-roadmap">
        {roadmap.map((r, i) => (
          <li class="air-phase">
            <span class="air-phase__num" aria-hidden="true">{String(i + 1).padStart(2, "0")}</span>
            <div class="air-phase__body">
              <h3 class="air-phase__name">{r.phase}</h3>
              <p class="air-phase__text">{r.body}</p>
              <p class="air-phase__deliverable">
                <span class="air-phase__deliverable-tag">Deliverable:</span> {r.deliverable}
              </p>
            </div>
          </li>
        ))}
      </ol>

      <div class="air-timeline">
        <p class="air-timeline__eyebrow">Typical timeline</p>
        <hr class="air-rule" />
        <dl class="air-timeline__rows">
          {timelineRows.map((t) => (
            <div class="air-timeline__row">
              <dt class="air-timeline__scale">
                <span class="air-timeline__scale-name">{t.scale}</span>
                <span class="air-timeline__scale-range">{t.range}</span>
              </dt>
              <dd class="air-timeline__duration">{t.duration}</dd>
            </div>
          ))}
        </dl>
        <hr class="air-rule" />
      </div>
    </div>
  </section>

  <AnimatedDivider />

  <section class="air-section air-section--examples" aria-labelledby="examples-heading">
    <div class="container-prose air-section__inner">
      <h2 id="examples-heading" class="air-section__heading">What AI-ready content looks like.</h2>
      <p class="air-section__lead">
        Concrete examples of the transformations the scorecard measures. Each pair shows the failure mode at score 0 and the working pattern at score 2.
      </p>

      <div class="air-examples">
        <div class="air-example-group">
          <h3 class="air-example-group__label">Metadata that AI systems can filter</h3>
          <hr class="air-rule" />
          <ul class="air-meta-list">
            {metadataExamples.map((e) => (
              <li class="air-meta-row">
                <p class="air-meta-row__label">{e.label}</p>
                <p class="air-meta-row__body">{e.body}</p>
              </li>
            ))}
          </ul>
          <hr class="air-rule" />
        </div>

        <div class="air-example-group">
          <h3 class="air-example-group__label">Section-aware chunking</h3>
          <div class="air-ba-grid">
            <article class="air-ba">
              <p class="air-ba__label">Without section IDs</p>
              <p class="air-ba__body">A 2,000-word topic gets split into three chunks of ~667 words each. Chunk 2 starts mid-paragraph, references "the step above" (which is now in Chunk 1), and includes half a table. The AI retrieves Chunk 2 and the user sees a fragment that doesn't make sense.</p>
            </article>
            <article class="air-ba">
              <p class="air-ba__label">With section IDs</p>
              <p class="air-ba__body">The same topic has five sections, each with a stable ID and self-contained heading. Chunking happens at section boundaries. Each chunk is a complete, citable unit. The AI retrieves the exact section, and the user sees a coherent answer with a deep-link back to source.</p>
            </article>
          </div>
        </div>

        <div class="air-example-group">
          <h3 class="air-example-group__label">Controlled vocabulary vs. free-text tags</h3>
          <div class="air-ba-grid">
            <article class="air-ba">
              <p class="air-ba__label">Free-text chaos</p>
              <p class="air-ba__body">Topic A is tagged "developer". Topic B is tagged "dev". Topic C is tagged "software engineer". Topic D has no audience tag. A filter for <code>audience=developer</code> returns only Topic A — missing 75% of relevant content. The chatbot appears to have knowledge gaps that don't actually exist.</p>
            </article>
            <article class="air-ba">
              <p class="air-ba__label">Controlled vocabulary</p>
              <p class="air-ba__body">A DITA subject scheme defines exactly seven valid audience values: <em>technical-writer, developer, build-engineer, manager, localization-specialist, editor, all</em>. Validation rejects any other value. The same filter returns 100% of relevant content — zero false negatives.</p>
            </article>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="air-section air-section--output" aria-labelledby="output-heading">
    <div class="container-prose air-section__inner">
      <h2 id="output-heading" class="air-section__heading">Output: chatbot-ready JSONL.</h2>
      <p class="air-section__lead">
        Each section becomes a JSONL record with the text content, topic title, section heading, topic type (concept / task / reference), all metadata fields (audience, difficulty, domain, intent, duration, chatbot-priority), the section ID for deep-linking, and the parent map path for breadcrumb context. A glossary index maps terms to definitions with synonyms. A content manifest provides a searchable index of all topics.
      </p>

      <p class="air-output__eyebrow">Three exported artifacts</p>
      <hr class="air-rule" />
      <dl class="air-output">
        {outputFiles.map((f) => (
          <div class="air-output__row">
            <dt class="air-output__name">{f.name}</dt>
            <dd class="air-output__purpose">{f.purpose}</dd>
          </div>
        ))}
      </dl>
      <hr class="air-rule" />
    </div>
  </section>

  <AnimatedDivider />

  <CTAModule
    audience="general"
    body="Submit a 20-topic sample. We'll score it on all seven dimensions, return a gap analysis with recommended next steps, and indicate the engineering effort required to reach production-grade retrieval. No obligation to proceed."
  />
</BaseLayout>

<style>
  /* ─── Section spacing ─── */
  .air-section {
    padding-top: var(--space-16);
    padding-bottom: var(--space-16);
  }

  @media (min-width: 768px) {
    .air-section {
      padding-top: var(--space-20);
      padding-bottom: var(--space-20);
    }
  }

  .air-section__heading {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-6) 0;
    text-wrap: balance;
  }

  .air-section__lead {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin: 0 0 var(--space-12) 0;
    text-wrap: pretty;
    max-width: 65ch;
  }

  .air-section__visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .air-rule {
    border: 0;
    border-top: var(--border-hairline);
    margin: 0;
  }

  /* ─── Framing prose ─── */
  .air-framing {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .air-framing p {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    line-height: var(--leading-normal);
    color: var(--color-text-secondary);
    margin: 0;
    text-wrap: pretty;
  }

  /* ─── Scorecard: horizontal-row layout ─── */
  .air-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  /* Mobile (<768px): vertical stack inside each row */
  .air-dim {
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: var(--space-2) var(--space-4);
    padding: var(--space-6) 0;
    border-top: var(--border-hairline);
  }

  .air-dim:last-child {
    border-bottom: var(--border-hairline);
  }

  /* Tablet (≥768px): 2-zone — number column + content column.
     Name + the three content columns stack vertically inside column 2. */
  @media (min-width: 768px) {
    .air-dim {
      grid-template-columns: 56px 1fr;
      gap: var(--space-3) var(--space-6);
      align-items: start;
    }

    .air-dim__num {
      grid-row: 1 / -1;
      grid-column: 1;
    }

    .air-dim__name,
    .air-dim__col {
      grid-column: 2;
    }
  }

  /* Desktop (≥1024px): full 5-column horizontal row.
     num | name | question | why | scoring */
  @media (min-width: 1024px) {
    .air-dim {
      grid-template-columns: 48px 150px minmax(0, 1.3fr) minmax(0, 1.3fr) 240px;
      grid-template-rows: auto;
      gap: var(--space-6);
      align-items: start;
      padding: var(--space-8) 0;
    }

    .air-dim__num {
      grid-row: 1;
      grid-column: 1;
    }

    .air-dim__name {
      grid-row: 1;
      grid-column: 2;
      padding-top: 6px;
    }

    .air-dim__col--question { grid-row: 1; grid-column: 3; padding-top: 2px; }
    .air-dim__col--why      { grid-row: 1; grid-column: 4; }
    .air-dim__col--scoring  { grid-row: 1; grid-column: 5; }
  }

  .air-dim__col {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .air-dim__num {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: var(--weight-regular);
    line-height: 1;
    color: #fcd34d;
    font-feature-settings: "tnum";
    padding-top: 2px;
    margin: 0;
  }

  .air-dim__name {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: var(--weight-semibold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-primary);
    margin: 0;
  }

  .air-dim__question {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 16px;
    line-height: 1.4;
    color: var(--color-text-primary);
    margin: 0;
    text-wrap: pretty;
  }

  .air-dim__why-label,
  .air-dim__scoring-label {
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0;
  }

  .air-dim__why {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    line-height: var(--leading-normal);
    color: var(--color-text-secondary);
    margin: 0;
    text-wrap: pretty;
  }

  .air-dim__scores {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .air-score {
    display: grid;
    grid-template-columns: 24px 1fr;
    gap: var(--space-3);
    align-items: baseline;
  }

  .air-score__num {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: var(--weight-semibold);
    color: #fcd34d;
    font-feature-settings: "tnum";
  }

  .air-score__body {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    line-height: 1.4;
    color: var(--color-text-secondary);
    text-wrap: pretty;
  }

  /* ─── Interpret your score ─── */
  .air-interpret {
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .air-interpret__row {
    display: grid;
