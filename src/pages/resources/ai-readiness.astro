<script>
  function setupAirHero() {
    const svg = document.getElementById("air-hero-flow");
    if (!svg) return;
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            svg.classList.add("drawn");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );
    observer.observe(svg);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupAirHero);
  } else {
    setupAirHero();
  }
  document.addEventListener("astro:page-load", setupAirHero);
</script>
