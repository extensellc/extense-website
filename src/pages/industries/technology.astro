---
/*
  /industries/technology

  Bespoke build — Technology & Semiconductors. NO OLD page existed on the
  legacy site; this page is wholly [DRAFT-approved] (see
  docs/reframe-2026/technology.md for sign-off trail).

  Section order:
    1. Hero (universal) — H1 [DRAFT] "Technology & Semiconductors" +
       [DRAFT] compressed subdeck + Option-D side visual (three artifacts
       under one engineering practice)
    2. SectionSiblings (industries)
    3. Three Product Surfaces [DRAFT] - 3-card grid
    4. Continuous Publishing Cadence [DRAFT] - 01-05 strip with body
       paragraphs (banded)
    5. Explore Related [DRAFT] - 3-card cross-link (banded)
    6. CTA - "Free Technical Content Assessment" [DRAFT]

  Page-local CSS prefix: tech-. Hero SVG inline, scroll-revealed via
  IntersectionObserver (.drawn), with reduced-motion fallback.

  Replaces the prior IndustryPageLayout-based version (which had a rich
  productSurfacePanels render — content compressed into the S3 card grid
  + the hero side visual). With this port, all 6 industry sub-pages are
  bespoke; IndustryPageLayout becomes a candidate for deletion in a
  follow-up cleanup commit.
*/

import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/site/Hero.astro";
import SectionSiblings from "../../components/site/SectionSiblings.astro";
import CTAModule from "../../components/site/CTAModule.astro";

interface Card {
  title: string;
  body: string;
  icon: string;
}

const surfaceCards: Card[] = [
  {
    title: "Hardware & Silicon Documentation",
    icon: "chip",
    body: "Datasheets, application notes, and reference designs for semiconductor vendors — JEDEC-conformant, EDA-toolchain-integrated, version-aligned with silicon respins. PCB design files, IPC-conformant assembly docs, and FCC certification packages for consumer electronics, networking equipment, and IoT devices.",
  },
  {
    title: "Software & API Documentation",
    icon: "code",
    body: "Developer-facing reference docs, integration guides, and code samples. Auto-generated from OpenAPI specs where possible; hand-authored where developer experience requires editorial care. Versioned release notes and changelogs tied to semantic-version tags; aggregated views for buyers tracking platform adoption.",
  },
  {
    title: "Security & Compliance Documentation",
    icon: "shield",
    body: "SOC 2 reports, ISO 27001 statement of applicability and control narratives, penetration test reports, NIST 800-series mappings. The documentation buyer security teams review before signing — and the audit-trail evidence the next year's auditor walks through. ITAR/EAR handling where defense-tech and dual-use export controls apply.",
  },
];

interface WorkflowStep {
  num: string;
  title: string;
  desc: string;
  body: string;
}

const cadence: WorkflowStep[] = [
  {
    num: "01", title: "Source-of-Truth Authoring",
    desc: "Author against the single content source",
    body: "Hardware specs, API references, and control narratives written into a structured CCMS with metadata that survives the publishing pipeline. EDA toolchain integration syncs silicon revisions; source-control hooks keep API specs aligned with code.",
  },
  {
    num: "02", title: "Validation Pass",
    desc: "Validate against schemas and business rules",
    body: "Schema validation catches structural drift; business-rule validation catches semantic violations (datasheet-vs-silicon drift, API-vs-implementation drift, control-narrative-vs-evidence drift). Failures return to the author before publishing runs.",
  },
  {
    num: "03", title: "Auto-Generation",
    desc: "Generate machine-readable docs from source",
    body: "Where source is structured (OpenAPI specs, EDA output, IdP provisioning logs), the publishing pipeline auto-generates the relevant documentation surfaces. Hand-authored content layers on top where editorial care is required.",
  },
  {
    num: "04", title: "Pre-Release Build",
    desc: "Build outputs for every target surface",
    body: "PDF datasheets for distribution. Web-ready API reference for developer portal. SOC 2 control narrative for the auditor. Output formats generated in parallel from one source, each in its target typographic register.",
  },
  {
    num: "05", title: "Release-Tied Publication",
    desc: "Publish on the release cadence",
    body: "Hardware: tied to silicon respin or product launch. Software: tied to semantic-version release. Security: tied to annual audit cycle plus continuous evidence collection. The publishing cadence matches the release cadence — no doc lag.",
  },
];

interface RelatedCard {
  eyebrow: string;
  title: string;
  body: string;
  href: string;
}

const related: RelatedCard[] = [
  {
    eyebrow: "Industry",
    title: "Government & Defense",
    body: "S1000D data modules, IETM delivery, and MIL-STD compliance for defense-tech vendors — where ITAR-controlled silicon and dual-use export documentation overlap with technology product programs.",
    href: "/industries/government-and-defense",
  },
  {
    eyebrow: "Solution",
    title: "AI-Ready Content",
    body: "Retrieval over technical documentation estates — datasheets, API references, security policies — engineered so developer-facing AI assistants cite the right page, the right version, the right product line.",
    href: "/solutions/ai-ready-content",
  },
  {
    eyebrow: "Service",
    title: "DITA Engineering",
    body: "The engineering discipline that makes hardware, software, and security documentation live in one content system — specialization, profiling, and publishing automation across distinct typographic registers.",
    href: "/services/dita-engineering",
  },
];
---

<BaseLayout
  title="Technology & Semiconductors — Industries"
  description="Documentation engineering across hardware/silicon, software/API, and security/compliance — three product surfaces, three audiences, one engineering discipline. Datasheets, API references, SOC 2 attestations, CI/CD-driven publishing."
>
  <Hero
    variant="universal"
    title="Technology & Semiconductors"
    subdeck="Datasheets for system integrators, API docs for developers, security attestations for buyer security teams — three product surfaces, three audiences, one engineering discipline."
    subdeckMaxWidth="520px"
  >
    <svg
      class="tech-hero-flow"
      id="tech-hero-flow"
      viewBox="0 0 560 320"
      xmlns="http://www.w3.org/2000/svg"
      aria-label="Three technology documentation artifacts — datasheet, API reference, SOC 2 narrative — sitting on one engineering practice (extense.tech-docs) with CI/CD-driven publishing."
      role="img"
    >
      <g class="corner--accent fx" style="--d: 0ms">
        <path d="M 12 24 L 12 12 L 24 12" />
        <path d="M 536 12 L 548 12 L 548 24" />
        <path d="M 12 296 L 12 308 L 24 308" />
        <path d="M 536 308 L 548 308 L 548 296" />
      </g>

      <text class="chrome fx" x="30" y="30" style="--d: 80ms">in :: tech.unified</text>

      {/* Compact Card 1 — DATASHEET */}
      <g class="fx" style="--d: 200ms">
        <rect class="node node--custom" x="20" y="50" width="160" height="116" rx="3" />
        <rect class="artifact-strip" x="20" y="50" width="160" height="6" />
        <text class="doc-ref" x="100" y="72" text-anchor="middle">DATASHEET</text>
        <text class="card-title" x="100" y="92" text-anchor="middle">16-Bit SRAM</text>
        <line class="artifact-rule" x1="36" y1="104" x2="164" y2="104" />
        <text class="field-key" x="36" y="124">VDD</text>
        <text class="field-val" x="164" y="124" text-anchor="end">3.3V ±5%</text>
        <text class="field-key" x="36" y="144">tACS</text>
        <text class="field-val" x="164" y="144" text-anchor="end">2.5 ns max</text>
      </g>

      {/* Compact Card 2 — API REFERENCE */}
      <g class="fx" style="--d: 260ms">
        <rect class="node node--custom" x="200" y="50" width="160" height="116" rx="3" />
        <rect class="artifact-strip" x="200" y="50" width="160" height="6" />
        <text class="doc-ref" x="280" y="72" text-anchor="middle">API REFERENCE</text>
        <text class="card-title" x="280" y="92" text-anchor="middle">Payments API</text>
        <line class="artifact-rule" x1="216" y1="104" x2="344" y2="104" />
        <text class="field-mono" x="280" y="122" text-anchor="middle">POST /v3/payments</text>
        <text class="field-key" x="216" y="144">Auth</text>
        <text class="field-val" x="344" y="144" text-anchor="end">Bearer + idem</text>
      </g>

      {/* Compact Card 3 — SOC 2 NARRATIVE */}
      <g class="fx" style="--d: 320ms">
        <rect class="node node--custom" x="380" y="50" width="160" height="116" rx="3" />
        <rect class="artifact-strip" x="380" y="50" width="160" height="6" />
        <text class="doc-ref" x="460" y="72" text-anchor="middle">SOC 2 · CC6.1</text>
        <text class="card-title" x="460" y="92" text-anchor="middle">Access Controls</text>
        <line class="artifact-rule" x1="396" y1="104" x2="524" y2="104" />
        <text class="field-key" x="396" y="124">Control</text>
        <text class="field-val" x="524" y="124" text-anchor="end">SAML + MFA</text>
        <text class="field-key" x="396" y="144">Evidence</text>
        <text class="field-val" x="524" y="144" text-anchor="end">IdP logs</text>
      </g>

      {/* Connectors from each card → unifying bar */}
      <path class="flow-conn" style="--d: 460ms" d="M 100 166 L 100 196 M 95 191 L 100 196 L 105 191" />
      <path class="flow-conn" style="--d: 480ms" d="M 280 166 L 280 196 M 275 191 L 280 196 L 285 191" />
      <path class="flow-conn" style="--d: 500ms" d="M 460 166 L 460 196 M 455 191 L 460 196 L 465 191" />

      {/* Unifying bar */}
      <g class="fx" style="--d: 580ms">
        <rect class="node node--custom" x="20" y="196" width="520" height="50" rx="3" />
        <rect class="artifact-strip" x="20" y="196" width="520" height="6" />
        <text class="node-label node-label--custom" x="280" y="224" text-anchor="middle">extense.tech-docs</text>
        <text class="node-caption" x="280" y="240" text-anchor="middle">one engineering discipline · CI/CD-driven publishing</text>
      </g>

      {/* Footer multiplier annotation */}
      <text class="multiplier-label fx" x="280" y="268" text-anchor="middle" style="--d: 700ms">three registers &middot; one engineering practice &middot; release-tied cadence</text>

      {/* Bottom chrome */}
      <g class="fx" style="--d: 820ms">
        <line class="chrome-rule" x1="30" y1="286" x2="530" y2="286" />
        <rect class="build-dot" x="32" y="296" width="6" height="6" />
        <text class="chrome chrome--strong" x="46"  y="302">FIG. 01</text>
        <text class="chrome"               x="92"  y="302">/</text>
        <text class="chrome chrome--strong" x="100" y="302">tech.unified</text>
        <text class="chrome chrome--strong" x="530" y="302" text-anchor="end">3 SURFACES &middot; 1 PRACTICE &middot; CI/CD</text>
      </g>
    </svg>
  </Hero>

  <SectionSiblings variant="industries" current="technology" />

  {/* ───────── S3 — Three Product Surfaces ───────── */}
  <section class="tech-section" aria-labelledby="tech-surfaces-heading">
    <div class="container-page tech-section__inner">
      <div class="tech-heading-block">
        <h2 id="tech-surfaces-heading" class="tech-heading">Three Product Surfaces</h2>
        <p class="tech-intro">
          Technology and semiconductor companies ship three distinct documentation surfaces — one for system integrators reading datasheets, one for developers reading API reference, one for buyer security teams reading SOC 2 narratives. Each carries its own typographic register, structural conventions, and audit-trail obligations. Engineering documentation discipline is what makes the three live in the same content system without losing their distinct shapes.
        </p>
      </div>
      <ul class="tech-grid-3">
        {surfaceCards.map((c) => (
          <li class="tech-card">
            <span class="tech-card__icon" aria-hidden="true">
              {c.icon === "chip" && (
                <svg viewBox="0 0 20 20"><rect x="6" y="6" width="8" height="8" rx="1" /><line x1="8" y1="3" x2="8" y2="6" /><line x1="12" y1="3" x2="12" y2="6" /><line x1="8" y1="14" x2="8" y2="17" /><line x1="12" y1="14" x2="12" y2="17" /><line x1="3" y1="8" x2="6" y2="8" /><line x1="3" y1="12" x2="6" y2="12" /><line x1="14" y1="8" x2="17" y2="8" /><line x1="14" y1="12" x2="17" y2="12" /></svg>
              )}
              {c.icon === "code" && (
                <svg viewBox="0 0 20 20"><polyline points="6,6 2,10 6,14" /><polyline points="14,6 18,10 14,14" /></svg>
              )}
              {c.icon === "shield" && (
                <svg viewBox="0 0 20 20"><path d="M10 2.5 L16 4.6 V9.2 c0 4-3 6.4-6 7.8 c-3-1.4-6-3.8-6-7.8 V4.6 Z" /></svg>
              )}
            </span>
            <h3 class="tech-card__title">{c.title}</h3>
            <p class="tech-card__body">{c.body}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* ───────── S4 — Continuous Publishing Cadence (banded) ───────── */}
  <section class="tech-section tech-section--band" aria-labelledby="tech-cadence-heading">
    <div class="container-page tech-section__inner">
      <div class="tech-heading-block">
        <h2 id="tech-cadence-heading" class="tech-heading">Continuous Publishing Cadence</h2>
        <p class="tech-intro">
          The operational arc from source to released documentation — five gated stages tying the publishing cadence to each surface's release cycle (silicon respin, semantic-version release, audit cycle).
        </p>
      </div>
      <ol class="tech-roadmap">
        {cadence.map((s, i) => (
          <>
            <li class="tech-step">
              <span class="tech-step__num">{s.num}</span>
              <h3 class="tech-step__title">{s.title}</h3>
              <p class="tech-step__desc">{s.desc}</p>
              <p class="tech-step__body">{s.body}</p>
            </li>
            {i < cadence.length - 1 && (
              <li class="tech-step__arrow" aria-hidden="true">&rarr;</li>
            )}
          </>
        ))}
      </ol>
    </div>
  </section>

  {/* ───────── S5 — Explore Related (3-card, banded) ───────── */}
  <section class="tech-section tech-section--band" aria-labelledby="tech-related-heading">
    <div class="container-page tech-section__inner">
      <div class="tech-heading-block">
        <h2 id="tech-related-heading" class="tech-heading">Explore Related</h2>
      </div>
      <ul class="tech-related-grid">
        {related.map((r) => (
          <li class="tech-related-card-item">
            <a href={r.href} class="tech-related-card">
              <span class="tech-related-card__eyebrow">{r.eyebrow}</span>
              <h3 class="tech-related-card__title">{r.title}</h3>
              <p class="tech-related-card__body">{r.body}</p>
              <span class="tech-related-card__cta">
                Explore <span class="tech-related-card__arrow" aria-hidden="true">&rarr;</span>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <CTAModule
    audience="general"
    compact
    accentLine
    heading="Free Technical Content Assessment"
    body="Share a 20-page sample — datasheet, API reference, or security attestation. We'll return a content-readiness assessment focused on the publishing-cadence and retrieval-readiness questions specific to technology and semiconductor documentation. No commitment required."
  />
</BaseLayout>

<style>
  /* ─── Hero side visual (Option D — three artifacts under one practice) ─── */
  .tech-hero-flow {
    width: 560px;
    max-width: 100%;
    height: auto;
    color: var(--color-text-primary);
    overflow: visible;
    display: block;
    shape-rendering: geometricPrecision;
  }
  .tech-hero-flow .chrome {
    font-family: var(--font-mono);
    font-size: 9px;
    fill: var(--color-text-muted);
    letter-spacing: 0.06em;
    user-select: none;
  }
  .tech-hero-flow .chrome--strong {
    fill: var(--color-text-primary);
    font-weight: var(--weight-medium);
  }
  .tech-hero-flow .corner--accent {
    stroke: var(--color-accent-primary-hover);
    stroke-width: 1.25;
    fill: none;
  }
  .tech-hero-flow .chrome-rule {
    stroke: var(--color-border-subtle);
    stroke-width: 1;
  }
  .tech-hero-flow .build-dot {
    fill: var(--color-accent-primary-hover);
    stroke: none;
  }
  .tech-hero-flow .node {
    fill: var(--color-page-bg);
    stroke: var(--color-text-primary);
    stroke-width: 1.5;
    vector-effect: non-scaling-stroke;
  }
  .tech-hero-flow .node--custom {
    fill: #fef3c7;
    stroke: var(--color-accent-primary);
  }
  .tech-hero-flow .node-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: var(--weight-medium);
    fill: var(--color-text-primary);
    letter-spacing: 0.02em;
  }
  .tech-hero-flow .node-label--custom {
    fill: var(--color-accent-primary-pressed);
  }
  .tech-hero-flow .node-caption {
    font-family: var(--font-mono);
    font-size: 10px;
    fill: var(--color-text-secondary);
    letter-spacing: 0.04em;
  }
  .tech-hero-flow .artifact-strip {
    fill: var(--color-accent-primary);
    stroke: none;
  }
  .tech-hero-flow .artifact-rule {
    stroke: var(--color-border-subtle);
    stroke-width: 1;
  }
  .tech-hero-flow .doc-ref {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: var(--weight-semibold);
    fill: var(--color-accent-primary-pressed);
    letter-spacing: 0.12em;
  }
  .tech-hero-flow .card-title {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: var(--weight-medium);
    fill: var(--color-text-primary);
    letter-spacing: 0.02em;
  }
  .tech-hero-flow .field-key {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: var(--weight-medium);
    fill: var(--color-text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .tech-hero-flow .field-val {
    font-family: var(--font-mono);
    font-size: 10px;
    fill: var(--color-text-primary);
    letter-spacing: 0.02em;
  }
  .tech-hero-flow .field-mono {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: var(--weight-medium);
    fill: var(--color-accent-primary-pressed);
    letter-spacing: 0.02em;
  }
  .tech-hero-flow .multiplier-label {
    font-family: var(--font-mono);
    font-size: 10.5px;
    fill: var(--color-text-secondary);
    letter-spacing: 0.06em;
  }
  .tech-hero-flow .flow-conn {
    stroke: var(--color-accent-primary-hover);
    stroke-width: 1.5;
    fill: none;
    vector-effect: non-scaling-stroke;
    stroke-dasharray: 240;
    stroke-dashoffset: 240;
  }
  .tech-hero-flow .fx {
    opacity: 0;
  }
  .tech-hero-flow.drawn .fx {
    animation: tech-fade 360ms ease-out forwards;
    animation-delay: var(--d, 0ms);
  }
  .tech-hero-flow.drawn .flow-conn {
    animation: tech-draw 620ms ease-out forwards;
    animation-delay: var(--d, 0ms);
  }
  @keyframes tech-fade {
    to { opacity: 1; }
  }
  @keyframes tech-draw {
    to { stroke-dashoffset: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .tech-hero-flow .fx {
      opacity: 1 !important;
      animation: none !important;
    }
    .tech-hero-flow .flow-conn {
      stroke-dashoffset: 0 !important;
      animation: none !important;
    }
  }

  /* ─── Section shell ─── */
  .tech-section {
    padding-top: var(--section-pad-default);
    padding-bottom: var(--section-pad-default);
    border-top: var(--border-hairline);
  }
  .tech-section--band {
    background-color: var(--color-surface-band);
  }
  @media (max-width: 767px) {
    .tech-section {
      padding-top: var(--space-16);
      padding-bottom: var(--space-16);
    }
  }

  /* ─── Section heading block ─── */
  .tech-heading-block {
    margin-bottom: var(--space-12);
    max-width: 80ch;
  }
  .tech-heading {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-4) 0;
    text-wrap: balance;
  }
  .tech-intro {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin: 0;
    text-wrap: pretty;
  }

  /* ─── 3-card grid ─── */
  .tech-grid-3 {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }
  @media (min-width: 768px) {
    .tech-grid-3 {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .tech-card {
    display: flex;
    flex-direction: column;
    border: var(--border-hairline);
    padding: var(--space-6) var(--space-6) var(--space-8);
    background-color: var(--color-page-bg);
  }
  .tech-card__icon {
    display: inline-flex;
    align-self: flex-start;
    color: var(--color-accent-primary);
    margin-bottom: var(--space-5);
  }
  .tech-card__icon svg {
    width: 22px;
    height: 22px;
  }
  .tech-card__icon svg circle,
  .tech-card__icon svg ellipse,
  .tech-card__icon svg line,
  .tech-card__icon svg polyline,
  .tech-card__icon svg polygon,
  .tech-card__icon svg rect,
  .tech-card__icon svg path {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .tech-card__title {
    font-family: var(--font-display);
    font-size: var(--text-display-sm);
    font-weight: var(--weight-medium);
    line-height: var(--leading-snug);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-3) 0;
    text-wrap: balance;
  }
  .tech-card__body {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin: 0;
    text-wrap: pretty;
  }

  /* ─── 5-step numbered roadmap strip ─── */
  .tech-roadmap {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: stretch;
    gap: var(--space-2);
  }
  .tech-step {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    border: var(--border-hairline);
    border-radius: var(--radius-sm);
    padding: var(--space-5) var(--space-4) var(--space-6);
    background-color: var(--color-page-bg);
  }
  .tech-step__num {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    font-weight: var(--weight-medium);
    letter-spacing: 0.1em;
    color: var(--color-accent-primary);
  }
  .tech-step__title {
    font-family: var(--font-display);
    font-size: var(--text-display-sm);
    font-weight: var(--weight-medium);
    line-height: var(--leading-snug);
    color: var(--color-text-primary);
    margin: 0;
  }
  .tech-step__desc {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin: 0;
    text-wrap: pretty;
  }
