---
/*
  /industries/government-and-defense

  Faithful reframe of the old ex-tense.co page (Defense & Aerospace
  Documentation), expanded to equal-weight civilian + defense per the
  Industries Govt & Defense wireframe.
  See docs/reframe-2026/government-and-defense.md.

  Section order:
    1. Hero (universal) — H1 + paired subdeck + Option-D side visual
       (two-register convergence: 3 defense pillars + 3 civilian standards
       converging into extense.gov-docs)
    2. SectionSiblings (industries variant)
    3. S1000D Implementation [OLD] · 3-card grid — DEFENSE
    4. Agency Publishing & Section 508 [DRAFT-approved] · 3-card grid — CIVILIAN (banded)
    5. Security & Compliance [OLD] · 3-card grid — joint
    6. The S1000D Lifecycle [OLD] · 5-step 01-05 strip — DEFENSE (banded)
    7. The Agency Publishing Lifecycle [DRAFT-approved] · 5-step 01-05 strip — CIVILIAN
    8. Explore Related Industries · 2-card cross-link (banded)
    9. CTA — Free S1000D Readiness Assessment [OLD]

  Page-local CSS prefix: gd-. Hero SVG inline, scroll-revealed via
  IntersectionObserver (.drawn), with reduced-motion fallback.

  Replaces the prior IndustryPageLayout-based version; the layout's stale
  /capabilities/* links go away with it.
*/

import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/site/Hero.astro";
import SectionSiblings from "../../components/site/SectionSiblings.astro";
import CTAModule from "../../components/site/CTAModule.astro";

interface Card {
  title: string;
  body: string;
  icon: string;
}

const implCards: Card[] = [
  {
    title: "Data Modules (DMs)",
    icon: "doc",
    body: "Granular content chunks authored as XML data modules and managed in a Common Source Data Base (CSDB). We design DM coding schemes, implement SNS structures, and enforce naming conventions across multi-vendor programs.",
  },
  {
    title: "Applicability & Filtering",
    icon: "check-circle",
    body: "ACT/CCT/PCT configuration management — filtering content by tail number, block number, or variant. We implement applicability cross-reference tables that ensure technicians see only the procedures relevant to their specific aircraft configuration.",
  },
  {
    title: "BREX Rules & Validation",
    icon: "shield",
    body: "Business Rule Exchange implementation that enforces project-specific constraints — required metadata, allowed illustration formats, and mandatory cross-references. Our BREX validation runs in CI pipelines, catching violations before data despatch.",
  },
];

const civilianCards: Card[] = [
  {
    title: "Section 508 Conformance",
    icon: "a11y",
    body: "Accessible content engineered at the source — semantic structure, alt-text discipline, screen-reader-conformant PDF generation, and authoring-tool integration. We implement accessibility constraints in the content model so violations are caught at authoring time, not at the OIG review.",
  },
  {
    title: "Agency Publishing Standards",
    icon: "seal",
    body: "Each federal agency has its own content and publishing conventions — IRS publication guides, FAA directive formats, GSA documentation standards. We adapt the authoring environment, the schema layer, and the publishing pipeline to the agency's actual conventions rather than a generic federal template.",
  },
  {
    title: "Records Management & FOIA",
    icon: "archive",
    body: "Title 5 USC and Title 44 records-management compliance built into the content lifecycle — retention metadata at the data module level, FOIA-readiness for every published artifact, and audit trails that satisfy NARA and OIG retention reviews.",
  },
];

const complianceCards: Card[] = [
  {
    title: "ITAR & Classified Handling",
    icon: "lock",
    body: "Release sanitization workflows that redact controlled data for foreign national distribution. We implement marking automation, paragraph-level classification, and derivative classification guides integrated into the authoring environment.",
  },
  {
    title: "Air-Gapped Publishing",
    icon: "server",
    body: "Isolated build environments with no network connectivity for SECRET and above content. We configure offline DITA-OT toolchains, local schema catalogs, and removable-media delivery workflows for SCIF environments.",
  },
  {
    title: "Audit & Traceability",
    icon: "audit",
    body: "Complete audit logs for every view, edit, export, and distribution event. We build traceability matrices linking requirements → procedures → test results to satisfy DCMA and DCAA audit requirements.",
  },
];

interface LifecycleStep {
  num: string;
  title: string;
  desc: string;
  body: string;
}

const defenseLifecycle: LifecycleStep[] = [
  {
    num: "01", title: "DM Authoring",
    desc: "Create data modules in XML",
    body: "Procedure, description, illustration, and fault-isolation modules typed against the S1000D schema, with applicability metadata and SNS codes attached at authoring time.",
  },
  {
    num: "02", title: "CSDB Check-in",
    desc: "Validate against BREX & Schema",
    body: "Submission to the Common Source Data Base runs schema, BREX, and applicability validation. Failed modules return to the author with diagnostic output.",
  },
  {
    num: "03", title: "QA & Review",
    desc: "SME sign-off & release marking",
    body: "Subject-matter experts verify technical accuracy; editors verify standards conformance. Approved modules are stamped with release status and distribution marking.",
  },
  {
    num: "04", title: "Despatch",
    desc: "DMRL distribution to partners",
    body: "Controlled distribution to OEMs, suppliers, and ILS partners per the Data Module Requirements List, with each delivery logged for DCMA audit.",
  },
  {
    num: "05", title: "IETP Build",
    desc: "Interactive Electronic Technical Pubs",
    body: "Approved data modules compile into the deliverable IETM — searchable, applicability-filtered, and consumed in-cockpit, in-field, or at the depot.",
  },
];

const civilianLifecycle: LifecycleStep[] = [
  {
    num: "01", title: "Authoring",
    desc: "Draft against agency publishing standards",
    body: "Content authored to the agency's specific publishing manual — IRS publication guides, FAA directive formats, GSA documentation standards — with semantic structure baked into the source.",
  },
  {
    num: "02", title: "Section 508 Review",
    desc: "Accessibility conformance",
    body: "Automated checks cover alt-text, heading structure, contrast, and form labels; manual review verifies screen-reader compatibility and keyboard navigation.",
  },
  {
    num: "03", title: "Approval & Sign-off",
    desc: "Internal & inter-agency review",
    body: "Program-office and legal review, plus inter-agency clearance where required. Records-retention metadata attaches as part of the workflow, not after.",
  },
  {
    num: "04", title: "Publication",
    desc: "Release via agency channel or Federal Register",
    body: "Public-facing content to the agency website or Federal Register; internal content to the agency knowledge base. Publication metadata captures channel, version, and retention obligations.",
  },
  {
    num: "05", title: "Records Retention",
    desc: "NARA archival & FOIA-readiness",
    body: "Records scheduled per NARA-approved schedules, indexed for FOIA discovery, with audit trails for every access, edit, and disposition event.",
  },
];

interface RelatedCard {
  eyebrow: string;
  title: string;
  body: string;
  href: string;
}

const related: RelatedCard[] = [
  {
    eyebrow: "Industry",
    title: "Transportation",
    body: "Service information operations across modes — automotive VIN-specific guides, aviation ATA Spec 2200 maintenance manuals, and rail AAR M-1003 procedures.",
    href: "/industries/transportation",
  },
  {
    eyebrow: "Solution",
    title: "XML Data Interoperability",
    body: "S1000D-to-DITA bridges, XSLT transformation pipelines, and API-driven content delivery.",
    href: "/solutions/xml-data-interoperability",
  },
];
---

<BaseLayout
  title="Government Agencies & Defense — Industries"
  description="Defense and federal civilian agency documentation engineering: S1000D, MIL-STD, ITAR, IETMs for the armed forces; Section 508, Title 44 records-management, and agency publishing standards for civilian agencies."
>
  <Hero
    variant="universal"
    title="Government Agencies & Defense"
    subdeck="Mission-critical S1000D, MIL-STD, and ITAR-compliant technical documentation — engineered for interoperability between OEMs, suppliers, and the armed forces. Federal civilian agency content modernization — Section 508-conformant, records-management compliant, and engineered to agency publishing standards."
    subdeckMaxWidth="520px"
  >
    <svg
      class="gd-hero-flow"
      id="gd-hero-flow"
      viewBox="0 0 560 320"
      xmlns="http://www.w3.org/2000/svg"
      aria-label="Government and defense compliance: three defense engineering primitives and three civilian standards converging into one engineering practice."
      role="img"
    >
      <g class="corner--accent fx" style="--d: 0ms">
        <path d="M 12 24 L 12 12 L 24 12" />
        <path d="M 536 12 L 548 12 L 548 24" />
        <path d="M 12 296 L 12 308 L 24 308" />
        <path d="M 536 308 L 548 308 L 548 296" />
      </g>

      <text class="chrome fx" x="30" y="30" style="--d: 80ms">in :: gov.compliance</text>

      {/* Register captions */}
      <text class="stage-caption fx" x="90"  y="58" text-anchor="middle" style="--d: 160ms">DEFENSE</text>
      <text class="stage-caption fx" x="470" y="58" text-anchor="middle" style="--d: 200ms">CIVILIAN</text>

      {/* Defense pillars (left, custom amber) */}
      <g class="fx" style="--d: 280ms">
        <rect class="node node--custom" x="20" y="72" width="140" height="32" rx="3" />
        <text class="node-label node-label--custom" x="90" y="93" text-anchor="middle">&lt;dmodule&gt;</text>
      </g>
      <g class="fx" style="--d: 340ms">
        <rect class="node node--custom" x="20" y="112" width="140" height="32" rx="3" />
        <text class="node-label node-label--custom" x="90" y="133" text-anchor="middle">&lt;applic&gt;</text>
      </g>
      <g class="fx" style="--d: 400ms">
        <rect class="node node--custom" x="20" y="152" width="140" height="32" rx="3" />
        <text class="node-label node-label--custom" x="90" y="173" text-anchor="middle">&lt;brex&gt;</text>
      </g>

      {/* Civilian pillars (right, custom amber) */}
      <g class="fx" style="--d: 320ms">
        <rect class="node node--custom" x="400" y="72" width="140" height="32" rx="3" />
        <text class="node-label node-label--custom" x="470" y="93" text-anchor="middle">SECTION 508</text>
      </g>
      <g class="fx" style="--d: 380ms">
        <rect class="node node--custom" x="400" y="112" width="140" height="32" rx="3" />
        <text class="node-label node-label--custom" x="470" y="133" text-anchor="middle">TITLE 44</text>
      </g>
      <g class="fx" style="--d: 440ms">
        <rect class="node node--custom" x="400" y="152" width="140" height="32" rx="3" />
        <text class="node-label node-label--custom" x="470" y="173" text-anchor="middle">AGENCY STD</text>
      </g>

      {/* 6 convergent connectors → central chip */}
      <path class="flow-conn" style="--d: 540ms" d="M 160 88  L 220 212" />
      <path class="flow-conn" style="--d: 580ms" d="M 160 128 L 240 212" />
      <path class="flow-conn" style="--d: 620ms" d="M 160 168 L 260 212" />
      <path class="flow-conn" style="--d: 540ms" d="M 400 88  L 340 212" />
      <path class="flow-conn" style="--d: 580ms" d="M 400 128 L 320 212" />
      <path class="flow-conn" style="--d: 620ms" d="M 400 168 L 300 212" />

      {/* Central chip */}
      <g class="fx" style="--d: 720ms">
        <rect class="node node--custom" x="190" y="210" width="180" height="46" rx="3" />
        <rect class="artifact-strip" x="190" y="210" width="180" height="6" />
        <text class="node-label node-label--custom" x="280" y="240" text-anchor="middle">extense.gov-docs</text>
      </g>

      <text class="node-caption fx" x="280" y="274" text-anchor="middle" style="--d: 840ms">ONE PRACTICE</text>

      {/* Bottom chrome */}
      <g class="fx" style="--d: 980ms">
        <line class="chrome-rule" x1="30" y1="286" x2="530" y2="286" />
        <rect class="build-dot" x="32" y="296" width="6" height="6" />
        <text class="chrome chrome--strong" x="46"  y="302">FIG. 01</text>
        <text class="chrome"               x="92"  y="302">/</text>
        <text class="chrome chrome--strong" x="100" y="302">gov.compliance</text>
        <text class="chrome chrome--strong" x="530" y="302" text-anchor="end">2 REGISTERS &rarr; 1 PRACTICE</text>
      </g>
    </svg>
  </Hero>

  <SectionSiblings variant="industries" current="government-and-defense" />

  {/* ───────── S3 — S1000D Implementation (defense) ───────── */}
  <section class="gd-section" aria-labelledby="gd-impl-heading">
    <div class="container-page gd-section__inner">
      <div class="gd-heading-block">
        <p class="gd-eyebrow">DEFENSE REGISTER</p>
        <h2 id="gd-impl-heading" class="gd-heading">S1000D Implementation</h2>
        <p class="gd-intro">
          S1000D is not just a schema — it is a complex business logic engine governing data module creation, applicability filtering, and cross-organizational data exchange. We implement every layer.
        </p>
      </div>
      <ul class="gd-grid-3">
        {implCards.map((c) => (
          <li class="gd-card">
            <span class="gd-card__icon" aria-hidden="true">
              {c.icon === "doc" && (
                <svg viewBox="0 0 20 20"><path d="M5 3 H12 L15 6 V17 H5 Z" /><polyline points="12,3 12,6 15,6" /><line x1="7" y1="9" x2="13" y2="9" /><line x1="7" y1="12" x2="13" y2="12" /></svg>
              )}
              {c.icon === "check-circle" && (
                <svg viewBox="0 0 20 20"><circle cx="10" cy="10" r="7" /><polyline points="6.5,10 9,12.5 13.5,8" /></svg>
              )}
              {c.icon === "shield" && (
                <svg viewBox="0 0 20 20"><path d="M10 2.5 L16 4.6 V9.2 c0 4-3 6.4-6 7.8 c-3-1.4-6-3.8-6-7.8 V4.6 Z" /></svg>
              )}
              {c.icon === "a11y" && (
                <svg viewBox="0 0 20 20"><circle cx="10" cy="4" r="1.5" /><line x1="10" y1="5.5" x2="10" y2="13" /><line x1="5" y1="8" x2="15" y2="8" /><line x1="10" y1="11" x2="7" y2="17" /><line x1="10" y1="11" x2="13" y2="17" /></svg>
              )}
              {c.icon === "seal" && (
                <svg viewBox="0 0 20 20"><circle cx="10" cy="8" r="5" /><polyline points="6,12 5,17 10,15 15,17 14,12" /></svg>
              )}
              {c.icon === "archive" && (
                <svg viewBox="0 0 20 20"><rect x="3" y="6" width="14" height="11" rx="0.5" /><path d="M3 6 L4.5 4 H9.5 L11 6" /><line x1="6" y1="10" x2="14" y2="10" /><line x1="6" y1="13" x2="14" y2="13" /></svg>
              )}
              {c.icon === "lock" && (
                <svg viewBox="0 0 20 20"><rect x="5" y="9" width="10" height="9" rx="1" /><path d="M7 9 V6 c0-1.5 1.5-3 3-3 c1.5 0 3 1.5 3 3 V9" /></svg>
              )}
              {c.icon === "server" && (
                <svg viewBox="0 0 20 20"><rect x="4" y="4" width="12" height="4" rx="0.5" /><rect x="4" y="10" width="12" height="4" rx="0.5" /><circle cx="6.5" cy="6" r="0.5" /><circle cx="6.5" cy="12" r="0.5" /></svg>
              )}
              {c.icon === "audit" && (
                <svg viewBox="0 0 20 20"><rect x="4" y="3" width="12" height="14" rx="0.5" /><line x1="6" y1="6" x2="14" y2="6" /><line x1="6" y1="9" x2="14" y2="9" /><polyline points="6,12 8,14 12,10" /></svg>
              )}
            </span>
            <h3 class="gd-card__title">{c.title}</h3>
            <p class="gd-card__body">{c.body}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* ───────── S4 — Agency Publishing & Section 508 (civilian) — banded ───────── */}
  <section class="gd-section gd-section--band" aria-labelledby="gd-civilian-heading">
    <div class="container-page gd-section__inner">
      <div class="gd-heading-block gd-heading-block--wide">
        <p class="gd-eyebrow">CIVILIAN REGISTER</p>
        <h2 id="gd-civilian-heading" class="gd-heading">Agency Publishing &amp; Section 508</h2>
        <p class="gd-intro">
          Federal civilian agency content isn't just published — it's authored to standards that govern accessibility, retention, and public consumption. Section 508 conformance, agency-specific publishing conventions, and records-management compliance are built into the content architecture, not bolted on at review time.
        </p>
      </div>
      <ul class="gd-grid-3">
        {civilianCards.map((c) => (
          <li class="gd-card">
            <span class="gd-card__icon" aria-hidden="true">
              {c.icon === "doc" && (
                <svg viewBox="0 0 20 20"><path d="M5 3 H12 L15 6 V17 H5 Z" /><polyline points="12,3 12,6 15,6" /><line x1="7" y1="9" x2="13" y2="9" /><line x1="7" y1="12" x2="13" y2="12" /></svg>
              )}
              {c.icon === "check-circle" && (
                <svg viewBox="0 0 20 20"><circle cx="10" cy="10" r="7" /><polyline points="6.5,10 9,12.5 13.5,8" /></svg>
              )}
              {c.icon === "shield" && (
                <svg viewBox="0 0 20 20"><path d="M10 2.5 L16 4.6 V9.2 c0 4-3 6.4-6 7.8 c-3-1.4-6-3.8-6-7.8 V4.6 Z" /></svg>
              )}
              {c.icon === "a11y" && (
                <svg viewBox="0 0 20 20"><circle cx="10" cy="4" r="1.5" /><line x1="10" y1="5.5" x2="10" y2="13" /><line x1="5" y1="8" x2="15" y2="8" /><line x1="10" y1="11" x2="7" y2="17" /><line x1="10" y1="11" x2="13" y2="17" /></svg>
              )}
              {c.icon === "seal" && (
                <svg viewBox="0 0 20 20"><circle cx="10" cy="8" r="5" /><polyline points="6,12 5,17 10,15 15,17 14,12" /></svg>
              )}
              {c.icon === "archive" && (
                <svg viewBox="0 0 20 20"><rect x="3" y="6" width="14" height="11" rx="0.5" /><path d="M3 6 L4.5 4 H9.5 L11 6" /><line x1="6" y1="10" x2="14" y2="10" /><line x1="6" y1="13" x2="14" y2="13" /></svg>
              )}
              {c.icon === "lock" && (
                <svg viewBox="0 0 20 20"><rect x="5" y="9" width="10" height="9" rx="1" /><path d="M7 9 V6 c0-1.5 1.5-3 3-3 c1.5 0 3 1.5 3 3 V9" /></svg>
              )}
              {c.icon === "server" && (
                <svg viewBox="0 0 20 20"><rect x="4" y="4" width="12" height="4" rx="0.5" /><rect x="4" y="10" width="12" height="4" rx="0.5" /><circle cx="6.5" cy="6" r="0.5" /><circle cx="6.5" cy="12" r="0.5" /></svg>
              )}
              {c.icon === "audit" && (
                <svg viewBox="0 0 20 20"><rect x="4" y="3" width="12" height="14" rx="0.5" /><line x1="6" y1="6" x2="14" y2="6" /><line x1="6" y1="9" x2="14" y2="9" /><polyline points="6,12 8,14 12,10" /></svg>
              )}
            </span>
            <h3 class="gd-card__title">{c.title}</h3>
            <p class="gd-card__body">{c.body}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* ───────── S5 — Security & Compliance (joint) ───────── */}
  <section class="gd-section" aria-labelledby="gd-compliance-heading">
    <div class="container-page gd-section__inner">
      <div class="gd-heading-block">
        <h2 id="gd-compliance-heading" class="gd-heading">Security &amp; Compliance</h2>
        <p class="gd-intro">
          We build documentation workflows for classified, ITAR-controlled, and CUI environments — with the access controls and audit trails that defense programs and federal civilian agencies require.
        </p>
      </div>
      <ul class="gd-grid-3">
        {complianceCards.map((c) => (
          <li class="gd-card">
            <span class="gd-card__icon" aria-hidden="true">
              {c.icon === "doc" && (
                <svg viewBox="0 0 20 20"><path d="M5 3 H12 L15 6 V17 H5 Z" /><polyline points="12,3 12,6 15,6" /><line x1="7" y1="9" x2="13" y2="9" /><line x1="7" y1="12" x2="13" y2="12" /></svg>
              )}
              {c.icon === "check-circle" && (
                <svg viewBox="0 0 20 20"><circle cx="10" cy="10" r="7" /><polyline points="6.5,10 9,12.5 13.5,8" /></svg>
              )}
              {c.icon === "shield" && (
                <svg viewBox="0 0 20 20"><path d="M10 2.5 L16 4.6 V9.2 c0 4-3 6.4-6 7.8 c-3-1.4-6-3.8-6-7.8 V4.6 Z" /></svg>
              )}
              {c.icon === "a11y" && (
                <svg viewBox="0 0 20 20"><circle cx="10" cy="4" r="1.5" /><line x1="10" y1="5.5" x2="10" y2="13" /><line x1="5" y1="8" x2="15" y2="8" /><line x1="10" y1="11" x2="7" y2="17" /><line x1="10" y1="11" x2="13" y2="17" /></svg>
              )}
              {c.icon === "seal" && (
                <svg viewBox="0 0 20 20"><circle cx="10" cy="8" r="5" /><polyline points="6,12 5,17 10,15 15,17 14,12" /></svg>
              )}
              {c.icon === "archive" && (
                <svg viewBox="0 0 20 20"><rect x="3" y="6" width="14" height="11" rx="0.5" /><path d="M3 6 L4.5 4 H9.5 L11 6" /><line x1="6" y1="10" x2="14" y2="10" /><line x1="6" y1="13" x2="14" y2="13" /></svg>
              )}
              {c.icon === "lock" && (
                <svg viewBox="0 0 20 20"><rect x="5" y="9" width="10" height="9" rx="1" /><path d="M7 9 V6 c0-1.5 1.5-3 3-3 c1.5 0 3 1.5 3 3 V9" /></svg>
              )}
              {c.icon === "server" && (
                <svg viewBox="0 0 20 20"><rect x="4" y="4" width="12" height="4" rx="0.5" /><rect x="4" y="10" width="12" height="4" rx="0.5" /><circle cx="6.5" cy="6" r="0.5" /><circle cx="6.5" cy="12" r="0.5" /></svg>
              )}
              {c.icon === "audit" && (
                <svg viewBox="0 0 20 20"><rect x="4" y="3" width="12" height="14" rx="0.5" /><line x1="6" y1="6" x2="14" y2="6" /><line x1="6" y1="9" x2="14" y2="9" /><polyline points="6,12 8,14 12,10" /></svg>
              )}
            </span>
            <h3 class="gd-card__title">{c.title}</h3>
            <p class="gd-card__body">{c.body}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* ───────── S6 — The S1000D Lifecycle (defense) — banded ───────── */}
  <section class="gd-section gd-section--band" aria-labelledby="gd-def-lifecycle-heading">
    <div class="container-page gd-section__inner">
      <div class="gd-heading-block">
        <p class="gd-eyebrow">DEFENSE REGISTER</p>
        <h2 id="gd-def-lifecycle-heading" class="gd-heading">The S1000D Lifecycle</h2>
        <p class="gd-intro">
          The operational arc from XML authoring to fielded IETP delivery — five gated stages, each with its own conformance and traceability obligations.
        </p>
      </div>
      <ol class="gd-roadmap">
        {defenseLifecycle.map((s, i) => (
          <>
            <li class="gd-step">
              <span class="gd-step__num">{s.num}</span>
              <h3 class="gd-step__title">{s.title}</h3>
              <p class="gd-step__desc">{s.desc}</p>
              <p class="gd-step__body">{s.body}</p>
            </li>
            {i < defenseLifecycle.length - 1 && (
              <li class="gd-step__arrow" aria-hidden="true">&rarr;</li>
            )}
          </>
        ))}
      </ol>
    </div>
  </section>

  {/* ───────── S7 — The Agency Publishing Lifecycle (civilian) ───────── */}
  <section class="gd-section" aria-labelledby="gd-civ-lifecycle-heading">
