      label: "Compliance and warranty documentation",
      description: "Warranty content tied to service-procedure accuracy; safety case documentation; configuration-management records that satisfy regulator audit. The connection between procedure accuracy and claim approval — or accident-investigation defense — runs through these documents.",
    },
  ]}
  standards={[
    {
      label: "S1000D (Issues 4.x – 6.0)",
      description: "International specification for technical publications. Originated in defense-aerospace; now load-bearing in commercial aviation, defense vehicles, and increasingly heavy commercial automotive and rail.",
