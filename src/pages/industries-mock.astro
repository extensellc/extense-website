---
/*
  TEMP / industries-mock — three hero-visual candidates to replace the
  current dual-panel ComplianceReferenceCard on /industries.

  Each option renders the live Hero component with the same title + subdeck
  the real page uses, so the side visuals can be judged in their final
  context. Pick one in-browser, then build the real visual and `git rm`
  this file. Unlinked from nav.

  Option A — Radial fan-out: one artifact, six conformance languages.
  Option B — Pipeline: standard -> discipline -> audit.
  Option C — Audit-passed artifact: stamped with multiple auditor approvals.
*/

import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/site/Hero.astro";

const HERO_TITLE = "Six regulated verticals.";
const HERO_SUBDECK = "Documentation in regulated industries isn't writing — it's compliance engineering. Domain depth, not generic skill, bridges the named standards.";
---

<BaseLayout
  title="Industries hero mockups — Extense LLC"
  description="Internal mockup page. Three hero-visual candidates for /industries."
>
  <section class="im-banner">
    <div class="container-page">
      <p class="im-banner__label">INDUSTRIES HERO MOCK · PICK ONE</p>
      <nav class="im-banner__nav" aria-label="Mock options">
        <a href="#opt-a">A · Radial fan-out</a>
        <a href="#opt-b">B · Pipeline</a>
        <a href="#opt-c">C · Stamped artifact</a>
      </nav>
    </div>
  </section>

  {/* ────────────── OPTION A ────────────── */}
  <section class="im-option" id="opt-a">
    <div class="container-page">
      <h2 class="im-option__heading">Option A — One artifact, six conformance languages</h2>
      <p class="im-option__note">
        Radial fan-out from a single structured artifact to the six standards each vertical engineers to. Lens shift: the standard, not the vertical name, is the connector. Argues "one engineering practice, six conformance languages."
      </p>
    </div>
    <Hero variant="universal" title={HERO_TITLE} subdeck={HERO_SUBDECK} subdeckMaxWidth="520px">
      <svg
        class="mock-svg mock-a"
        id="mock-a"
        viewBox="0 0 560 320"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        role="presentation"
      >
        {/* Corner registration marks */}
        <g class="corner--accent fx" style="--d: 0ms">
          <path d="M 12 24 L 12 12 L 24 12" />
          <path d="M 536 12 L 548 12 L 548 24" />
          <path d="M 12 296 L 12 308 L 24 308" />
          <path d="M 536 308 L 548 308 L 548 296" />
        </g>

        <text class="chrome fx" x="30" y="30" style="--d: 80ms">in :: compliance.languages</text>

        {/* Center artifact (140 x 130, centered at 280,175) */}
        <g class="fx" style="--d: 200ms">
          <rect class="node node--custom" x="210" y="110" width="140" height="130" rx="3" />
          {/* amber header strip */}
          <rect class="artifact-strip" x="210" y="110" width="140" height="6" />
          {/* artifact identifier */}
          <text class="node-label node-label--custom" x="280" y="142" text-anchor="middle">&lt;artifact&gt;</text>
          {/* content hairlines */}
          <line class="artifact-line" x1="226" y1="160" x2="334" y2="160" />
          <line class="artifact-line" x1="226" y1="172" x2="316" y2="172" />
          <line class="artifact-line" x1="226" y1="184" x2="334" y2="184" />
          <line class="artifact-line" x1="226" y1="196" x2="304" y2="196" />
          {/* metadata footer */}
          <line class="artifact-rule" x1="226" y1="212" x2="334" y2="212" />
          <text class="node-caption" x="280" y="226" text-anchor="middle">v1.0 · 2025-Q3</text>
        </g>

        {/* Six radial connectors */}
        <path class="flow-conn" style="--d: 360ms" d="M 210 130 L 118 80" />
        <path class="flow-conn" style="--d: 420ms" d="M 210 175 L 118 175" />
        <path class="flow-conn" style="--d: 480ms" d="M 210 220 L 118 270" />
        <path class="flow-conn" style="--d: 360ms" d="M 350 130 L 442 80" />
        <path class="flow-conn" style="--d: 420ms" d="M 350 175 L 442 175" />
        <path class="flow-conn" style="--d: 480ms" d="M 350 220 L 442 270" />

        {/* Six standard labels — left column, right-anchored */}
        <g class="fx" style="--d: 620ms">
          <text class="standard-label" x="110" y="84" text-anchor="end">S1000D</text>
          <text class="standard-label" x="110" y="179" text-anchor="end">21 CFR PART 11</text>
          <text class="standard-label" x="110" y="274" text-anchor="end">SOX 404</text>
        </g>
        {/* Six standard labels — right column, left-anchored */}
        <g class="fx" style="--d: 700ms">
          <text class="standard-label" x="450" y="84" text-anchor="start">ATA 2200</text>
          <text class="standard-label" x="450" y="179" text-anchor="start">NAIC ORSA</text>
          <text class="standard-label" x="450" y="274" text-anchor="start">SOC 2 TYPE II</text>
        </g>

        {/* Bottom chrome */}
        <g class="fx" style="--d: 900ms">
          <line class="chrome-rule" x1="30" y1="286" x2="530" y2="286" />
          <rect class="build-dot" x="32" y="296" width="6" height="6" />
          <text class="chrome chrome--strong" x="46" y="302">FIG. A</text>
          <text class="chrome" x="92" y="302">/</text>
          <text class="chrome chrome--strong" x="100" y="302">compliance.languages</text>
          <text class="chrome chrome--strong" x="530" y="302" text-anchor="end">1 PRACTICE &rarr; 6 STANDARDS</text>
        </g>
      </svg>
    </Hero>
  </section>

  {/* ────────────── OPTION B ────────────── */}
  <section class="im-option" id="opt-b">
    <div class="container-page">
      <h2 class="im-option__heading">Option B — Standard &rarr; discipline &rarr; audit</h2>
      <p class="im-option__note">
        Three-stage pipeline: standards inputs on the left, one engineering discipline in the middle, audit gate on the right. Argues the flow: any vertical's input funnels through the same discipline and exits audit-ready.
      </p>
    </div>
    <Hero variant="universal" title={HERO_TITLE} subdeck={HERO_SUBDECK} subdeckMaxWidth="520px">
      <svg
        class="mock-svg mock-b"
        id="mock-b"
        viewBox="0 0 560 320"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        role="presentation"
      >
        {/* Corner registration marks */}
        <g class="corner--accent fx" style="--d: 0ms">
          <path d="M 12 24 L 12 12 L 24 12" />
          <path d="M 536 12 L 548 12 L 548 24" />
          <path d="M 12 296 L 12 308 L 24 308" />
          <path d="M 536 308 L 548 308 L 548 296" />
        </g>

        <text class="chrome fx" x="30" y="30" style="--d: 80ms">in :: compliance.pipeline</text>

        {/* Stage 1 caption */}
        <text class="stage-caption fx" x="90" y="62" text-anchor="middle" style="--d: 160ms">STANDARDS</text>

        {/* Standards stack (left, 140 wide, 6 rows at y=80..245) */}
        <g class="fx" style="--d: 240ms">
          <rect class="node node--soft" x="20" y="72" width="140" height="194" rx="3" />
          <text class="standard-row" x="34" y="92">S1000D</text>
          <text class="standard-row" x="34" y="120">21 CFR Part 11</text>
          <text class="standard-row" x="34" y="148">SOX 404</text>
          <text class="standard-row" x="34" y="176">ATA 2200</text>
          <text class="standard-row" x="34" y="204">NAIC ORSA</text>
          <text class="standard-row" x="34" y="232">SOC 2 Type II</text>
          <line class="row-rule" x1="34" y1="100" x2="146" y2="100" />
          <line class="row-rule" x1="34" y1="128" x2="146" y2="128" />
          <line class="row-rule" x1="34" y1="156" x2="146" y2="156" />
          <line class="row-rule" x1="34" y1="184" x2="146" y2="184" />
          <line class="row-rule" x1="34" y1="212" x2="146" y2="212" />
          <text class="row-count" x="146" y="256" text-anchor="end">6 / 6</text>
        </g>

        {/* Stage 2 caption */}
        <text class="stage-caption fx" x="280" y="62" text-anchor="middle" style="--d: 200ms">DISCIPLINE</text>

        {/* Connector standards -> discipline */}
        <path class="flow-conn" style="--d: 360ms" d="M 160 170 L 205 170 M 200 165 L 205 170 L 200 175" />

        {/* Discipline (center, 130 wide, custom amber) */}
        <g class="fx" style="--d: 440ms">
          <rect class="node node--custom" x="210" y="100" width="140" height="140" rx="3" />
          <rect class="artifact-strip" x="210" y="100" width="140" height="6" />
          <text class="node-label node-label--custom" x="280" y="134" text-anchor="middle">extense.compliance</text>
          <line class="artifact-rule" x1="226" y1="146" x2="334" y2="146" />
          <text class="discipline-line" x="280" y="166" text-anchor="middle">author · structure</text>
          <text class="discipline-line" x="280" y="184" text-anchor="middle">validate · publish</text>
          <text class="discipline-line" x="280" y="202" text-anchor="middle">audit-trace</text>
          <line class="artifact-rule" x1="226" y1="214" x2="334" y2="214" />
          <text class="node-caption" x="280" y="228" text-anchor="middle">ONE PRACTICE</text>
        </g>

        {/* Connector discipline -> audit */}
        <path class="flow-conn" style="--d: 560ms" d="M 350 170 L 395 170 M 390 165 L 395 170 L 390 175" />

        {/* Stage 3 caption */}
        <text class="stage-caption fx" x="470" y="62" text-anchor="middle" style="--d: 240ms">AUDIT</text>

        {/* Audit gate (right, 140 wide) */}
        <g class="fx" style="--d: 640ms">
          <rect class="node node--soft" x="400" y="72" width="140" height="194" rx="3" />
          {/* checklist */}
          <g class="check-row">
            <path class="check" d="M 416 96 L 421 101 L 430 91" />
            <text class="audit-line" x="436" y="100">conformance</text>
          </g>
          <g class="check-row">
            <path class="check" d="M 416 124 L 421 129 L 430 119" />
            <text class="audit-line" x="436" y="128">traceability</text>
          </g>
          <g class="check-row">
            <path class="check" d="M 416 152 L 421 157 L 430 147" />
            <text class="audit-line" x="436" y="156">defensibility</text>
          </g>
          <line class="row-rule" x1="416" y1="174" x2="524" y2="174" />
          {/* pass stamp */}
          <rect class="pass-stamp" x="418" y="200" width="104" height="40" rx="2" />
          <text class="pass-text" x="470" y="218" text-anchor="middle">PASS</text>
          <text class="pass-meta" x="470" y="232" text-anchor="middle">2025-Q2</text>
        </g>

        {/* Bottom chrome */}
        <g class="fx" style="--d: 820ms">
          <line class="chrome-rule" x1="30" y1="286" x2="530" y2="286" />
          <rect class="build-dot" x="32" y="296" width="6" height="6" />
          <text class="chrome chrome--strong" x="46" y="302">FIG. B</text>
          <text class="chrome" x="92" y="302">/</text>
          <text class="chrome chrome--strong" x="100" y="302">compliance.pipeline</text>
          <text class="chrome chrome--strong" x="530" y="302" text-anchor="end">INPUT &rarr; DISCIPLINE &rarr; AUDIT</text>
        </g>
      </svg>
    </Hero>
  </section>

  {/* ────────────── OPTION C ────────────── */}
  <section class="im-option" id="opt-c">
    <div class="container-page">
      <h2 class="im-option__heading">Option C — Audit-passed artifact (stamped)</h2>
      <p class="im-option__note">
        Single structured artifact in the center, overlaid with multiple auditor stamps. Most visceral of the three; less data, more weight on "this practice survives the audits that matter."
      </p>
    </div>
    <Hero variant="universal" title={HERO_TITLE} subdeck={HERO_SUBDECK} subdeckMaxWidth="520px">
      <svg
        class="mock-svg mock-c"
        id="mock-c"
        viewBox="0 0 560 320"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        role="presentation"
      >
        {/* Corner registration marks */}
        <g class="corner--accent fx" style="--d: 0ms">
          <path d="M 12 24 L 12 12 L 24 12" />
          <path d="M 536 12 L 548 12 L 548 24" />
          <path d="M 12 296 L 12 308 L 24 308" />
          <path d="M 536 308 L 548 308 L 548 296" />
        </g>

        <text class="chrome fx" x="30" y="30" style="--d: 80ms">in :: artifact.evidence</text>

        {/* Center artifact, large (200 wide x 220 tall, x=180-380, y=50-270) */}
        <g class="fx" style="--d: 200ms">
          <rect class="node" x="180" y="50" width="200" height="220" rx="3" />
          {/* amber header strip */}
          <rect class="artifact-strip-strong" x="180" y="50" width="200" height="8" />
          {/* identifier */}
          <text class="node-label node-label--custom" x="280" y="84" text-anchor="middle">extense.compliance</text>
          <line class="artifact-rule" x1="200" y1="96" x2="360" y2="96" />
          {/* title */}
          <text class="artifact-title" x="280" y="118" text-anchor="middle">&lt;artifact&gt;</text>
          {/* content hairlines (5) */}
          <line class="artifact-line" x1="200" y1="138" x2="360" y2="138" />
          <line class="artifact-line" x1="200" y1="152" x2="344" y2="152" />
          <line class="artifact-line" x1="200" y1="166" x2="360" y2="166" />
          <line class="artifact-line" x1="200" y1="180" x2="332" y2="180" />
          <line class="artifact-line" x1="200" y1="194" x2="360" y2="194" />
          {/* second block */}
          <line class="artifact-line" x1="200" y1="216" x2="354" y2="216" />
          <line class="artifact-line" x1="200" y1="230" x2="336" y2="230" />
          {/* metadata footer */}
          <line class="artifact-rule" x1="200" y1="246" x2="360" y2="246" />
          <text class="node-caption" x="280" y="260" text-anchor="middle">v1.0 · effective 2025-Q3</text>
        </g>

        {/* Four audit stamps, slight rotation, overlapping artifact edges */}
        <g class="stamp fx" transform="rotate(-7 100 90)" style="--d: 500ms">
          <rect class="stamp-box" x="40" y="68" width="120" height="44" />
          <text class="stamp-line stamp-line--big" x="100" y="90" text-anchor="middle">SEC · FILED</text>
          <text class="stamp-line" x="100" y="104" text-anchor="middle">2024-Q4</text>
        </g>

        <g class="stamp fx" transform="rotate(5 460 90)" style="--d: 620ms">
          <rect class="stamp-box" x="400" y="68" width="120" height="44" />
          <text class="stamp-line stamp-line--big" x="460" y="90" text-anchor="middle">FAA · APPROVED</text>
          <text class="stamp-line" x="460" y="104" text-anchor="middle">2024-Q4</text>
        </g>

        <g class="stamp fx" transform="rotate(-4 100 220)" style="--d: 740ms">
          <rect class="stamp-box" x="40" y="198" width="120" height="44" />
          <text class="stamp-line stamp-line--big" x="100" y="220" text-anchor="middle">FDA · CLEARED</text>
          <text class="stamp-line" x="100" y="234" text-anchor="middle">2025-Q1</text>
        </g>

        <g class="stamp fx" transform="rotate(6 460 220)" style="--d: 860ms">
          <rect class="stamp-box" x="400" y="198" width="120" height="44" />
          <text class="stamp-line stamp-line--big" x="460" y="220" text-anchor="middle">DoD · ACCEPTED</text>
          <text class="stamp-line" x="460" y="234" text-anchor="middle">2025-Q2</text>
        </g>

        {/* Bottom chrome */}
        <g class="fx" style="--d: 1000ms">
          <line class="chrome-rule" x1="30" y1="286" x2="530" y2="286" />
          <rect class="build-dot" x="32" y="296" width="6" height="6" />
          <text class="chrome chrome--strong" x="46" y="302">FIG. C</text>
          <text class="chrome" x="92" y="302">/</text>
          <text class="chrome chrome--strong" x="100" y="302">artifact.evidence</text>
          <text class="chrome chrome--strong" x="530" y="302" text-anchor="end">AUDITS PASSED &middot; 4 / 4</text>
        </g>
      </svg>
    </Hero>
  </section>
</BaseLayout>

<style>
  /* ─── Banner ─── */
  .im-banner {
    background: #fef3c7;
    border-bottom: var(--border-hairline);
    padding: var(--space-3) 0;
  }
  .im-banner__label {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.1em;
    color: var(--color-accent-primary-pressed);
    margin: 0 0 var(--space-2) 0;
  }
  .im-banner__nav {
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;
  }
  .im-banner__nav a {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-text-primary);
    text-decoration: none;
    border-bottom: 1px solid var(--color-accent-primary);
    padding-bottom: 1px;
  }
  .im-banner__nav a:hover {
    color: var(--color-link-hover);
  }

  /* ─── Option section ─── */
  .im-option {
    border-top: var(--border-hairline);
    padding-top: var(--space-8);
  }
  .im-option__heading {
    font-family: var(--font-display);
    font-size: var(--text-display-md);
    font-weight: var(--weight-regular);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-3) 0;
    letter-spacing: var(--tracking-tight);
  }
  .im-option__note {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin: 0;
    max-width: 70ch;
    text-wrap: pretty;
  }

  /* ─── Shared SVG idiom ─── */
  .mock-svg {
    width: 560px;
    max-width: 100%;
    height: auto;
    color: var(--color-text-primary);
    overflow: visible;
    display: block;
    shape-rendering: geometricPrecision;
  }
  .mock-svg .chrome {
    font-family: var(--font-mono);
    font-size: 9px;
    fill: var(--color-text-muted);
    letter-spacing: 0.06em;
    user-select: none;
  }
  .mock-svg .chrome--strong {
    fill: var(--color-text-primary);
    font-weight: var(--weight-medium);
  }
  .mock-svg .corner--accent {
    stroke: var(--color-accent-primary-hover);
    stroke-width: 1.25;
    fill: none;
  }
  .mock-svg .chrome-rule {
    stroke: var(--color-border-subtle);
    stroke-width: 1;
  }
  .mock-svg .build-dot {
    fill: var(--color-accent-primary-hover);
    stroke: none;
  }
  .mock-svg .node {
    fill: var(--color-page-bg);
    stroke: var(--color-text-primary);
    stroke-width: 1.5;
    vector-effect: non-scaling-stroke;
  }
  .mock-svg .node--custom {
    fill: #fef3c7;
    stroke: var(--color-accent-primary);
  }
  .mock-svg .node--soft {
    fill: var(--color-page-bg);
    stroke: var(--color-border-subtle);
    stroke-width: 1;
    stroke-dasharray: 4 4;
  }
  .mock-svg .node-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: var(--weight-medium);
    fill: var(--color-text-primary);
    letter-spacing: 0.02em;
  }
  .mock-svg .node-label--custom {
    fill: var(--color-accent-primary-pressed);
  }
  .mock-svg .node-caption {
    font-family: var(--font-mono);
    font-size: 10px;
    fill: var(--color-text-secondary);
    letter-spacing: 0.04em;
  }
  .mock-svg .flow-conn {
    stroke: var(--color-accent-primary-hover);
    stroke-width: 1.5;
    fill: none;
    vector-effect: non-scaling-stroke;
    stroke-dasharray: 240;
    stroke-dashoffset: 240;
  }

  /* artifact chrome (shared between A & C) */
  .mock-svg .artifact-strip {
    fill: var(--color-accent-primary);
    stroke: none;
  }
  .mock-svg .artifact-strip-strong {
    fill: var(--color-accent-primary);
    stroke: none;
  }
  .mock-svg .artifact-line {
    stroke: var(--color-text-muted);
    stroke-width: 1;
    opacity: 0.5;
  }
  .mock-svg .artifact-rule {
    stroke: var(--color-border-subtle);
    stroke-width: 1;
  }

  /* ─── Option A specifics ─── */
  .mock-a .standard-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: var(--weight-semibold);
    fill: var(--color-text-primary);
    letter-spacing: 0.06em;
  }

  /* ─── Option B specifics ─── */
  .mock-b .stage-caption {
    font-family: var(--font-mono);
    font-size: 9.5px;
    font-weight: var(--weight-semibold);
    fill: var(--color-accent-primary-pressed);
    letter-spacing: 0.12em;
  }
  .mock-b .standard-row {
    font-family: var(--font-mono);
    font-size: 10.5px;
    fill: var(--color-text-primary);
    letter-spacing: 0.04em;
  }
  .mock-b .row-rule {
    stroke: var(--color-border-subtle);
    stroke-width: 1;
    stroke-dasharray: 2 3;
  }
  .mock-b .row-count {
    font-family: var(--font-mono);
    font-size: 9px;
    fill: var(--color-text-muted);
    letter-spacing: 0.06em;
  }
  .mock-b .discipline-line {
    font-family: var(--font-mono);
    font-size: 10px;
    fill: var(--color-text-primary);
    letter-spacing: 0.04em;
  }
  .mock-b .check {
    stroke: var(--color-accent-primary-hover);
    stroke-width: 1.5;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .mock-b .audit-line {
    font-family: var(--font-mono);
    font-size: 10.5px;
    fill: var(--color-text-primary);
    letter-spacing: 0.04em;
  }
  .mock-b .pass-stamp {
    fill: #fef3c7;
    stroke: var(--color-accent-primary);
    stroke-width: 1.5;
  }
  .mock-b .pass-text {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: var(--weight-semibold);
    fill: var(--color-accent-primary-pressed);
    letter-spacing: 0.16em;
  }
  .mock-b .pass-meta {
    font-family: var(--font-mono);
    font-size: 9px;
    fill: var(--color-accent-primary-pressed);
    letter-spacing: 0.08em;
  }

  /* ─── Option C specifics ─── */
  .mock-c .artifact-title {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: var(--weight-medium);
    fill: var(--color-text-primary);
    letter-spacing: 0.02em;
  }
  .mock-c .stamp-box {
    fill: rgba(255, 255, 255, 0.92);
    stroke: var(--color-accent-primary);
    stroke-width: 1.5;
  }
  .mock-c .stamp-line {
    font-family: var(--font-mono);
    font-size: 9px;
    fill: var(--color-accent-primary-pressed);
    letter-spacing: 0.1em;
  }
  .mock-c .stamp-line--big {
    font-size: 11px;
    font-weight: var(--weight-semibold);
    letter-spacing: 0.08em;
  }

  /* ─── Animation (shared) ─── */
  .mock-svg .fx {
    opacity: 0;
  }
  .mock-svg.drawn .fx {
    animation: mock-fade 360ms ease-out forwards;
    animation-delay: var(--d, 0ms);
  }
  .mock-svg.drawn .flow-conn {
    animation: mock-draw 620ms ease-out forwards;
    animation-delay: var(--d, 0ms);
  }
  @keyframes mock-fade {
    to { opacity: 1; }
  }
  @keyframes mock-draw {
    to { stroke-dashoffset: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .mock-svg .fx {
      opacity: 1 !important;
      animation: none !important;
    }
    .mock-svg .flow-conn {
      stroke-dashoffset: 0 !important;
      animation: none !important;
    }
  }
</style>

<script>
  function setupMocks() {
    const svgs = document.querySelectorAll(".mock-svg");
    if (svgs.length === 0) return;
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("drawn");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );
    svgs.forEach((svg) => observer.observe(svg));
  }
  document.addEventListener("DOMContentLoaded", setupMocks);
</script>
