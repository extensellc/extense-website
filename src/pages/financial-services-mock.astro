---
/*
  TEMP / financial-services-mock — three hero-visual candidates for
  /industries/financial-services.

  Each option renders the live Hero component with the locked H1
  ("Financial Services Documentation & Compliance") + [OLD] subdeck so the
  side visuals can be judged in their final context. Pick one in-browser;
  build the real page with the chosen visual and `git rm` this file.
  Unlinked from nav.

  A — Single-source reuse fan: <policy> → 4 deliverables (matches the page's
      Unified Content Strategy thesis).
  B — SOX control chain pipeline: 5-stage horizontal flow
      (Author → Approve → Version → Audit → Disclose).
  C — Multi-jurisdiction profiling fan: <disclosure> → 4 regulators
      (US-SEC, EU-ESMA, UK-FCA, APAC-MAS).
*/

import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/site/Hero.astro";

const HERO_TITLE = "Financial Services Documentation & Compliance";
const HERO_SUBDECK = "Precision, compliance, and auditability for banking, fintech, and capital markets — where a single content error can trigger regulatory action.";
---

<BaseLayout
  title="FS hero mockups — Extense LLC"
  description="Internal mockup page. Three hero-visual candidates for /industries/financial-services."
>
  <section class="fsm-banner">
    <div class="container-page">
      <p class="fsm-banner__label">FINANCIAL SERVICES HERO MOCK · PICK ONE</p>
      <nav class="fsm-banner__nav" aria-label="Mock options">
        <a href="#opt-a">A · Single-source reuse fan</a>
        <a href="#opt-b">B · SOX control chain pipeline</a>
        <a href="#opt-c">C · Multi-jurisdiction profiling fan</a>
        <a href="#opt-d">D · Reuse fan + audit trace on the source</a>
      </nav>
    </div>
  </section>

  {/* ────────────── OPTION A ────────────── */}
  <section class="fsm-option" id="opt-a">
    <div class="container-page">
      <h2 class="fsm-option__heading">Option A — Single-source reuse fan</h2>
      <p class="fsm-option__note">
        Central <code>&lt;policy&gt;</code> chip with four deliverables fanning
        out (Employee Handbook, Compliance Manual, Training Deck, Client
        Disclosure). Literal rendering of the Unified Content Strategy thesis
        the page's S4 sub-block names.
      </p>
    </div>
    <Hero variant="universal" title={HERO_TITLE} subdeck={HERO_SUBDECK} subdeckMaxWidth="520px">
      <svg
        class="mock-svg mock-a"
        id="mock-a"
        viewBox="0 0 560 320"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        role="presentation"
      >
        <g class="corner--accent fx" style="--d: 0ms">
          <path d="M 12 24 L 12 12 L 24 12" />
          <path d="M 536 12 L 548 12 L 548 24" />
          <path d="M 12 296 L 12 308 L 24 308" />
          <path d="M 536 308 L 548 308 L 548 296" />
        </g>

        <text class="chrome fx" x="30" y="30" style="--d: 80ms">in :: financial.reuse</text>

        {/* Four corner deliverable chips */}
        <g class="fx" style="--d: 280ms">
          <rect class="node node--custom" x="20" y="58" width="160" height="36" rx="3" />
          <text class="node-label node-label--custom" x="100" y="81" text-anchor="middle">EMPLOYEE HANDBOOK</text>
        </g>
        <g class="fx" style="--d: 320ms">
          <rect class="node node--custom" x="380" y="58" width="160" height="36" rx="3" />
          <text class="node-label node-label--custom" x="460" y="81" text-anchor="middle">COMPLIANCE MANUAL</text>
        </g>
        <g class="fx" style="--d: 360ms">
          <rect class="node node--custom" x="20" y="226" width="160" height="36" rx="3" />
          <text class="node-label node-label--custom" x="100" y="249" text-anchor="middle">TRAINING DECK</text>
        </g>
        <g class="fx" style="--d: 400ms">
          <rect class="node node--custom" x="380" y="226" width="160" height="36" rx="3" />
          <text class="node-label node-label--custom" x="460" y="249" text-anchor="middle">CLIENT DISCLOSURE</text>
        </g>

        {/* 4 radial connectors from <policy> to corner chips */}
        <path class="flow-conn" style="--d: 540ms" d="M 210 145 L 180 94" />
        <path class="flow-conn" style="--d: 560ms" d="M 350 145 L 380 94" />
        <path class="flow-conn" style="--d: 580ms" d="M 210 195 L 180 226" />
        <path class="flow-conn" style="--d: 600ms" d="M 350 195 L 380 226" />

        {/* Central <policy> chip */}
        <g class="fx" style="--d: 700ms">
          <rect class="node node--custom" x="210" y="125" width="140" height="90" rx="3" />
          <rect class="artifact-strip" x="210" y="125" width="140" height="6" />
          <text class="node-label node-label--custom" x="280" y="158" text-anchor="middle">&lt;policy&gt;</text>
          <line class="artifact-rule" x1="226" y1="170" x2="334" y2="170" />
          <text class="node-caption" x="280" y="186" text-anchor="middle">single source</text>
          <text class="node-caption" x="280" y="202" text-anchor="middle">extense.compliance</text>
        </g>

        {/* Bottom chrome */}
        <g class="fx" style="--d: 880ms">
          <line class="chrome-rule" x1="30" y1="286" x2="530" y2="286" />
          <rect class="build-dot" x="32" y="296" width="6" height="6" />
          <text class="chrome chrome--strong" x="46"  y="302">FIG. A</text>
          <text class="chrome"               x="92"  y="302">/</text>
          <text class="chrome chrome--strong" x="100" y="302">financial.reuse</text>
          <text class="chrome chrome--strong" x="530" y="302" text-anchor="end">ONE POLICY &rarr; MANY DELIVERABLES</text>
        </g>
      </svg>
    </Hero>
  </section>

  {/* ────────────── OPTION B ────────────── */}
  <section class="fsm-option" id="opt-b">
    <div class="container-page">
      <h2 class="fsm-option__heading">Option B — SOX control chain pipeline</h2>
      <p class="fsm-option__note">
        Five-stage horizontal flow rendering the SOX 404 evidence chain —
        Authorship → Approval → Version Control → Audit → External
        Disclosure. Argues the audit-traceability thesis the S3 Audit Trails
        & Compliance card carries.
      </p>
    </div>
    <Hero variant="universal" title={HERO_TITLE} subdeck={HERO_SUBDECK} subdeckMaxWidth="520px">
      <svg
        class="mock-svg mock-b"
        id="mock-b"
        viewBox="0 0 560 320"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        role="presentation"
      >
        <g class="corner--accent fx" style="--d: 0ms">
          <path d="M 12 24 L 12 12 L 24 12" />
          <path d="M 536 12 L 548 12 L 548 24" />
          <path d="M 12 296 L 12 308 L 24 308" />
          <path d="M 536 308 L 548 308 L 548 296" />
        </g>

        <text class="chrome fx" x="30" y="30" style="--d: 80ms">in :: financial.control-chain</text>

        {/* 5 chips at y=110-180 (height 70), each with stacked number + label */}
        <g class="fx" style="--d: 200ms">
          <rect class="node node--custom" x="20" y="110" width="90" height="70" rx="3" />
          <text class="stage-num" x="65" y="138" text-anchor="middle">01</text>
          <text class="stage-label" x="65" y="160" text-anchor="middle">AUTHOR</text>
        </g>
        <path class="flow-conn" style="--d: 280ms" d="M 110 145 L 130 145 M 125 140 L 130 145 L 125 150" />

        <g class="fx" style="--d: 320ms">
          <rect class="node node--custom" x="130" y="110" width="90" height="70" rx="3" />
          <text class="stage-num" x="175" y="138" text-anchor="middle">02</text>
          <text class="stage-label" x="175" y="160" text-anchor="middle">APPROVE</text>
        </g>
        <path class="flow-conn" style="--d: 400ms" d="M 220 145 L 240 145 M 235 140 L 240 145 L 235 150" />

        <g class="fx" style="--d: 440ms">
          <rect class="node node--custom" x="240" y="110" width="90" height="70" rx="3" />
          <text class="stage-num" x="285" y="138" text-anchor="middle">03</text>
          <text class="stage-label" x="285" y="160" text-anchor="middle">VERSION</text>
        </g>
        <path class="flow-conn" style="--d: 520ms" d="M 330 145 L 350 145 M 345 140 L 350 145 L 345 150" />

        <g class="fx" style="--d: 560ms">
          <rect class="node node--custom" x="350" y="110" width="90" height="70" rx="3" />
          <text class="stage-num" x="395" y="138" text-anchor="middle">04</text>
          <text class="stage-label" x="395" y="160" text-anchor="middle">AUDIT</text>
        </g>
        <path class="flow-conn" style="--d: 640ms" d="M 440 145 L 460 145 M 455 140 L 460 145 L 455 150" />

        <g class="fx" style="--d: 680ms">
          <rect class="node node--custom" x="460" y="110" width="80" height="70" rx="3" />
          <text class="stage-num" x="500" y="138" text-anchor="middle">05</text>
          <text class="stage-label" x="500" y="160" text-anchor="middle">DISCLOSE</text>
        </g>

        {/* Audit outcome caption below */}
        <text class="outcome-caption fx" x="280" y="210" text-anchor="middle" style="--d: 760ms">SOX 404 EVIDENCE CHAIN</text>
        <text class="outcome-sub fx" x="280" y="226" text-anchor="middle" style="--d: 800ms">authored once · traceable through 10-K certification</text>

        {/* Bottom chrome */}
        <g class="fx" style="--d: 900ms">
          <line class="chrome-rule" x1="30" y1="286" x2="530" y2="286" />
          <rect class="build-dot" x="32" y="296" width="6" height="6" />
          <text class="chrome chrome--strong" x="46"  y="302">FIG. B</text>
          <text class="chrome"               x="92"  y="302">/</text>
          <text class="chrome chrome--strong" x="100" y="302">financial.control-chain</text>
          <text class="chrome chrome--strong" x="530" y="302" text-anchor="end">5 STAGES &rarr; AUDIT-READY</text>
        </g>
      </svg>
    </Hero>
  </section>

  {/* ────────────── OPTION C ────────────── */}
  <section class="fsm-option" id="opt-c">
    <div class="container-page">
      <h2 class="fsm-option__heading">Option C — Multi-jurisdiction profiling fan</h2>
      <p class="fsm-option__note">
        Central <code>&lt;disclosure&gt;</code> chip fanning to four regulator
        outputs (US · SEC, EU · ESMA, UK · FCA, APAC · MAS). Argues the
        Multi-Jurisdiction Delivery card's thesis — one master doc, many
        jurisdiction-specific variants.
      </p>
    </div>
    <Hero variant="universal" title={HERO_TITLE} subdeck={HERO_SUBDECK} subdeckMaxWidth="520px">
      <svg
        class="mock-svg mock-c"
        id="mock-c"
        viewBox="0 0 560 320"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        role="presentation"
      >
        <g class="corner--accent fx" style="--d: 0ms">
          <path d="M 12 24 L 12 12 L 24 12" />
          <path d="M 536 12 L 548 12 L 548 24" />
          <path d="M 12 296 L 12 308 L 24 308" />
          <path d="M 536 308 L 548 308 L 548 296" />
        </g>

        <text class="chrome fx" x="30" y="30" style="--d: 80ms">in :: financial.jurisdictions</text>

        {/* Four corner jurisdiction chips */}
        <g class="fx" style="--d: 280ms">
          <rect class="node node--custom" x="20" y="58" width="130" height="36" rx="3" />
          <text class="node-label node-label--custom" x="85" y="81" text-anchor="middle">US · SEC</text>
        </g>
        <g class="fx" style="--d: 320ms">
          <rect class="node node--custom" x="410" y="58" width="130" height="36" rx="3" />
          <text class="node-label node-label--custom" x="475" y="81" text-anchor="middle">EU · ESMA</text>
        </g>
        <g class="fx" style="--d: 360ms">
          <rect class="node node--custom" x="20" y="226" width="130" height="36" rx="3" />
          <text class="node-label node-label--custom" x="85" y="249" text-anchor="middle">UK · FCA</text>
        </g>
        <g class="fx" style="--d: 400ms">
          <rect class="node node--custom" x="410" y="226" width="130" height="36" rx="3" />
          <text class="node-label node-label--custom" x="475" y="249" text-anchor="middle">APAC · MAS</text>
        </g>

        {/* 4 radial connectors */}
        <path class="flow-conn" style="--d: 540ms" d="M 210 145 L 150 94" />
        <path class="flow-conn" style="--d: 560ms" d="M 350 145 L 410 94" />
        <path class="flow-conn" style="--d: 580ms" d="M 210 195 L 150 226" />
        <path class="flow-conn" style="--d: 600ms" d="M 350 195 L 410 226" />

        {/* Central <disclosure> chip */}
        <g class="fx" style="--d: 700ms">
          <rect class="node node--custom" x="210" y="125" width="140" height="90" rx="3" />
          <rect class="artifact-strip" x="210" y="125" width="140" height="6" />
          <text class="node-label node-label--custom" x="280" y="158" text-anchor="middle">&lt;disclosure&gt;</text>
          <line class="artifact-rule" x1="226" y1="170" x2="334" y2="170" />
          <text class="node-caption" x="280" y="186" text-anchor="middle">one master</text>
          <text class="node-caption" x="280" y="202" text-anchor="middle">DITA profiled</text>
        </g>

        {/* Bottom chrome */}
        <g class="fx" style="--d: 880ms">
          <line class="chrome-rule" x1="30" y1="286" x2="530" y2="286" />
          <rect class="build-dot" x="32" y="296" width="6" height="6" />
          <text class="chrome chrome--strong" x="46"  y="302">FIG. C</text>
          <text class="chrome"               x="92"  y="302">/</text>
          <text class="chrome chrome--strong" x="100" y="302">financial.jurisdictions</text>
          <text class="chrome chrome--strong" x="530" y="302" text-anchor="end">ONE MASTER &rarr; MANY VARIANTS</text>
        </g>
      </svg>
    </Hero>
  </section>

  {/* ────────────── OPTION D ────────────── */}
  <section class="fsm-option" id="opt-d">
    <div class="container-page">
      <h2 class="fsm-option__heading">Option D — Reuse fan + audit trace on the source</h2>
      <p class="fsm-option__note">
        Same layout as A (central <code>&lt;policy&gt;</code> + 4 deliverables
        fanning to the corners), with audit metadata baked into the source
        chip itself — version, approval, SOX-404 binding, git-style diff hash.
        Captures both load-bearing themes from the page: single-source reuse
        (the fan) and audit traceability (the metadata).
      </p>
    </div>
    <Hero variant="universal" title={HERO_TITLE} subdeck={HERO_SUBDECK} subdeckMaxWidth="520px">
      <svg
        class="mock-svg mock-d"
        id="mock-d"
        viewBox="0 0 560 320"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        role="presentation"
      >
        <g class="corner--accent fx" style="--d: 0ms">
          <path d="M 12 24 L 12 12 L 24 12" />
          <path d="M 536 12 L 548 12 L 548 24" />
          <path d="M 12 296 L 12 308 L 24 308" />
          <path d="M 536 308 L 548 308 L 548 296" />
        </g>

        <text class="chrome fx" x="30" y="30" style="--d: 80ms">in :: financial.reuse-traced</text>

        {/* Four corner deliverable chips */}
        <g class="fx" style="--d: 280ms">
          <rect class="node node--custom" x="20" y="58" width="160" height="36" rx="3" />
          <text class="node-label node-label--custom" x="100" y="81" text-anchor="middle">EMPLOYEE HANDBOOK</text>
        </g>
        <g class="fx" style="--d: 320ms">
          <rect class="node node--custom" x="380" y="58" width="160" height="36" rx="3" />
          <text class="node-label node-label--custom" x="460" y="81" text-anchor="middle">COMPLIANCE MANUAL</text>
        </g>
        <g class="fx" style="--d: 360ms">
          <rect class="node node--custom" x="20" y="226" width="160" height="36" rx="3" />
          <text class="node-label node-label--custom" x="100" y="249" text-anchor="middle">TRAINING DECK</text>
        </g>
        <g class="fx" style="--d: 400ms">
          <rect class="node node--custom" x="380" y="226" width="160" height="36" rx="3" />
          <text class="node-label node-label--custom" x="460" y="249" text-anchor="middle">CLIENT DISCLOSURE</text>
        </g>

        {/* 4 radial connectors */}
        <path class="flow-conn" style="--d: 540ms" d="M 210 140 L 180 94" />
        <path class="flow-conn" style="--d: 560ms" d="M 350 140 L 380 94" />
        <path class="flow-conn" style="--d: 580ms" d="M 210 190 L 180 226" />
        <path class="flow-conn" style="--d: 600ms" d="M 350 190 L 380 226" />

        {/* Central <policy> chip with audit metadata baked in */}
        <g class="fx" style="--d: 700ms">
          <rect class="node node--custom" x="210" y="110" width="140" height="110" rx="3" />
          <rect class="artifact-strip" x="210" y="110" width="140" height="6" />
          <text class="node-label node-label--custom" x="280" y="138" text-anchor="middle">&lt;policy&gt;</text>
          <line class="artifact-rule" x1="226" y1="148" x2="334" y2="148" />
          <text class="meta-line" x="280" y="163" text-anchor="middle">v3.2 · 2025-Q2</text>
          <text class="meta-line" x="280" y="178" text-anchor="middle">SOX 404 · linked</text>
          <text class="meta-line meta-line--diff" x="280" y="193" text-anchor="middle">a1b2c3 → d4e5f6</text>
          <line class="artifact-rule" x1="226" y1="203" x2="334" y2="203" />
          <text class="node-caption" x="280" y="216" text-anchor="middle">extense.compliance</text>
        </g>

        {/* Bottom chrome */}
        <g class="fx" style="--d: 880ms">
          <line class="chrome-rule" x1="30" y1="286" x2="530" y2="286" />
          <rect class="build-dot" x="32" y="296" width="6" height="6" />
          <text class="chrome chrome--strong" x="46"  y="302">FIG. D</text>
          <text class="chrome"               x="92"  y="302">/</text>
          <text class="chrome chrome--strong" x="100" y="302">financial.reuse-traced</text>
          <text class="chrome chrome--strong" x="530" y="302" text-anchor="end">ONE SOURCE &rarr; MANY · AUDIT-TRACEABLE</text>
        </g>
      </svg>
    </Hero>
  </section>
</BaseLayout>

<style>
  /* ─── Banner ─── */
  .fsm-banner {
    background: #fef3c7;
    border-bottom: var(--border-hairline);
    padding: var(--space-3) 0;
  }
  .fsm-banner__label {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.1em;
    color: var(--color-accent-primary-pressed);
    margin: 0 0 var(--space-2) 0;
  }
  .fsm-banner__nav {
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;
  }
  .fsm-banner__nav a {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-text-primary);
    text-decoration: none;
    border-bottom: 1px solid var(--color-accent-primary);
    padding-bottom: 1px;
  }
  .fsm-banner__nav a:hover {
    color: var(--color-link-hover);
  }

  /* ─── Option section ─── */
  .fsm-option {
    border-top: var(--border-hairline);
    padding-top: var(--space-8);
  }
  .fsm-option__heading {
    font-family: var(--font-display);
    font-size: var(--text-display-md);
    font-weight: var(--weight-regular);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-3) 0;
    letter-spacing: var(--tracking-tight);
  }
  .fsm-option__note {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin: 0;
    max-width: 70ch;
    text-wrap: pretty;
  }
  .fsm-option__note code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: #fef3c7;
    padding: 0 4px;
    border-radius: 2px;
  }

  /* ─── Shared SVG idiom ─── */
  .mock-svg {
    width: 560px;
    max-width: 100%;
    height: auto;
    color: var(--color-text-primary);
    overflow: visible;
    display: block;
    shape-rendering: geometricPrecision;
  }
  .mock-svg .chrome {
    font-family: var(--font-mono);
    font-size: 9px;
    fill: var(--color-text-muted);
    letter-spacing: 0.06em;
    user-select: none;
  }
  .mock-svg .chrome--strong {
    fill: var(--color-text-primary);
    font-weight: var(--weight-medium);
  }
  .mock-svg .corner--accent {
    stroke: var(--color-accent-primary-hover);
    stroke-width: 1.25;
    fill: none;
  }
  .mock-svg .chrome-rule {
    stroke: var(--color-border-subtle);
    stroke-width: 1;
  }
  .mock-svg .build-dot {
    fill: var(--color-accent-primary-hover);
    stroke: none;
  }
  .mock-svg .node {
    fill: var(--color-page-bg);
    stroke: var(--color-text-primary);
    stroke-width: 1.5;
    vector-effect: non-scaling-stroke;
  }
  .mock-svg .node--custom {
    fill: #fef3c7;
    stroke: var(--color-accent-primary);
  }
  .mock-svg .node-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: var(--weight-medium);
    fill: var(--color-text-primary);
    letter-spacing: 0.02em;
  }
  .mock-svg .node-label--custom {
    fill: var(--color-accent-primary-pressed);
  }
  .mock-svg .node-caption {
    font-family: var(--font-mono);
    font-size: 10px;
    fill: var(--color-text-secondary);
    letter-spacing: 0.04em;
  }
  .mock-svg .artifact-strip {
    fill: var(--color-accent-primary);
    stroke: none;
  }
  .mock-svg .artifact-rule {
    stroke: var(--color-border-subtle);
    stroke-width: 1;
  }
  .mock-svg .flow-conn {
    stroke: var(--color-accent-primary-hover);
    stroke-width: 1.5;
    fill: none;
    vector-effect: non-scaling-stroke;
    stroke-dasharray: 240;
    stroke-dashoffset: 240;
  }

  /* Option D meta lines (in the central policy chip) */
  .mock-d .meta-line {
    font-family: var(--font-mono);
    font-size: 10px;
    fill: var(--color-text-primary);
    letter-spacing: 0.04em;
  }
  .mock-d .meta-line--diff {
    fill: var(--color-accent-primary-pressed);
    letter-spacing: 0.06em;
  }

  /* Option B stage chips */
  .mock-b .stage-num {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: var(--weight-semibold);
    fill: var(--color-accent-primary-pressed);
    letter-spacing: 0.06em;
  }
  .mock-b .stage-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: var(--weight-medium);
    fill: var(--color-text-primary);
    letter-spacing: 0.06em;
  }
  .mock-b .outcome-caption {
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: var(--weight-semibold);
    fill: var(--color-accent-primary-pressed);
    letter-spacing: 0.12em;
  }
  .mock-b .outcome-sub {
    font-family: var(--font-mono);
    font-size: 9px;
    fill: var(--color-text-secondary);
    letter-spacing: 0.04em;
  }

  /* ─── Animation (shared) ─── */
  .mock-svg .fx {
    opacity: 0;
  }
  .mock-svg.drawn .fx {
    animation: fsm-fade 360ms ease-out forwards;
    animation-delay: var(--d, 0ms);
  }
  .mock-svg.drawn .flow-conn {
    animation: fsm-draw 620ms ease-out forwards;
    animation-delay: var(--d, 0ms);
  }
  @keyframes fsm-fade {
    to { opacity: 1; }
  }
  @keyframes fsm-draw {
    to { stroke-dashoffset: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .mock-svg .fx {
      opacity: 1 !important;
      animation: none !important;
    }
    .mock-svg .flow-conn {
      stroke-dashoffset: 0 !important;
      animation: none !important;
    }
  }
</style>

<script>
  function setupMocks() {
    const svgs = document.querySelectorAll(".mock-svg");
    if (svgs.length === 0) return;
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("drawn");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );
    svgs.forEach((svg) => observer.observe(svg));
  }
  document.addEventListener("DOMContentLoaded", setupMocks);
</script>
