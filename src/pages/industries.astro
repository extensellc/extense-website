---
/*
  /industries — placeholder page.

  Created as part of the Phase 4.5 nav restructure. Content to be filled
  out in a later pass — eventually the consolidated landing for the
  Public Sector / Private Sector audience subtrees.
*/

import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Industries"
  description="Regulated-sector practice areas served by Extense LLC. Coming soon."
>
  <section class="placeholder-page">
    <div class="container-prose placeholder-page__inner">
      <p class="eyebrow placeholder-page__eyebrow">Industries</p>
      <h1 class="placeholder-page__heading">Coming soon.</h1>
      <p class="placeholder-page__body">
        This page is in progress. For an overview of what Extense does today, see
        <a href="/capabilities">Capabilities</a>, or get in touch via
        <a href="/contact">Contact</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .placeholder-page {
    padding-top: var(--section-pad-default);
    padding-bottom: var(--section-pad-default);
  }
  .placeholder-page__eyebrow {
    margin-bottom: var(--space-4);
  }
  .placeholder-page__heading {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-6) 0;
    text-wrap: balance;
  }
  .placeholder-page__body {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin: 0;
    text-wrap: pretty;
  }
</style>
