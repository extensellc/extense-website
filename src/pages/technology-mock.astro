---
/*
  TEMP / technology-mock — three hero-visual candidates for
  /industries/technology.

  Each option renders the live Hero component with the locked [DRAFT] H1 +
  [DRAFT] subdeck so the side visuals can be judged in their final context.
  Pick one in-browser; build the real page with the chosen visual and
  `git rm` this file. Unlinked from nav.

  A — Three product surfaces in parallel: 3 small artifact cards side-by-side
      (DATASHEET · API REFERENCE · SOC 2 NARRATIVE), each with its own
      typographic register. Literal rendering of the page thesis.
  B — Source → 3 outputs fan: <source> chip with radial outputs to the
      three surface chips.
  C — 3 sources → 1 practice: HW · SW · SEC chips at top converging into
      a central extense.tech-docs chip.
*/

import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/site/Hero.astro";

const HERO_TITLE = "Technology & Semiconductors";
const HERO_SUBDECK = "Datasheets for system integrators, API docs for developers, security attestations for buyer security teams — three product surfaces, three audiences, one engineering discipline.";
---

<BaseLayout
  title="Technology hero mockups — Extense LLC"
  description="Internal mockup page. Three hero-visual candidates for /industries/technology."
>
  <section class="techm-banner">
    <div class="container-page">
      <p class="techm-banner__label">TECHNOLOGY HERO MOCK · PICK ONE</p>
      <nav class="techm-banner__nav" aria-label="Mock options">
        <a href="#opt-a">A · Three surfaces in parallel</a>
        <a href="#opt-b">B · Source → 3 outputs fan</a>
        <a href="#opt-c">C · 3 sources → 1 practice</a>
        <a href="#opt-d">D · Three artifacts under one practice</a>
      </nav>
    </div>
  </section>

  {/* ────────────── OPTION A ────────────── */}
  <section class="techm-option" id="opt-a">
    <div class="container-page">
      <h2 class="techm-option__heading">Option A — Three product surfaces in parallel</h2>
      <p class="techm-option__note">
        Three artifact cards side-by-side, each rendered in its own
        typographic register: DATASHEET (chip spec fields), API REFERENCE
        (endpoint + auth + params), SOC 2 NARRATIVE (control objective +
        evidence). Literal rendering of the page's three-surface thesis.
      </p>
    </div>
    <Hero variant="universal" title={HERO_TITLE} subdeck={HERO_SUBDECK} subdeckMaxWidth="520px">
      <svg
        class="mock-svg mock-a"
        id="mock-a"
        viewBox="0 0 560 320"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        role="presentation"
      >
        <g class="corner--accent fx" style="--d: 0ms">
          <path d="M 12 24 L 12 12 L 24 12" />
          <path d="M 536 12 L 548 12 L 548 24" />
          <path d="M 12 296 L 12 308 L 24 308" />
          <path d="M 536 308 L 548 308 L 548 296" />
        </g>

        <text class="chrome fx" x="30" y="30" style="--d: 80ms">in :: tech.surfaces</text>

        {/* Card 1 — DATASHEET */}
        <g class="fx" style="--d: 200ms">
          <rect class="node node--custom" x="20" y="58" width="160" height="208" rx="3" />
          <rect class="artifact-strip" x="20" y="58" width="160" height="6" />
          <text class="doc-ref" x="100" y="80" text-anchor="middle">DATASHEET</text>
          <text class="card-title" x="100" y="100" text-anchor="middle">16-Bit SRAM</text>
          <line class="artifact-rule" x1="36" y1="112" x2="164" y2="112" />
          <text class="field-key" x="36" y="132">VDD</text>
          <text class="field-val" x="164" y="132" text-anchor="end">3.3V ±5%</text>
          <text class="field-key" x="36" y="152">tACS</text>
          <text class="field-val" x="164" y="152" text-anchor="end">2.5 ns max</text>
          <text class="field-key" x="36" y="172">Op. temp</text>
          <text class="field-val" x="164" y="172" text-anchor="end">−40°C/+85°C</text>
          <text class="field-key" x="36" y="192">Package</text>
          <text class="field-val" x="164" y="192" text-anchor="end">100-TQFP</text>
          <line class="artifact-rule" x1="36" y1="210" x2="164" y2="210" />
          <text class="card-footer" x="36" y="226">CMOS-1234A</text>
          <text class="card-footer" x="164" y="226" text-anchor="end">Rev. 4.2</text>
        </g>

        {/* Card 2 — API REFERENCE */}
        <g class="fx" style="--d: 280ms">
          <rect class="node node--custom" x="200" y="58" width="160" height="208" rx="3" />
          <rect class="artifact-strip" x="200" y="58" width="160" height="6" />
          <text class="doc-ref" x="280" y="80" text-anchor="middle">API REFERENCE</text>
          <text class="card-title" x="280" y="100" text-anchor="middle">Payments API</text>
          <line class="artifact-rule" x1="216" y1="112" x2="344" y2="112" />
          <text class="field-key" x="216" y="132">Endpoint</text>
          <text class="field-mono" x="280" y="148" text-anchor="middle">POST /v3/payments</text>
          <text class="field-key" x="216" y="170">Auth</text>
          <text class="field-val" x="344" y="170" text-anchor="end">Bearer + idem-key</text>
          <text class="field-key" x="216" y="190">Params</text>
          <text class="field-val" x="344" y="190" text-anchor="end">amount, currency</text>
          <line class="artifact-rule" x1="216" y1="210" x2="344" y2="210" />
          <text class="card-footer" x="216" y="226">v3.2.0</text>
          <text class="card-footer" x="344" y="226" text-anchor="end">OpenAPI 3.1</text>
        </g>

        {/* Card 3 — SOC 2 NARRATIVE */}
        <g class="fx" style="--d: 360ms">
          <rect class="node node--custom" x="380" y="58" width="160" height="208" rx="3" />
          <rect class="artifact-strip" x="380" y="58" width="160" height="6" />
          <text class="doc-ref" x="460" y="80" text-anchor="middle">SOC 2 · CC6.1</text>
          <text class="card-title" x="460" y="100" text-anchor="middle">Access Controls</text>
          <line class="artifact-rule" x1="396" y1="112" x2="524" y2="112" />
          <text class="field-key" x="396" y="132">Objective</text>
          <text class="field-val" x="524" y="132" text-anchor="end">restrict access</text>
          <text class="field-key" x="396" y="152">Control</text>
          <text class="field-val" x="524" y="152" text-anchor="end">SAML + MFA</text>
          <text class="field-key" x="396" y="172">Evidence</text>
          <text class="field-val" x="524" y="172" text-anchor="end">IdP logs · review</text>
          <text class="field-key" x="396" y="192">Sample</text>
          <text class="field-val" x="524" y="192" text-anchor="end">25 prov · 4 qtrs</text>
          <line class="artifact-rule" x1="396" y1="210" x2="524" y2="210" />
          <text class="card-footer" x="396" y="226">Type II 2026</text>
          <text class="card-footer" x="524" y="226" text-anchor="end">Audited</text>
        </g>

        {/* Bottom chrome */}
        <g class="fx" style="--d: 720ms">
          <line class="chrome-rule" x1="30" y1="286" x2="530" y2="286" />
          <rect class="build-dot" x="32" y="296" width="6" height="6" />
          <text class="chrome chrome--strong" x="46"  y="302">FIG. A</text>
          <text class="chrome"               x="92"  y="302">/</text>
          <text class="chrome chrome--strong" x="100" y="302">tech.surfaces</text>
          <text class="chrome chrome--strong" x="530" y="302" text-anchor="end">3 REGISTERS &middot; 1 DISCIPLINE</text>
        </g>
      </svg>
    </Hero>
  </section>

  {/* ────────────── OPTION B ────────────── */}
  <section class="techm-option" id="opt-b">
    <div class="container-page">
      <h2 class="techm-option__heading">Option B — Source → 3 outputs fan</h2>
      <p class="techm-option__note">
        Central <code>&lt;source&gt;</code> chip on the left with radial
        outputs to three surface chips on the right (DATASHEET · API
        REFERENCE · SOC 2 NARRATIVE). Standard one-source-many-outputs
        idiom.
      </p>
    </div>
    <Hero variant="universal" title={HERO_TITLE} subdeck={HERO_SUBDECK} subdeckMaxWidth="520px">
      <svg
        class="mock-svg mock-b"
        id="mock-b"
        viewBox="0 0 560 320"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        role="presentation"
      >
        <g class="corner--accent fx" style="--d: 0ms">
          <path d="M 12 24 L 12 12 L 24 12" />
          <path d="M 536 12 L 548 12 L 548 24" />
          <path d="M 12 296 L 12 308 L 24 308" />
          <path d="M 536 308 L 548 308 L 548 296" />
        </g>

        <text class="chrome fx" x="30" y="30" style="--d: 80ms">in :: tech.outputs</text>

        {/* <source> chip on the left */}
        <g class="fx" style="--d: 200ms">
          <rect class="node node--custom" x="40" y="125" width="160" height="80" rx="3" />
          <rect class="artifact-strip" x="40" y="125" width="160" height="6" />
          <text class="node-label node-label--custom" x="120" y="155" text-anchor="middle">&lt;source&gt;</text>
          <line class="artifact-rule" x1="56" y1="167" x2="184" y2="167" />
          <text class="node-caption" x="120" y="185" text-anchor="middle">structured content</text>
          <text class="node-caption" x="120" y="200" text-anchor="middle">extense.tech-docs</text>
        </g>

        {/* 3 radial connectors */}
        <path class="flow-conn" style="--d: 380ms" d="M 200 145 L 380 80  M 376 76 L 380 80 L 376 84" />
        <path class="flow-conn" style="--d: 420ms" d="M 200 165 L 380 165 M 375 160 L 380 165 L 375 170" />
        <path class="flow-conn" style="--d: 460ms" d="M 200 185 L 380 250 M 376 246 L 380 250 L 376 254" />

        {/* 3 surface chips on the right */}
        <g class="fx" style="--d: 540ms">
          <rect class="node node--custom" x="380" y="60" width="160" height="40" rx="3" />
          <text class="node-label node-label--custom" x="460" y="85" text-anchor="middle">DATASHEET</text>
        </g>
        <g class="fx" style="--d: 580ms">
          <rect class="node node--custom" x="380" y="145" width="160" height="40" rx="3" />
          <text class="node-label node-label--custom" x="460" y="170" text-anchor="middle">API REFERENCE</text>
        </g>
        <g class="fx" style="--d: 620ms">
          <rect class="node node--custom" x="380" y="230" width="160" height="40" rx="3" />
          <text class="node-label node-label--custom" x="460" y="255" text-anchor="middle">SOC 2 NARRATIVE</text>
        </g>

        {/* Bottom chrome */}
        <g class="fx" style="--d: 760ms">
          <line class="chrome-rule" x1="30" y1="286" x2="530" y2="286" />
          <rect class="build-dot" x="32" y="296" width="6" height="6" />
          <text class="chrome chrome--strong" x="46"  y="302">FIG. B</text>
          <text class="chrome"               x="92"  y="302">/</text>
          <text class="chrome chrome--strong" x="100" y="302">tech.outputs</text>
          <text class="chrome chrome--strong" x="530" y="302" text-anchor="end">1 SOURCE &rarr; 3 SURFACES</text>
        </g>
      </svg>
    </Hero>
  </section>

  {/* ────────────── OPTION C ────────────── */}
  <section class="techm-option" id="opt-c">
    <div class="container-page">
      <h2 class="techm-option__heading">Option C — 3 sources → 1 practice</h2>
      <p class="techm-option__note">
        Three source chips at top (HARDWARE / SOFTWARE / SECURITY) converging
        into a central <code>extense.tech-docs</code> chip. Inverse of B;
        argues "one engineering discipline behind three documentation
        registers."
      </p>
    </div>
    <Hero variant="universal" title={HERO_TITLE} subdeck={HERO_SUBDECK} subdeckMaxWidth="520px">
      <svg
        class="mock-svg mock-c"
        id="mock-c"
        viewBox="0 0 560 320"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        role="presentation"
      >
        <g class="corner--accent fx" style="--d: 0ms">
          <path d="M 12 24 L 12 12 L 24 12" />
          <path d="M 536 12 L 548 12 L 548 24" />
          <path d="M 12 296 L 12 308 L 24 308" />
          <path d="M 536 308 L 548 308 L 548 296" />
        </g>

        <text class="chrome fx" x="30" y="30" style="--d: 80ms">in :: tech.practice</text>

        {/* Three source chips at top */}
        <g class="fx" style="--d: 200ms">
          <rect class="node node--custom" x="20" y="80" width="160" height="36" rx="3" />
          <text class="node-label node-label--custom" x="100" y="103" text-anchor="middle">HARDWARE</text>
        </g>
        <g class="fx" style="--d: 240ms">
          <rect class="node node--custom" x="200" y="80" width="160" height="36" rx="3" />
          <text class="node-label node-label--custom" x="280" y="103" text-anchor="middle">SOFTWARE</text>
        </g>
        <g class="fx" style="--d: 280ms">
          <rect class="node node--custom" x="380" y="80" width="160" height="36" rx="3" />
          <text class="node-label node-label--custom" x="460" y="103" text-anchor="middle">SECURITY</text>
        </g>

        {/* 3 convergent connectors → central chip */}
        <path class="flow-conn" style="--d: 420ms" d="M 100 116 L 280 200" />
        <path class="flow-conn" style="--d: 460ms" d="M 280 116 L 280 200" />
        <path class="flow-conn" style="--d: 500ms" d="M 460 116 L 280 200" />

        {/* Central extense.tech-docs chip */}
        <g class="fx" style="--d: 600ms">
          <rect class="node node--custom" x="180" y="200" width="200" height="60" rx="3" />
          <rect class="artifact-strip" x="180" y="200" width="200" height="6" />
          <text class="node-label node-label--custom" x="280" y="228" text-anchor="middle">extense.tech-docs</text>
          <line class="artifact-rule" x1="196" y1="240" x2="364" y2="240" />
          <text class="node-caption" x="280" y="254" text-anchor="middle">one engineering discipline</text>
        </g>

        {/* Bottom chrome */}
        <g class="fx" style="--d: 760ms">
          <line class="chrome-rule" x1="30" y1="286" x2="530" y2="286" />
          <rect class="build-dot" x="32" y="296" width="6" height="6" />
          <text class="chrome chrome--strong" x="46"  y="302">FIG. C</text>
          <text class="chrome"               x="92"  y="302">/</text>
          <text class="chrome chrome--strong" x="100" y="302">tech.practice</text>
          <text class="chrome chrome--strong" x="530" y="302" text-anchor="end">3 SURFACES &rarr; 1 PRACTICE</text>
        </g>
      </svg>
    </Hero>
  </section>

  {/* ────────────── OPTION D ────────────── */}
  <section class="techm-option" id="opt-d">
    <div class="container-page">
      <h2 class="techm-option__heading">Option D — Three artifacts under one engineering practice</h2>
      <p class="techm-option__note">
        Compact versions of A's three artifact cards across the top, sitting
        on a unifying <code>extense.tech-docs</code> bar at the bottom with
        a CI/CD-cadence indicator inside. Captures all three load-bearing
        moves: three surfaces (the artifacts), one discipline (the unifying
        bar), and continuous publishing cadence (the CI/CD indicator). Same
        hybrid pattern LS / Transportation / Insurance used.
      </p>
    </div>
    <Hero variant="universal" title={HERO_TITLE} subdeck={HERO_SUBDECK} subdeckMaxWidth="520px">
      <svg
        class="mock-svg mock-d"
        id="mock-d"
        viewBox="0 0 560 320"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        role="presentation"
      >
        <g class="corner--accent fx" style="--d: 0ms">
          <path d="M 12 24 L 12 12 L 24 12" />
          <path d="M 536 12 L 548 12 L 548 24" />
          <path d="M 12 296 L 12 308 L 24 308" />
          <path d="M 536 308 L 548 308 L 548 296" />
        </g>

        <text class="chrome fx" x="30" y="30" style="--d: 80ms">in :: tech.unified</text>

        {/* Compact Card 1 — DATASHEET */}
        <g class="fx" style="--d: 200ms">
          <rect class="node node--custom" x="20" y="50" width="160" height="116" rx="3" />
          <rect class="artifact-strip" x="20" y="50" width="160" height="6" />
          <text class="doc-ref" x="100" y="72" text-anchor="middle">DATASHEET</text>
          <text class="card-title" x="100" y="92" text-anchor="middle">16-Bit SRAM</text>
          <line class="artifact-rule" x1="36" y1="104" x2="164" y2="104" />
          <text class="field-key" x="36" y="124">VDD</text>
          <text class="field-val" x="164" y="124" text-anchor="end">3.3V ±5%</text>
          <text class="field-key" x="36" y="144">tACS</text>
          <text class="field-val" x="164" y="144" text-anchor="end">2.5 ns max</text>
        </g>

        {/* Compact Card 2 — API REFERENCE */}
        <g class="fx" style="--d: 260ms">
          <rect class="node node--custom" x="200" y="50" width="160" height="116" rx="3" />
          <rect class="artifact-strip" x="200" y="50" width="160" height="6" />
          <text class="doc-ref" x="280" y="72" text-anchor="middle">API REFERENCE</text>
          <text class="card-title" x="280" y="92" text-anchor="middle">Payments API</text>
          <line class="artifact-rule" x1="216" y1="104" x2="344" y2="104" />
          <text class="field-mono" x="280" y="122" text-anchor="middle">POST /v3/payments</text>
          <text class="field-key" x="216" y="144">Auth</text>
          <text class="field-val" x="344" y="144" text-anchor="end">Bearer + idem</text>
        </g>

        {/* Compact Card 3 — SOC 2 NARRATIVE */}
        <g class="fx" style="--d: 320ms">
          <rect class="node node--custom" x="380" y="50" width="160" height="116" rx="3" />
          <rect class="artifact-strip" x="380" y="50" width="160" height="6" />
          <text class="doc-ref" x="460" y="72" text-anchor="middle">SOC 2 · CC6.1</text>
          <text class="card-title" x="460" y="92" text-anchor="middle">Access Controls</text>
          <line class="artifact-rule" x1="396" y1="104" x2="524" y2="104" />
          <text class="field-key" x="396" y="124">Control</text>
          <text class="field-val" x="524" y="124" text-anchor="end">SAML + MFA</text>
          <text class="field-key" x="396" y="144">Evidence</text>
          <text class="field-val" x="524" y="144" text-anchor="end">IdP logs</text>
        </g>

        {/* Connectors from each card → unifying bar */}
        <path class="flow-conn" style="--d: 460ms" d="M 100 166 L 100 196 M 95 191 L 100 196 L 105 191" />
        <path class="flow-conn" style="--d: 480ms" d="M 280 166 L 280 196 M 275 191 L 280 196 L 285 191" />
        <path class="flow-conn" style="--d: 500ms" d="M 460 166 L 460 196 M 455 191 L 460 196 L 465 191" />

        {/* Unifying bar */}
        <g class="fx" style="--d: 580ms">
          <rect class="node node--custom" x="20" y="196" width="520" height="50" rx="3" />
          <rect class="artifact-strip" x="20" y="196" width="520" height="6" />
          <text class="node-label node-label--custom" x="280" y="224" text-anchor="middle">extense.tech-docs</text>
          <text class="node-caption" x="280" y="240" text-anchor="middle">one engineering discipline · CI/CD-driven publishing</text>
        </g>

        {/* Footer multiplier annotation */}
        <text class="multiplier-label fx" x="280" y="268" text-anchor="middle" style="--d: 700ms">three registers &middot; one engineering practice &middot; release-tied cadence</text>

        {/* Bottom chrome */}
        <g class="fx" style="--d: 820ms">
          <line class="chrome-rule" x1="30" y1="286" x2="530" y2="286" />
          <rect class="build-dot" x="32" y="296" width="6" height="6" />
          <text class="chrome chrome--strong" x="46"  y="302">FIG. D</text>
          <text class="chrome"               x="92"  y="302">/</text>
          <text class="chrome chrome--strong" x="100" y="302">tech.unified</text>
          <text class="chrome chrome--strong" x="530" y="302" text-anchor="end">3 SURFACES &middot; 1 PRACTICE &middot; CI/CD</text>
        </g>
      </svg>
    </Hero>
  </section>
</BaseLayout>

<style>
  /* ─── Banner ─── */
  .techm-banner {
    background: #fef3c7;
    border-bottom: var(--border-hairline);
    padding: var(--space-3) 0;
  }
  .techm-banner__label {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.1em;
    color: var(--color-accent-primary-pressed);
    margin: 0 0 var(--space-2) 0;
  }
  .techm-banner__nav {
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;
  }
  .techm-banner__nav a {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-text-primary);
    text-decoration: none;
    border-bottom: 1px solid var(--color-accent-primary);
    padding-bottom: 1px;
  }
  .techm-banner__nav a:hover {
    color: var(--color-link-hover);
  }

  /* ─── Option section ─── */
  .techm-option {
    border-top: var(--border-hairline);
    padding-top: var(--space-8);
  }
  .techm-option__heading {
    font-family: var(--font-display);
    font-size: var(--text-display-md);
    font-weight: var(--weight-regular);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-3) 0;
    letter-spacing: var(--tracking-tight);
  }
  .techm-option__note {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin: 0;
    max-width: 70ch;
    text-wrap: pretty;
  }
  .techm-option__note code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: #fef3c7;
    padding: 0 4px;
    border-radius: 2px;
  }

  /* ─── Shared SVG idiom ─── */
  .mock-svg {
    width: 560px;
    max-width: 100%;
    height: auto;
    color: var(--color-text-primary);
    overflow: visible;
    display: block;
    shape-rendering: geometricPrecision;
  }
  .mock-svg .chrome {
    font-family: var(--font-mono);
    font-size: 9px;
    fill: var(--color-text-muted);
    letter-spacing: 0.06em;
    user-select: none;
  }
  .mock-svg .chrome--strong {
    fill: var(--color-text-primary);
    font-weight: var(--weight-medium);
  }
  .mock-svg .corner--accent {
    stroke: var(--color-accent-primary-hover);
    stroke-width: 1.25;
    fill: none;
  }
  .mock-svg .chrome-rule {
    stroke: var(--color-border-subtle);
    stroke-width: 1;
