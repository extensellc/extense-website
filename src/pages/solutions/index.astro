---
/*
  /solutions — Solutions landing page.

  Spec ref: Solutions-page redesign brief.

  Section order:
    1. TopNav (BaseLayout)
    2. SolutionsHero — thesis ("Content compounds. So does the cost
       of getting it wrong.") + content-pipeline visual.
    3. SolutionsProblem — diagnosis ("The problem at scale.") — three
       parallel constraints that take over once authorship stops being
       the binding one.
    4. SolutionsApproach — resolution ("Documentation is a SYSTEM, not
       a deliverable.") — the single engineering principle.
    5. SolutionsAreas — four editorial chapter-blocks for the four
       solution sub-areas (TDP, Migration, Interop, AI-Ready), each
       with body copy, a pull-quote curiosity hook, and a link to its
       sub-page.
    6. CTAModule (audience: general) — Sample Content Assessment.
    7. Footer (BaseLayout)
*/

import BaseLayout from "../../layouts/BaseLayout.astro";
import SolutionsHero from "../../components/site/SolutionsHero.astro";
import SolutionsProblem from "../../components/site/SolutionsProblem.astro";
import SolutionsApproach from "../../components/site/SolutionsApproach.astro";
import SolutionsAreas from "../../components/site/SolutionsAreas.astro";
import CTAModule from "../../components/site/CTAModule.astro";
---

<BaseLayout
  title="Solutions"
  description="Extense engineers content as infrastructure: modeled, validated, machine-readable, ready for every output channel and every consumer — including AI."
>
  <SolutionsHero />
  <SolutionsProblem />
  <SolutionsApproach />
  <SolutionsAreas />

  <CTAModule
    audience="general"
    body="Bring us a 20-page sample document. We'll return what it would look like as engineered content — conversion feasibility, reuse percentage, and the pipeline that would produce it — within two business days. No obligation to proceed."
  />
</BaseLayout>
