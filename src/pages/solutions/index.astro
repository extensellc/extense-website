---
/*
  /solutions — Solutions landing page.

  Spec ref: Solutions-page redesign brief.

  Section order (work in progress; building section by section):
    1. TopNav (BaseLayout)
    2. SolutionsHero — thesis: "Content compounds. So does the cost of
       getting it wrong." Asymmetric layout with the content-pipeline
       diagram on the right.
    3. [next] The problem at scale (DocumentRow stack)
    4. [next] The approach (single principle, large type)
    5. [next] Four solution areas (editorial sections, hairline-divided)
    6. [next] CTA (CTAModule)
    7. Footer (BaseLayout)

  Temporary: while the lower sections are unbuilt, the four sub-page
  links remain in a small hairline strip at the bottom so the page stays
  navigable. They'll be replaced by the proper editorial-section
  treatment in the next pass.
*/

import BaseLayout from "../../layouts/BaseLayout.astro";
import SolutionsHero from "../../components/site/SolutionsHero.astro";
import SolutionsProblem from "../../components/site/SolutionsProblem.astro";

const subpages = [
  { name: "Technical Docs & Publishing", href: "/solutions/technical-docs-and-publishing" },
  { name: "Content Migration",            href: "/solutions/content-migration" },
  { name: "XML Data Interoperability",    href: "/solutions/xml-data-interoperability" },
  { name: "AI-Ready Content",             href: "/solutions/ai-ready-content" },
];
---

<BaseLayout
  title="Solutions"
  description="Extense engineers content as infrastructure: modeled, validated, machine-readable, ready for every output channel and every consumer — including AI."
>
  <SolutionsHero />

  <SolutionsProblem />

  <!-- TEMPORARY scaffold: sub-page links while the rest of the page is
       being built. To be removed once the proper "four solution areas"
       editorial section lands. -->
  <section class="solutions-scaffold" aria-label="Solutions sub-pages (placeholder)">
    <div class="container-prose solutions-scaffold__inner">
      <p class="eyebrow solutions-scaffold__eyebrow">In progress — sub-pages available below</p>
      <ul class="solutions-scaffold__list">
        {subpages.map((s) => (
          <li><a href={s.href}>{s.name} →</a></li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .solutions-scaffold {
    padding-top: var(--space-16);
    padding-bottom: var(--section-pad-default);
    border-top: var(--border-hairline);
  }
  .solutions-scaffold__eyebrow {
    margin-bottom: var(--space-6);
    color: var(--color-text-muted);
  }
  .solutions-scaffold__list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: var(--border-hairline);
  }
  .solutions-scaffold__list li {
    border-bottom: var(--border-hairline);
  }
  .solutions-scaffold__list a {
    display: block;
    padding: var(--space-3) 0;
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text-primary);
    text-decoration: none;
    transition: color var(--duration-base) var(--easing-out);
  }
  .solutions-scaffold__list a:hover,
  .solutions-scaffold__list a:focus-visible {
    color: var(--color-link);
    text-decoration: none;
  }
</style>
