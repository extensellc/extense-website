---
/*
  /solutions — Solutions landing page.

  Spec ref: Solutions-page redesign brief.

  Section order (reframed 2026 — old-site order, solution framing):
    1. TopNav (BaseLayout)
    2. SolutionsHero — "Content compounds. So does the cost of getting it
       wrong." + content-pipeline visual.
    3. SolutionsProblem — "Solving the Content Problem at Scale": asset/
       liability intro + the Assess -> Architect -> Implement -> Optimize strip.
    4. SolutionsAreas — "Our Solutions": the four solution cards (old-site
       copy) linking to the sub-pages.
    5. CTAModule (audience: general) — Sample Content Assessment.
    6. Footer (BaseLayout)

  (The standalone "Documentation is a system" principle section was dropped —
  it restated the thesis the hero + framing section already carry.)
*/

import BaseLayout from "../../layouts/BaseLayout.astro";
import SolutionsHero from "../../components/site/SolutionsHero.astro";
import SolutionsProblem from "../../components/site/SolutionsProblem.astro";
import SolutionsAreas from "../../components/site/SolutionsAreas.astro";
import CTAModule from "../../components/site/CTAModule.astro";
---

<BaseLayout
  title="Solutions"
  description="Extense engineers content as infrastructure: modeled, validated, machine-readable, ready for every output channel and every consumer — including AI."
>
  <SolutionsHero />
  <SolutionsProblem />
  <SolutionsAreas />

  <CTAModule
    accentLine
    audience="general"
    body="Bring us a 20-page sample document. We'll return what it would look like as engineered content — conversion feasibility, reuse percentage, and the pipeline that would produce it — within two business days. No obligation to proceed."
  />
</BaseLayout>
