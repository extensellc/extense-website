---
/*
  /solutions/ai-ready-content — placeholder sub-page.

  Created as part of the Phase 4.5 nav restructure. Content to be
  filled out in a later pass.
*/

import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="AI-Ready Content" description="Chunking, metadata, and retrieval architecture for AI-consumed content. Coming soon.">
  <section class="placeholder-page">
    <div class="container-prose placeholder-page__inner">
      <p class="eyebrow placeholder-page__eyebrow">Solutions</p>
      <h1 class="placeholder-page__heading">AI-Ready Content</h1>
      <p class="placeholder-page__body">
        This page is in progress. For an overview of what Extense does today, see
        <a href="/capabilities">Capabilities</a>, or get in touch via
        <a href="/contact">Contact</a>.
      </p>
      <p class="placeholder-page__back">
        <a href="/solutions">&larr; Back to all Solutions</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .placeholder-page {
    padding-top: var(--section-pad-default);
    padding-bottom: var(--section-pad-default);
  }
  .placeholder-page__eyebrow {
    margin-bottom: var(--space-4);
  }
  .placeholder-page__heading {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-6) 0;
    text-wrap: balance;
  }
  .placeholder-page__body {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin: 0 0 var(--space-8) 0;
    text-wrap: pretty;
  }
  .placeholder-page__back {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    font-weight: var(--weight-medium);
    margin: 0;
  }
</style>