---
/*
  /company/our-process

  Process deep-dive — the 5-phase methodology that /company summarizes,
  with per-phase deliverables, typical duration, exit criteria, and
  client touchpoints. Carries forward the old page's continuous-improvement
  loop ("The Full Circle") and the 4-stat outcomes band.

  See docs/reframe-2026/our-process.md for the locked wireframe + decisions.

  Section order:
    S1 Hero + 5-phase strip — single combined section. Top of section
       is a 2-column lead+aside (H1 + subdeck on the left, compact
       linear-with-loopback SVG on the right at ≥1024px). Below: the
       5-card linear strip with scroll-reveal motion. The compact loop
       SVG renders the subdeck's 'linear five phases + continuous loop'
       claim as a single 5-dot row with an amber loopback curve
       underneath; no separate Full Circle heading/intro — the SVG's
       FIG. chrome self-labels.
    S2 Phase by phase (5 deep-dive sections) — [DRAFT extended from OLD + /company]
       2.1 Discovery
       2.2 Architecture
       2.3 Migration
       2.4 Implementation
       2.5 Enablement
    S3 Typical client outcomes (4-stat band) — [OLD]
    S4 CTAModule — shared

  Page-local CSS prefix: proc-.
*/

import BaseLayout from "../../layouts/BaseLayout.astro";
import CTAModule from "../../components/site/CTAModule.astro";

interface OverviewPhase {
  number: string;
  name: string;
  subtitle: string;
  body: string;
}

const overviewPhases: OverviewPhase[] = [
  {
    number: "01",
    name: "Discovery",
    subtitle: "Stakeholder interviews & content audit",
    body: "Surface the constraints the architecture has to obey. Interview producers and consumers, audit existing content, map use cases the system must support.",
  },
  {
    number: "02",
    name: "Architecture",
    subtitle: "Taxonomy & DITA model design",
    body: "Design schema, taxonomy, metadata strategy, and reuse model against this client's constraints — not against textbook structured-content principles.",
  },
  {
    number: "03",
    name: "Migration",
    subtitle: "Batch conversion & cleanup",
    body: "Recover reusable assets from legacy content; retire or rewrite what isn't. QA harness designed before the first batch runs.",
  },
  {
    number: "04",
    name: "Implementation",
    subtitle: "CCMS config & stylesheet dev",
    body: "Wire the architecture into the toolchain — CCMS, publishing pipeline, integration points. Deliver the smallest implementation that runs.",
  },
  {
    number: "05",
    name: "Enablement",
    subtitle: "Training & handover",
    body: "Train the team, document the runbook, transfer ownership cleanly. 30/60/90-day check-ins after handover.",
  },
];

interface Facet {
  label: string;
  value: string;
}

interface PhaseDeepDive {
  number: string;
  name: string;
  body: string;
  facets: Facet[];
}

const phases: PhaseDeepDive[] = [
  {
    number: "01",
    name: "Discovery",
    body: "We don't move past Discovery until the constraints that would otherwise sink a content model have surfaced. That includes interviewing the people who will produce, edit, and consume the content, auditing what exists today, and mapping the use cases the system has to support. The goal isn't to gather requirements; it's to find the constraints the architecture has to obey.",
    facets: [
      { label: "Deliverables",       value: "Stakeholder interview synthesis · Content inventory and audit · Use-case map · Constraints register" },
      { label: "Typical duration",   value: "2–4 weeks, depending on content corpus size and the number of stakeholder groups" },
      { label: "Exit criteria",      value: "Constraints register signed off; use cases mapped to capabilities; no surfaced blocker remains unresolved" },
      { label: "Client touchpoints", value: "Weekly working session with content owners; one full readout at end of phase with stakeholder review" },
    ],
  },
  {
    number: "02",
    name: "Architecture",
    body: "The architecture is the leverage point. Schema design, taxonomy, metadata strategy, and reuse decisions made here determine what's possible in every downstream phase. We design against the use cases Discovery surfaced, not against generic structured-content principles. The architecture has to work for this client's content, not for a textbook example of DITA.",
    facets: [
      { label: "Deliverables",       value: "Information model (DITA specialization, schema, subject scheme) · Taxonomy and metadata strategy · Reuse model · Publishing target spec" },
      { label: "Typical duration",   value: "3–6 weeks" },
      { label: "Exit criteria",      value: "Schema validates against a representative content sample; metadata fields enumerated; reuse boundaries explicit; client team can author a topic in the model and have it validate" },
      { label: "Client touchpoints", value: "Weekly schema review with editorial leads; one mid-phase prototyping checkpoint with sample topic walkthrough" },
    ],
  },
  {
    number: "03",
    name: "Migration",
    body: "Migration is recovery, not transcription. The conversion engine identifies reusable assets in legacy content and lifts them into the target schema; what isn't recoverable gets retired or rewritten with intent. We design the QA harness before the first batch runs — failing migrations fail because the validation strategy was an afterthought.",
    facets: [
      { label: "Deliverables",       value: "QA harness · Conversion pipeline · Migration batches (typically iterative) · Per-batch recovery report" },
      { label: "Typical duration",   value: "4–12 weeks, proportional to corpus size; the first batch often spans 2–3 weeks alone" },
      { label: "Exit criteria",      value: "QA harness passes on a representative sample; recovery rate target met; rejected content categorized for retirement or rewrite" },
      { label: "Client touchpoints", value: "Weekly migration status reports with batch metrics; per-batch review of QA failures" },
    ],
  },
  {
    number: "04",
    name: "Implementation",
    body: "Implementation makes the architecture operational across the toolchain — CCMS configuration, publishing pipelines, integration points. The discipline at this phase is to resist scope expansion: every feature added during implementation is a feature the team has to maintain afterward. We deliver the smallest implementation that runs.",
    facets: [
      { label: "Deliverables",       value: "CCMS configuration · Publishing pipeline (containerized DITA-OT or equivalent) · Integration points (API connectors, webhooks) · CI/CD wiring · System documentation" },
      { label: "Typical duration",   value: "6–10 weeks" },
      { label: "Exit criteria",      value: "End-to-end publish from CCMS to all target outputs; production push tested; rollback procedure validated" },
      { label: "Client touchpoints", value: "Biweekly sprint reviews with engineering and content stakeholders; UAT with author cohort before go-live" },
    ],
  },
  {
    number: "05",
    name: "Enablement",
    body: "Enablement runs through every phase, not at the end. Discovery teaches the practitioner how the program works. Architecture documentation becomes the team's runbook. Migration training transitions authors. CCMS rollout becomes the operating manual. The handover isn't a phase — it's a discipline applied throughout.",
    facets: [
      { label: "Deliverables",       value: "Author training materials · Schema runbook · Troubleshooting guide · Ongoing-support playbook (escalation paths, common issues)" },
      { label: "Typical duration",   value: "Runs through every prior phase; concentrated 3–4 weeks at the close of Implementation for formal training" },
      { label: "Exit criteria",      value: "Authors produce valid topics independently; CCMS operations team resolves 80%+ of operational tasks without Extense; runbook captures known issues" },
      { label: "Client touchpoints", value: "Continuous from Phase 1; formal training events at end of Implementation; 30/60/90-day check-ins post-handover" },
    ],
  },
];

interface OutcomeStat {
  value: string;
  label: string;
}

const outcomes: OutcomeStat[] = [
  { value: "60%", label: "Faster publishing" },
  { value: "72%", label: "Translation savings" },
  { value: "45%", label: "Content reuse rate" },
  { value: "90%", label: "Fewer support tickets" },
];
---

<BaseLayout
  title="Our Content Engineering Process"
  description="The Extense engagement process from Discovery to Enablement: deliverables, typical durations, exit criteria, and client touchpoints for every phase, plus the continuous-improvement loop that follows handover."
>
  {/* ───────── S1 — Hero + 5-phase overview strip (combined) ───────── */}
  <section class="proc-section proc-section--hero" aria-labelledby="proc-hero-heading">
    <div class="container-page proc-section__inner">
      <div class="proc-hero__top">
        <div class="proc-hero__lead">
          <h1 id="proc-hero-heading" class="proc-hero__title">Our Process</h1>
          <p class="proc-hero__subdeck">
            Five phases. Continuous improvement. Inspectable artifacts at every step. We move linearly from Discovery to Enablement, then settle into a continuous improvement loop — every phase ends with a signed-off deliverable, not a status update.
          </p>
        </div>

        <div class="proc-hero__aside">
          <svg
            class="proc-circle-flow"
            id="proc-circle-flow"
            viewBox="0 0 480 220"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
            role="presentation"
          >
            {/* corner reg marks */}
            <g class="corner fx" style="--d: 0ms">
              <path d="M 12 22 L 12 12 L 22 12" />
              <path d="M 458 12 L 468 12 L 468 22" />
              <path d="M 12 198 L 12 208 L 22 208" />
              <path d="M 458 208 L 468 208 L 468 198" />
            </g>

            <text class="chrome fx" x="24" y="30" style="--d: 80ms">in :: process.continuous</text>

            {/* 5 numbered phase markers */}
            <g class="fx" style="--d: 200ms">
              <text class="toc-num" x="60" y="68" text-anchor="middle">01</text>
              <circle class="dot" cx="60" cy="90" r="7" />
            </g>
            <g class="fx" style="--d: 280ms">
              <text class="toc-num" x="150" y="68" text-anchor="middle">02</text>
              <circle class="dot" cx="150" cy="90" r="7" />
            </g>
            <g class="fx" style="--d: 360ms">
              <text class="toc-num" x="240" y="68" text-anchor="middle">03</text>
              <circle class="dot" cx="240" cy="90" r="7" />
            </g>
            <g class="fx" style="--d: 440ms">
              <text class="toc-num" x="330" y="68" text-anchor="middle">04</text>
              <circle class="dot" cx="330" cy="90" r="7" />
            </g>
            <g class="fx" style="--d: 520ms">
              <text class="toc-num" x="420" y="68" text-anchor="middle">05</text>
              <circle class="dot" cx="420" cy="90" r="7" />
            </g>

            {/* Linear arrows between dots */}
            <path class="flow-conn" style="--d: 600ms" d="M70 90 L140 90 M135 86 L140 90 L135 94" />
            <path class="flow-conn" style="--d: 680ms" d="M160 90 L230 90 M225 86 L230 90 L225 94" />
            <path class="flow-conn" style="--d: 760ms" d="M250 90 L320 90 M315 86 L320 90 L315 94" />
            <path class="flow-conn" style="--d: 840ms" d="M340 90 L410 90 M405 86 L410 90 L405 94" />

            {/* Loopback: from dot 5 down/left/up back to dot 1 */}
            <path
              class="flow-conn"
              style="--d: 920ms"
              d="M420 100 C 460 140, 460 160, 380 160 L 100 160 C 20 160, 20 140, 60 100 M55 104 L60 100 L65 104"
            />

            {/* ↻ continuous chip on the loopback */}
            <g class="fx" style="--d: 1180ms">
              <rect class="node node--custom" x="200" y="148" width="80" height="22" rx="3" />
              <text class="node-label node-label--custom node-label--sm" x="240" y="164" text-anchor="middle">↻ continuous</text>
            </g>

            {/* Bottom chrome */}
            <g class="fx" style="--d: 1300ms">
              <line class="chrome-rule" x1="24" y1="194" x2="456" y2="194" />
              <rect class="build-dot" x="172" y="201" width="6" height="6" />
              <text class="chrome chrome--strong" x="186" y="207">FIG. 01</text>
              <text class="chrome" x="236" y="207">/</text>
              <text class="chrome chrome--strong" x="244" y="207">process.continuous</text>
              <text class="chrome chrome--strong" x="456" y="207" text-anchor="end">5 + 1</text>
            </g>
          </svg>
        </div>
      </div>

      <ol class="proc-strip" id="proc-strip">
        {overviewPhases.map((p, i) => (
          <>
            <li class="proc-strip__card fx" style={`--d: ${i * 280}ms`}>
              <span class="proc-strip__num">{p.number}</span>
              <h2 class="proc-strip__name">{p.name}</h2>
              <p class="proc-strip__subtitle">{p.subtitle}</p>
              <p class="proc-strip__body">{p.body}</p>
            </li>
            {i < overviewPhases.length - 1 && (
              <li class="proc-strip__arrow fx" aria-hidden="true" style={`--d: ${i * 280 + 200}ms`}>
                <svg viewBox="0 0 32 16" class="proc-strip__arrow-svg" aria-hidden="true">
                  <path class="proc-strip__arrow-path" d="M 0 8 L 28 8 M 24 4 L 28 8 L 24 12" />
                </svg>
              </li>
            )}
          </>
        ))}
      </ol>

    </div>
  </section>

  {/* ───────── S3 — Phase by phase deep-dive ───────── */}
  <section class="proc-section proc-section--band" aria-labelledby="proc-deep-heading">
    <div class="container-page proc-section__inner">
      <div class="proc-heading-block proc-heading-block--wide">
        <h2 id="proc-deep-heading" class="proc-heading">Phase by phase</h2>
        <p class="proc-intro">
          What each phase produces, how long it usually takes, when we know it's done, and how often you'll see progress.
        </p>
      </div>

      <ol class="proc-phases">
        {phases.map((p) => (
          <li class="proc-phase">
            <div class="proc-phase__rail">
              <span class="proc-phase__num">{p.number}</span>
            </div>
            <div class="proc-phase__content">
              <h3 class="proc-phase__heading">{p.name}</h3>
              <p class="proc-phase__body">{p.body}</p>

              <p class="proc-phase__eyebrow">Example profile</p>
              <dl class="proc-facets">
                {p.facets.map((f) => (
                  <div class="proc-facet">
                    <dt class="proc-facet__label">{f.label}</dt>
                    <dd class="proc-facet__value">{f.value}</dd>
                  </div>
                ))}
              </dl>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  {/* ───────── S3 — Typical client outcomes ───────── */}
  <section class="proc-section proc-section--no-rules" aria-labelledby="proc-outcomes-heading">
    <div class="container-page proc-section__inner">
      <div class="proc-heading-block proc-heading-block--wide">
        <h2 id="proc-outcomes-heading" class="proc-heading">Typical client outcomes</h2>
        <p class="proc-intro">
          Aggregate improvements measured across recent engagements. Numbers reflect the methodology applied — not best-case projections.
        </p>
      </div>

      <ul class="proc-stat-band">
        {outcomes.map((s) => (
          <li class="proc-stat">
            <span class="proc-stat__value">{s.value}</span>
            <span class="proc-stat__label">{s.label}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <CTAModule
    audience="general"
    compact
    accentLine
    heading="Free Content Health Check"
    body="Upload a 20-page sample document. We'll return conversion feasibility, reuse potential, and ROI projection within two business days — at no cost."
  />
</BaseLayout>

<style>
  /* ─── Section shell ─── */
  .proc-section {
    padding-top: var(--space-12);
    padding-bottom: var(--space-12);
    border-top: var(--border-hairline);
  }
  .proc-section--band {
    background-color: var(--color-surface-band);
  }
  @media (max-width: 767px) {
    .proc-section {
      padding-top: var(--space-8);
      padding-bottom: var(--space-8);
    }
  }

  /* Top section — combined hero + 5-phase strip. No border-top (it's the
     first section on the page). Generous padding-top to match the
     hero-section feel; padding-bottom matches the other proc sections. */
  .proc-section--hero {
    padding-top: var(--space-16);
    padding-bottom: var(--space-12);
    border-top: 0;
  }

  /* Modifier — strips the section's top divider AND the inner stat
     band's top/bottom hairlines. Used on the Typical client outcomes
     section so the 4 numbers float on the page background without any
     framing rules. */
  .proc-section--no-rules {
    border-top: 0;
  }
  .proc-section--no-rules .proc-stat-band {
    border-top: 0;
    border-bottom: 0;
  }
  @media (min-width: 768px) {
    .proc-section--hero {
      padding-top: var(--space-32);
    }
  }

  /* ─── Inline hero typography (replaces the Hero component for this
     combined section). Matches the Hero component's universal variant. ─── */
  .proc-hero__title {
    font-family: var(--font-display);
    font-size: var(--text-display-xl);
    font-weight: var(--weight-regular);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-6) 0;
    text-wrap: balance;
    max-width: var(--container-prose);
  }
  .proc-hero__subdeck {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    font-weight: var(--weight-regular);
    line-height: var(--leading-normal);
    color: var(--color-text-secondary);
    margin: 0;
    max-width: 540px;
    text-wrap: pretty;
  }

  /* Hero top — lead block (H1 + subdeck) on the left, compact loop SVG
     on the right at ≥1024px; stacked on mobile. Mirrors the case-study
     header layout. */
  .proc-hero__top {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    margin-bottom: var(--space-12);
  }
  @media (min-width: 1024px) {
    .proc-hero__top {
      flex-direction: row;
      align-items: center;
      gap: var(--space-16);
      margin-bottom: var(--space-16);
    }
  }
  .proc-hero__lead {
    flex: 1 1 auto;
    min-width: 0;
  }
  .proc-hero__aside {
    flex: 0 0 auto;
    width: 100%;
    max-width: 520px;
  }
  @media (min-width: 1024px) {
    .proc-hero__aside {
      width: 520px;
      max-width: 50%;
    }
  }

  .proc-heading-block {
    margin-bottom: var(--space-10);
    max-width: 80ch;
  }
  /* Wide variant — drops the 80ch cap so a long single-line intro can
     span the full container without wrapping. */
  .proc-heading-block--wide {
    max-width: none;
  }
  .proc-heading-block--wide .proc-intro {
    max-width: none;
    white-space: nowrap;
  }
  /* Re-enable wrapping below desktop so very narrow viewports don't
     overflow horizontally. */
  @media (max-width: 1023px) {
    .proc-heading-block--wide .proc-intro {
      white-space: normal;
      text-wrap: pretty;
    }
  }
  .proc-heading-block--centered {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
  }
  .proc-heading {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-4) 0;
    text-wrap: balance;
  }
  .proc-intro {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin: 0;
    text-wrap: pretty;
  }

  /* ─── S2 — 5-phase overview strip ─── */
  .proc-strip {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }
  @media (min-width: 1024px) {
    .proc-strip {
      grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr auto 1fr;
      align-items: stretch;
      gap: var(--space-3);
    }
  }
  .proc-strip__card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-5) var(--space-5) var(--space-6);
    border: var(--border-hairline);
    background-color: var(--color-page-bg);
  }
  .proc-strip__num {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: var(--weight-semibold);
    letter-spacing: 0.12em;
    color: var(--color-accent-primary-pressed);
  }
  .proc-strip__name {
    font-family: var(--font-display);
    font-size: var(--text-display-sm);
    font-weight: var(--weight-medium);
    line-height: var(--leading-snug);
    color: var(--color-text-primary);
    margin: 0;
    text-wrap: balance;
  }
  .proc-strip__subtitle {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    font-weight: var(--weight-medium);
    line-height: var(--leading-snug);
    color: var(--color-text-primary);
    margin: 0;
    text-wrap: pretty;
  }
  .proc-strip__body {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    line-height: var(--leading-normal);
    color: var(--color-text-secondary);
    margin: var(--space-2) 0 0 0;
    text-wrap: pretty;
  }
  .proc-strip__arrow {
    display: none;
    align-self: center;
    color: var(--color-accent-primary-hover);
  }
  @media (min-width: 1024px) {
    .proc-strip__arrow {
      display: flex;
      justify-content: center;
      align-items: center;
    }
  }
  .proc-strip__arrow-svg {
    width: 32px;
    height: 16px;
    color: currentColor;
    overflow: visible;
    display: block;
  }
  .proc-strip__arrow-path {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
    stroke-linecap: square;
    vector-effect: non-scaling-stroke;
  }

  /* Scroll-reveal: cards fade + translateY in sequence, arrows draw with
     stroke-dashoffset between them. IntersectionObserver adds .drawn to
     the strip container when in viewport; per-element --d controls
     stagger. Reduced-motion fallback removes both. */
  .proc-strip .fx {
    opacity: 0;
  }
  .proc-strip__card.fx {
    transform: translateY(8px);
    transition:
      opacity 360ms ease-out,
      transform 360ms ease-out;
  }
  .proc-strip__arrow.fx .proc-strip__arrow-path {
    stroke-dasharray: 36;
    stroke-dashoffset: 36;
    transition: stroke-dashoffset 480ms ease-out;
  }
  .proc-strip.drawn .fx {
    opacity: 1;
    transition-delay: var(--d, 0ms);
  }
  .proc-strip.drawn .proc-strip__card.fx {
    transform: translateY(0);
  }
  .proc-strip.drawn .proc-strip__arrow.fx .proc-strip__arrow-path {
    stroke-dashoffset: 0;
    transition-delay: var(--d, 0ms);
  }
  @media (prefers-reduced-motion: reduce) {
    .proc-strip .fx {
      opacity: 1 !important;
      transition: none !important;
    }
    .proc-strip__card.fx {
      transform: none !important;
    }
    .proc-strip__arrow.fx .proc-strip__arrow-path {
      stroke-dashoffset: 0 !important;
      transition: none !important;
    }
  }

  /* ─── S3 — Phase deep-dive ─── */
  .proc-phases {
    list-style: none;
    margin: var(--space-8) 0 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .proc-phase {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    padding: var(--space-12) 0;
    border-top: var(--border-hairline);
  }
  .proc-phase:last-child {
    border-bottom: var(--border-hairline);
  }
  @media (min-width: 768px) {
    .proc-phase {
      grid-template-columns: 120px 1fr;
      gap: var(--space-8);
      align-items: start;
    }
  }
  @media (min-width: 1024px) {
    .proc-phase {
      grid-template-columns: 160px 1fr;
      gap: var(--space-12);
    }
  }
  .proc-phase__rail {
    display: flex;
    align-items: baseline;
  }
  .proc-phase__num {
    font-family: var(--font-display);
    font-size: 64px;
    font-weight: var(--weight-regular);
    line-height: 1;
    color: var(--color-accent-primary-pressed);
    font-feature-settings: "tnum";
  }
  @media (min-width: 1024px) {
    .proc-phase__num {
      font-size: 88px;
    }
  }
  .proc-phase__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }
