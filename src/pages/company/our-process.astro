<script>
  function setupProcCircle() {
    const svg = document.getElementById("proc-circle-flow");
    if (!svg) return;
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            svg.classList.add("drawn");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );
    observer.observe(svg);
  }

  document.addEventListener("DOMContentLoaded", setupProcCircle);
  document.addEventListener("astro:page-load", setupProcCircle);
</script>
