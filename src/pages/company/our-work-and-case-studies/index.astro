<script>
  function setupOwcsHero() {
    const svg = document.getElementById("owcs-hero-flow");
    if (!svg) return;
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            svg.classList.add("drawn");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );
    observer.observe(svg);
  }

  document.addEventListener("DOMContentLoaded", setupOwcsHero);
  document.addEventListener("astro:page-load", setupOwcsHero);
</script>
