---
/*
  TEMP — Hero visual mockups for /company/our-work-and-case-studies.
  Five candidate concepts laid out vertically for in-browser comparison.
  Delete this file after selection.

  Route: /company/our-work-and-case-studies-mock
*/
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Our Work & Case Studies — Hero visual mockups"
  description="Temporary mockup page; delete after selection."
>
  <div class="container-page owcsm-wrap">
    <header class="owcsm-page-head">
      <p class="owcsm-eyebrow">TEMP · MOCKUPS</p>
      <h1 class="owcsm-page-h1">Our Work & Case Studies — hero visual candidates</h1>
      <p class="owcsm-page-intro">
        Five concepts for the right-hand hero side-visual on
        <code>/company/our-work-and-case-studies</code>. Page H1 is
        <em>Measurable Results, Real Deliverables</em>; the load-bearing
        thesis is that every metric is backed by an inspectable artifact.
      </p>
    </header>

    {/* ───────────── CONCEPT A — Metric × Artifact pairing strip ───────────── */}
    <section class="owcsm-mock">
      <header class="owcsm-mock__head">
        <p class="owcsm-mock__tag">CONCEPT A</p>
        <h2 class="owcsm-mock__title">Metric × Artifact pairing strip</h2>
        <p class="owcsm-mock__desc">
          Three rows pair an artifact filename with the measurement it
          produced. Most literal rendering of the subdeck's "every metric
          backed by artifacts you can inspect."
        </p>
      </header>
      <div class="owcsm-svg-frame">
        <svg
          class="owcsm-svg"
          viewBox="0 0 560 320"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
          role="presentation"
        >
          {/* corner reg marks */}
          <g class="corner fx" style="--d: 0ms">
            <path d="M 12 24 L 12 12 L 24 12" />
            <path d="M 536 12 L 548 12 L 548 24" />
            <path d="M 12 296 L 12 308 L 24 308" />
            <path d="M 536 308 L 548 308 L 548 296" />
          </g>

          <text class="chrome fx" x="30" y="32" style="--d: 80ms">in :: results.measured</text>
          <text class="chrome label--muted fx" x="30" y="48" style="--d: 160ms">ARTIFACT &rarr; MEASUREMENT</text>

          {/* Row 1 */}
          <g class="fx" style="--d: 280ms">
            <rect class="node" x="30" y="66" width="190" height="36" rx="3" />
            <text class="node-label" x="125" y="89" text-anchor="middle">bookmap.ditamap</text>
          </g>
          <path class="flow-conn" style="--d: 360ms" d="M222 84 L328 84 M323 79 L328 84 L323 89" />
          <g class="fx" style="--d: 480ms">
            <rect class="node node--custom" x="330" y="66" width="200" height="36" rx="3" />
            <text class="node-label node-label--custom" x="430" y="89" text-anchor="middle">76 TOPICS</text>
          </g>

          {/* Row 2 */}
          <g class="fx" style="--d: 600ms">
            <rect class="node" x="30" y="124" width="190" height="36" rx="3" />
            <text class="node-label" x="125" y="147" text-anchor="middle">metadata-pipeline.py</text>
          </g>
          <path class="flow-conn" style="--d: 680ms" d="M222 142 L328 142 M323 137 L328 142 L323 147" />
          <g class="fx" style="--d: 800ms">
            <rect class="node node--custom" x="330" y="124" width="200" height="36" rx="3" />
            <text class="node-label node-label--custom" x="430" y="147" text-anchor="middle">100% METADATA</text>
          </g>

          {/* Row 3 */}
          <g class="fx" style="--d: 920ms">
            <rect class="node" x="30" y="182" width="190" height="36" rx="3" />
            <text class="node-label" x="125" y="205" text-anchor="middle">dita-ot.plugin.zip</text>
          </g>
          <path class="flow-conn" style="--d: 1000ms" d="M222 200 L328 200 M323 195 L328 200 L323 205" />
          <g class="fx" style="--d: 1120ms">
            <rect class="node node--custom" x="330" y="182" width="200" height="36" rx="3" />
            <text class="node-label node-label--custom" x="430" y="205" text-anchor="middle">4 FORMATS</text>
          </g>

          {/* extense.measured chip — connects all three rows */}
          <g class="fx" style="--d: 1280ms">
            <line class="chrome-rule rule--accent" x1="275" y1="66" x2="275" y2="218" />
            <rect class="node node--custom" x="225" y="232" width="110" height="24" rx="3" />
            <text class="node-label node-label--custom node-label--sm" x="280" y="249" text-anchor="middle">extense.measured</text>
          </g>

          {/* Bottom chrome */}
          <g class="fx" style="--d: 1440ms">
            <line class="chrome-rule" x1="30" y1="282" x2="530" y2="282" />
            <rect class="build-dot" x="232" y="292" width="6" height="6" />
            <text class="chrome chrome--strong" x="246" y="298">FIG. 01</text>
            <text class="chrome" x="296" y="298">/</text>
            <text class="chrome chrome--strong" x="304" y="298">artifact.measured</text>
            <text class="chrome chrome--strong" x="530" y="298" text-anchor="end">MEASURED</text>
          </g>
        </svg>
      </div>
    </section>

    {/* ───────────── CONCEPT B — Verification certificate ───────────── */}
    <section class="owcsm-mock">
      <header class="owcsm-mock__head">
        <p class="owcsm-mock__tag">CONCEPT B</p>
        <h2 class="owcsm-mock__title">Verification certificate</h2>
        <p class="owcsm-mock__desc">
          Four aggregate stats radiate around a central
          <code>extense.measured</code> chip. Frames the page as a single
          verification artifact — every metric vouched for.
        </p>
      </header>
      <div class="owcsm-svg-frame">
        <svg
          class="owcsm-svg"
          viewBox="0 0 560 320"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
          role="presentation"
        >
          <g class="corner fx" style="--d: 0ms">
            <path d="M 12 24 L 12 12 L 24 12" />
            <path d="M 536 12 L 548 12 L 548 24" />
            <path d="M 12 296 L 12 308 L 24 308" />
            <path d="M 536 308 L 548 308 L 548 296" />
          </g>

          <text class="chrome fx" x="30" y="32" style="--d: 80ms">in :: measured.impact</text>

          {/* TL tile — 2 → 9 */}
          <g class="fx" style="--d: 280ms">
            <rect class="tile" x="40" y="60" width="160" height="78" rx="3" />
            <text class="tile-value" x="120" y="100" text-anchor="middle">2 &rarr; 9</text>
            <text class="tile-label" x="120" y="124" text-anchor="middle">AI-READINESS</text>
          </g>

          {/* TR tile — 0 → 100% */}
          <g class="fx" style="--d: 360ms">
            <rect class="tile" x="360" y="60" width="160" height="78" rx="3" />
            <text class="tile-value" x="440" y="100" text-anchor="middle">0 &rarr; 100%</text>
            <text class="tile-label" x="440" y="124" text-anchor="middle">METADATA COVERAGE</text>
          </g>

          {/* BL tile — 350% */}
          <g class="fx" style="--d: 440ms">
            <rect class="tile" x="40" y="182" width="160" height="78" rx="3" />
            <text class="tile-value" x="120" y="222" text-anchor="middle">350%</text>
            <text class="tile-label" x="120" y="246" text-anchor="middle">REUSABLE CONTENT</text>
          </g>

          {/* BR tile — −70% */}
          <g class="fx" style="--d: 520ms">
            <rect class="tile" x="360" y="182" width="160" height="78" rx="3" />
            <text class="tile-value" x="440" y="222" text-anchor="middle">&minus;70%</text>
            <text class="tile-label" x="440" y="246" text-anchor="middle">LESS REWORK</text>
          </g>

          {/* Connector lines from each tile to central chip */}
          <path class="flow-conn" style="--d: 640ms" d="M200 124 L220 150" />
          <path class="flow-conn" style="--d: 700ms" d="M360 124 L340 150" />
          <path class="flow-conn" style="--d: 760ms" d="M200 196 L220 174" />
          <path class="flow-conn" style="--d: 820ms" d="M360 196 L340 174" />

          {/* Central chip */}
          <g class="fx" style="--d: 940ms">
            <rect class="node node--custom" x="220" y="146" width="120" height="32" rx="3" />
            <text class="node-label node-label--custom" x="280" y="166" text-anchor="middle">extense.measured</text>
          </g>

          {/* Bottom chrome */}
          <g class="fx" style="--d: 1080ms">
            <line class="chrome-rule" x1="30" y1="282" x2="530" y2="282" />
            <rect class="build-dot" x="232" y="292" width="6" height="6" />
            <text class="chrome chrome--strong" x="246" y="298">FIG. 02</text>
            <text class="chrome" x="296" y="298">/</text>
            <text class="chrome chrome--strong" x="304" y="298">measured.impact</text>
            <text class="chrome chrome--strong" x="530" y="298" text-anchor="end">4 STATS &middot; 1 VERDICT</text>
          </g>
        </svg>
      </div>
    </section>

    {/* ───────────── CONCEPT C — Two-row engagement strip ───────────── */}
    <section class="owcsm-mock">
      <header class="owcsm-mock__head">
        <p class="owcsm-mock__tag">CONCEPT C</p>
        <h2 class="owcsm-mock__title">Two-row engagement strip</h2>
        <p class="owcsm-mock__desc">
          Top row = the 3 anonymized industries from S3. Bottom row = the
          3 named case-study artifacts from S4. Amber connector between
          renders the page's entire inventory at a glance.
        </p>
      </header>
      <div class="owcsm-svg-frame">
        <svg
          class="owcsm-svg"
          viewBox="0 0 560 320"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
          role="presentation"
        >
          <g class="corner fx" style="--d: 0ms">
            <path d="M 12 24 L 12 12 L 24 12" />
            <path d="M 536 12 L 548 12 L 548 24" />
            <path d="M 12 296 L 12 308 L 24 308" />
            <path d="M 536 308 L 548 308 L 548 296" />
          </g>

          <text class="chrome fx" x="30" y="32" style="--d: 80ms">in :: outcomes + artifacts</text>
          <text class="chrome label--muted fx" x="30" y="48" style="--d: 160ms">ANONYMIZED ENGAGEMENTS</text>

          {/* Top row — anonymized industries (default nodes) */}
          <g class="fx" style="--d: 280ms">
            <rect class="node" x="30" y="62" width="160" height="56" rx="3" />
            <text class="eyebrow-sm" x="110" y="86" text-anchor="middle">MANUFACTURING</text>
            <text class="node-label" x="110" y="106" text-anchor="middle">60% cost cut</text>
          </g>
          <g class="fx" style="--d: 360ms">
            <rect class="node" x="200" y="62" width="160" height="56" rx="3" />
            <text class="eyebrow-sm" x="280" y="86" text-anchor="middle">MEDICAL DEVICE</text>
            <text class="node-label" x="280" y="106" text-anchor="middle">100% audit pass</text>
          </g>
          <g class="fx" style="--d: 440ms">
            <rect class="node" x="370" y="62" width="160" height="56" rx="3" />
            <text class="eyebrow-sm" x="450" y="86" text-anchor="middle">FINTECH</text>
            <text class="node-label" x="450" y="106" text-anchor="middle">0 doc lag days</text>
          </g>

          {/* Amber rule + chip */}
          <path class="flow-conn" style="--d: 580ms" d="M30 160 L530 160" />
          <g class="fx" style="--d: 760ms">
            <rect class="node node--custom" x="220" y="148" width="120" height="24" rx="3" />
            <text class="node-label node-label--custom node-label--sm" x="280" y="165" text-anchor="middle">extense.measured</text>
          </g>

          <text class="chrome label--accent fx" x="30" y="200" style="--d: 880ms">NAMED CASE STUDIES &middot; ARTIFACTS</text>

          {/* Bottom row — case-study artifacts (custom amber nodes) */}
          <g class="fx" style="--d: 960ms">
            <rect class="node node--custom" x="30" y="210" width="160" height="56" rx="3" />
            <text class="eyebrow-sm eyebrow-sm--accent" x="110" y="234" text-anchor="middle">DITA TRAINING</text>
            <text class="node-label node-label--custom node-label--sm" x="110" y="254" text-anchor="middle">bookmap.ditamap</text>
          </g>
          <g class="fx" style="--d: 1040ms">
            <rect class="node node--custom" x="200" y="210" width="160" height="56" rx="3" />
            <text class="eyebrow-sm eyebrow-sm--accent" x="280" y="234" text-anchor="middle">AI PIPELINE</text>
            <text class="node-label node-label--custom node-label--sm" x="280" y="254" text-anchor="middle">metadata-pipeline.py</text>
          </g>
          <g class="fx" style="--d: 1120ms">
            <rect class="node node--custom" x="370" y="210" width="160" height="56" rx="3" />
            <text class="eyebrow-sm eyebrow-sm--accent" x="450" y="234" text-anchor="middle">PUBLISHING</text>
            <text class="node-label node-label--custom node-label--sm" x="450" y="254" text-anchor="middle">dita-ot.plugin</text>
          </g>

          {/* Bottom chrome */}
          <g class="fx" style="--d: 1280ms">
            <line class="chrome-rule" x1="30" y1="282" x2="530" y2="282" />
            <rect class="build-dot" x="232" y="292" width="6" height="6" />
            <text class="chrome chrome--strong" x="246" y="298">FIG. 03</text>
            <text class="chrome" x="296" y="298">/</text>
            <text class="chrome chrome--strong" x="304" y="298">work.inventory</text>
            <text class="chrome chrome--strong" x="530" y="298" text-anchor="end">3 + 3 &middot; CROSS-VERIFIED</text>
          </g>
        </svg>
      </div>
    </section>

    {/* ───────────── CONCEPT D — Report cover artifact ───────────── */}
    <section class="owcsm-mock">
      <header class="owcsm-mock__head">
        <p class="owcsm-mock__tag">CONCEPT D</p>
        <h2 class="owcsm-mock__title">Report cover with measurement callouts</h2>
        <p class="owcsm-mock__desc">
          A single stylized document with callout chips pulling out the
          measurements it produced. Single artifact, many measurements —
          renders "real deliverables" almost as a noun.
        </p>
      </header>
      <div class="owcsm-svg-frame">
        <svg
          class="owcsm-svg"
          viewBox="0 0 560 320"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
          role="presentation"
        >
          <g class="corner fx" style="--d: 0ms">
            <path d="M 12 24 L 12 12 L 24 12" />
            <path d="M 536 12 L 548 12 L 548 24" />
            <path d="M 12 296 L 12 308 L 24 308" />
            <path d="M 536 308 L 548 308 L 548 296" />
          </g>

          <text class="chrome fx" x="30" y="32" style="--d: 80ms">in :: deliverable.inspected</text>

          {/* Document outline */}
          <g class="fx" style="--d: 200ms">
            <rect class="doc" x="40" y="56" width="200" height="220" rx="3" />
            {/* doc tab/header */}
            <rect class="doc-band" x="40" y="56" width="200" height="20" />
            <text class="doc-label" x="50" y="71">training-guide.pdf</text>

            {/* doc content lines (stylized) */}
            <rect class="doc-title" x="56" y="92" width="100" height="6" />
            <rect class="doc-line" x="56" y="110" width="168" height="3" />
            <rect class="doc-line" x="56" y="120" width="168" height="3" />
            <rect class="doc-line" x="56" y="130" width="140" height="3" />

            <rect class="doc-rule" x="56" y="148" width="168" height="1" />

            <rect class="doc-title" x="56" y="160" width="80" height="6" />
            <rect class="doc-line" x="56" y="178" width="168" height="3" />
            <rect class="doc-line" x="56" y="188" width="168" height="3" />
            <rect class="doc-line" x="56" y="198" width="120" height="3" />

            <rect class="doc-rule" x="56" y="216" width="168" height="1" />

            <rect class="doc-title" x="56" y="228" width="90" height="6" />
            <rect class="doc-line" x="56" y="246" width="168" height="3" />
            <rect class="doc-line" x="56" y="256" width="168" height="3" />
          </g>

          {/* Callouts — line from doc edge to chip */}
          <path class="flow-conn" style="--d: 480ms" d="M240 95 L300 95 L300 84 L330 84" />
          <g class="fx" style="--d: 640ms">
            <rect class="node node--custom" x="330" y="66" width="190" height="36" rx="3" />
            <text class="node-label node-label--custom" x="425" y="89" text-anchor="middle">76 DITA TOPICS</text>
          </g>

          <path class="flow-conn" style="--d: 720ms" d="M240 165 L300 165 L300 165 L330 165" />
          <g class="fx" style="--d: 880ms">
            <rect class="node node--custom" x="330" y="147" width="190" height="36" rx="3" />
            <text class="node-label node-label--custom" x="425" y="170" text-anchor="middle">12 HANDS-ON LABS</text>
          </g>

          <path class="flow-conn" style="--d: 960ms" d="M240 235 L300 235 L300 246 L330 246" />
          <g class="fx" style="--d: 1120ms">
            <rect class="node node--custom" x="330" y="228" width="190" height="36" rx="3" />
            <text class="node-label node-label--custom" x="425" y="251" text-anchor="middle">218 PRINTED PAGES</text>
          </g>

          {/* Bottom chrome */}
          <g class="fx" style="--d: 1280ms">
            <line class="chrome-rule" x1="30" y1="282" x2="530" y2="282" />
            <rect class="build-dot" x="232" y="292" width="6" height="6" />
            <text class="chrome chrome--strong" x="246" y="298">FIG. 04</text>
            <text class="chrome" x="296" y="298">/</text>
            <text class="chrome chrome--strong" x="304" y="298">deliverable.inspected</text>
            <text class="chrome chrome--strong" x="530" y="298" text-anchor="end">1 ARTIFACT &middot; 3 MEASUREMENTS</text>
          </g>
        </svg>
      </div>
    </section>

    {/* ───────────── CONCEPT E — Score arc 2 → 9 ───────────── */}
    <section class="owcsm-mock">
      <header class="owcsm-mock__head">
        <p class="owcsm-mock__tag">CONCEPT E</p>
        <h2 class="owcsm-mock__title">Score arc · 2 &rarr; 9</h2>
        <p class="owcsm-mock__desc">
          Minimal horizontal AI-readiness scale: muted baseline dot at 2,
          amber measured dot at 9, with a "+7 measured improvement"
          caption. Punchy and aphoristic but more abstract than A–D.
        </p>
      </header>
      <div class="owcsm-svg-frame">
        <svg
          class="owcsm-svg"
          viewBox="0 0 560 320"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
          role="presentation"
        >
          <g class="corner fx" style="--d: 0ms">
            <path d="M 12 24 L 12 12 L 24 12" />
            <path d="M 536 12 L 548 12 L 548 24" />
            <path d="M 12 296 L 12 308 L 24 308" />
            <path d="M 536 308 L 548 308 L 548 296" />
          </g>

          <text class="chrome fx" x="30" y="32" style="--d: 80ms">in :: ai-readiness.scored</text>
          <text class="chrome label--muted fx" x="30" y="48" style="--d: 160ms">10-POINT SCALE &middot; BEFORE / AFTER</text>

          {/* Axis line */}
          <line class="axis fx" x1="60" y1="186" x2="500" y2="186" style="--d: 280ms" />

          {/* Tick marks at 1-10 */}
          {Array.from({length: 10}).map((_, i) => {
            const x = 60 + i * (440 / 9);
            const isAnchor = i === 0 || i === 9;
            return (
              <g class="fx" style={`--d: ${360 + i * 40}ms`}>
                <line class={isAnchor ? "tick tick--strong" : "tick"} x1={x} y1="180" x2={x} y2="192" />
                <text class="tick-num" x={x} y="208" text-anchor="middle">{i + 1}</text>
              </g>
            );
          })}

          {/* Amber arc/line from baseline (2) to measured (9) */}
          <path class="flow-conn flow-conn--thick" style="--d: 920ms" d="M109 186 L451 186" />

          {/* Baseline dot at x=109 (tick 2) */}
          <g class="fx" style="--d: 1060ms">
            <circle class="dot dot--baseline" cx="109" cy="186" r="7" />
            <text class="dot-label dot-label--muted" x="109" y="240" text-anchor="middle">BASELINE</text>
            <text class="dot-value dot-value--muted" x="109" y="260" text-anchor="middle">2</text>
          </g>

          {/* Measured dot at x=451 (tick 9) */}
          <g class="fx" style="--d: 1180ms">
            <circle class="dot dot--measured" cx="451" cy="186" r="9" />
            <text class="dot-label dot-label--accent" x="451" y="240" text-anchor="middle">MEASURED</text>
            <text class="dot-value dot-value--accent" x="451" y="260" text-anchor="middle">9</text>
          </g>

          {/* Caption above */}
          <g class="fx" style="--d: 1320ms">
            <rect class="node node--custom" x="220" y="120" width="120" height="28" rx="3" />
            <text class="node-label node-label--custom" x="280" y="139" text-anchor="middle">+7 measured</text>
          </g>

          {/* Bottom chrome */}
          <g class="fx" style="--d: 1440ms">
            <line class="chrome-rule" x1="30" y1="282" x2="530" y2="282" />
            <rect class="build-dot" x="232" y="292" width="6" height="6" />
            <text class="chrome chrome--strong" x="246" y="298">FIG. 05</text>
            <text class="chrome" x="296" y="298">/</text>
            <text class="chrome chrome--strong" x="304" y="298">ai-readiness.scored</text>
            <text class="chrome chrome--strong" x="530" y="298" text-anchor="end">BEFORE &rarr; AFTER</text>
          </g>
        </svg>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  /* ─── Page chrome ─── */
  .owcsm-wrap {
    padding-top: var(--space-12);
    padding-bottom: var(--space-24);
  }
  .owcsm-page-head {
    margin-bottom: var(--space-16);
    max-width: 80ch;
  }
  .owcsm-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent-primary-pressed);
    margin: 0 0 var(--space-3) 0;
  }
  .owcsm-page-h1 {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-4) 0;
    text-wrap: balance;
  }
  .owcsm-page-intro {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin: 0;
    text-wrap: pretty;
  }
  .owcsm-page-intro code,
  .owcsm-mock__desc code {
