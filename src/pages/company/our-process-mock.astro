---
/*
  TEMP — Smaller hero-aside visual mockups for /company/our-process.
  Three candidate concepts laid out vertically for in-browser comparison.
  Delete this file after selection.

  Route: /company/our-process-mock
*/
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Our Process — Smaller hero visual mockups"
  description="Temporary mockup page; delete after selection."
>
  <div class="container-page opm-wrap">
    <header class="opm-page-head">
      <p class="opm-eyebrow">TEMP · MOCKUPS</p>
      <h1 class="opm-page-h1">Our Process — smaller hero-aside visual candidates</h1>
      <p class="opm-page-intro">
        Three concepts to replace the full 960×400 Full Circle SVG with a
        more compact visual that sits beside the H1 + subdeck in the hero.
        Each is sized to fit the upper-right slot when the subdeck is
        capped at ~540px.
      </p>
    </header>

    {/* ───────────── CONCEPT A — Compact loop circle ───────────── */}
    <section class="opm-mock">
      <header class="opm-mock__head">
        <p class="opm-mock__tag">CONCEPT A</p>
        <h2 class="opm-mock__title">Compact loop circle</h2>
        <p class="opm-mock__desc">
          Six numbered nodes on a circle, central amber
          <code>↻ extense.continuous</code> chip, single arrowhead on the
          ring indicating clockwise flow. Pure topology — reads as "this
          loops."
        </p>
      </header>
      <div class="opm-svg-frame">
        <svg
          class="opm-svg drawn"
          viewBox="0 0 320 260"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
          role="presentation"
        >
          <g class="corner">
            <path d="M 12 22 L 12 12 L 22 12" />
            <path d="M 298 12 L 308 12 L 308 22" />
            <path d="M 12 238 L 12 248 L 22 248" />
            <path d="M 298 248 L 308 248 L 308 238" />
          </g>

          <text class="chrome" x="24" y="30">in :: process.continuous</text>

          {/* Amber loop ring (center 160,135 radius 78) with arrowhead */}
          <circle class="ring" cx="160" cy="135" r="78" />
          {/* Arrowhead at top suggesting clockwise direction */}
          <path class="ring-arrow" d="M168 57 L172 53 L176 57" />

          {/* 6 small amber dots evenly spaced on circle, with numbers above
              Position formula: cx + r*sin(angle), cy - r*cos(angle)
              Angles (deg from top, clockwise): 0, 60, 120, 180, 240, 300 */}
          {/* 01 — top (0°) */}
          <circle class="dot" cx="160" cy="57" r="5" />
          <text class="toc-num" x="160" y="44" text-anchor="middle">01</text>
          {/* 02 — top-right (60°): 160 + 78*sin(60) = 160 + 67.5 = 227.5; 135 - 78*cos(60) = 135 - 39 = 96 */}
          <circle class="dot" cx="227" cy="96" r="5" />
          <text class="toc-num" x="243" y="92" text-anchor="start">02</text>
          {/* 03 — bottom-right (120°): 160 + 67.5 = 227.5; 135 + 39 = 174 */}
          <circle class="dot" cx="227" cy="174" r="5" />
          <text class="toc-num" x="243" y="178" text-anchor="start">03</text>
          {/* 04 — bottom (180°) */}
          <circle class="dot" cx="160" cy="213" r="5" />
          <text class="toc-num" x="160" y="232" text-anchor="middle">04</text>
          {/* 05 — bottom-left (240°): 160 - 67.5 = 92.5; 135 + 39 = 174 */}
          <circle class="dot" cx="93" cy="174" r="5" />
          <text class="toc-num" x="77" y="178" text-anchor="end">05</text>
          {/* 06 — top-left (300°): 160 - 67.5 = 92.5; 135 - 39 = 96 */}
          <circle class="dot" cx="93" cy="96" r="5" />
          <text class="toc-num" x="77" y="92" text-anchor="end">06</text>

          {/* Central chip */}
          <rect class="chip" x="100" y="121" width="120" height="28" rx="3" />
          <text class="chip-label" x="160" y="140" text-anchor="middle">↻ extense.continuous</text>

          {/* Bottom chrome */}
          <line class="chrome-rule" x1="24" y1="240" x2="296" y2="240" />
          <rect class="build-dot" x="92" y="248" width="6" height="6" />
          <text class="chrome chrome--strong" x="106" y="254">FIG. 01</text>
          <text class="chrome" x="156" y="254">/</text>
          <text class="chrome chrome--strong" x="164" y="254">process.continuous</text>
        </svg>
      </div>
    </section>

    {/* ───────────── CONCEPT B — Linear-with-loopback ───────────── */}
    <section class="opm-mock">
      <header class="opm-mock__head">
        <p class="opm-mock__tag">CONCEPT B</p>
        <h2 class="opm-mock__title">Linear-with-loopback</h2>
        <p class="opm-mock__desc">
          Five numbered dots in a horizontal row with arrows between, plus
          a curved amber loopback under the row returning from 05 back to
          01. Tagged <code>↻ continuous</code> on the loopback. Reads as
          "5 linear phases + a loop"; mirrors the 5-card strip below.
        </p>
      </header>
      <div class="opm-svg-frame">
        <svg
          class="opm-svg drawn"
          viewBox="0 0 480 220"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
          role="presentation"
        >
          <g class="corner">
            <path d="M 12 22 L 12 12 L 22 12" />
            <path d="M 458 12 L 468 12 L 468 22" />
            <path d="M 12 198 L 12 208 L 22 208" />
            <path d="M 458 208 L 468 208 L 468 198" />
          </g>

          <text class="chrome" x="24" y="30">in :: process.continuous</text>

          {/* 5 numbered phase dots */}
          {/* Positions: 60, 150, 240, 330, 420 along x; y = 90 */}
          <text class="toc-num" x="60"  y="68" text-anchor="middle">01</text>
          <text class="toc-num" x="150" y="68" text-anchor="middle">02</text>
          <text class="toc-num" x="240" y="68" text-anchor="middle">03</text>
          <text class="toc-num" x="330" y="68" text-anchor="middle">04</text>
          <text class="toc-num" x="420" y="68" text-anchor="middle">05</text>

          <circle class="dot" cx="60"  cy="90" r="7" />
          <circle class="dot" cx="150" cy="90" r="7" />
          <circle class="dot" cx="240" cy="90" r="7" />
          <circle class="dot" cx="330" cy="90" r="7" />
          <circle class="dot" cx="420" cy="90" r="7" />

          {/* Arrows between dots */}
          <path class="conn" d="M70 90 L140 90 M135 86 L140 90 L135 94" />
          <path class="conn" d="M160 90 L230 90 M225 86 L230 90 L225 94" />
          <path class="conn" d="M250 90 L320 90 M315 86 L320 90 L315 94" />
          <path class="conn" d="M340 90 L410 90 M405 86 L410 90 L405 94" />

          {/* Loopback curve from dot 5 going down, left, back up to dot 1 */}
          <path
            class="conn loop"
            d="M420 100 C 460 140, 460 160, 380 160 L 100 160 C 20 160, 20 140, 60 100 M55 104 L60 100 L65 104"
          />

          {/* "↻ continuous" chip on the loopback */}
          <rect class="chip" x="200" y="148" width="80" height="22" rx="3" />
          <text class="chip-label chip-label--sm" x="240" y="164" text-anchor="middle">↻ continuous</text>

          {/* Bottom chrome */}
          <line class="chrome-rule" x1="24" y1="194" x2="456" y2="194" />
          <rect class="build-dot" x="172" y="201" width="6" height="6" />
          <text class="chrome chrome--strong" x="186" y="207">FIG. 01</text>
          <text class="chrome" x="236" y="207">/</text>
          <text class="chrome chrome--strong" x="244" y="207">process.continuous</text>
          <text class="chrome chrome--strong" x="456" y="207" text-anchor="end">5 + 1</text>
        </svg>
      </div>
    </section>

    {/* ───────────── CONCEPT C — Iconic mark ───────────── */}
    <section class="opm-mock">
      <header class="opm-mock__head">
        <p class="opm-mock__tag">CONCEPT C</p>
        <h2 class="opm-mock__title">Iconic mark</h2>
        <p class="opm-mock__desc">
          A large amber <code>↻</code> glyph centered with
          <code>extense.continuous</code> label beneath. No phases drawn —
          pure brand stamp. The most minimal; reads as a logo more than a
          diagram.
        </p>
      </header>
      <div class="opm-svg-frame">
        <svg
          class="opm-svg drawn"
          viewBox="0 0 280 160"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
          role="presentation"
        >
          <g class="corner">
            <path d="M 12 22 L 12 12 L 22 12" />
            <path d="M 258 12 L 268 12 L 268 22" />
            <path d="M 12 138 L 12 148 L 22 148" />
            <path d="M 258 148 L 268 148 L 268 138" />
          </g>

          <text class="chrome" x="20" y="28">in :: process.continuous</text>

          {/* Large amber ↻ glyph */}
          <text class="glyph" x="140" y="98" text-anchor="middle">↻</text>
          {/* Label beneath */}
          <text class="brand-label" x="140" y="122" text-anchor="middle">extense.continuous</text>

          {/* Bottom chrome */}
          <line class="chrome-rule" x1="20" y1="134" x2="260" y2="134" />
          <rect class="build-dot" x="62" y="141" width="6" height="6" />
          <text class="chrome chrome--strong" x="76" y="147">FIG. 01</text>
          <text class="chrome" x="126" y="147">/</text>
          <text class="chrome chrome--strong" x="134" y="147">process.continuous</text>
        </svg>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  /* ─── Page chrome ─── */
  .opm-wrap {
    padding-top: var(--space-12);
    padding-bottom: var(--space-24);
  }
  .opm-page-head {
    margin-bottom: var(--space-16);
    max-width: 80ch;
  }
  .opm-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent-primary-pressed);
    margin: 0 0 var(--space-3) 0;
  }
  .opm-page-h1 {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-4) 0;
    text-wrap: balance;
  }
  .opm-page-intro {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin: 0;
    text-wrap: pretty;
  }
  .opm-page-intro code,
  .opm-mock__desc code {
    font-family: var(--font-mono);
    font-size: 0.92em;
    color: var(--color-text-primary);
    background-color: var(--color-surface-band);
    padding: 0 var(--space-1);
  }

  /* ─── Mock section ─── */
  .opm-mock {
    margin-bottom: var(--space-16);
    border-top: var(--border-hairline);
    padding-top: var(--space-12);
  }
  .opm-mock__head {
    margin-bottom: var(--space-8);
    max-width: 80ch;
  }
  .opm-mock__tag {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent-primary-pressed);
    margin: 0 0 var(--space-2) 0;
  }
  .opm-mock__title {
    font-family: var(--font-display);
    font-size: var(--text-display-md);
    font-weight: var(--weight-medium);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-3) 0;
    line-height: var(--leading-snug);
  }
  .opm-mock__desc {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin: 0;
    text-wrap: pretty;
  }
  .opm-svg-frame {
    background-color: var(--color-page-bg);
    border: var(--border-hairline);
    padding: var(--space-6);
    max-width: 560px;
  }

  /* ─── Shared SVG styling (document-grade idiom) ─── */
  .opm-svg {
    width: 100%;
    height: auto;
    color: var(--color-text-primary);
    overflow: visible;
    display: block;
    shape-rendering: geometricPrecision;
  }
  .opm-svg .chrome {
    font-family: var(--font-mono);
    font-size: 9px;
    fill: var(--color-text-muted);
    letter-spacing: 0.06em;
  }
  .opm-svg .chrome--strong {
    fill: var(--color-text-primary);
    font-weight: var(--weight-medium);
  }
  .opm-svg .corner {
    stroke: var(--color-accent-primary-hover);
    stroke-width: 1.25;
    fill: none;
  }
  .opm-svg .chrome-rule {
    stroke: var(--color-border-subtle);
    stroke-width: 1;
  }
  .opm-svg .build-dot {
    fill: var(--color-accent-primary-hover);
    stroke: none;
  }
  .opm-svg .ring {
    fill: none;
    stroke: var(--color-accent-primary-hover);
    stroke-width: 1.5;
    vector-effect: non-scaling-stroke;
  }
  .opm-svg .ring-arrow {
    fill: none;
    stroke: var(--color-accent-primary-hover);
    stroke-width: 1.5;
    stroke-linecap: square;
    vector-effect: non-scaling-stroke;
  }
  .opm-svg .dot {
    fill: var(--color-accent-primary);
    stroke: var(--color-accent-primary-pressed);
    stroke-width: 1.5;
    vector-effect: non-scaling-stroke;
  }
  .opm-svg .conn {
    fill: none;
    stroke: var(--color-accent-primary-hover);
    stroke-width: 1.5;
    vector-effect: non-scaling-stroke;
  }
  .opm-svg .loop {
    /* Loopback has no separate styling beyond .conn for now */
  }
  .opm-svg .toc-num {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: var(--weight-semibold);
    fill: var(--color-accent-primary-pressed);
    letter-spacing: 0.04em;
  }
  .opm-svg .chip {
    fill: #fef3c7;
    stroke: var(--color-accent-primary);
    stroke-width: 1.5;
    vector-effect: non-scaling-stroke;
  }
  .opm-svg .chip-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: var(--weight-medium);
    fill: var(--color-accent-primary-pressed);
    letter-spacing: 0.02em;
  }
  .opm-svg .chip-label--sm {
    font-size: 10px;
  }
  .opm-svg .glyph {
    font-family: var(--font-display);
    font-size: 56px;
    fill: var(--color-accent-primary-pressed);
    font-weight: var(--weight-regular);
  }
  .opm-svg .brand-label {
    font-family: var(--font-mono);
    font-size: 11px;
    fill: var(--color-text-primary);
    letter-spacing: 0.04em;
  }
</style>
