---
import IndustryPageLayout from "../../layouts/IndustryPageLayout.astro";
---

<IndustryPageLayout
  pageTitle="Automotive — Industries"
  pageDescription="Service documentation engineering for OEMs and Tier-1 suppliers. Service manuals, parts catalogs, owner's manuals across global dealer networks. Translation cost as the largest ROI lever; warranty exposure as the cost-of-being-wrong."
  heroTitle="Automotive"
  heroSubdeck="The service network's nervous system. Translation as the largest cost lever; warranty exposure as the failure mode. Service-information quality directly affects warranty claims, dealer satisfaction, and (in safety-relevant cases) recall exposure."
  industryHref="/private-sector/automotive"
  documentTypes={[
    {
      label: "Service repair manuals",
      description: "Procedure-level technical content for dealer technicians and independent repair networks.",
    },
    {
      label: "Parts catalogs",
      description: "Identification, ordering, and supersession data integrated with PIM and parts-database systems.",
    },
    {
      label: "Owner's manuals",
      description: "Customer-facing operating manuals across vehicle-family and trim-level variations.",
    },
    {
      label: "Technical Service Bulletins (TSBs)",
      description: "Field-issued guidance for service procedures, diagnostic patterns, and warranty implications.",
    },
    {
      label: "Dealer training materials",
      description: "Technician training, service-advisor training, certification curricula tied to vehicle programs.",
    },
    {
      label: "Warranty documentation",
      description: "Procedure-driven warranty content; the connection between service manual accuracy and claim approval.",
    },
  ]}
  standards={[
    {
      label: "SAE J2008",
      description: "Society of Automotive Engineers digital service-information specification — used across passenger and commercial vehicle programs.",
    },
    {
      label: "S1000D",
      description: "Increasingly adopted in heavy commercial vehicles, agricultural equipment, and defense-adjacent automotive programs. (Phase 4 practitioner verification on specific Issue.)",
    },
    {
      label: "JIS / ISO documentation standards",
      description: "Japanese and international standards for technical documentation across global OEM programs.",
    },
    {
      label: "OEM-specific publishing standards",
      description: "Each OEM program carries its own conventions; engagements adapt to the program's actual requirements.",
    },
  ]}
  failureMode={{
    eyebrow: "AUTOMOTIVE / WARRANTY",
    heading: "A dealer service-manual error voids OEM warranty exposure.",
    body: "Claims liability moves from the dealer back to the manufacturer. A single procedure error, replicated across a service network, becomes a multi-million-dollar claim event. In safety-relevant cases, the same content failure pattern surfaces as a NHTSA-reportable defect — and the recall costs are an order of magnitude higher.",
  }}
  capabilityRelevance={[
    {
      pillarLabel: "Information Architecture",
      pillarHref: "/capabilities/information-architecture",
      context: "Vehicle-family and program-level content models. Conditional content for trim and market variation; integration architecture with parts catalog data.",
    },
    {
      pillarLabel: "Content Migration",
      pillarHref: "/capabilities/content-migration",
      context: "Often follows M&A or platform consolidation. Legacy estates converged onto a single CCMS; conversion handled at scale across vehicle programs.",
    },
    {
      pillarLabel: "CCMS & Publishing",
      pillarHref: "/capabilities/ccms-and-publishing",
      context: "Heavy in this vertical. Large OEMs run massive service-information libraries; CCMS configuration and publishing automation are operational backbone.",
    },
    {
      pillarLabel: "AI-Ready Content",
      pillarHref: "/capabilities/ai-ready-content",
      context: "Service-technician-facing AI assistants are an emerging use case. Retrieval over service-information estates requires the same engineering discipline as regulated-industry RAG.",
    },
  ]}
  industryLogos={[{ label: "Toyota" }]}
  caseStudies={[
    {
      framing: "A global automotive OEM consolidating dealer service information across 30+ markets.",
      body: "Single-source DITA across vehicle programs with conditional content for market and trim variants. CCMS-driven workflows replaced parallel publishing chains; translation savings drove the business case.",
    },
    {
      framing: "A heavy-equipment manufacturer migrating from FrameMaker to a DITA-based CCMS.",
      body: "Migration architecture surfaced systemic content-quality issues that had been masked by FrameMaker's flexibility. Publishing pipeline integrated with parts-catalog data; service-manual accuracy improved alongside cost-out.",
    },
  ]}
  stats={[
    {
      number: "72%",
      label: "Translation cost savings",
      context: "The largest single ROI lever in this vertical — localization volume drops proportionally with reuse.",
    },
    {
      number: "60%",
      label: "Faster publishing",
      context: "Service-information updates released continuously rather than batched per quarterly release.",
    },
  ]}
  ctaBody="Submit a 20-page service-information sample. We'll return a translation-savings assessment, conversion feasibility, and the architecture decisions that would shape a production migration. Two business days, no obligation to proceed."
/>
