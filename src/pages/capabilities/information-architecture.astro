---
import PillarPageLayout from "../../layouts/PillarPageLayout.astro";
---

<PillarPageLayout
  pillarId="ia"
  pillarHref="/capabilities/information-architecture"
  pageTitle="Information Architecture — Capabilities"
  pageDescription="Schema design, taxonomy, reuse strategy, and governance for structured documentation programs. The foundation that determines what every downstream system can do with your content."
  heroTitle="Information Architecture"
  heroSubdeck="The decisions you make about how content is structured determine what every downstream system can do with it. Schema, taxonomy, metadata, reuse — the foundation that pays back across every engagement."
  deliverables={[
    {
      label: "Content models",
      description: "DITA element architecture, S1000D data modules, custom DTDs where the standard doesn't fit.",
    },
    {
      label: "Taxonomies and controlled vocabularies",
      description: "Subject schemes, classification hierarchies, term governance.",
    },
    {
      label: "Metadata strategy",
      description: "Authoring metadata, retrieval metadata, audit metadata — designed once, applied throughout.",
    },
    {
      label: "Reuse strategy",
      description: "Conref, conkeyref, and conditional content patterns. The mechanics that turn 60-page IFUs into 18 reusable topics.",
    },
    {
      label: "Conditional content design",
      description: "Profiling attributes, audience filters, market variants — the architecture that handles regulatory or commercial variation cleanly.",
    },
    {
      label: "Governance documentation",
      description: "The runbook that lets your team maintain the architecture after the engagement closes.",
    },
  ]}
  phases={[
    {
      phase: "Discovery",
      body: "Stakeholder interviews, content audit, current-state IA assessment, use-case mapping. The IA pillar leads here — most failed migrations failed because Discovery was skipped.",
    },
    {
      phase: "Architecture",
      body: "Content model design (DITA, S1000D, custom DTDs), taxonomy design, metadata strategy, reuse strategy. This is where the IA pillar concentrates its primary execution load.",
    },
    {
      phase: "Migration",
      body: "IA validation through pilot conversion of representative content. The pilot surfaces architecture decisions that need adjustment before production conversion runs.",
    },
    {
      phase: "Implementation",
      body: "IA propagation across authoring tools, CCMS configuration, validation rules. The architecture becomes operational across the toolchain.",
    },
    {
      phase: "Enablement",
      body: "Governance handover, IA documentation, author orientation, ongoing model evolution as products and content needs change.",
    },
  ]}
  anchorStat={{
    number: "90%",
    label: "Reduction in documentation-driven support escalations",
    context: "When users find what they need on the first try, they don't open tickets.",
  }}
  bridgeProse="The connection from IA quality to support volume is direct. Bad IA produces content users can't find, can't follow, or can't trust — every one of which surfaces as a support ticket. Architecture quality is measurable in escalation volume; if support tickets are climbing, the IA is the upstream cause more often than the writing."
  standardsAndTooling={[
    {
      label: "DITA 1.3",
      description: "OASIS standard. Specializations and constraints designed for the client's content model.",
    },
    {
      label: "S1000D Issue 5.0 / 6.0",
      description: "Defense and aerospace data module specifications. Conformance for federal and commercial defense contracts.",
    },
    {
      label: "Custom DTDs and XSDs",
      description: "Where the standard doesn't fit, designed and validated against actual content.",
    },
    {
      label: "Authoring tools",
      description: "Oxygen XML Author for IA design and validation; CCMS-native authoring environments for production.",
    },
    {
      label: "Taxonomy management",
      description: "Subject scheme implementation across CCMS platforms; controlled vocabulary governance.",
    },
  ]}
  failureMode={{
    eyebrow: "WHEN IA IS WRONG",
    heading: "Bad architecture breaks every downstream investment.",
    body: "Failed migrations because there's no clean target to migrate to. Reuse that doesn't work because the granularity is wrong. RAG retrieving the wrong chunks because semantic boundaries weren't designed in. Translation that costs more every quarter because there's no separation of concerns. The architecture decisions get re-litigated in every phase that follows.",
  }}
  ctaBody="Submit a 20-page sample. We'll return a content-model fitness assessment — what the existing IA can support, what it can't, and what redesign would make possible. Two business days, no obligation to proceed."
/>
