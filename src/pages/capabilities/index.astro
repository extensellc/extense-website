---
/*
  /capabilities — integration story page.

  Spec ref: EXTENSE_DESIGN_BRIEF.md §8

  Distinct from / (which shows pillars in parallel, as part of universal argument)
  and from pillar pages (which go deep on one capability each). /capabilities
  serves the multi-pillar buyer with a transformation mandate.

  Section order (centerpiece-led):
    1. TopNav
    2. Hero (Hero.universal)
    3. PhaseWeightMatrix (load-bearing centerpiece) — with intro line in
       container-prose centered within the section's container-data
    4. Lifecycle narrative — methodology-as-narrative (3–5 paragraphs)
    5. Anonymized end-to-end case study — three subsections
    6. Engagement shape — compact structured list of engagement types
    7. Pivot to pillar pages (PillarCard × 4) — same component, routing role
    8. CTAModule (general toggle preset)
    9. Footer
*/

import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/site/Hero.astro";
import PhaseWeightMatrix from "../../components/site/PhaseWeightMatrix.astro";
import PillarCard from "../../components/site/PillarCard.astro";
import CTAModule from "../../components/site/CTAModule.astro";

const pillars = [
  {
    pillar: "ia" as const,
    name: "Information Architecture",
    scope: "The schema, taxonomy, and reuse strategy that determine what every downstream system can do.",
    href: "/capabilities/information-architecture",
  },
  {
    pillar: "migration" as const,
    name: "Content Migration",
    scope: "The recovery operation. Convert legacy content into reusable assets at the start of any modernization.",
    href: "/capabilities/content-migration",
  },
  {
    pillar: "ccms" as const,
    name: "CCMS & Publishing",
    scope: "The operating system plus the CI/CD that makes structured content pay back daily.",
    href: "/capabilities/ccms-and-publishing",
  },
  {
    pillar: "ai-ready" as const,
    name: "AI-Ready Content",
    scope: "The translation layer between structured documentation and the AI systems that consume it.",
    href: "/capabilities/ai-ready-content",
  },
];

// Engagement-shape items — actuals come from Phase 4 practitioner session.
const engagementShapes = [
  {
    label: "Single-pillar engagement",
    body: "Specific scope: one pillar deep. Common when the client knows the problem (CCMS replacement, IA refactor, RAG enablement) and wants targeted execution.",
  },
  {
    label: "Multi-pillar transformation program",
    body: "End-to-end: IA + Migration + CCMS + AI-Ready, sequenced across the lifecycle. Common when the program is a content-modernization mandate.",
  },
  {
    label: "Discovery + Architecture only",
    body: "Assessment-shaped engagement. Surface the constraints, design the target schema and content model, leave implementation to internal teams or other vendors.",
  },
  {
    label: "Ongoing support and enablement",
    body: "Continuing engagement after initial implementation. Author training, governance, runbook maintenance, content-model evolution as products change.",
  },
];
---

<BaseLayout
  title="Capabilities — Four Capabilities, One Lifecycle"
  description="Extense LLC capability integration: information architecture, content migration, CCMS & publishing, and AI-ready content engineering. How phases concentrate and overlap when multiple pillars are in scope."
>
  <Hero
    variant="universal"
    title="Four capabilities. One lifecycle."
    subdeck="End-to-end content engineering across information architecture, migration, CCMS implementation, and AI-ready retrieval. Most engagements move through more than one pillar."
  />

  <section class="cap-section cap-section--matrix" aria-labelledby="matrix-heading">
    <div class="container-data cap-section__inner">
      <div class="cap-section__matrix-intro">
        <p class="cap-section__intro-text">
          Each pillar concentrates work in different methodology phases. The shape of an Extense engagement is how those distributions overlap.
        </p>
      </div>
      <h2 id="matrix-heading" class="sr-only">Pillar work distribution across methodology phases</h2>
      <PhaseWeightMatrix />
    </div>
  </section>

  <section class="cap-section cap-section--narrative" aria-labelledby="narrative-heading">
    <div class="container-prose cap-section__inner">
      <h2 id="narrative-heading" class="cap-section__heading">How an engagement moves through the lifecycle.</h2>
      <div class="cap-section__prose">
        <p>
          IA work concentrates early, but it never fully closes. The decisions made in Architecture — schema design, taxonomy, reuse strategy — surface as constraints during Migration, configurations during Implementation, and retrieval boundaries during AI enablement. When IA is right, downstream phases inherit a foundation that holds. When it isn't, the same work has to be re-litigated in every phase.
        </p>
        <p>
          Migration work depends on Architecture decisions made in IA. The conversion engine is only as good as the target schema it's converting toward — and most failed migrations failed because the target was unspecified or wrong before the first batch ran. The Migration phase carries the heaviest production load, but Architecture carries serious load too.
        </p>
        <p>
          CCMS Implementation requires Architecture decisions made during Migration. The content model that lands in the CCMS shapes workflows, permissions, publishing pipelines. Get the IA wrong and the CCMS configuration fights the authors. Get the Migration wrong and the CCMS launches with the same authoring problems the legacy system had.
        </p>
        <p>
          AI-Ready Architecture often runs in parallel with CCMS Architecture, not after. Chunking strategy, metadata schema, and retrieval architecture are content-engineering decisions that interact with the CCMS configuration; they shouldn't be retrofitted. The most successful AI deployments are the ones where the content was engineered for retrieval before the model was selected.
        </p>
        <p>
          Enablement runs through every phase, not at the end. Discovery teaches the practitioner how the program works today. Architecture documentation becomes the team's runbook. Migration training transitions authors. CCMS rollout becomes the operating manual. AI-Ready evaluation becomes ongoing tuning. The handover isn't a phase — it's a discipline.
        </p>
      </div>
    </div>
  </section>

  <section class="cap-section cap-section--case-study" aria-labelledby="case-study-heading">
    <div class="container-prose cap-section__inner">
      <h2 id="case-study-heading" class="cap-section__heading">An end-to-end engagement.</h2>
      <p class="cap-section__case-frame">
        A Class III medical device manufacturer consolidating regulatory documentation across global markets, migrating from FrameMaker to a DITA-based CCMS with RAG enablement on top.
      </p>

      <div class="cap-section__case-section">
        <h3 class="cap-section__case-h3">The situation</h3>
        <p class="cap-section__case-body">
          Decades of FrameMaker IFUs across multiple device families, each with regulatory variants for FDA, EU, Australia, and dozens of additional markets. Translation costs trending upward year-over-year. A new AI-assisted compliance assistant initiative running into recall-risk concerns because the content estate couldn't be cleanly retrieved. Documentation team running parallel workflows that weren't sustainable.
        </p>
      </div>

      <div class="cap-section__case-section">
        <h3 class="cap-section__case-h3">The work</h3>
        <p class="cap-section__case-body">
          IA design first: device-family content model with regulatory-variant profiling, controlled vocabulary aligned to MedDRA, reuse strategy across IFUs and labels. Migration phase converted legacy FrameMaker estate to clean DITA at scale, with a QA harness that surfaced pre-existing content errors as part of the migration. CCMS implementation deployed configured workflows for regulated authoring. AI-Ready phase architected chunking and metadata for the compliance assistant pipeline, with retrieval evaluation against representative queries before model deployment.
        </p>
      </div>

      <div class="cap-section__case-section">
        <h3 class="cap-section__case-h3">The outcome</h3>
        <p class="cap-section__case-body">
          Material translation savings on subsequent regulatory submissions. Faster publishing across markets via CI/CD-driven build pipelines. Compliance assistant deployed against a content estate engineered for retrieval, rather than retrofitted afterward. Documentation team operating a single source rather than parallel workflows.
        </p>
        <p class="cap-section__case-note">
          Anonymized for client confidentiality. Specific scope, contract details, and named outcomes available under appropriate NDA channels.
        </p>
      </div>
    </div>
  </section>

  <section class="cap-section cap-section--engagement-shape" aria-labelledby="engagement-shape-heading">
    <div class="container-prose cap-section__inner">
      <h2 id="engagement-shape-heading" class="cap-section__heading">How engagements are scoped.</h2>
      <dl class="cap-section__shape-list">
        {engagementShapes.map((s) => (
          <div class="cap-section__shape-item">
            <dt class="cap-section__shape-label">{s.label}</dt>
            <dd class="cap-section__shape-body">{s.body}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <section class="cap-section cap-section--pillar-pivot" aria-labelledby="pillar-pivot-heading">
    <div class="container-data cap-section__inner">
      <h2 id="pillar-pivot-heading" class="cap-section__heading">Go deeper on a single pillar.</h2>
      <div class="cap-section__pillar-grid">
        {pillars.map((p) => (
          <PillarCard pillar={p.pillar} name={p.name} scope={p.scope} href={p.href} />
        ))}
      </div>
    </div>
  </section>

  <CTAModule
    audience="general"
    body="Submit a 20-page sample. We'll return conversion feasibility, content recovery rate, and engineering effort within two business days. The analysis is the basis for any engagement scope, single-pillar through full lifecycle."
  />
</BaseLayout>

<style>
  .cap-section {
    padding-top: var(--section-pad-default);
    padding-bottom: var(--section-pad-default);
  }

  @media (max-width: 767px) {
    .cap-section {
      padding-top: var(--space-16);
      padding-bottom: var(--space-16);
    }
  }

  .cap-section--matrix {
    padding-top: var(--section-pad-emphasis);
    padding-bottom: var(--section-pad-emphasis);
  }

  @media (max-width: 767px) {
    .cap-section--matrix {
      padding-top: var(--space-20);
      padding-bottom: var(--space-20);
    }
  }

  .cap-section__matrix-intro {
    max-width: var(--container-prose);
    margin-left: auto;
    margin-right: auto;
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .cap-section__intro-text {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    font-weight: var(--weight-regular);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    text-wrap: balance;
  }

  .cap-section__heading {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin-bottom: var(--space-8);
    text-wrap: balance;
  }

  .cap-section__prose p {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    text-wrap: pretty;
  }

  .cap-section__prose p + p {
    margin-top: var(--space-6);
  }

  .cap-section__case-frame {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-12);
    font-style: italic;
    text-wrap: pretty;
  }

  .cap-section__case-section {
    margin-bottom: var(--space-8);
  }

  .cap-section__case-section:last-child {
    margin-bottom: 0;
  }

  .cap-section__case-h3 {
    font-family: var(--font-display);
    font-size: var(--text-display-md);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    color: var(--color-text-primary);
    margin-bottom: var(--space-3);
  }

  .cap-section__case-body {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    text-wrap: pretty;
  }

  .cap-section__case-note {
    margin-top: var(--space-3);
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    font-style: italic;
  }

  .cap-section__shape-list {
    margin: 0;
    padding: 0;
  }

  .cap-section__shape-item {
    padding-top: var(--space-6);
    padding-bottom: var(--space-6);
    border-top: var(--border-hairline);
  }

  .cap-section__shape-item:last-child {
    border-bottom: var(--border-hairline);
  }

  .cap-section__shape-label {
    font-family: var(--font-body);
    font-size: var(--text-body);
    font-weight: var(--weight-semibold);
    color: var(--color-text-primary);
    margin-bottom: var(--space-2);
  }

  .cap-section__shape-body {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin: 0;
    text-wrap: pretty;
  }

  .cap-section__pillar-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    margin-top: var(--space-12);
  }

  @media (min-width: 600px) {
    .cap-section__pillar-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-8);
    }
  }

  @media (min-width: 1024px) {
    .cap-section__pillar-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-8);
    }
  }
</style>
