---
/*
  /insights/[slug] — individual post page.

  Renders a single insights post as long-form content within container-prose.
  Hero section uses post title and meta; main body renders the markdown content.

  Phase 4 directive: post bodies are placeholder structural shells until the
  practitioner-led editorial production replaces them. Body markdown handled
  by Astro's content collection rendering.
*/

import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/site/Hero.astro";
import CTAModule from "../../components/site/CTAModule.astro";

export async function getStaticPaths() {
  const posts = await getCollection("insights", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const dateLabel = post.data.publishedAt.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title={post.data.title} description={post.data.summary}>
  <Hero
    variant="universal"
    title={post.data.title}
    subdeck={post.data.summary}
    eyebrow={post.data.topic}
  />

  <section class="post-section">
    <div class="container-prose post-section__inner">
      <div class="post-section__meta">
        <time datetime={post.data.publishedAt.toISOString()}>{dateLabel}</time>
        <span class="post-section__sep" aria-hidden="true">·</span>
        <span>{post.data.readingTime}</span>
      </div>

      <article class="post-section__article prose">
        <Content />
      </article>

      <div class="post-section__back">
        <a href="/insights" class="post-section__back-link">
          ← Back to all insights
        </a>
      </div>
    </div>
  </section>

  <CTAModule
    audience="general"
    body="Submit a 20-page sample. We'll return conversion feasibility, content recovery rate, and engineering effort within two business days. The analysis is the basis for any further engagement, with no obligation to proceed."
  />
</BaseLayout>

<style>
  .post-section {
    padding-top: var(--space-12);
    padding-bottom: var(--section-pad-default);
  }

  @media (max-width: 767px) {
    .post-section {
      padding-bottom: var(--space-16);
    }
  }

  .post-section__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: baseline;
    font-family: var(--font-body);
    font-size: var(--text-caption);
    color: var(--color-text-muted);
    margin-bottom: var(--space-12);
  }

  .post-section__sep {
    color: var(--color-text-muted);
  }

  .post-section__article {
    /* Long-form prose styling — see :global(.prose) below */
  }

  .post-section__back {
    margin-top: var(--space-16);
    padding-top: var(--space-8);
    border-top: var(--border-hairline);
  }

  .post-section__back-link {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    font-weight: var(--weight-medium);
    color: var(--color-link);
    text-decoration: none;
  }

  .post-section__back-link:hover,
  .post-section__back-link:focus-visible {
    color: var(--color-link-hover);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }

  /* .prose styles defined in global.css — applied to .post-section__article */
</style>
