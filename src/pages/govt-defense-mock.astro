---
/*
  TEMP / govt-defense-mock — three hero-visual candidates for
  /industries/government-and-defense.

  Each option renders the live Hero component with the planned [DRAFT] H1 +
  paired civilian/defense subdeck so the side visuals can be judged in their
  final context. Pick one in-browser; build the real page with the chosen
  visual and `git rm` this file. Unlinked from nav.

  A — Architecture pipeline: DM types → CSDB → IETP.
  B — Three-pillar convergence: <dmodule> / <applic> / <brex> → extense.s1000d → <ietp>.
  C — One source, many outputs: <dmodule> → PDF / IETM / training / XML.
*/

import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/site/Hero.astro";

const HERO_TITLE = "Government Agencies & Defense";
const HERO_SUBDECK = "Mission-critical S1000D, MIL-STD, and ITAR-compliant technical documentation — engineered for interoperability between OEMs, suppliers, and the armed forces. Federal civilian agency content modernization — Section 508-conformant, records-management compliant, and engineered to agency publishing standards.";
---

<BaseLayout
  title="G&D hero mockups — Extense LLC"
  description="Internal mockup page. Three hero-visual candidates for /industries/government-and-defense."
>
  <section class="gdm-banner">
    <div class="container-page">
      <p class="gdm-banner__label">GOVT &amp; DEFENSE HERO MOCK · PICK ONE</p>
      <nav class="gdm-banner__nav" aria-label="Mock options">
        <a href="#opt-a">A · Architecture pipeline</a>
        <a href="#opt-b">B · Three-pillar convergence</a>
        <a href="#opt-c">C · One source, many outputs</a>
        <a href="#opt-d">D · Two-register convergence</a>
        <a href="#opt-e">E · Two parallel pipelines</a>
      </nav>
    </div>
  </section>

  {/* ────────────── OPTION A ────────────── */}
  <section class="gdm-option" id="opt-a">
    <div class="container-page">
      <h2 class="gdm-option__heading">Option A — Architecture pipeline</h2>
      <p class="gdm-option__note">
        Four DM types feeding through the CSDB into the IETP build. Argues the
        S1000D <em>system</em> — source-of-truth modules → managed library →
        published interactive technical publication.
      </p>
    </div>
    <Hero variant="universal" title={HERO_TITLE} subdeck={HERO_SUBDECK}>
      <svg
        class="mock-svg mock-a"
        id="mock-a"
        viewBox="0 0 560 320"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        role="presentation"
      >
        <g class="corner--accent fx" style="--d: 0ms">
          <path d="M 12 24 L 12 12 L 24 12" />
          <path d="M 536 12 L 548 12 L 548 24" />
          <path d="M 12 296 L 12 308 L 24 308" />
          <path d="M 536 308 L 548 308 L 548 296" />
        </g>

        <text class="chrome fx" x="30" y="30" style="--d: 80ms">in :: s1000d.architecture</text>

        {/* Stage captions */}
        <text class="stage-caption fx" x="90"  y="62" text-anchor="middle" style="--d: 160ms">DATA MODULES</text>
        <text class="stage-caption fx" x="280" y="62" text-anchor="middle" style="--d: 200ms">CSDB</text>
        <text class="stage-caption fx" x="470" y="62" text-anchor="middle" style="--d: 240ms">IETP</text>

        {/* Left column: 4 DM type chips (soft-dashed) */}
        <g class="fx" style="--d: 320ms">
          <rect class="node node--soft" x="20" y="84" width="140" height="32" rx="3" />
          <text class="dm-label" x="34" y="105">&lt;procedure&gt;</text>
        </g>
        <g class="fx" style="--d: 380ms">
          <rect class="node node--soft" x="20" y="124" width="140" height="32" rx="3" />
          <text class="dm-label" x="34" y="145">&lt;description&gt;</text>
        </g>
        <g class="fx" style="--d: 440ms">
          <rect class="node node--soft" x="20" y="164" width="140" height="32" rx="3" />
          <text class="dm-label" x="34" y="185">&lt;illustration&gt;</text>
        </g>
        <g class="fx" style="--d: 500ms">
          <rect class="node node--soft" x="20" y="204" width="140" height="32" rx="3" />
          <text class="dm-label" x="34" y="225">&lt;faultIsolation&gt;</text>
        </g>

        {/* Convergent connectors: 4 DM chips → CSDB chip */}
        <path class="flow-conn" style="--d: 580ms" d="M 160 100 L 210 170" />
        <path class="flow-conn" style="--d: 580ms" d="M 160 140 L 210 170" />
        <path class="flow-conn" style="--d: 580ms" d="M 160 180 L 210 170" />
        <path class="flow-conn" style="--d: 580ms" d="M 160 220 L 210 170" />

        {/* CSDB chip (center, custom amber) */}
        <g class="fx" style="--d: 700ms">
          <rect class="node node--custom" x="210" y="138" width="140" height="64" rx="3" />
          <rect class="artifact-strip" x="210" y="138" width="140" height="6" />
          <text class="node-label node-label--custom" x="280" y="174" text-anchor="middle">&lt;csdb&gt;</text>
          <text class="node-caption" x="280" y="192" text-anchor="middle">extense.s1000d</text>
        </g>

        {/* Connector CSDB → IETP */}
        <path class="flow-conn" style="--d: 820ms" d="M 350 170 L 395 170 M 390 165 L 395 170 L 390 175" />

        {/* IETP chip (right, custom amber) */}
        <g class="fx" style="--d: 900ms">
          <rect class="node node--custom" x="400" y="138" width="140" height="64" rx="3" />
          <rect class="artifact-strip" x="400" y="138" width="140" height="6" />
          <text class="node-label node-label--custom" x="470" y="174" text-anchor="middle">&lt;ietp&gt;</text>
          <text class="node-caption" x="470" y="192" text-anchor="middle">interactive tech pub</text>
        </g>

        {/* Bottom chrome */}
        <g class="fx" style="--d: 1040ms">
          <line class="chrome-rule" x1="30" y1="286" x2="530" y2="286" />
          <rect class="build-dot" x="32" y="296" width="6" height="6" />
          <text class="chrome chrome--strong" x="46"  y="302">FIG. A</text>
          <text class="chrome"               x="92"  y="302">/</text>
          <text class="chrome chrome--strong" x="100" y="302">s1000d.architecture</text>
          <text class="chrome chrome--strong" x="530" y="302" text-anchor="end">DM &rarr; CSDB &rarr; IETP</text>
        </g>
      </svg>
    </Hero>
  </section>

  {/* ────────────── OPTION B ────────────── */}
  <section class="gdm-option" id="opt-b">
    <div class="container-page">
      <h2 class="gdm-option__heading">Option B — Three-pillar convergence</h2>
      <p class="gdm-option__note">
        Three S1000D engineering layers (modules, applicability, business
        rules) converging into one practice, with the IETP as the governed
        output. Same idiom as the XML-engineering hero, specialized for S1000D.
      </p>
    </div>
    <Hero variant="universal" title={HERO_TITLE} subdeck={HERO_SUBDECK}>
      <svg
        class="mock-svg mock-b"
        id="mock-b"
        viewBox="0 0 560 320"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        role="presentation"
      >
        <g class="corner--accent fx" style="--d: 0ms">
          <path d="M 12 24 L 12 12 L 24 12" />
          <path d="M 536 12 L 548 12 L 548 24" />
          <path d="M 12 296 L 12 308 L 24 308" />
          <path d="M 536 308 L 548 308 L 548 296" />
        </g>

        <text class="chrome fx" x="30" y="30" style="--d: 80ms">in :: s1000d.engineering</text>

        {/* Three pillar chips at top */}
        <g class="fx" style="--d: 200ms">
          <rect class="node node--custom" x="40" y="56" width="140" height="34" rx="3" />
          <text class="node-label node-label--custom" x="110" y="78" text-anchor="middle">&lt;dmodule&gt;</text>
        </g>
        <g class="fx" style="--d: 280ms">
          <rect class="node node--custom" x="210" y="56" width="140" height="34" rx="3" />
          <text class="node-label node-label--custom" x="280" y="78" text-anchor="middle">&lt;applic&gt;</text>
        </g>
        <g class="fx" style="--d: 360ms">
          <rect class="node node--custom" x="380" y="56" width="140" height="34" rx="3" />
          <text class="node-label node-label--custom" x="450" y="78" text-anchor="middle">&lt;brex&gt;</text>
        </g>

        {/* Convergent connectors → center S1000D chip */}
        <path class="flow-conn" style="--d: 460ms" d="M 110 90 L 280 178" />
        <path class="flow-conn" style="--d: 500ms" d="M 280 90 L 280 178" />
        <path class="flow-conn" style="--d: 540ms" d="M 450 90 L 280 178" />

        {/* Raw <ietp> (left, soft-dashed) */}
        <g class="fx" style="--d: 660ms">
          <rect class="node node--soft" x="24" y="178" width="130" height="44" rx="3" />
          <text class="node-label label--muted" x="89" y="205" text-anchor="middle">&lt;ietp&gt;</text>
          <text class="node-caption" x="89" y="240" text-anchor="middle">raw / ungoverned</text>
        </g>

        {/* Center S1000D chip */}
        <g class="fx" style="--d: 740ms">
          <rect class="node node--custom" x="190" y="178" width="180" height="44" rx="3" />
          <rect class="artifact-strip" x="190" y="178" width="180" height="6" />
          <text class="node-label node-label--custom" x="280" y="208" text-anchor="middle">extense.s1000d</text>
        </g>

        {/* Connector raw → center */}
        <path class="flow-conn" style="--d: 820ms" d="M 154 200 L 190 200 M 185 195 L 190 200 L 185 205" />

        {/* Governed <ietp> (right, custom amber) */}
        <g class="fx" style="--d: 920ms">
          <rect class="node node--custom" x="406" y="178" width="130" height="44" rx="3" />
          <text class="node-label node-label--custom" x="471" y="205" text-anchor="middle">&lt;ietp&gt;</text>
          <text class="node-caption" x="471" y="240" text-anchor="middle">governed</text>
        </g>

        {/* Connector center → governed */}
        <path class="flow-conn" style="--d: 1000ms" d="M 370 200 L 406 200 M 401 195 L 406 200 L 401 205" />

        {/* Bottom chrome */}
        <g class="fx" style="--d: 1140ms">
          <line class="chrome-rule" x1="30" y1="286" x2="530" y2="286" />
          <rect class="build-dot" x="32" y="296" width="6" height="6" />
          <text class="chrome chrome--strong" x="46"  y="302">FIG. B</text>
          <text class="chrome"               x="92"  y="302">/</text>
          <text class="chrome chrome--strong" x="100" y="302">s1000d.engineering</text>
          <text class="chrome chrome--strong" x="530" y="302" text-anchor="end">3 LAYERS &rarr; 1 PRACTICE</text>
        </g>
      </svg>
    </Hero>
  </section>

  {/* ────────────── OPTION C ────────────── */}
  <section class="gdm-option" id="opt-c">
    <div class="container-page">
      <h2 class="gdm-option__heading">Option C — One source, many outputs</h2>
      <p class="gdm-option__note">
        Central <code>&lt;dmodule&gt;</code> with radial fan to four defense
        output formats (PDF tech manual, IETM, training, XML data exchange).
        Emphasizes single-source reuse — the publishing-engineering idiom,
        specialized for defense outputs.
      </p>
    </div>
    <Hero variant="universal" title={HERO_TITLE} subdeck={HERO_SUBDECK}>
      <svg
        class="mock-svg mock-c"
        id="mock-c"
        viewBox="0 0 560 320"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        role="presentation"
      >
        <g class="corner--accent fx" style="--d: 0ms">
          <path d="M 12 24 L 12 12 L 24 12" />
          <path d="M 536 12 L 548 12 L 548 24" />
          <path d="M 12 296 L 12 308 L 24 308" />
          <path d="M 536 308 L 548 308 L 548 296" />
        </g>

        <text class="chrome fx" x="30" y="30" style="--d: 80ms">in :: s1000d.reuse</text>

        {/* Center <dmodule> chip */}
        <g class="fx" style="--d: 200ms">
          <rect class="node node--custom" x="210" y="125" width="140" height="90" rx="3" />
          <rect class="artifact-strip" x="210" y="125" width="140" height="6" />
          <text class="node-label node-label--custom" x="280" y="158" text-anchor="middle">&lt;dmodule&gt;</text>
          <line class="artifact-rule" x1="226" y1="170" x2="334" y2="170" />
          <text class="node-caption" x="280" y="186" text-anchor="middle">single source</text>
          <text class="node-caption" x="280" y="202" text-anchor="middle">extense.s1000d</text>
        </g>

        {/* Radial connectors: from <dmodule> to 4 outputs */}
        <path class="flow-conn" style="--d: 380ms" d="M 210 145 L 110 80" />
        <path class="flow-conn" style="--d: 440ms" d="M 210 195 L 110 270" />
        <path class="flow-conn" style="--d: 380ms" d="M 350 145 L 450 80" />
        <path class="flow-conn" style="--d: 440ms" d="M 350 195 L 450 270" />

        {/* Four output labels (custom amber chips) */}
        <g class="fx" style="--d: 580ms">
          <rect class="node node--custom" x="20" y="62" width="100" height="34" rx="3" />
          <text class="node-label node-label--custom" x="70" y="84" text-anchor="middle">PDF · TM</text>
        </g>
        <g class="fx" style="--d: 640ms">
          <rect class="node node--custom" x="440" y="62" width="100" height="34" rx="3" />
          <text class="node-label node-label--custom" x="490" y="84" text-anchor="middle">IETM</text>
        </g>
        <g class="fx" style="--d: 700ms">
          <rect class="node node--custom" x="20" y="252" width="100" height="34" rx="3" />
          <text class="node-label node-label--custom" x="70" y="274" text-anchor="middle">TRAINING</text>
        </g>
        <g class="fx" style="--d: 760ms">
          <rect class="node node--custom" x="440" y="252" width="100" height="34" rx="3" />
          <text class="node-label node-label--custom" x="490" y="274" text-anchor="middle">XML EXCH.</text>
        </g>

        {/* Bottom chrome */}
        <g class="fx" style="--d: 920ms">
          <line class="chrome-rule" x1="30" y1="318" x2="530" y2="318" opacity="0" />
        </g>
        <g class="fx" style="--d: 920ms">
          <rect class="build-dot" x="32" y="296" width="6" height="6" />
          <text class="chrome chrome--strong" x="46"  y="302">FIG. C</text>
          <text class="chrome"               x="92"  y="302">/</text>
          <text class="chrome chrome--strong" x="100" y="302">s1000d.reuse</text>
          <text class="chrome chrome--strong" x="530" y="302" text-anchor="end">ONE SOURCE &rarr; MANY OUTPUTS</text>
        </g>
      </svg>
    </Hero>
  </section>

  {/* ────────────── OPTION D ────────────── */}
  <section class="gdm-option" id="opt-d">
    <div class="container-page">
      <h2 class="gdm-option__heading">Option D — Two-register convergence</h2>
      <p class="gdm-option__note">
        Three defense pillars (<code>&lt;dmodule&gt;</code> / <code>&lt;applic&gt;</code> /
        <code>&lt;brex&gt;</code>) and three civilian standards (SECTION 508 /
        TITLE 44 / AGENCY STD) converging into one engineering practice.
        Literal rendering of the page thesis — both registers on screen,
        equal weight.
      </p>
    </div>
    <Hero variant="universal" title={HERO_TITLE} subdeck={HERO_SUBDECK}>
      <svg
        class="mock-svg mock-d"
        id="mock-d"
        viewBox="0 0 560 320"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        role="presentation"
      >
        <g class="corner--accent fx" style="--d: 0ms">
          <path d="M 12 24 L 12 12 L 24 12" />
          <path d="M 536 12 L 548 12 L 548 24" />
          <path d="M 12 296 L 12 308 L 24 308" />
          <path d="M 536 308 L 548 308 L 548 296" />
        </g>

        <text class="chrome fx" x="30" y="30" style="--d: 80ms">in :: gov.compliance</text>

        {/* Register captions */}
        <text class="stage-caption fx" x="90"  y="58" text-anchor="middle" style="--d: 160ms">DEFENSE</text>
        <text class="stage-caption fx" x="470" y="58" text-anchor="middle" style="--d: 200ms">CIVILIAN</text>

        {/* Defense pillars (left, custom amber) */}
        <g class="fx" style="--d: 280ms">
          <rect class="node node--custom" x="20" y="72" width="140" height="32" rx="3" />
          <text class="node-label node-label--custom" x="90" y="93" text-anchor="middle">&lt;dmodule&gt;</text>
        </g>
        <g class="fx" style="--d: 340ms">
          <rect class="node node--custom" x="20" y="112" width="140" height="32" rx="3" />
          <text class="node-label node-label--custom" x="90" y="133" text-anchor="middle">&lt;applic&gt;</text>
        </g>
        <g class="fx" style="--d: 400ms">
          <rect class="node node--custom" x="20" y="152" width="140" height="32" rx="3" />
          <text class="node-label node-label--custom" x="90" y="173" text-anchor="middle">&lt;brex&gt;</text>
        </g>

        {/* Civilian pillars (right, custom amber) */}
        <g class="fx" style="--d: 320ms">
          <rect class="node node--custom" x="400" y="72" width="140" height="32" rx="3" />
          <text class="node-label node-label--custom" x="470" y="93" text-anchor="middle">SECTION 508</text>
        </g>
        <g class="fx" style="--d: 380ms">
          <rect class="node node--custom" x="400" y="112" width="140" height="32" rx="3" />
          <text class="node-label node-label--custom" x="470" y="133" text-anchor="middle">TITLE 44</text>
        </g>
        <g class="fx" style="--d: 440ms">
          <rect class="node node--custom" x="400" y="152" width="140" height="32" rx="3" />
          <text class="node-label node-label--custom" x="470" y="173" text-anchor="middle">AGENCY STD</text>
        </g>

        {/* 6 convergent connectors -> central chip top edge */}
        <path class="flow-conn" style="--d: 540ms" d="M 160 88  L 220 212" />
        <path class="flow-conn" style="--d: 580ms" d="M 160 128 L 240 212" />
        <path class="flow-conn" style="--d: 620ms" d="M 160 168 L 260 212" />
        <path class="flow-conn" style="--d: 540ms" d="M 400 88  L 340 212" />
        <path class="flow-conn" style="--d: 580ms" d="M 400 128 L 320 212" />
        <path class="flow-conn" style="--d: 620ms" d="M 400 168 L 300 212" />

        {/* Central chip */}
        <g class="fx" style="--d: 720ms">
          <rect class="node node--custom" x="190" y="210" width="180" height="46" rx="3" />
          <rect class="artifact-strip" x="190" y="210" width="180" height="6" />
          <text class="node-label node-label--custom" x="280" y="240" text-anchor="middle">extense.gov-docs</text>
        </g>

        {/* ONE PRACTICE caption below chip */}
        <text class="node-caption fx" x="280" y="274" text-anchor="middle" style="--d: 840ms">ONE PRACTICE</text>

        {/* Bottom chrome */}
        <g class="fx" style="--d: 980ms">
          <line class="chrome-rule" x1="30" y1="286" x2="530" y2="286" />
          <rect class="build-dot" x="32" y="296" width="6" height="6" />
          <text class="chrome chrome--strong" x="46"  y="302">FIG. D</text>
          <text class="chrome"               x="92"  y="302">/</text>
          <text class="chrome chrome--strong" x="100" y="302">gov.compliance</text>
          <text class="chrome chrome--strong" x="530" y="302" text-anchor="end">2 REGISTERS &rarr; 1 PRACTICE</text>
        </g>
      </svg>
    </Hero>
  </section>

  {/* ────────────── OPTION E ────────────── */}
  <section class="gdm-option" id="opt-e">
    <div class="container-page">
      <h2 class="gdm-option__heading">Option E — Two parallel pipelines</h2>
      <p class="gdm-option__note">
        Two parallel horizontal pipelines under one practice. Defense rail:
        <code>&lt;dmodule&gt;</code> → <code>&lt;csdb&gt;</code> →
        <code>&lt;ietp&gt;</code>. Civilian rail: SECTION 508 → AGENCY PUB →
        FED. REGISTER. Argues the flow rather than the discipline.
      </p>
    </div>
    <Hero variant="universal" title={HERO_TITLE} subdeck={HERO_SUBDECK}>
      <svg
        class="mock-svg mock-e"
        id="mock-e"
        viewBox="0 0 560 320"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        role="presentation"
      >
        <g class="corner--accent fx" style="--d: 0ms">
          <path d="M 12 24 L 12 12 L 24 12" />
          <path d="M 536 12 L 548 12 L 548 24" />
          <path d="M 12 296 L 12 308 L 24 308" />
          <path d="M 536 308 L 548 308 L 548 296" />
        </g>

        <text class="chrome fx" x="30" y="30" style="--d: 80ms">in :: gov.pipelines</text>

        {/* Row labels */}
        <text class="stage-caption fx" x="70" y="135" text-anchor="middle" style="--d: 160ms">DEFENSE</text>
        <text class="stage-caption fx" x="70" y="215" text-anchor="middle" style="--d: 200ms">CIVILIAN</text>

        {/* Defense rail */}
        <g class="fx" style="--d: 240ms">
          <rect class="node node--custom" x="130" y="110" width="110" height="40" rx="3" />
          <text class="node-label node-label--custom" x="185" y="135" text-anchor="middle">&lt;dmodule&gt;</text>
        </g>
        <path class="flow-conn" style="--d: 320ms" d="M 240 130 L 270 130 M 265 125 L 270 130 L 265 135" />
        <g class="fx" style="--d: 360ms">
          <rect class="node node--custom" x="270" y="110" width="110" height="40" rx="3" />
          <text class="node-label node-label--custom" x="325" y="135" text-anchor="middle">&lt;csdb&gt;</text>
        </g>
        <path class="flow-conn" style="--d: 440ms" d="M 380 130 L 410 130 M 405 125 L 410 130 L 405 135" />
        <g class="fx" style="--d: 480ms">
          <rect class="node node--custom" x="410" y="110" width="110" height="40" rx="3" />
          <text class="node-label node-label--custom" x="465" y="135" text-anchor="middle">&lt;ietp&gt;</text>
        </g>

        {/* Civilian rail */}
        <g class="fx" style="--d: 280ms">
          <rect class="node node--custom" x="130" y="190" width="110" height="40" rx="3" />
          <text class="node-label node-label--custom" x="185" y="215" text-anchor="middle">SECTION 508</text>
        </g>
        <path class="flow-conn" style="--d: 360ms" d="M 240 210 L 270 210 M 265 205 L 270 210 L 265 215" />
        <g class="fx" style="--d: 400ms">
          <rect class="node node--custom" x="270" y="190" width="110" height="40" rx="3" />
          <text class="node-label node-label--custom" x="325" y="215" text-anchor="middle">AGENCY PUB</text>
        </g>
        <path class="flow-conn" style="--d: 480ms" d="M 380 210 L 410 210 M 405 205 L 410 210 L 405 215" />
        <g class="fx" style="--d: 520ms">
          <rect class="node node--custom" x="410" y="190" width="110" height="40" rx="3" />
