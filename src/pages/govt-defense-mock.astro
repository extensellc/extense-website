  /* ─── Animation (shared) ─── */
  .mock-svg .fx {
    opacity: 0;
  }
  .mock-svg.drawn .fx {
    animation: gdm-fade 360ms ease-out forwards;
    animation-delay: var(--d, 0ms);
  }
  .mock-svg.drawn .flow-conn {
    animation: gdm-draw 620ms ease-out forwards;
    animation-delay: var(--d, 0ms);
  }
  @keyframes gdm-fade {
    to { opacity: 1; }
  }
  @keyframes gdm-draw {
    to { stroke-dashoffset: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .mock-svg .fx {
      opacity: 1 !important;
      animation: none !important;
    }
    .mock-svg .flow-conn {
      stroke-dashoffset: 0 !important;
      animation: none !important;
    }
  }
</style>

<script>
  function setupMocks() {
    const svgs = document.querySelectorAll(".mock-svg");
    if (svgs.length === 0) return;
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("drawn");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );
    svgs.forEach((svg) => observer.observe(svg));
  }
  document.addEventListener("DOMContentLoaded", setupMocks);
</script>
