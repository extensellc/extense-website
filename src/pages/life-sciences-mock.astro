---
/*
  TEMP / life-sciences-mock — three hero-visual candidates for
  /industries/life-sciences.

  Each option renders the live Hero component with [OLD] H1
  ("Life Sciences & Pharma") + [OLD] subdeck so the side visuals can be
  judged in their final context. Pick one in-browser; build the real page
  with the chosen visual and `git rm` this file. Unlinked from nav.

  A — Multi-market submission fan: <content> → 4 regulators
      (FDA · eCTD M3, EMA · NeeS/eCTD, PMDA · JP, TGA · AU).
  B — IFU translation propagation: <ifu> + Δ change event → translation
      layer → 5 language chips + "+25 more" overflow indicator.
  C — Component reuse + audit: <component> → 21 CFR Part 11 audit band →
      4 deliverables (IFU · SPL · CSR · Module 3).
*/

import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/site/Hero.astro";

const HERO_TITLE = "Life Sciences & Pharma";
const HERO_SUBDECK = "Structured content management for FDA, EMA, and MDR compliance — where content errors affect patient safety and can delay market authorization by months.";
---

<BaseLayout
  title="LS hero mockups — Extense LLC"
  description="Internal mockup page. Three hero-visual candidates for /industries/life-sciences."
>
  <section class="lsm-banner">
    <div class="container-page">
      <p class="lsm-banner__label">LIFE SCIENCES HERO MOCK · PICK ONE</p>
      <nav class="lsm-banner__nav" aria-label="Mock options">
        <a href="#opt-a">A · Multi-market submission fan</a>
        <a href="#opt-b">B · IFU translation propagation</a>
        <a href="#opt-c">C · Component reuse + audit</a>
        <a href="#opt-d">D · Component change propagation across artifacts</a>
      </nav>
    </div>
  </section>

  {/* ────────────── OPTION A ────────────── */}
  <section class="lsm-option" id="opt-a">
    <div class="container-page">
      <h2 class="lsm-option__heading">Option A — Multi-market submission fan</h2>
      <p class="lsm-option__note">
        Central <code>&lt;content&gt;</code> chip with four regulator outputs
        (FDA · eCTD Module 3, EMA · NeeS/eCTD, PMDA · JP, TGA · AU). Renders
        the page's Multi-Market Submissions card thesis: one source content
        repository serves every authority.
      </p>
    </div>
    <Hero variant="universal" title={HERO_TITLE} subdeck={HERO_SUBDECK} subdeckMaxWidth="520px">
      <svg
        class="mock-svg mock-a"
        id="mock-a"
        viewBox="0 0 560 320"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        role="presentation"
      >
        <g class="corner--accent fx" style="--d: 0ms">
          <path d="M 12 24 L 12 12 L 24 12" />
          <path d="M 536 12 L 548 12 L 548 24" />
          <path d="M 12 296 L 12 308 L 24 308" />
          <path d="M 536 308 L 548 308 L 548 296" />
        </g>

        <text class="chrome fx" x="30" y="30" style="--d: 80ms">in :: lifesci.submissions</text>

        {/* 4 corner regulator chips */}
        <g class="fx" style="--d: 280ms">
          <rect class="node node--custom" x="20" y="58" width="160" height="36" rx="3" />
          <text class="node-label node-label--custom" x="100" y="81" text-anchor="middle">FDA · eCTD M3</text>
        </g>
        <g class="fx" style="--d: 320ms">
          <rect class="node node--custom" x="380" y="58" width="160" height="36" rx="3" />
          <text class="node-label node-label--custom" x="460" y="81" text-anchor="middle">EMA · NeeS/eCTD</text>
        </g>
        <g class="fx" style="--d: 360ms">
          <rect class="node node--custom" x="20" y="226" width="160" height="36" rx="3" />
          <text class="node-label node-label--custom" x="100" y="249" text-anchor="middle">PMDA · JP</text>
        </g>
        <g class="fx" style="--d: 400ms">
          <rect class="node node--custom" x="380" y="226" width="160" height="36" rx="3" />
          <text class="node-label node-label--custom" x="460" y="249" text-anchor="middle">TGA · AU</text>
        </g>

        {/* 4 radial connectors */}
        <path class="flow-conn" style="--d: 540ms" d="M 210 145 L 180 94" />
        <path class="flow-conn" style="--d: 560ms" d="M 350 145 L 380 94" />
        <path class="flow-conn" style="--d: 580ms" d="M 210 195 L 180 226" />
        <path class="flow-conn" style="--d: 600ms" d="M 350 195 L 380 226" />

        {/* Central <content> chip */}
        <g class="fx" style="--d: 700ms">
          <rect class="node node--custom" x="210" y="125" width="140" height="90" rx="3" />
          <rect class="artifact-strip" x="210" y="125" width="140" height="6" />
          <text class="node-label node-label--custom" x="280" y="158" text-anchor="middle">&lt;content&gt;</text>
          <line class="artifact-rule" x1="226" y1="170" x2="334" y2="170" />
          <text class="node-caption" x="280" y="186" text-anchor="middle">single source</text>
          <text class="node-caption" x="280" y="202" text-anchor="middle">DITA profiled</text>
        </g>

        {/* Bottom chrome */}
        <g class="fx" style="--d: 880ms">
          <line class="chrome-rule" x1="30" y1="286" x2="530" y2="286" />
          <rect class="build-dot" x="32" y="296" width="6" height="6" />
          <text class="chrome chrome--strong" x="46"  y="302">FIG. A</text>
          <text class="chrome"               x="92"  y="302">/</text>
          <text class="chrome chrome--strong" x="100" y="302">lifesci.submissions</text>
          <text class="chrome chrome--strong" x="530" y="302" text-anchor="end">ONE SOURCE &rarr; 4 REGULATORS</text>
        </g>
      </svg>
    </Hero>
  </section>

  {/* ────────────── OPTION B ────────────── */}
  <section class="lsm-option" id="opt-b">
    <div class="container-page">
      <h2 class="lsm-option__heading">Option B — IFU translation propagation</h2>
      <p class="lsm-option__note">
        <code>&lt;ifu&gt;</code> source with a "safety warning · v3.2" change
        marker, propagation arrow through a TRANSLATION LAYER rule, then five
        language chips (EN · FR · DE · JA · ZH) plus a "+25 MORE" overflow
        indicator. Literal rendering of the IFU card's example — one safety
        warning change, 30+ language versions flagged.
      </p>
    </div>
    <Hero variant="universal" title={HERO_TITLE} subdeck={HERO_SUBDECK} subdeckMaxWidth="520px">
      <svg
        class="mock-svg mock-b"
        id="mock-b"
        viewBox="0 0 560 320"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        role="presentation"
      >
        <g class="corner--accent fx" style="--d: 0ms">
          <path d="M 12 24 L 12 12 L 24 12" />
          <path d="M 536 12 L 548 12 L 548 24" />
          <path d="M 12 296 L 12 308 L 24 308" />
          <path d="M 536 308 L 548 308 L 548 296" />
        </g>

        <text class="chrome fx" x="30" y="30" style="--d: 80ms">in :: lifesci.translation</text>

        {/* Source <ifu> chip with change marker */}
        <g class="fx" style="--d: 200ms">
          <rect class="node node--custom" x="200" y="56" width="160" height="56" rx="3" />
          <rect class="artifact-strip" x="200" y="56" width="160" height="6" />
          <text class="node-label node-label--custom" x="280" y="84" text-anchor="middle">&lt;ifu&gt;</text>
          <text class="node-caption" x="280" y="102" text-anchor="middle">safety warning · v3.2</text>
        </g>

        {/* Vertical spine with Δ propagation marker */}
        <path class="flow-conn" style="--d: 320ms" d="M 280 112 L 280 178 M 275 173 L 280 178 L 285 173" />
        <text class="propagation-label fx" x="296" y="150" style="--d: 400ms">Δ propagating</text>

        {/* TRANSLATION LAYER caption + hairline */}
        <text class="layer-caption fx" x="280" y="196" text-anchor="middle" style="--d: 460ms">TRANSLATION LAYER</text>
        <line class="layer-rule fx" x1="40" y1="204" x2="520" y2="204" style="--d: 500ms" />

        {/* 5 language chips at y=220-256 + "+25 MORE" indicator */}
        <g class="fx" style="--d: 560ms">
          <rect class="node node--custom" x="40" y="220" width="68" height="36" rx="3" />
          <text class="node-label node-label--custom" x="74" y="243" text-anchor="middle">EN</text>
        </g>
        <g class="fx" style="--d: 580ms">
          <rect class="node node--custom" x="120" y="220" width="68" height="36" rx="3" />
          <text class="node-label node-label--custom" x="154" y="243" text-anchor="middle">FR</text>
        </g>
        <g class="fx" style="--d: 600ms">
          <rect class="node node--custom" x="200" y="220" width="68" height="36" rx="3" />
          <text class="node-label node-label--custom" x="234" y="243" text-anchor="middle">DE</text>
        </g>
        <g class="fx" style="--d: 620ms">
          <rect class="node node--custom" x="280" y="220" width="68" height="36" rx="3" />
          <text class="node-label node-label--custom" x="314" y="243" text-anchor="middle">JA</text>
        </g>
        <g class="fx" style="--d: 640ms">
          <rect class="node node--custom" x="360" y="220" width="68" height="36" rx="3" />
          <text class="node-label node-label--custom" x="394" y="243" text-anchor="middle">ZH</text>
        </g>
        <g class="fx" style="--d: 700ms">
          <rect class="node node--soft" x="440" y="220" width="80" height="36" rx="3" />
          <text class="overflow-label" x="480" y="243" text-anchor="middle">+25 MORE</text>
        </g>

        {/* Bottom chrome */}
        <g class="fx" style="--d: 820ms">
          <line class="chrome-rule" x1="30" y1="286" x2="530" y2="286" />
          <rect class="build-dot" x="32" y="296" width="6" height="6" />
          <text class="chrome chrome--strong" x="46"  y="302">FIG. B</text>
          <text class="chrome"               x="92"  y="302">/</text>
          <text class="chrome chrome--strong" x="100" y="302">lifesci.translation</text>
          <text class="chrome chrome--strong" x="530" y="302" text-anchor="end">ONE CHANGE &rarr; 30+ LANGUAGES</text>
        </g>
      </svg>
    </Hero>
  </section>

  {/* ────────────── OPTION C ────────────── */}
  <section class="lsm-option" id="opt-c">
    <div class="container-page">
      <h2 class="lsm-option__heading">Option C — Component reuse + audit</h2>
      <p class="lsm-option__note">
        <code>&lt;component&gt;</code> source flowing through a 21 CFR Part 11
        audit band (validated · audit trail · signature) down to four
        deliverables (IFU · SPL · CSR · Module 3). Same compositional pattern
        as the FS hero, specialized for life-sciences artifacts.
      </p>
    </div>
    <Hero variant="universal" title={HERO_TITLE} subdeck={HERO_SUBDECK} subdeckMaxWidth="520px">
      <svg
        class="mock-svg mock-c"
        id="mock-c"
        viewBox="0 0 560 320"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        role="presentation"
      >
        <g class="corner--accent fx" style="--d: 0ms">
          <path d="M 12 24 L 12 12 L 24 12" />
          <path d="M 536 12 L 548 12 L 548 24" />
          <path d="M 12 296 L 12 308 L 24 308" />
          <path d="M 536 308 L 548 308 L 548 296" />
        </g>

        <text class="chrome fx" x="30" y="30" style="--d: 80ms">in :: lifesci.architecture</text>

        {/* Row 1: <component> source */}
        <g class="fx" style="--d: 200ms">
          <rect class="node node--custom" x="210" y="58" width="140" height="44" rx="3" />
          <rect class="artifact-strip" x="210" y="58" width="140" height="6" />
          <text class="node-label node-label--custom" x="280" y="82" text-anchor="middle">&lt;component&gt;</text>
          <text class="node-caption" x="280" y="95" text-anchor="middle">extense.compliance</text>
        </g>

        {/* Spine: source → audit band */}
        <path class="flow-conn" style="--d: 320ms" d="M 280 102 L 280 124 M 275 119 L 280 124 L 285 119" />

        {/* Audit band — 3 cells */}
        <g class="fx" style="--d: 400ms">
          <rect class="node node--soft" x="40" y="124" width="150" height="46" rx="3" />
          <text class="meta-label" x="115" y="142" text-anchor="middle">PART 11</text>
          <text class="meta-value" x="115" y="159" text-anchor="middle">validated</text>
        </g>
        <g class="fx" style="--d: 440ms">
          <rect class="node node--soft" x="205" y="124" width="150" height="46" rx="3" />
          <text class="meta-label" x="280" y="142" text-anchor="middle">AUDIT</text>
          <text class="meta-value" x="280" y="159" text-anchor="middle">GxP-traced</text>
        </g>
        <g class="fx" style="--d: 480ms">
          <rect class="node node--soft" x="370" y="124" width="150" height="46" rx="3" />
          <text class="meta-label" x="445" y="142" text-anchor="middle">SIGNATURE</text>
          <text class="meta-value" x="445" y="159" text-anchor="middle">e-sign · sealed</text>
        </g>

        {/* Spine: audit → distribution */}
        <path class="flow-conn" style="--d: 580ms" d="M 280 170 L 280 192" />

        {/* Fan: spine → 4 deliverables */}
        <path class="flow-conn" style="--d: 640ms" d="M 280 192 L 80 220" />
        <path class="flow-conn" style="--d: 660ms" d="M 280 192 L 215 220" />
        <path class="flow-conn" style="--d: 680ms" d="M 280 192 L 350 220" />
        <path class="flow-conn" style="--d: 700ms" d="M 280 192 L 480 220" />

        {/* 4 deliverable chips */}
        <g class="fx" style="--d: 760ms">
          <rect class="node node--custom" x="20" y="220" width="120" height="36" rx="3" />
          <text class="node-label node-label--custom" x="80" y="243" text-anchor="middle">IFU</text>
        </g>
        <g class="fx" style="--d: 780ms">
          <rect class="node node--custom" x="155" y="220" width="120" height="36" rx="3" />
          <text class="node-label node-label--custom" x="215" y="243" text-anchor="middle">SPL</text>
        </g>
        <g class="fx" style="--d: 800ms">
          <rect class="node node--custom" x="290" y="220" width="120" height="36" rx="3" />
          <text class="node-label node-label--custom" x="350" y="243" text-anchor="middle">CSR</text>
        </g>
        <g class="fx" style="--d: 820ms">
          <rect class="node node--custom" x="425" y="220" width="120" height="36" rx="3" />
          <text class="node-label node-label--custom" x="485" y="243" text-anchor="middle">MODULE 3</text>
        </g>

        {/* Bottom chrome */}
        <g class="fx" style="--d: 920ms">
          <line class="chrome-rule" x1="30" y1="286" x2="530" y2="286" />
          <rect class="build-dot" x="32" y="296" width="6" height="6" />
          <text class="chrome chrome--strong" x="46"  y="302">FIG. C</text>
          <text class="chrome"               x="92"  y="302">/</text>
          <text class="chrome chrome--strong" x="100" y="302">lifesci.architecture</text>
          <text class="chrome chrome--strong" x="530" y="302" text-anchor="end">SOURCE &rarr; AUDIT &rarr; DELIVERABLES</text>
        </g>
      </svg>
    </Hero>
  </section>

  {/* ────────────── OPTION D ────────────── */}
  <section class="lsm-option" id="opt-d">
    <div class="container-page">
      <h2 class="lsm-option__heading">Option D — Component change propagation across artifacts</h2>
      <p class="lsm-option__note">
        Same change-event move as B, but the downstream broadens from
        languages-of-one-IFU to all four artifact types. Source
        <code>&lt;component&gt;</code> with Δ change marker, propagation
        annotation on the spine, fan to four deliverables (IFU · SPL · CSR ·
        Module 3), then a single footer annotation that carries the multi-
        market / multi-language / audit-trail scale without crowding the chips.
        Combines B's distinctive change-propagation thesis with C's multi-
        artifact coverage and A's regulatory multiplier.
      </p>
    </div>
    <Hero variant="universal" title={HERO_TITLE} subdeck={HERO_SUBDECK} subdeckMaxWidth="520px">
      <svg
        class="mock-svg mock-d"
        id="mock-d"
        viewBox="0 0 560 320"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        role="presentation"
      >
        <g class="corner--accent fx" style="--d: 0ms">
          <path d="M 12 24 L 12 12 L 24 12" />
          <path d="M 536 12 L 548 12 L 548 24" />
          <path d="M 12 296 L 12 308 L 24 308" />
          <path d="M 536 308 L 548 308 L 548 296" />
        </g>

        <text class="chrome fx" x="30" y="30" style="--d: 80ms">in :: lifesci.propagation</text>

        {/* Source <component> chip with change marker */}
        <g class="fx" style="--d: 200ms">
          <rect class="node node--custom" x="200" y="58" width="160" height="56" rx="3" />
          <rect class="artifact-strip" x="200" y="58" width="160" height="6" />
          <text class="node-label node-label--custom" x="280" y="86" text-anchor="middle">&lt;component&gt;</text>
          <text class="node-caption" x="280" y="104" text-anchor="middle">Δ safety warning · v3.2</text>
        </g>

        {/* Vertical spine with Δ propagation annotation */}
        <path class="flow-conn" style="--d: 340ms" d="M 280 114 L 280 180 M 275 175 L 280 180 L 285 175" />
        <text class="propagation-label fx" x="296" y="150" style="--d: 420ms">Δ propagating</text>

        {/* Fan to 4 deliverables */}
        <path class="flow-conn" style="--d: 500ms" d="M 280 180 L 80 200" />
        <path class="flow-conn" style="--d: 520ms" d="M 280 180 L 215 200" />
        <path class="flow-conn" style="--d: 540ms" d="M 280 180 L 350 200" />
        <path class="flow-conn" style="--d: 560ms" d="M 280 180 L 485 200" />

        {/* 4 deliverable chips at y=200-240 (h=40), width=120 each, gap=15 */}
        <g class="fx" style="--d: 620ms">
          <rect class="node node--custom" x="20" y="200" width="120" height="40" rx="3" />
          <text class="node-label node-label--custom" x="80" y="225" text-anchor="middle">IFU</text>
        </g>
        <g class="fx" style="--d: 640ms">
          <rect class="node node--custom" x="155" y="200" width="120" height="40" rx="3" />
          <text class="node-label node-label--custom" x="215" y="225" text-anchor="middle">SPL</text>
        </g>
        <g class="fx" style="--d: 660ms">
          <rect class="node node--custom" x="290" y="200" width="120" height="40" rx="3" />
          <text class="node-label node-label--custom" x="350" y="225" text-anchor="middle">CSR</text>
        </g>
        <g class="fx" style="--d: 680ms">
          <rect class="node node--custom" x="425" y="200" width="120" height="40" rx="3" />
          <text class="node-label node-label--custom" x="485" y="225" text-anchor="middle">MODULE 3</text>
        </g>

        {/* Footer multiplier annotation */}
        <text class="multiplier-label fx" x="280" y="262" text-anchor="middle" style="--d: 780ms">each &times; 30+ language variants &middot; multi-market &middot; audit-traceable</text>

        {/* Bottom chrome */}
        <g class="fx" style="--d: 880ms">
          <line class="chrome-rule" x1="30" y1="286" x2="530" y2="286" />
          <rect class="build-dot" x="32" y="296" width="6" height="6" />
          <text class="chrome chrome--strong" x="46"  y="302">FIG. D</text>
          <text class="chrome"               x="92"  y="302">/</text>
          <text class="chrome chrome--strong" x="100" y="302">lifesci.propagation</text>
          <text class="chrome chrome--strong" x="530" y="302" text-anchor="end">ONE CHANGE &rarr; ALL ARTIFACTS</text>
        </g>
      </svg>
    </Hero>
  </section>
</BaseLayout>

<style>
  /* ─── Banner ─── */
  .lsm-banner {
    background: #fef3c7;
    border-bottom: var(--border-hairline);
    padding: var(--space-3) 0;
  }
  .lsm-banner__label {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.1em;
    color: var(--color-accent-primary-pressed);
    margin: 0 0 var(--space-2) 0;
  }
  .lsm-banner__nav {
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;
  }
  .lsm-banner__nav a {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-text-primary);
    text-decoration: none;
    border-bottom: 1px solid var(--color-accent-primary);
    padding-bottom: 1px;
  }
  .lsm-banner__nav a:hover {
    color: var(--color-link-hover);
  }

  /* ─── Option section ─── */
  .lsm-option {
    border-top: var(--border-hairline);
    padding-top: var(--space-8);
  }
  .lsm-option__heading {
    font-family: var(--font-display);
    font-size: var(--text-display-md);
    font-weight: var(--weight-regular);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-3) 0;
    letter-spacing: var(--tracking-tight);
  }
  .lsm-option__note {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin: 0;
    max-width: 70ch;
    text-wrap: pretty;
  }
  .lsm-option__note code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: #fef3c7;
    padding: 0 4px;
    border-radius: 2px;
  }

  /* ─── Shared SVG idiom ─── */
  .mock-svg {
    width: 560px;
    max-width: 100%;
    height: auto;
    color: var(--color-text-primary);
    overflow: visible;
    display: block;
    shape-rendering: geometricPrecision;
  }
  .mock-svg .chrome {
    font-family: var(--font-mono);
    font-size: 9px;
    fill: var(--color-text-muted);
    letter-spacing: 0.06em;
    user-select: none;
  }
  .mock-svg .chrome--strong {
    fill: var(--color-text-primary);
    font-weight: var(--weight-medium);
  }
  .mock-svg .corner--accent {
    stroke: var(--color-accent-primary-hover);
    stroke-width: 1.25;
    fill: none;
  }
  .mock-svg .chrome-rule {
    stroke: var(--color-border-subtle);
    stroke-width: 1;
  }
  .mock-svg .build-dot {
    fill: var(--color-accent-primary-hover);
    stroke: none;
  }
  .mock-svg .node {
    fill: var(--color-page-bg);
    stroke: var(--color-text-primary);
    stroke-width: 1.5;
    vector-effect: non-scaling-stroke;
  }
  .mock-svg .node--custom {
    fill: #fef3c7;
    stroke: var(--color-accent-primary);
  }
  .mock-svg .node--soft {
    fill: var(--color-page-bg);
    stroke: var(--color-border-subtle);
    stroke-width: 1;
    stroke-dasharray: 4 4;
  }
  .mock-svg .node-label {
