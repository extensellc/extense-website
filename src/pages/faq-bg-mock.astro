---
/*
  TEMP staging route — moving hero BACKGROUND concepts for /resources/faq.
  Each block mimics the FAQ hero (centered text) over an animated,
  document-grade background. Unlinked; delete (git rm) after selection.
  All motion is slow + low-opacity and falls back to static under
  prefers-reduced-motion.
*/
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Frequently asked questions.";
const subdeck = "Answers to common questions about content engineering, AI-ready content, publishing automation, CCMS platforms, and what it's like to work with Extense.";
---

<BaseLayout title="MOCK — FAQ hero backgrounds" description="Temporary staging route for the FAQ moving-background concepts.">
  <div class="mk-intro container-data">
    <p class="mk-kicker">TEMP · pick one · delete after selection</p>
    <h1 class="mk-title">FAQ hero — moving background concepts</h1>
    <p class="mk-note">Three subtle, document-grade animated backgrounds. Motion is slow and low-contrast so the text stays legible; all fall back to static with reduced-motion.</p>
  </div>

  {/* Concept A — drifting blueprint grid */}
  <p class="mk-label container-data">Concept A · drifting blueprint grid</p>
  <section class="bgsec">
    <div class="bgsec__bg bgA" aria-hidden="true"></div>
    <div class="container-page bgsec__inner">
      <h2 class="bgsec__title">{title}</h2>
      <p class="bgsec__subdeck">{subdeck}</p>
    </div>
  </section>

  {/* Concept B — node constellation */}
  <p class="mk-label container-data">Concept B · drifting node constellation</p>
  <section class="bgsec">
    <div class="bgsec__bg bgB" aria-hidden="true">
      <svg viewBox="0 0 1200 420" preserveAspectRatio="xMidYMid slice" class="bgB__svg">
        <g class="bgB__lines">
          <line x1="120" y1="90" x2="320" y2="180" /><line x1="320" y1="180" x2="240" y2="330" />
          <line x1="320" y1="180" x2="560" y2="120" /><line x1="560" y1="120" x2="780" y2="220" />
          <line x1="780" y1="220" x2="980" y2="120" /><line x1="780" y1="220" x2="880" y2="350" />
          <line x1="560" y1="120" x2="620" y2="300" /><line x1="980" y1="120" x2="1080" y2="260" />
        </g>
        <g class="bgB__nodes">
          <circle cx="120" cy="90" r="3" /><circle cx="320" cy="180" r="3" /><circle cx="240" cy="330" r="3" />
          <circle cx="560" cy="120" r="3" class="amber" /><circle cx="780" cy="220" r="3" /><circle cx="980" cy="120" r="3" />
          <circle cx="880" cy="350" r="3" /><circle cx="620" cy="300" r="3" class="amber" /><circle cx="1080" cy="260" r="3" />
        </g>
      </svg>
    </div>
    <div class="container-page bgsec__inner">
      <h2 class="bgsec__title">{title}</h2>
      <p class="bgsec__subdeck">{subdeck}</p>
    </div>
  </section>

  {/* Concept C — dotted field + slow amber sweep */}
  <p class="mk-label container-data">Concept C · dotted field with a slow amber light-sweep</p>
  <section class="bgsec">
    <div class="bgsec__bg bgC" aria-hidden="true"></div>
    <div class="container-page bgsec__inner">
      <h2 class="bgsec__title">{title}</h2>
      <p class="bgsec__subdeck">{subdeck}</p>
    </div>
  </section>
</BaseLayout>

<style>
  .mk-intro { padding-top: var(--space-16); padding-bottom: var(--space-4); }
  .mk-kicker { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-accent-primary-pressed); margin: 0 0 var(--space-3); }
  .mk-title { font-family: var(--font-display); font-size: var(--text-display-lg); font-weight: var(--weight-regular); letter-spacing: var(--tracking-tight); color: var(--color-text-primary); margin: 0 0 var(--space-4); }
  .mk-note { font-family: var(--font-body); font-size: var(--text-body); color: var(--color-text-secondary); max-width: 70ch; margin: 0; }
  .mk-label { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-accent-primary-pressed); margin: var(--space-12) auto var(--space-3); }

  /* Hero-like block */
  .bgsec {
    position: relative;
    overflow: hidden;
    padding-top: var(--space-32);
    padding-bottom: var(--space-32);
    background-color: var(--color-page-bg);
    border-top: var(--border-hairline);
    border-bottom: var(--border-hairline);
  }
  .bgsec__bg { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
  .bgsec__inner { position: relative; z-index: 1; }
  .bgsec__title {
    font-family: var(--font-display); font-size: var(--text-display-xl); font-weight: var(--weight-regular);
    line-height: var(--leading-tight); letter-spacing: var(--tracking-tight); color: var(--color-text-primary);
    text-align: center; margin: 0; text-wrap: balance;
  }
  .bgsec__subdeck {
    font-family: var(--font-body); font-size: var(--text-body-lg); line-height: var(--leading-normal);
    color: var(--color-text-secondary); text-align: center; max-width: 620px; margin: var(--space-6) auto 0; text-wrap: pretty;
  }

  /* ── Concept A: drifting blueprint grid ── */
  .bgA::before {
    content: ""; position: absolute; inset: 0;
    background-image:
      linear-gradient(to right, var(--color-border-subtle) 1px, transparent 1px),
      linear-gradient(to bottom, var(--color-border-subtle) 1px, transparent 1px);
    background-size: 46px 46px;
    opacity: 0.7;
    -webkit-mask-image: radial-gradient(ellipse 75% 78% at 50% 50%, #000 30%, transparent 82%);
            mask-image: radial-gradient(ellipse 75% 78% at 50% 50%, #000 30%, transparent 82%);
    animation: bgA-drift 60s linear infinite;
  }
  @keyframes bgA-drift { from { background-position: 0 0; } to { background-position: 46px 46px; } }

  /* ── Concept B: node constellation ── */
  .bgB { -webkit-mask-image: radial-gradient(ellipse 80% 82% at 50% 50%, #000 25%, transparent 85%);
                 mask-image: radial-gradient(ellipse 80% 82% at 50% 50%, #000 25%, transparent 85%); }
  .bgB__svg { width: 100%; height: 100%; display: block; }
  .bgB__lines line { stroke: var(--color-border-subtle); stroke-width: 1; vector-effect: non-scaling-stroke; }
  .bgB__nodes circle { fill: var(--color-text-muted); opacity: 0.5; }
  .bgB__nodes circle.amber { fill: var(--color-accent-primary); opacity: 0.8; }
  .bgB__svg { animation: bgB-float 24s ease-in-out infinite alternate; }
  @keyframes bgB-float { from { transform: translate(-10px, -6px); } to { transform: translate(10px, 6px); } }
  .bgB__nodes circle { animation: bgB-pulse 6s ease-in-out infinite; }
  .bgB__nodes circle:nth-child(2n) { animation-delay: -2s; }
  .bgB__nodes circle:nth-child(3n) { animation-delay: -4s; }
  @keyframes bgB-pulse { 0%, 100% { opacity: 0.3; } 50% { opacity: 0.75; } }

  /* ── Concept C: dotted field + amber light-sweep ── */
  .bgC::before {
    content: ""; position: absolute; inset: 0;
    background-image: radial-gradient(var(--color-border-subtle) 1.2px, transparent 1.6px);
    background-size: 26px 26px;
    opacity: 0.65;
    -webkit-mask-image: radial-gradient(ellipse 78% 80% at 50% 50%, #000 30%, transparent 85%);
            mask-image: radial-gradient(ellipse 78% 80% at 50% 50%, #000 30%, transparent 85%);
  }
  .bgC::after {
    content: ""; position: absolute; inset: 0;
    background: linear-gradient(110deg, transparent 42%, rgba(245, 158, 11, 0.12) 50%, transparent 58%);
    background-size: 280% 100%;
    animation: bgC-sweep 9s ease-in-out infinite;
  }
  @keyframes bgC-sweep { 0% { background-position: 130% 0; } 100% { background-position: -30% 0; } }

  @media (prefers-reduced-motion: reduce) {
    .bgA::before, .bgB__svg, .bgB__nodes circle, .bgC::after { animation: none !important; }
    .bgC::after { background-position: 50% 0; }
  }
</style>
