---
/*
  TEMP staging route — FAQ hero side-visual, "reference index" direction.
  Two variations to pick the detailing. Unlinked; delete (git rm) once a
  concept is chosen and built into the real hero.
*/
import BaseLayout from "../layouts/BaseLayout.astro";

const flat = [
  { n: "01", q: "Why DITA, not Word?", tag: "practice" },
  { n: "02", q: "Is DITA relevant in 2026?", tag: "practice" },
  { n: "03", q: "CCMS vs Git workflow?", tag: "practice" },
  { n: "04", q: "Make content AI-ready?", tag: "ai-ready", hl: true },
  { n: "05", q: "Publishing automation?", tag: "ai-ready" },
  { n: "06", q: "Pricing & engagement?", tag: "working" },
];

const grouped = [
  { kind: "head", label: "01 · Practice & methodology" },
  { kind: "row", q: "Why DITA, not Word?" },
  { kind: "row", q: "CCMS vs Git workflow?" },
  { kind: "head", label: "02 · AI-readiness & automation" },
  { kind: "row", q: "Make content AI-ready?", hl: true },
  { kind: "head", label: "03 · Working with Extense" },
  { kind: "row", q: "What's your pricing model?" },
];
---

<BaseLayout title="MOCK — FAQ hero (reference index)" description="Temporary staging route for the FAQ reference-index hero visual.">
  <section class="mk-intro">
    <div class="container-data">
      <p class="mk-kicker">TEMP · pick one · delete after selection</p>
      <h1 class="mk-title">FAQ hero — reference index</h1>
      <p class="mk-note">Two variations of the index direction. Same idiom, different detailing.</p>
    </div>
  </section>

  {/* ─────────────── Variation 1 — flat index with category tags ─────────────── */}
  <section class="mk-concept">
    <div class="container-data">
      <p class="mk-label">Variation 1 · flat index, category tags, one entry highlighted</p>
      <svg class="mk-svg" viewBox="0 0 520 260" xmlns="http://www.w3.org/2000/svg" role="presentation" aria-hidden="true">
        <g class="corner">
          <path d="M 12 22 L 12 12 L 22 12" /><path d="M 498 12 L 508 12 L 508 22" />
          <path d="M 12 238 L 12 248 L 22 248" /><path d="M 498 248 L 508 248 L 508 238" />
        </g>
        <text class="chrome" x="24" y="30">in :: faq.index</text>
        <text class="eyebrow-svg" x="24" y="54">FAQ &#183; REFERENCE INDEX</text>

        {flat.map((r, i) => {
          const y = 88 + i * 26;
          return (
            <g>
              {r.hl && <rect class="row-hl" x="16" y={y - 14} width="488" height="22" rx="2" />}
              <text class={r.hl ? "idx-num idx-num--hl" : "idx-num"} x="24" y={y}>{r.n}</text>
              <text class={r.hl ? "idx-q idx-q--hl" : "idx-q"} x="48" y={y}>{r.q}</text>
              <line class={r.hl ? "leader leader--hl" : "leader"} x1="232" y1={y - 3} x2="430" y2={y - 3} />
              <text class={r.hl ? "idx-tag idx-tag--hl" : "idx-tag"} x="496" y={y} text-anchor="end">{r.tag}</text>
            </g>
          );
        })}

        <line class="chrome-rule" x1="24" y1="238" x2="496" y2="238" />
        <rect class="build-dot" x="150" y="245" width="6" height="6" />
        <text class="chrome chrome--strong" x="164" y="251">FAQ.index</text>
        <text class="chrome chrome--strong" x="496" y="251" text-anchor="end">3 categories &#183; 15 entries</text>
      </svg>
    </div>
  </section>

  {/* ─────────────── Variation 2 — grouped by category ─────────────── */}
  <section class="mk-concept mk-concept--alt">
    <div class="container-data">
      <p class="mk-label">Variation 2 · grouped by category (table-of-contents style)</p>
      <svg class="mk-svg" viewBox="0 0 520 260" xmlns="http://www.w3.org/2000/svg" role="presentation" aria-hidden="true">
        <g class="corner">
          <path d="M 12 22 L 12 12 L 22 12" /><path d="M 498 12 L 508 12 L 508 22" />
          <path d="M 12 238 L 12 248 L 22 248" /><path d="M 498 248 L 508 248 L 508 238" />
        </g>
        <text class="chrome" x="24" y="30">in :: faq.contents</text>

        {grouped.map((r, i) => {
          const y = 64 + i * 25;
          if (r.kind === "head") {
            return <text class="grp-head" x="24" y={y}>{r.label}</text>;
          }
          return (
            <g>
              {r.hl && <rect class="row-hl" x="34" y={y - 13} width="470" height="20" rx="2" />}
              <text class={r.hl ? "idx-q idx-q--hl" : "idx-q"} x="44" y={y}>{r.q}</text>
              <line class={r.hl ? "leader leader--hl" : "leader"} x1="232" y1={y - 3} x2="476" y2={y - 3} />
              <circle class={r.hl ? "tick tick--hl" : "tick"} cx="492" cy={y - 4} r="2.5" />
            </g>
          );
        })}

        <line class="chrome-rule" x1="24" y1="238" x2="496" y2="238" />
        <rect class="build-dot" x="150" y="245" width="6" height="6" />
        <text class="chrome chrome--strong" x="164" y="251">FAQ.contents</text>
        <text class="chrome chrome--strong" x="496" y="251" text-anchor="end">3 categories &#183; 15 entries</text>
      </svg>
    </div>
  </section>
</BaseLayout>

<style>
  .mk-intro { padding-top: var(--space-16); padding-bottom: var(--space-8); }
  .mk-kicker { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-accent-primary-pressed); margin: 0 0 var(--space-3); }
  .mk-title { font-family: var(--font-display); font-size: var(--text-display-lg); font-weight: var(--weight-regular); letter-spacing: var(--tracking-tight); color: var(--color-text-primary); margin: 0 0 var(--space-4); }
  .mk-note { font-family: var(--font-body); font-size: var(--text-body); color: var(--color-text-secondary); max-width: 70ch; margin: 0; }
  .mk-concept { padding-top: var(--space-12); padding-bottom: var(--space-12); border-top: var(--border-hairline); }
  .mk-concept--alt { background-color: var(--color-surface-band); }
  .mk-label { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-accent-primary-pressed); margin: 0 0 var(--space-6); }

  .mk-svg { width: 520px; max-width: 100%; height: auto; display: block; overflow: visible; shape-rendering: geometricPrecision; }
  .mk-svg .chrome { font-family: var(--font-mono); font-size: 9px; fill: var(--color-text-muted); letter-spacing: 0.06em; }
  .mk-svg .chrome--strong { fill: var(--color-text-primary); font-weight: var(--weight-medium); }
  .mk-svg .corner { stroke: var(--color-accent-primary-hover); stroke-width: 1.25; fill: none; }
  .mk-svg .chrome-rule { stroke: var(--color-border-subtle); stroke-width: 1; }
  .mk-svg .build-dot { fill: var(--color-accent-primary-hover); }

  .mk-svg .eyebrow-svg { font-family: var(--font-mono); font-size: 9px; fill: var(--color-accent-primary-pressed); letter-spacing: 0.14em; font-weight: var(--weight-semibold); }
  .mk-svg .grp-head { font-family: var(--font-mono); font-size: 10px; fill: var(--color-accent-primary-pressed); letter-spacing: 0.08em; font-weight: var(--weight-semibold); text-transform: uppercase; }

  .mk-svg .idx-num { font-family: var(--font-mono); font-size: 11px; fill: var(--color-accent-primary-pressed); font-weight: var(--weight-semibold); }
  .mk-svg .idx-q { font-family: var(--font-mono); font-size: 11px; fill: var(--color-text-primary); letter-spacing: 0.01em; }
  .mk-svg .idx-tag { font-family: var(--font-mono); font-size: 9px; fill: var(--color-text-muted); letter-spacing: 0.04em; }
  .mk-svg .leader { stroke: var(--color-border-subtle); stroke-width: 1; stroke-dasharray: 0.5 3.5; stroke-linecap: round; vector-effect: non-scaling-stroke; }
  .mk-svg .tick { fill: var(--color-border-subtle); }

  .mk-svg .row-hl { fill: #fef3c7; }
  .mk-svg .idx-num--hl, .mk-svg .idx-q--hl, .mk-svg .idx-tag--hl { fill: var(--color-accent-primary-pressed); }
  .mk-svg .leader--hl { stroke: var(--color-accent-primary); }
  .mk-svg .tick--hl { fill: var(--color-accent-primary); }
</style>
