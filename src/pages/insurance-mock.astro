---
/*
  TEMP / insurance-mock — two hero-visual candidates for
  /industries/insurance.

  Each option renders the live Hero component with the locked [OLD] H1
  + [OLD] subdeck so the side visuals can be judged in their final context.
  Pick one in-browser; build the real page with the chosen visual and
  `git rm` this file. Unlinked from nav.

  B — Component assembly: 5 clause components → assembled <filing-package>.
      Renders the S3 lead-off Component Content Management thesis directly.
  D — Component × jurisdiction assembly: 5 clause components → profiler
      (state filter) → assembled <policy-form>, with M×N multiplier
      annotation. Captures both modular-component and 50-state-variant
      dimensions in one composition.
*/

import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/site/Hero.astro";

const HERO_TITLE = "Insurance Policy Construction";
const HERO_SUBDECK = "Modular content architectures for multi-state, multi-product policy assembly — where a single misplaced clause can void coverage or trigger regulatory penalties.";
---

<BaseLayout
  title="Insurance hero mockups — Extense LLC"
  description="Internal mockup page. Two hero-visual candidates for /industries/insurance."
>
  <section class="insm-banner">
    <div class="container-page">
      <p class="insm-banner__label">INSURANCE HERO MOCK · PICK ONE</p>
      <nav class="insm-banner__nav" aria-label="Mock options">
        <a href="#opt-b">B · Component assembly</a>
        <a href="#opt-d">D · Component × jurisdiction assembly</a>
      </nav>
    </div>
  </section>

  {/* ────────────── OPTION B ────────────── */}
  <section class="insm-option" id="opt-b">
    <div class="container-page">
      <h2 class="insm-option__heading">Option B — Component assembly</h2>
      <p class="insm-option__note">
        Five clause components stacked on the left — <code>&lt;declarations&gt;</code>,
        <code>&lt;agreements&gt;</code>, <code>&lt;conditions&gt;</code>,
        <code>&lt;exclusions&gt;</code>, <code>&lt;endorsements&gt;</code> —
        converging into one assembled <code>&lt;filing-package&gt;</code>.
        Renders the page's lead-off thesis (S3 Component Content Management):
        an insurance policy is a modular assembly, not a document.
      </p>
    </div>
    <Hero variant="universal" title={HERO_TITLE} subdeck={HERO_SUBDECK} subdeckMaxWidth="520px">
      <svg
        class="mock-svg mock-b"
        id="mock-b"
        viewBox="0 0 560 320"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        role="presentation"
      >
        <g class="corner--accent fx" style="--d: 0ms">
          <path d="M 12 24 L 12 12 L 24 12" />
          <path d="M 536 12 L 548 12 L 548 24" />
          <path d="M 12 296 L 12 308 L 24 308" />
          <path d="M 536 308 L 548 308 L 548 296" />
        </g>

        <text class="chrome fx" x="30" y="30" style="--d: 80ms">in :: ins.modular</text>

        {/* 5 component chips stacked on the left */}
        <g class="fx" style="--d: 200ms">
          <rect class="node node--custom" x="20" y="64" width="170" height="28" rx="3" />
          <text class="node-label node-label--custom" x="105" y="83" text-anchor="middle">&lt;declarations&gt;</text>
        </g>
        <g class="fx" style="--d: 260ms">
          <rect class="node node--custom" x="20" y="100" width="170" height="28" rx="3" />
          <text class="node-label node-label--custom" x="105" y="119" text-anchor="middle">&lt;agreements&gt;</text>
        </g>
        <g class="fx" style="--d: 320ms">
          <rect class="node node--custom" x="20" y="136" width="170" height="28" rx="3" />
          <text class="node-label node-label--custom" x="105" y="155" text-anchor="middle">&lt;conditions&gt;</text>
        </g>
        <g class="fx" style="--d: 380ms">
          <rect class="node node--custom" x="20" y="172" width="170" height="28" rx="3" />
          <text class="node-label node-label--custom" x="105" y="191" text-anchor="middle">&lt;exclusions&gt;</text>
        </g>
        <g class="fx" style="--d: 440ms">
          <rect class="node node--custom" x="20" y="208" width="170" height="28" rx="3" />
          <text class="node-label node-label--custom" x="105" y="227" text-anchor="middle">&lt;endorsements&gt;</text>
        </g>

        {/* 5 convergent connectors */}
        <path class="flow-conn" style="--d: 580ms" d="M 190 78  L 400 160" />
        <path class="flow-conn" style="--d: 600ms" d="M 190 114 L 400 160" />
        <path class="flow-conn" style="--d: 620ms" d="M 190 150 L 400 160" />
        <path class="flow-conn" style="--d: 640ms" d="M 190 186 L 400 160" />
        <path class="flow-conn" style="--d: 660ms" d="M 190 222 L 400 160" />

        {/* Output: assembled <filing-package> chip */}
        <g class="fx" style="--d: 740ms">
          <rect class="node node--custom" x="400" y="125" width="140" height="70" rx="3" />
          <rect class="artifact-strip" x="400" y="125" width="140" height="6" />
          <text class="node-label node-label--custom" x="470" y="155" text-anchor="middle">&lt;filing-package&gt;</text>
          <line class="artifact-rule" x1="416" y1="167" x2="524" y2="167" />
          <text class="node-caption" x="470" y="183" text-anchor="middle">assembled</text>
        </g>

        {/* Bottom chrome */}
        <g class="fx" style="--d: 860ms">
          <line class="chrome-rule" x1="30" y1="286" x2="530" y2="286" />
          <rect class="build-dot" x="32" y="296" width="6" height="6" />
          <text class="chrome chrome--strong" x="46"  y="302">FIG. B</text>
          <text class="chrome"               x="92"  y="302">/</text>
          <text class="chrome chrome--strong" x="100" y="302">ins.modular</text>
          <text class="chrome chrome--strong" x="530" y="302" text-anchor="end">5 COMPONENTS &rarr; 1 PACKAGE</text>
        </g>
      </svg>
    </Hero>
  </section>

  {/* ────────────── OPTION D ────────────── */}
  <section class="insm-option" id="opt-d">
    <div class="container-page">
      <h2 class="insm-option__heading">Option D — Component × jurisdiction assembly</h2>
      <p class="insm-option__note">
        Same five components on the left, flowing into a profiler chip with
        a sample state filter (<code>state="CA"</code>), then out to an
        assembled state-specific <code>&lt;policy-form&gt;</code>. Footer
        multiplier annotates the M×N math: 5 components × 50 jurisdictions
        = 250 unique policies. Combines B's modular thesis with the page's
        50-state-variant thesis (S3 Conditional Filtering).
      </p>
    </div>
    <Hero variant="universal" title={HERO_TITLE} subdeck={HERO_SUBDECK} subdeckMaxWidth="520px">
      <svg
        class="mock-svg mock-d"
        id="mock-d"
        viewBox="0 0 560 320"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        role="presentation"
      >
        <g class="corner--accent fx" style="--d: 0ms">
          <path d="M 12 24 L 12 12 L 24 12" />
          <path d="M 536 12 L 548 12 L 548 24" />
          <path d="M 12 296 L 12 308 L 24 308" />
          <path d="M 536 308 L 548 308 L 548 296" />
        </g>

        <text class="chrome fx" x="30" y="30" style="--d: 80ms">in :: ins.assembly</text>

        {/* 5 component chips stacked on the left */}
        <g class="fx" style="--d: 200ms">
          <rect class="node node--custom" x="20" y="60" width="140" height="26" rx="3" />
          <text class="node-label node-label--custom" x="90" y="78" text-anchor="middle">&lt;declarations&gt;</text>
        </g>
        <g class="fx" style="--d: 240ms">
          <rect class="node node--custom" x="20" y="94" width="140" height="26" rx="3" />
          <text class="node-label node-label--custom" x="90" y="112" text-anchor="middle">&lt;agreements&gt;</text>
        </g>
        <g class="fx" style="--d: 280ms">
          <rect class="node node--custom" x="20" y="128" width="140" height="26" rx="3" />
          <text class="node-label node-label--custom" x="90" y="146" text-anchor="middle">&lt;conditions&gt;</text>
        </g>
        <g class="fx" style="--d: 320ms">
          <rect class="node node--custom" x="20" y="162" width="140" height="26" rx="3" />
          <text class="node-label node-label--custom" x="90" y="180" text-anchor="middle">&lt;exclusions&gt;</text>
        </g>
        <g class="fx" style="--d: 360ms">
          <rect class="node node--custom" x="20" y="196" width="140" height="26" rx="3" />
          <text class="node-label node-label--custom" x="90" y="214" text-anchor="middle">&lt;endorsements&gt;</text>
        </g>

        {/* 5 convergent connectors → profiler */}
        <path class="flow-conn" style="--d: 480ms" d="M 160 73  L 220 145" />
        <path class="flow-conn" style="--d: 500ms" d="M 160 107 L 220 145" />
        <path class="flow-conn" style="--d: 520ms" d="M 160 141 L 220 145" />
        <path class="flow-conn" style="--d: 540ms" d="M 160 175 L 220 145" />
        <path class="flow-conn" style="--d: 560ms" d="M 160 209 L 220 145" />

        {/* Profiler chip (middle) */}
        <g class="fx" style="--d: 640ms">
          <rect class="node node--custom" x="220" y="115" width="140" height="80" rx="3" />
          <rect class="artifact-strip" x="220" y="115" width="140" height="6" />
          <text class="node-label node-label--custom" x="290" y="143" text-anchor="middle">&lt;profile&gt;</text>
          <line class="artifact-rule" x1="236" y1="155" x2="344" y2="155" />
          <text class="meta-value" x="290" y="173" text-anchor="middle">state="CA"</text>
          <text class="node-caption" x="290" y="188" text-anchor="middle">applicable filter</text>
        </g>

        {/* Connector profiler → output */}
        <path class="flow-conn" style="--d: 740ms" d="M 360 155 L 395 155 M 390 150 L 395 155 L 390 160" />

        {/* Output: assembled <policy-form> chip */}
        <g class="fx" style="--d: 820ms">
          <rect class="node node--custom" x="400" y="115" width="140" height="80" rx="3" />
          <rect class="artifact-strip" x="400" y="115" width="140" height="6" />
          <text class="node-label node-label--custom" x="470" y="143" text-anchor="middle">&lt;policy-form&gt;</text>
          <line class="artifact-rule" x1="416" y1="155" x2="524" y2="155" />
          <text class="node-caption" x="470" y="173" text-anchor="middle">state-specific</text>
          <text class="node-caption" x="470" y="188" text-anchor="middle">filing-ready</text>
        </g>

        {/* Footer multiplier annotation */}
        <text class="multiplier-label fx" x="280" y="252" text-anchor="middle" style="--d: 920ms">5 components &times; 50 jurisdictions = 250 unique policies</text>

        {/* Bottom chrome */}
        <g class="fx" style="--d: 1020ms">
          <line class="chrome-rule" x1="30" y1="286" x2="530" y2="286" />
          <rect class="build-dot" x="32" y="296" width="6" height="6" />
          <text class="chrome chrome--strong" x="46"  y="302">FIG. D</text>
          <text class="chrome"               x="92"  y="302">/</text>
          <text class="chrome chrome--strong" x="100" y="302">ins.assembly</text>
          <text class="chrome chrome--strong" x="530" y="302" text-anchor="end">COMPONENTS &times; JURISDICTIONS &rarr; POLICIES</text>
        </g>
      </svg>
    </Hero>
  </section>
</BaseLayout>

<style>
  /* ─── Banner ─── */
  .insm-banner {
    background: #fef3c7;
    border-bottom: var(--border-hairline);
    padding: var(--space-3) 0;
  }
  .insm-banner__label {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.1em;
    color: var(--color-accent-primary-pressed);
    margin: 0 0 var(--space-2) 0;
  }
  .insm-banner__nav {
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;
  }
  .insm-banner__nav a {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-text-primary);
    text-decoration: none;
    border-bottom: 1px solid var(--color-accent-primary);
    padding-bottom: 1px;
  }
  .insm-banner__nav a:hover {
    color: var(--color-link-hover);
  }

  /* ─── Option section ─── */
  .insm-option {
    border-top: var(--border-hairline);
    padding-top: var(--space-8);
  }
  .insm-option__heading {
    font-family: var(--font-display);
    font-size: var(--text-display-md);
    font-weight: var(--weight-regular);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-3) 0;
    letter-spacing: var(--tracking-tight);
  }
  .insm-option__note {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin: 0;
    max-width: 70ch;
    text-wrap: pretty;
  }
  .insm-option__note code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: #fef3c7;
    padding: 0 4px;
    border-radius: 2px;
  }

  /* ─── Shared SVG idiom ─── */
  .mock-svg {
    width: 560px;
    max-width: 100%;
    height: auto;
    color: var(--color-text-primary);
    overflow: visible;
    display: block;
    shape-rendering: geometricPrecision;
  }
  .mock-svg .chrome {
    font-family: var(--font-mono);
    font-size: 9px;
    fill: var(--color-text-muted);
    letter-spacing: 0.06em;
    user-select: none;
  }
  .mock-svg .chrome--strong {
    fill: var(--color-text-primary);
    font-weight: var(--weight-medium);
  }
  .mock-svg .corner--accent {
    stroke: var(--color-accent-primary-hover);
    stroke-width: 1.25;
    fill: none;
  }
  .mock-svg .chrome-rule {
    stroke: var(--color-border-subtle);
    stroke-width: 1;
  }
  .mock-svg .build-dot {
    fill: var(--color-accent-primary-hover);
    stroke: none;
  }
  .mock-svg .node {
    fill: var(--color-page-bg);
    stroke: var(--color-text-primary);
    stroke-width: 1.5;
    vector-effect: non-scaling-stroke;
  }
  .mock-svg .node--custom {
    fill: #fef3c7;
    stroke: var(--color-accent-primary);
  }
  .mock-svg .node-label {
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: var(--weight-medium);
    fill: var(--color-text-primary);
    letter-spacing: 0.02em;
  }
  .mock-svg .node-label--custom {
    fill: var(--color-accent-primary-pressed);
  }
  .mock-svg .node-caption {
    font-family: var(--font-mono);
    font-size: 10px;
    fill: var(--color-text-secondary);
    letter-spacing: 0.04em;
  }
  .mock-svg .artifact-strip {
    fill: var(--color-accent-primary);
    stroke: none;
  }
  .mock-svg .artifact-rule {
    stroke: var(--color-border-subtle);
    stroke-width: 1;
  }
  .mock-svg .flow-conn {
    stroke: var(--color-accent-primary-hover);
    stroke-width: 1.5;
    fill: none;
    vector-effect: non-scaling-stroke;
    stroke-dasharray: 240;
    stroke-dashoffset: 240;
  }
  .mock-svg .meta-value {
    font-family: var(--font-mono);
    font-size: 11px;
    fill: var(--color-text-primary);
    letter-spacing: 0.04em;
  }
  .mock-svg .multiplier-label {
    font-family: var(--font-mono);
    font-size: 10.5px;
    fill: var(--color-text-secondary);
    letter-spacing: 0.06em;
  }

  /* ─── Animation (shared) ─── */
  .mock-svg .fx {
    opacity: 0;
  }
  .mock-svg.drawn .fx {
    animation: insm-fade 360ms ease-out forwards;
    animation-delay: var(--d, 0ms);
  }
  .mock-svg.drawn .flow-conn {
    animation: insm-draw 620ms ease-out forwards;
    animation-delay: var(--d, 0ms);
  }
  @keyframes insm-fade {
    to { opacity: 1; }
  }
  @keyframes insm-draw {
    to { stroke-dashoffset: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .mock-svg .fx {
      opacity: 1 !important;
      animation: none !important;
    }
    .mock-svg .flow-conn {
      stroke-dashoffset: 0 !important;
      animation: none !important;
    }
  }
</style>

<script>
  function setupMocks() {
    const svgs = document.querySelectorAll(".mock-svg");
    if (svgs.length === 0) return;
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("drawn");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );
    svgs.forEach((svg) => observer.observe(svg));
  }
  document.addEventListener("DOMContentLoaded", setupMocks);
</script>
