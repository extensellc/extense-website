---
/*
  TEMP MOCK -- hero-visual candidates for /services/ccms-services.
  Not linked in nav. DELETE once the visual is chosen.
  Three concepts rendered in the established hero node-graph idiom
  (corner marks, mono FIG. chrome, amber connectors). Shown statically
  (no scroll-reveal) for side-by-side comparison.
*/

import BaseLayout from "../../layouts/BaseLayout.astro";

const candidates = [
  {
    id: "A",
    name: "Workflow state graph",
    note: "Draft -> Review -> Approved -> Published, with a rework branch looping back. Conveys workflow management as the operational backbone of the CCMS.",
  },
  {
    id: "B",
    name: "CCMS hub with admin disciplines",
    note: "Central amber <ccms> node with four admin disciplines arranged around it (User Support, Schema Ops, Integrations, Backup & DR). Most directly captures the 'managed services' thesis.",
  },
  {
    id: "C",
    name: "Multi-platform convergence (many -> one)",
    note: "Four platform pills on the left (IXIASOFT, Tridion, Heretto, Paligo) all converging into a single amber managed-service hub. Inverts the Publishing fan so it reads distinctly.",
  },
];
---

<BaseLayout title="[MOCK] CCMS hero visuals -- Extense LLC" description="Temporary mockup page.">
  <section class="mock">
    <div class="mock__inner">
      <p class="mock__kicker">TEMP MOCK &middot; delete after selection</p>
      <h1 class="mock__title">CCMS Services &mdash; hero visual candidates</h1>
      <p class="mock__lead">Three concepts in the established hero idiom. Pick A, B, or C (or ask for a tweak); I'll build the real page with it and remove this page.</p>

      <!-- A — Workflow state graph -->
      <div class="mock__block">
        <p class="mock__label"><span class="mock__id">A</span> {candidates[0].name}</p>
        <p class="mock__desc">{candidates[0].note}</p>
        <div class="ccms-hero-visual">
          <svg class="ccms-hero-flow" viewBox="0 0 560 320" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" role="presentation">
            <g class="corner--accent"><path d="M 12 24 L 12 12 L 24 12" /><path d="M 536 12 L 548 12 L 548 24" /><path d="M 12 296 L 12 308 L 24 308" /><path d="M 536 308 L 548 308 L 548 296" /></g>
            <text class="chrome" x="30" y="32">in :: workflow.state</text>

            <g>
              <rect class="node" x="22" y="120" width="104" height="44" rx="3" />
              <text class="node-label" x="74" y="147" text-anchor="middle">draft</text>
            </g>
            <g>
              <rect class="node" x="159" y="120" width="104" height="44" rx="3" />
              <text class="node-label" x="211" y="147" text-anchor="middle">review</text>
            </g>
            <g>
              <rect class="node" x="296" y="120" width="104" height="44" rx="3" />
              <text class="node-label" x="348" y="147" text-anchor="middle">approved</text>
            </g>
            <g>
              <rect class="node node--custom" x="433" y="120" width="104" height="44" rx="3" />
              <text class="node-label node-label--custom" x="485" y="147" text-anchor="middle">published</text>
            </g>

            <path class="conn" d="M126 142 L159 142" />
            <path class="conn" d="M154 137 L159 142 L154 147" />
            <path class="conn" d="M263 142 L296 142" />
            <path class="conn" d="M291 137 L296 142 L291 147" />
            <path class="conn" d="M400 142 L433 142" />
            <path class="conn" d="M428 137 L433 142 L428 147" />

            <!-- rework branch: review bottom -> curve -> draft bottom -->
            <path class="conn" d="M211 164 Q155 230 80 168" />
            <path class="conn" d="M85 163 L80 168 L88 172" />
            <text class="node-caption" x="143" y="216" text-anchor="middle">rework</text>

            <line class="chrome-rule" x1="30" y1="286" x2="530" y2="286" />
            <rect class="build-dot" x="232" y="296" width="6" height="6" />
            <text class="chrome chrome--strong" x="246" y="302">FIG. 01</text>
            <text class="chrome" x="296" y="302">/</text>
            <text class="chrome chrome--strong" x="304" y="302">workflow.state</text>
            <text class="chrome chrome--strong" x="530" y="302" text-anchor="end">DRAFT &rarr; PUBLISHED</text>
          </svg>
        </div>
      </div>

      <!-- B — CCMS hub with admin disciplines -->
      <div class="mock__block">
        <p class="mock__label"><span class="mock__id">B</span> {candidates[1].name}</p>
        <p class="mock__desc">{candidates[1].note}</p>
        <div class="ccms-hero-visual">
          <svg class="ccms-hero-flow" viewBox="0 0 560 320" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" role="presentation">
            <g class="corner--accent"><path d="M 12 24 L 12 12 L 24 12" /><path d="M 536 12 L 548 12 L 548 24" /><path d="M 12 296 L 12 308 L 24 308" /><path d="M 536 308 L 548 308 L 548 296" /></g>
            <text class="chrome" x="30" y="32">in :: managed.surface</text>

            <!-- Top: user support -->
            <g>
              <rect class="node" x="210" y="54" width="140" height="34" rx="3" />
              <text class="node-label" x="280" y="76" text-anchor="middle">user support</text>
            </g>

            <!-- Left: schema ops -->
            <g>
              <rect class="node" x="24" y="148" width="120" height="34" rx="3" />
              <text class="node-label" x="84" y="170" text-anchor="middle">schema ops</text>
            </g>

            <!-- Center: CCMS hub (custom amber) -->
            <g>
              <rect class="node node--custom" x="225" y="140" width="110" height="44" rx="3" />
              <text class="node-label node-label--custom" x="280" y="167" text-anchor="middle">&lt;ccms&gt;</text>
            </g>

            <!-- Right: integrations -->
            <g>
              <rect class="node" x="416" y="148" width="120" height="34" rx="3" />
              <text class="node-label" x="476" y="170" text-anchor="middle">integrations</text>
            </g>

            <!-- Bottom: backup & DR -->
            <g>
              <rect class="node" x="210" y="232" width="140" height="34" rx="3" />
              <text class="node-label" x="280" y="254" text-anchor="middle">backup &amp; DR</text>
            </g>

            <!-- Connectors: hub edges to each surrounding box -->
            <path class="conn" d="M280 140 L280 88" />
            <path class="conn" d="M280 184 L280 232" />
            <path class="conn" d="M225 162 L144 165" />
            <path class="conn" d="M335 162 L416 165" />

            <line class="chrome-rule" x1="30" y1="286" x2="530" y2="286" />
            <rect class="build-dot" x="232" y="296" width="6" height="6" />
            <text class="chrome chrome--strong" x="246" y="302">FIG. 01</text>
            <text class="chrome" x="296" y="302">/</text>
            <text class="chrome chrome--strong" x="304" y="302">managed.surface</text>
            <text class="chrome chrome--strong" x="530" y="302" text-anchor="end">OPS &mdash; PLATFORM</text>
          </svg>
        </div>
      </div>

      <!-- C — Multi-platform convergence -->
      <div class="mock__block">
        <p class="mock__label"><span class="mock__id">C</span> {candidates[2].name}</p>
        <p class="mock__desc">{candidates[2].note}</p>
        <div class="ccms-hero-visual">
          <svg class="ccms-hero-flow" viewBox="0 0 560 320" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" role="presentation">
            <g class="corner--accent"><path d="M 12 24 L 12 12 L 24 12" /><path d="M 536 12 L 548 12 L 548 24" /><path d="M 12 296 L 12 308 L 24 308" /><path d="M 536 308 L 548 308 L 548 296" /></g>
            <text class="chrome" x="30" y="32">in :: managed.platforms</text>

            <!-- 4 platform pills on the left -->
            <g>
              <rect class="node" x="22" y="50" width="120" height="30" rx="3" />
              <text class="node-label" x="82" y="69" text-anchor="middle">IXIASOFT</text>
            </g>
            <g>
              <rect class="node" x="22" y="110" width="120" height="30" rx="3" />
              <text class="node-label" x="82" y="129" text-anchor="middle">Tridion</text>
            </g>
            <g>
              <rect class="node" x="22" y="170" width="120" height="30" rx="3" />
              <text class="node-label" x="82" y="189" text-anchor="middle">Heretto</text>
            </g>
            <g>
              <rect class="node" x="22" y="230" width="120" height="30" rx="3" />
              <text class="node-label" x="82" y="249" text-anchor="middle">Paligo</text>
            </g>

            <!-- Central managed-service hub (custom amber) -->
            <g>
              <rect class="node node--custom" x="370" y="130" width="170" height="50" rx="4" />
              <text class="node-label node-label--custom" x="455" y="153" text-anchor="middle">&lt;ccms&gt;</text>
              <text class="node-caption" x="455" y="171" text-anchor="middle">managed service</text>
            </g>

            <!-- Convergence lines: each platform right edge -> hub left edge -->
            <path class="conn" d="M142 65 L370 155" />
            <path class="conn" d="M142 125 L370 155" />
            <path class="conn" d="M142 185 L370 155" />
            <path class="conn" d="M142 245 L370 155" />

            <line class="chrome-rule" x1="30" y1="286" x2="530" y2="286" />
            <rect class="build-dot" x="232" y="296" width="6" height="6" />
            <text class="chrome chrome--strong" x="246" y="302">FIG. 01</text>
            <text class="chrome" x="296" y="302">/</text>
            <text class="chrome chrome--strong" x="304" y="302">managed.platforms</text>
            <text class="chrome chrome--strong" x="530" y="302" text-anchor="end">MANY &rarr; ONE</text>
          </svg>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .mock {
    padding: var(--space-16) 0 var(--space-24);
  }
  .mock__inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 var(--space-6);
  }
  .mock__kicker {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent-primary-pressed);
    margin: 0 0 var(--space-3);
  }
  .mock__title {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: var(--weight-regular);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-3);
  }
  .mock__lead {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-16);
  }
  .mock__block {
    margin-bottom: var(--space-16);
    padding-top: var(--space-8);
    border-top: var(--border-hairline);
  }
  .mock__label {
    font-family: var(--font-display);
    font-size: var(--text-display-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-2);
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .mock__id {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background-color: #fef3c7;
    color: var(--color-accent-primary-pressed);
    font-family: var(--font-mono);
    font-size: var(--text-caption);
  }
  .mock__desc {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-6);
    max-width: 60ch;
  }

  /* ─── Hero visual idiom (static; mirrors the DITA/Publishing hero) ─── */
  .ccms-hero-visual {
    width: 100%;
    display: flex;
    justify-content: center;
    padding: var(--space-6);
    border: var(--border-hairline);
    border-radius: var(--radius-sm);
    background-color: var(--color-page-bg);
  }
  .ccms-hero-flow {
    width: 560px;
    max-width: 100%;
    height: auto;
    color: var(--color-text-primary);
    overflow: visible;
    display: block;
    shape-rendering: geometricPrecision;
  }
  .ccms-hero-flow .chrome {
    font-family: var(--font-mono);
    font-size: 9px;
    fill: var(--color-text-muted);
    letter-spacing: 0.06em;
    user-select: none;
  }
  .ccms-hero-flow .chrome--strong {
    fill: var(--color-text-primary);
    font-weight: var(--weight-medium);
  }
  .ccms-hero-flow .corner--accent {
    stroke: var(--color-accent-primary-hover);
    stroke-width: 1.25;
    fill: none;
  }
  .ccms-hero-flow .chrome-rule {
    stroke: var(--color-border-subtle);
    stroke-width: 1;
  }
  .ccms-hero-flow .build-dot {
    fill: var(--color-accent-primary-hover);
    stroke: none;
  }
  .ccms-hero-flow .node {
    fill: var(--color-page-bg);
    stroke: var(--color-text-primary);
    stroke-width: 1.5;
    vector-effect: non-scaling-stroke;
  }
  .ccms-hero-flow .node--custom {
    fill: #fef3c7;
    stroke: var(--color-accent-primary);
  }
  .ccms-hero-flow .node-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: var(--weight-medium);
    fill: var(--color-text-primary);
    letter-spacing: 0.02em;
  }
  .ccms-hero-flow .node-label--custom {
    fill: var(--color-accent-primary-pressed);
  }
  .ccms-hero-flow .node-caption {
    font-family: var(--font-mono);
    font-size: 10px;
    fill: var(--color-text-secondary);
    letter-spacing: 0.04em;
  }
  .ccms-hero-flow .conn {
    stroke: var(--color-accent-primary-hover);
    stroke-width: 1.5;
    fill: none;
    vector-effect: non-scaling-stroke;
  }
</style>
