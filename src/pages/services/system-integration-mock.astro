              <text class="node-label" x="496" y="68" text-anchor="middle">TMS</text>
            </g>

            <!-- Drops from each top box to the connector layer -->
            <path class="conn" d="M79 80 L79 134" />
            <path class="conn" d="M223 80 L223 134" />
            <path class="conn" d="M367 80 L367 134" />
            <path class="conn" d="M496 80 L496 134" />

            <!-- Amber connector layer -->
            <line class="conn" x1="24" y1="140" x2="540" y2="140" />

            <!-- Chip on the layer -->
            <g>
              <rect class="node node--custom" x="210" y="128" width="140" height="24" rx="3" />
              <text class="node-label node-label--custom" x="280" y="145" text-anchor="middle">extense.connectors</text>
            </g>

            <!-- Drop from chip down to CCMS -->
            <path class="conn" d="M280 152 L280 210" />

            <!-- CCMS at bottom (custom amber) -->
            <g>
              <rect class="node node--custom" x="210" y="210" width="140" height="44" rx="3" />
              <text class="node-label node-label--custom" x="280" y="237" text-anchor="middle">&lt;ccms&gt;</text>
            </g>

            <line class="chrome-rule" x1="30" y1="286" x2="530" y2="286" />
            <rect class="build-dot" x="232" y="296" width="6" height="6" />
            <text class="chrome chrome--strong" x="246" y="302">FIG. 01</text>
            <text class="chrome" x="296" y="302">/</text>
            <text class="chrome chrome--strong" x="304" y="302">connector.layer</text>
            <text class="chrome chrome--strong" x="530" y="302" text-anchor="end">SYSTEMS &rarr; CCMS</text>
          </svg>
        </div>
      </div>

      <!-- C — Ecosystem mesh -->
      <div class="mock__block">
        <p class="mock__label"><span class="mock__id">C</span> {candidates[2].name}</p>
        <p class="mock__desc">{candidates[2].note}</p>
        <div class="si-hero-visual">
          <svg class="si-hero-flow" viewBox="0 0 560 320" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" role="presentation">
            <g class="corner--accent"><path d="M 12 24 L 12 12 L 24 12" /><path d="M 536 12 L 548 12 L 548 24" /><path d="M 12 296 L 12 308 L 24 308" /><path d="M 536 308 L 548 308 L 548 296" /></g>
            <text class="chrome" x="30" y="32">in :: connector.mesh</text>

            <!-- Perimeter connectors (drawn first so nodes paint over them) -->
            <path class="conn" d="M140 76 L420 76" />
            <path class="conn" d="M140 248 L420 248" />
            <path class="conn" d="M90 92 L90 232" />
            <path class="conn" d="M470 92 L470 232" />

            <!-- Spokes from CCMS to each corner -->
            <path class="conn" d="M280 162 L140 76" />
            <path class="conn" d="M280 162 L420 76" />
            <path class="conn" d="M280 162 L140 248" />
            <path class="conn" d="M280 162 L420 248" />

            <!-- Corner nodes -->
            <g>
              <rect class="node" x="40" y="60" width="100" height="32" rx="3" />
              <text class="node-label" x="90" y="80" text-anchor="middle">JIRA</text>
            </g>
            <g>
              <rect class="node" x="420" y="60" width="100" height="32" rx="3" />
              <text class="node-label" x="470" y="80" text-anchor="middle">Git</text>
            </g>
            <g>
              <rect class="node" x="40" y="232" width="100" height="32" rx="3" />
              <text class="node-label" x="90" y="252" text-anchor="middle">TMS</text>
            </g>
            <g>
              <rect class="node" x="420" y="232" width="100" height="32" rx="3" />
              <text class="node-label" x="470" y="252" text-anchor="middle">PLM</text>
            </g>

            <!-- Center: CCMS hub (custom amber) -->
            <g>
              <rect class="node node--custom" x="225" y="140" width="110" height="44" rx="3" />
              <text class="node-label node-label--custom" x="280" y="167" text-anchor="middle">&lt;ccms&gt;</text>
            </g>

            <line class="chrome-rule" x1="30" y1="286" x2="530" y2="286" />
            <rect class="build-dot" x="232" y="296" width="6" height="6" />
            <text class="chrome chrome--strong" x="246" y="302">FIG. 01</text>
            <text class="chrome" x="296" y="302">/</text>
            <text class="chrome chrome--strong" x="304" y="302">connector.mesh</text>
            <text class="chrome chrome--strong" x="530" y="302" text-anchor="end">ECOSYSTEM</text>
          </svg>
        </div>
      </div>

      <!-- D — Before / after (manual handoff eliminated) -->
      <div class="mock__block">
        <p class="mock__label"><span class="mock__id">D</span> {candidates[3].name}</p>
        <p class="mock__desc">{candidates[3].note}</p>
        <div class="si-hero-visual">
          <svg class="si-hero-flow" viewBox="0 0 560 320" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" role="presentation">
            <g class="corner--accent"><path d="M 12 24 L 12 12 L 24 12" /><path d="M 536 12 L 548 12 L 548 24" /><path d="M 12 296 L 12 308 L 24 308" /><path d="M 536 308 L 548 308 L 548 296" /></g>
            <text class="chrome" x="30" y="32">in :: handoff.eliminated</text>

            <!-- BEFORE row label -->
            <text class="chrome label--muted" x="30" y="48">BEFORE &middot; MANUAL</text>

            <!-- BEFORE: JIRA -> swivel-chair -> CCMS, all soft/dashed -->
            <g>
              <rect class="node" x="24" y="60" width="110" height="34" rx="3" />
              <text class="node-label" x="79" y="82" text-anchor="middle">JIRA</text>
            </g>
            <g>
              <rect class="node node--soft" x="210" y="60" width="140" height="34" rx="3" />
              <text class="node-label label--muted" x="280" y="82" text-anchor="middle">swivel-chair</text>
            </g>
            <g>
              <rect class="node" x="420" y="60" width="110" height="34" rx="3" />
              <text class="node-label" x="475" y="82" text-anchor="middle">&lt;ccms&gt;</text>
            </g>

            <!-- BEFORE: dashed connectors -->
            <path class="conn--soft" d="M134 77 L210 77" />
            <path class="conn--soft" d="M350 77 L420 77" />

            <!-- Amber demarcation rule (transformation moment) -->
            <line class="conn" x1="30" y1="160" x2="530" y2="160" />

            <!-- extense.connectors chip on the rule -->
            <g>
              <rect class="node node--custom" x="210" y="148" width="140" height="24" rx="3" />
              <text class="node-label node-label--custom" x="280" y="165" text-anchor="middle">extense.connectors</text>
            </g>

            <!-- AFTER row label -->
            <text class="chrome label--accent" x="30" y="208">AFTER &middot; AUTOMATED</text>

            <!-- AFTER: JIRA -> direct amber arrow -> CCMS (amber) -->
            <g>
              <rect class="node" x="24" y="222" width="110" height="34" rx="3" />
              <text class="node-label" x="79" y="244" text-anchor="middle">JIRA</text>
            </g>
            <g>
              <rect class="node node--custom" x="420" y="222" width="110" height="34" rx="3" />
              <text class="node-label node-label--custom" x="475" y="244" text-anchor="middle">&lt;ccms&gt;</text>
            </g>
            <path class="conn" d="M134 239 L420 239" />
            <path class="conn" d="M415 234 L420 239 L415 244" />

            <line class="chrome-rule" x1="30" y1="286" x2="530" y2="286" />
            <rect class="build-dot" x="232" y="296" width="6" height="6" />
            <text class="chrome chrome--strong" x="246" y="302">FIG. 01</text>
            <text class="chrome" x="296" y="302">/</text>
            <text class="chrome chrome--strong" x="304" y="302">handoff.eliminated</text>
            <text class="chrome chrome--strong" x="530" y="302" text-anchor="end">MANUAL &rarr; AUTOMATED</text>
          </svg>
        </div>
      </div>

      <!-- J — Hub-and-spoke with flow arrows (A++) -->
      <div class="mock__block">
        <p class="mock__label"><span class="mock__id">J</span> {candidates[4].name}</p>
        <p class="mock__desc">{candidates[4].note}</p>
        <div class="si-hero-visual">
          <svg class="si-hero-flow" viewBox="0 0 560 320" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" role="presentation">
            <g class="corner--accent"><path d="M 12 24 L 12 12 L 24 12" /><path d="M 536 12 L 548 12 L 548 24" /><path d="M 12 296 L 12 308 L 24 308" /><path d="M 536 308 L 548 308 L 548 296" /></g>
            <text class="chrome" x="30" y="32">in :: connector.hub</text>

            <!-- Top: JIRA -->
            <g>
              <rect class="node" x="215" y="54" width="130" height="34" rx="3" />
              <text class="node-label" x="280" y="76" text-anchor="middle">JIRA</text>
            </g>

            <!-- Left: Git -->
            <g>
              <rect class="node" x="24" y="148" width="120" height="34" rx="3" />
              <text class="node-label" x="84" y="170" text-anchor="middle">Git</text>
            </g>

            <!-- Center: CCMS hub (custom amber) -->
            <g>
              <rect class="node node--custom" x="225" y="140" width="110" height="44" rx="3" />
              <text class="node-label node-label--custom" x="280" y="167" text-anchor="middle">&lt;ccms&gt;</text>
            </g>

            <!-- Right: Salesforce -->
            <g>
              <rect class="node" x="416" y="148" width="120" height="34" rx="3" />
              <text class="node-label" x="476" y="170" text-anchor="middle">Salesforce</text>
            </g>

            <!-- Bottom: TMS -->
            <g>
              <rect class="node" x="215" y="232" width="130" height="34" rx="3" />
              <text class="node-label" x="280" y="254" text-anchor="middle">TMS</text>
            </g>

            <!-- Spokes with arrowheads pointing INTO the hub -->
            <path class="conn" d="M280 88 L280 140" />
            <path class="conn" d="M275 135 L280 140 L285 135" />
            <path class="conn" d="M280 232 L280 184" />
            <path class="conn" d="M275 189 L280 184 L285 189" />
            <path class="conn" d="M144 165 L225 162" />
            <path class="conn" d="M220 157 L225 162 L220 167" />
            <path class="conn" d="M416 165 L335 162" />
            <path class="conn" d="M340 157 L335 162 L340 167" />

            <line class="chrome-rule" x1="30" y1="286" x2="530" y2="286" />
            <rect class="build-dot" x="232" y="296" width="6" height="6" />
            <text class="chrome chrome--strong" x="246" y="302">FIG. 01</text>
            <text class="chrome" x="296" y="302">/</text>
            <text class="chrome chrome--strong" x="304" y="302">connector.hub</text>
            <text class="chrome chrome--strong" x="530" y="302" text-anchor="end">SYSTEMS &rarr; CCMS</text>
          </svg>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .mock {
    padding: var(--space-16) 0 var(--space-24);
  }
  .mock__inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 var(--space-6);
  }
  .mock__kicker {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent-primary-pressed);
    margin: 0 0 var(--space-3);
  }
  .mock__title {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: var(--weight-regular);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-3);
  }
  .mock__lead {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-16);
  }
  .mock__block {
    margin-bottom: var(--space-16);
    padding-top: var(--space-8);
    border-top: var(--border-hairline);
  }
  .mock__label {
    font-family: var(--font-display);
    font-size: var(--text-display-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-2);
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .mock__id {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background-color: #fef3c7;
    color: var(--color-accent-primary-pressed);
    font-family: var(--font-mono);
    font-size: var(--text-caption);
  }
  .mock__desc {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-6);
    max-width: 60ch;
  }

  /* ─── Hero visual idiom (static; mirrors DITA/Publishing/CCMS heroes) ─── */
  .si-hero-visual {
    width: 100%;
    display: flex;
    justify-content: center;
    padding: var(--space-6);
    border: var(--border-hairline);
    border-radius: var(--radius-sm);
    background-color: var(--color-page-bg);
  }
  .si-hero-flow {
    width: 560px;
    max-width: 100%;
    height: auto;
    color: var(--color-text-primary);
    overflow: visible;
    display: block;
    shape-rendering: geometricPrecision;
  }
  .si-hero-flow .chrome {
    font-family: var(--font-mono);
    font-size: 9px;
    fill: var(--color-text-muted);
    letter-spacing: 0.06em;
    user-select: none;
  }
  .si-hero-flow .chrome--strong {
    fill: var(--color-text-primary);
    font-weight: var(--weight-medium);
  }
  .si-hero-flow .corner--accent {
    stroke: var(--color-accent-primary-hover);
    stroke-width: 1.25;
    fill: none;
  }
  .si-hero-flow .chrome-rule {
    stroke: var(--color-border-subtle);
    stroke-width: 1;
  }
  .si-hero-flow .build-dot {
    fill: var(--color-accent-primary-hover);
    stroke: none;
  }
  .si-hero-flow .node {
    fill: var(--color-page-bg);
    stroke: var(--color-text-primary);
    stroke-width: 1.5;
    vector-effect: non-scaling-stroke;
  }
  .si-hero-flow .node--custom {
    fill: #fef3c7;
    stroke: var(--color-accent-primary);
  }
  .si-hero-flow .node--soft {
    stroke: var(--color-border-subtle);
    stroke-width: 1;
    stroke-dasharray: 4 4;
  }
  .si-hero-flow .conn--soft {
    stroke: var(--color-border-subtle);
    stroke-width: 1;
    stroke-dasharray: 4 4;
    fill: none;
  }
  .si-hero-flow .label--muted {
    fill: var(--color-text-secondary);
  }
  .si-hero-flow .label--accent {
    fill: var(--color-accent-primary-pressed);
  }
  .si-hero-flow .node-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: var(--weight-medium);
    fill: var(--color-text-primary);
    letter-spacing: 0.02em;
  }
  .si-hero-flow .node-label--custom {
    fill: var(--color-accent-primary-pressed);
  }
  .si-hero-flow .conn {
    stroke: var(--color-accent-primary-hover);
    stroke-width: 1.5;
    fill: none;
    vector-effect: non-scaling-stroke;
  }
</style>
