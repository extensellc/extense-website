---
/*
  TEMP MOCK -- hero-visual candidates for /services/system-integration.
  Not linked in nav. DELETE once the visual is chosen.
  Three concepts rendered in the established hero node-graph idiom
  (corner marks, mono FIG. chrome, amber connectors). Shown statically
  (no scroll-reveal) for side-by-side comparison.
*/

import BaseLayout from "../../layouts/BaseLayout.astro";

const candidates = [
  {
    id: "A",
    name: "Hub-and-spoke",
    note: "Central amber <ccms> with four external systems (JIRA, Git, Salesforce, TMS) connected around it. Most direct rendering of 'we connect your CCMS to your toolchain'.",
  },
  {
    id: "B",
    name: "Connector-layer bridge",
    note: "Your external systems on top; an amber 'extense.connectors' band bridges down to <ccms> below. Conveys 'we build the bridge between your tools and your CCMS'.",
  },
  {
    id: "C",
    name: "Ecosystem mesh",
    note: "Five nodes (CCMS + JIRA / Git / TMS / PLM) in a pentagonal arrangement with both spokes to CCMS and perimeter connections between systems. Conveys 'interconnected ecosystem, not just CCMS at the center'.",
  },
  {
    id: "D",
    name: "Before / after -- manual handoff eliminated",
    note: "Top row (BEFORE / MANUAL, soft dashed): JIRA -> swivel-chair human -> CCMS. Amber 'extense.connectors' rule across the middle. Bottom row (AFTER / AUTOMATED): JIRA -> direct amber arrow -> CCMS (amber). Literally renders the page's headline value: eliminated swivel-chair handoffs.",
  },
  {
    id: "J",
    name: "Hub-and-spoke with flow arrows (A++)",
    note: "Same hub-and-spoke as A, but each spoke ends in a small amber arrowhead pointing INTO the CCMS hub, so the connectors read as content flowing in, not just static lines. Adds the 'content flows' dimension A is missing.",
  },
];
---

<BaseLayout title="[MOCK] System Integration hero visuals -- Extense LLC" description="Temporary mockup page.">
  <section class="mock">
    <div class="mock__inner">
      <p class="mock__kicker">TEMP MOCK &middot; delete after selection</p>
      <h1 class="mock__title">System Integration &mdash; hero visual candidates</h1>
      <p class="mock__lead">Five concepts in the established hero idiom. Pick A, B, C, D, or J (or ask for a tweak); I'll build the real page with it and remove this page.</p>

      <!-- A — Hub-and-spoke -->
      <div class="mock__block">
        <p class="mock__label"><span class="mock__id">A</span> {candidates[0].name}</p>
        <p class="mock__desc">{candidates[0].note}</p>
        <div class="si-hero-visual">
          <svg class="si-hero-flow" viewBox="0 0 560 320" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" role="presentation">
            <g class="corner--accent"><path d="M 12 24 L 12 12 L 24 12" /><path d="M 536 12 L 548 12 L 548 24" /><path d="M 12 296 L 12 308 L 24 308" /><path d="M 536 308 L 548 308 L 548 296" /></g>
            <text class="chrome" x="30" y="32">in :: connector.hub</text>

            <!-- Top: JIRA -->
            <g>
              <rect class="node" x="215" y="54" width="130" height="34" rx="3" />
              <text class="node-label" x="280" y="76" text-anchor="middle">JIRA</text>
            </g>

            <!-- Left: Git -->
            <g>
              <rect class="node" x="24" y="148" width="120" height="34" rx="3" />
              <text class="node-label" x="84" y="170" text-anchor="middle">Git</text>
            </g>

            <!-- Center: CCMS hub (custom amber) -->
            <g>
              <rect class="node node--custom" x="225" y="140" width="110" height="44" rx="3" />
              <text class="node-label node-label--custom" x="280" y="167" text-anchor="middle">&lt;ccms&gt;</text>
            </g>

            <!-- Right: Salesforce -->
            <g>
              <rect class="node" x="416" y="148" width="120" height="34" rx="3" />
              <text class="node-label" x="476" y="170" text-anchor="middle">Salesforce</text>
            </g>

            <!-- Bottom: TMS -->
            <g>
              <rect class="node" x="215" y="232" width="130" height="34" rx="3" />
              <text class="node-label" x="280" y="254" text-anchor="middle">TMS</text>
            </g>

            <!-- Connectors: hub edges to each surrounding box -->
            <path class="conn" d="M280 140 L280 88" />
            <path class="conn" d="M280 184 L280 232" />
            <path class="conn" d="M225 162 L144 165" />
            <path class="conn" d="M335 162 L416 165" />

            <line class="chrome-rule" x1="30" y1="286" x2="530" y2="286" />
            <rect class="build-dot" x="232" y="296" width="6" height="6" />
            <text class="chrome chrome--strong" x="246" y="302">FIG. 01</text>
            <text class="chrome" x="296" y="302">/</text>
            <text class="chrome chrome--strong" x="304" y="302">connector.hub</text>
            <text class="chrome chrome--strong" x="530" y="302" text-anchor="end">SYSTEMS &rarr; CCMS</text>
          </svg>
        </div>
      </div>

      <!-- B — Connector-layer bridge -->
      <div class="mock__block">
        <p class="mock__label"><span class="mock__id">B</span> {candidates[1].name}</p>
        <p class="mock__desc">{candidates[1].note}</p>
        <div class="si-hero-visual">
          <svg class="si-hero-flow" viewBox="0 0 560 320" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" role="presentation">
            <g class="corner--accent"><path d="M 12 24 L 12 12 L 24 12" /><path d="M 536 12 L 548 12 L 548 24" /><path d="M 12 296 L 12 308 L 24 308" /><path d="M 536 308 L 548 308 L 548 296" /></g>
            <text class="chrome" x="30" y="32">in :: connector.layer</text>

