---
/*
  /services/dita-engineering — service detail page (the largest of the 7).

  Built bespoke (page-local CSS), reusing the shared atoms (Hero,
  SectionSiblings, CTAModule) and the card / callout / 01-0N strip / related
  patterns from TW + SCS. Faithful rebuild of the old ex-tense.co page (all 11
  sections), re-skinned.

  Shape: Hero -> switcher -> Backbone (prose + Core Competencies callout) ->
  Engineering Workflow (5-step) -> Engineering the Standard (3 cards) -> Case
  Study box -> Legacy Conversion (3 cards + dedup) -> IA for DITA (checklist +
  Governance callout) -> AI-Ready (3 cards + Data Asset) -> Delivery & Hosting
  (6 cards) -> DITA-OT Services (6 cards) -> Related (3 cards) -> CTA.

  Doc: docs/reframe-2026/dita-engineering.md
*/

import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/site/Hero.astro";
import CTAModule from "../../components/site/CTAModule.astro";
import SectionSiblings from "../../components/site/SectionSiblings.astro";

const coreCompetencies: string[] = [
  "DITA 1.3 & 2.0 Standards",
  "RNG & DTD Constraints",
  "Schematron Validation",
  "SubjectScheme Taxonomy",
];

interface Step {
  num: string;
  title: string;
  desc: string;
}
const workflow: Step[] = [
  { num: "01", title: "Analysis", desc: "Audit existing content for semantic patterns." },
  { num: "02", title: "Modeling", desc: "Define topic types and domain requirements." },
  { num: "03", title: "Development", desc: "Code the DTD/RNG schemas and plugins." },
  { num: "04", title: "Validation", desc: "Implement Schematron rules for QA." },
  { num: "05", title: "Deployment", desc: "Package into CCMS-ready frameworks." },
];

interface RichCard {
  title: string;
  body: string; // may contain inline <code>
}
const techniques: RichCard[] = [
  {
    title: "Specialization",
    body: "We create custom DITA specializations. If you are documenting APIs, we build an <code>&lt;api-operation&gt;</code> topic type. If you are in pharma, we build a <code>&lt;clinical-protocol&gt;</code> shell.",
  },
  {
    title: "Constraints",
    body: "Too many choices confuse writers. We use DITA constraints to remove unused elements (like <code>&lt;longquoteref&gt;</code>), simplifying the authoring interface and reducing training time.",
  },
  {
    title: "SubjectScheme Maps",
    body: "We implement robust metadata taxonomies using SubjectScheme. This allows you to control the values allowed in attributes like <code>@audience</code> or <code>@platform</code>, ensuring consistent filtering.",
  },
];

interface Card {
  title: string;
  body: string;
}
const legacyCards: Card[] = [
  {
    title: "Source Analysis & Mapping",
    body: "We audit your legacy corpus to identify structural patterns, implicit topic boundaries, and reuse candidates. Every paragraph style, heading level, and inline convention is mapped to the appropriate DITA element before a single file is converted.",
  },
  {
    title: "Automated Conversion Pipelines",
    body: "Using industry-proven migration tools — Stilo Migrate, custom XSLT/Python scripts, and pandoc-based workflows — we automate the bulk conversion. Manual intervention is reserved for edge cases, not the rule. Typical throughput: thousands of pages per sprint.",
  },
  {
    title: "Post-Conversion QA",
    body: "Automated Schematron validation, side-by-side visual diff against the original, and metadata completeness checks. We don't hand off until every topic passes structural and content-fidelity gates.",
  },
];

const iaChecklist: string[] = [
  "<strong>Topic typing rules</strong> — when to use concept vs. task vs. reference vs. troubleshooting",
  "<strong>Map hierarchy design</strong> — bookmap, submap, and relationship table structures for your deliverables",
  "<strong>Key architecture</strong> — keydef maps, key scopes, and variable resolution strategies for multi-product content",
  "<strong>Reuse strategy</strong> — conref, conkeyref, and content-reference library patterns that scale without fragility",
  "<strong>Metadata &amp; filtering model</strong> — <code>@audience</code>, <code>@platform</code>, <code>@product</code>, <code>@rev</code> attributes plus SubjectScheme-controlled values",
  "<strong>Naming &amp; folder conventions</strong> — file naming, directory structure, and ID strategies that work across CCMS, Git, and CI pipelines",
];

const aiCards: Card[] = [
  {
    title: "RAG-Optimized Chunking",
    body: "We size and structure topics for optimal vector embedding — right-sized for token limits, self-contained for retrieval accuracy. Short descriptions become embedding-friendly summaries. Metadata becomes filter context.",
  },
  {
    title: "Semantic Labeling",
    body: "Every topic carries machine-readable labels — topic type, product version, audience, and domain context. When an LLM retrieves a chunk, it knows what kind of content it's citing and can attribute the source precisely.",
  },
  {
    title: "JSON-LD & Knowledge Graph Mapping",
    body: "We map DITA metadata and SubjectScheme taxonomies to Schema.org types and RDF triples. Your documentation becomes a queryable knowledge graph — not just a file system of XML documents.",
  },
];

const deliveryCards: Card[] = [
  {
    title: "Static Site Publishing",
    body: "DITA-OT builds HTML5 output deployed to AWS S3 + CloudFront, Azure Blob, Netlify, or GitHub Pages. CI/CD pipelines trigger rebuilds on every commit — your documentation site is always current.",
  },
  {
    title: "Headless Content APIs",
    body: "Transform DITA to JSON and serve through REST or GraphQL endpoints. Applications, chatbots, and embedded help panels pull exactly the content they need at runtime — no monolithic help portal required.",
  },
  {
    title: "PDF & Print",
    body: "Branded PDF output via XSL-FO or CSS Paged Media (Prince XML, Antenna House). We build PDF plugins that match your corporate identity — cover pages, headers, footers, legal boilerplate — all templated and automated.",
  },
  {
    title: "Portal & CMS Integration",
    body: "Publish DITA output into Drupal, WordPress, Salesforce Knowledge, or SharePoint. We build the connector layer that maps topics to CMS content types, preserves navigation hierarchy, and handles incremental updates.",
  },
  {
    title: "Context-Sensitive Help",
    body: "Map topics to application screens using resource IDs. We configure the delivery layer so your software's help button retrieves the right topic for the current context — in-app panels, modals, or external links.",
  },
  {
    title: "Hosted Documentation Portals",
    body: "Fully managed documentation hosting with search, versioning, access control, and analytics. We set up and maintain the infrastructure so your team focuses on content, not servers.",
  },
];

const ditaotCards: Card[] = [
  {
    title: "DITA-OT Upgrades",
    body: "Migrating from DITA-OT 2.x or 3.x to 4.x? We handle the upgrade — testing your existing plugins for compatibility, updating deprecated Ant targets, resolving XSLT conflicts, and validating output parity against your current builds.",
  },
  {
    title: "Custom Plugin Development",
    body: "We build DITA-OT plugins for branded HTML5 themes, custom PDF layouts, JSON/YAML output, SCORM packaging, Salesforce Knowledge export, and any transform target your pipeline requires. Delivered with unit tests and documentation.",
  },
  {
    title: "CI/CD Pipeline Integration",
    body: "DITA-OT wrapped in Docker containers, triggered by GitHub Actions, Jenkins, GitLab CI, or Azure DevOps. We build the pipeline that validates, transforms, and deploys on every merge — with build failure notifications and output artifact archiving.",
  },
  {
    title: "Performance Optimization",
    body: "Slow builds with large document sets? We profile your DITA-OT pipeline, optimize XSLT transforms, configure parallel processing, and implement incremental builds so only changed topics are re-rendered.",
  },
  {
    title: "Troubleshooting & Support",
    body: "Broken builds, rendering inconsistencies, plugin conflicts, and encoding issues. We diagnose and fix DITA-OT problems — and document the root cause so your team can avoid repeat issues.",
  },
  {
    title: "DITA-OT Managed Service",
    body: "Ongoing maintenance contract: we monitor your build pipelines, apply DITA-OT patch releases, update plugins for compatibility, and provide a dedicated support channel for your publishing team. SLA-backed response times.",
  },
];

interface Related {
  name: string;
  href: string;
  desc: string;
}
const related: Related[] = [
  {
    name: "Publishing Engineering",
    href: "/services/publishing-engineering",
    desc: "Custom multi-channel publishing pipelines for PDF, HTML5, EPUB, and API documentation.",
  },
  {
    name: "XML Engineering",
    href: "/services/xml-engineering",
    desc: "Custom schema design, XSLT transformation, and validation pipelines.",
  },
  {
    name: "Structured Content Strategy",
    href: "/services/structured-content-strategy",
    desc: "Information architecture, taxonomy design, and content governance frameworks.",
  },
];
---

<BaseLayout
  title="DITA Engineering & Architecture — Extense LLC"
  description="Out-of-the-box DITA is rarely enough. Extense engineers the semantic model — specialization, constraints, SubjectScheme — plus conversion, IA, delivery, and DITA-OT, so your content is semantically meaningful and ready for automation, search, and AI."
>
  <Hero
    variant="universal"
    title="DITA Engineering & Architecture"
    subdeck="Out-of-the-box DITA is rarely enough. We engineer the semantic model &mdash; specialization, constraints, and SubjectScheme &mdash; that enforces consistency across teams of 50+ writers and feeds automation, search, and AI."
  />

  <SectionSiblings variant="services" current="dita-engineering" />

  <!-- S3 Backbone -->
  <section class="dita-section" aria-labelledby="backbone-heading">
    <div class="container-page dita-section__inner">
      <div class="dita-heading-block">
        <h2 id="backbone-heading" class="dita-heading">The Backbone of Intelligent Content</h2>
        <p class="dita-intro">
          Standard DITA is powerful, but &ldquo;out-of-the-box&rdquo; is rarely enough for enterprise requirements. We engineer the standard to work for you.
        </p>
      </div>

      <div class="dita-backbone">
        <div class="dita-backbone__prose">
          <h3 class="dita-subheading">Why Engineering Matters</h3>
          <p>
            Implementing DITA without engineering the semantic model is like building a house without a blueprint. You might have walls and a roof, but the plumbing won't connect. Effective DITA engineering bridges the gap between raw XML standards and your specific business logic. It ensures that your content is not just &ldquo;structured&rdquo; but <strong>semantically meaningful</strong>, ready for automation, faceted search, and dynamic delivery. At Extense, our information architects don't just know the tags; we know how to constrain and specialize them to enforce consistency across teams of 50+ writers.
          </p>
        </div>
        <div class="dita-callout">
          <p class="dita-callout__label">Core Competencies</p>
          <ul class="dita-checklist">
            {coreCompetencies.map((c) => (
              <li class="dita-check">
                <span class="dita-check__mark" aria-hidden="true">&#10003;</span>
                <span class="dita-check__text">{c}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- S4 Engineering Workflow -->
  <section class="dita-section" aria-labelledby="workflow-heading">
    <div class="container-page dita-section__inner">
      <div class="dita-heading-block">
        <h2 id="workflow-heading" class="dita-heading">Our Engineering Workflow</h2>
      </div>
      <ol class="dita-roadmap">
        {workflow.map((s, i) => (
          <>
            <li class="dita-step">
              <span class="dita-step__num">{s.num}</span>
              <h3 class="dita-step__title">{s.title}</h3>
              <p class="dita-step__desc">{s.desc}</p>
            </li>
            {i < workflow.length - 1 && (
              <li class="dita-step__arrow" aria-hidden="true">&rarr;</li>
            )}
          </>
        ))}
      </ol>
    </div>
  </section>

  <!-- S5 Engineering the Standard (techniques) -->
  <section class="dita-section" aria-labelledby="techniques-heading">
    <div class="container-page dita-section__inner">
      <div class="dita-heading-block">
        <h2 id="techniques-heading" class="dita-heading">Engineering the Standard</h2>
        <p class="dita-intro">
          Three techniques turn raw DITA into a model that fits your product — and your writers.
        </p>
      </div>
      <ul class="dita-grid-3">
        {techniques.map((t) => (
          <li class="dita-card">
            <h3 class="dita-card__title">{t.title}</h3>
            <p class="dita-card__body" set:html={t.body} />
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- S6 Case Study -->
  <section class="dita-section" aria-labelledby="casestudy-heading">
    <div class="container-page dita-section__inner">
      <div class="dita-casestudy">
        <h2 id="casestudy-heading" class="dita-casestudy__heading">Case Study: Semiconductor Fabrication</h2>
        <dl class="dita-casestudy__rows">
          <div class="dita-casestudy__row">
            <dt class="dita-casestudy__label">Scenario</dt>
            <dd class="dita-casestudy__text">A client needed to document register maps for 500+ chips. Manual entry was error-prone.</dd>
          </div>
          <div class="dita-casestudy__row">
            <dt class="dita-casestudy__label">Solution</dt>
            <dd class="dita-casestudy__text">We developed a custom DITA specialization for register data and wrote an XSLT transformation to auto-generate the DITA topics directly from the engineering IP-XACT files.</dd>
          </div>
          <div class="dita-casestudy__row">
            <dt class="dita-casestudy__label">Result</dt>
            <dd class="dita-casestudy__text"><strong>100% accuracy</strong> and zero manual authoring time for reference data.</dd>
          </div>
        </dl>
      </div>
    </div>
  </section>

  <!-- S7 Legacy Conversion (band) -->
  <section class="dita-section dita-section--band" aria-labelledby="legacy-heading">
    <div class="container-page dita-section__inner">
      <div class="dita-heading-block">
        <h2 id="legacy-heading" class="dita-heading">Legacy Content Conversion to DITA</h2>
        <p class="dita-intro">
          Migrate your existing documentation — Word, FrameMaker, HTML, InDesign, or proprietary XML — into clean, structured DITA topics.
        </p>
      </div>
      <ul class="dita-grid-3">
        {legacyCards.map((c) => (
          <li class="dita-card">
            <h3 class="dita-card__title">{c.title}</h3>
            <p class="dita-card__body">{c.body}</p>
          </li>
        ))}
      </ul>
      <div class="dita-subblock">
        <h3 class="dita-subblock__title">Deduplication at Conversion Time</h3>
        <p class="dita-subblock__body">
          During conversion, we analyze every paragraph and span across your entire document collection using structured content analysis. Exact-match and near-match duplicates are identified, consolidated into reusable warehouse topics with conref pointers, and tracked in a deduplication report — saving you from discovering redundancy months later. <strong>Typical result:</strong> 15–30% of content identified as duplicate and consolidated in the first pass.
        </p>
      </div>
    </div>
  </section>

  <!-- S8 Information Architecture -->
  <section class="dita-section" aria-labelledby="ia-heading">
    <div class="container-page dita-section__inner">
      <div class="dita-heading-block">
        <h2 id="ia-heading" class="dita-heading">Information Architecture for DITA</h2>
        <p class="dita-intro">
          Structure that scales. We design the IA layer that turns a collection of topics into a navigable, filterable, reusable content system.
        </p>
      </div>
      <div class="dita-ia">
        <div class="dita-ia__define">
          <h3 class="dita-subheading">What We Define</h3>
          <ul class="dita-checklist">
            {iaChecklist.map((item) => (
              <li class="dita-check">
                <span class="dita-check__mark" aria-hidden="true">&#10003;</span>
                <span class="dita-check__text" set:html={item} />
              </li>
            ))}
          </ul>
        </div>
        <div class="dita-callout">
          <p class="dita-callout__label">Governance Deliverables</p>
          <p class="dita-callout__body">
            Every IA engagement produces a <strong>DITA Style Guide</strong> — a living document that codifies topic templates, element usage rules, metadata requirements, and writing patterns. This becomes your team's single source of truth for content standards.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- S9 AI-Ready (band) -->
  <section class="dita-section dita-section--band" aria-labelledby="aiready-heading">
    <div class="container-page dita-section__inner">
      <div class="dita-heading-block">
        <h2 id="aiready-heading" class="dita-heading">AI-Ready Content Engineering</h2>
        <p class="dita-intro">
          Your DITA content is already structured. We make it machine-intelligent — optimized for retrieval, embedding, and LLM grounding.
        </p>
      </div>
      <ul class="dita-grid-3">
        {aiCards.map((c) => (
          <li class="dita-card">
            <h3 class="dita-card__title">{c.title}</h3>
            <p class="dita-card__body">{c.body}</p>
          </li>
        ))}
      </ul>
      <div class="dita-subblock">
        <h3 class="dita-subblock__title">From Documentation to Data Asset</h3>
        <p class="dita-subblock__body">
          Well-engineered DITA is <strong>70%</strong> of what you need for an AI content pipeline. The topic architecture provides natural chunk boundaries, metadata provides filter dimensions, and short descriptions provide ready-made summaries. We close the remaining 30% with transform plugins, embedding pipelines, and delivery API integration.
        </p>
      </div>
    </div>
  </section>

  <!-- S10 Delivery & Hosting -->
  <section class="dita-section" aria-labelledby="delivery-heading">
    <div class="container-page dita-section__inner">
      <div class="dita-heading-block">
        <h2 id="delivery-heading" class="dita-heading">Delivery & Hosting</h2>
        <p class="dita-intro">
          Content that's structured but not delivered is content that doesn't exist. We build the last mile — from DITA source to live, accessible output.
        </p>
      </div>
      <ul class="dita-grid-6">
        {deliveryCards.map((c) => (
          <li class="dita-card">
            <h3 class="dita-card__title">{c.title}</h3>
            <p class="dita-card__body">{c.body}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- S11 DITA-OT Services (band) -->
  <section class="dita-section dita-section--band" aria-labelledby="ditaot-heading">
    <div class="container-page dita-section__inner">
      <div class="dita-heading-block">
        <h2 id="ditaot-heading" class="dita-heading">DITA-OT Services</h2>
        <p class="dita-intro">
          The DITA Open Toolkit is the engine behind every output. We keep it running, extend it, and upgrade it.
        </p>
      </div>
      <ul class="dita-grid-6">
        {ditaotCards.map((c) => (
          <li class="dita-card">
            <h3 class="dita-card__title">{c.title}</h3>
            <p class="dita-card__body">{c.body}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- S12 Related -->
  <section class="dita-section dita-related-section" aria-labelledby="related-heading">
    <div class="container-page dita-section__inner">
      <div class="dita-heading-block">
        <h2 id="related-heading" class="dita-heading">Related Services</h2>
      </div>
      <ul class="dita-related-grid">
        {related.map((r) => (
          <li class="dita-related-card-item">
            <a href={r.href} class="dita-related-card">
              <span class="dita-related-card__eyebrow">Service</span>
              <h3 class="dita-related-card__title">{r.name}</h3>
              <p class="dita-related-card__body">{r.desc}</p>
              <span class="dita-related-card__cta">
                Explore <span class="dita-related-card__arrow" aria-hidden="true">&rarr;</span>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <CTAModule
    audience="general"
    compact
    accentLine
    body="Send us a sample of your DITA source — or your current docs if you're pre-DITA. We'll assess your information model, specialization opportunities, and DITA-OT pipeline, and return a concrete engineering plan. No commitment required."
  />
</BaseLayout>

<style>
  .dita-section {
    padding-top: var(--section-pad-default);
    padding-bottom: var(--section-pad-default);
    border-top: var(--border-hairline);
  }
  .dita-section--band {
    background-color: var(--color-surface-band);
  }
  @media (max-width: 767px) {
    .dita-section {
      padding-top: var(--space-16);
      padding-bottom: var(--space-16);
    }
  }

  /* ─── Heading block ─── */
  .dita-heading-block {
    max-width: none;
    margin: 0 auto var(--space-12) auto;
    text-align: center;
  }
  .dita-heading {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin: 0;
    text-wrap: balance;
  }
  .dita-intro {
    margin: var(--space-4) auto 0 auto;
    max-width: 80ch;
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    text-wrap: pretty;
  }
  .dita-subheading {
    font-family: var(--font-display);
    font-size: var(--text-display-sm);
    font-weight: var(--weight-medium);
    line-height: var(--leading-snug);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-4) 0;
  }

  /* ─── Backbone two-column ─── */
  .dita-backbone {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    align-items: start;
  }
  @media (min-width: 900px) {
    .dita-backbone {
      grid-template-columns: 1.7fr 1fr;
      gap: var(--space-12);
    }
  }
  .dita-backbone__prose p {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin: 0;
    text-wrap: pretty;
  }
  .dita-backbone__prose strong {
    color: var(--color-text-primary);
    font-weight: var(--weight-semibold);
  }

  /* ─── Callout (Core Competencies, Governance) ─── */
  .dita-callout {
    background-color: rgb(229 223 215 / 0.4);
    border-left: 3px solid var(--color-accent-primary);
    border-radius: var(--radius-sm);
    padding: var(--space-6) var(--space-8);
  }
  .dita-callout__label {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    font-weight: var(--weight-medium);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent-primary-pressed);
    margin: 0 0 var(--space-4) 0;
  }
  .dita-callout__body {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin: 0;
    text-wrap: pretty;
  }
  .dita-callout__body strong {
    color: var(--color-text-primary);
    font-weight: var(--weight-semibold);
  }

  /* ─── Checklists ─── */
  .dita-checklist {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .dita-check {
    display: flex;
    gap: var(--space-3);
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    text-wrap: pretty;
  }
  .dita-check__mark {
    flex: 0 0 auto;
    color: var(--color-accent-primary-pressed);
    font-weight: var(--weight-semibold);
  }
  .dita-check__text :global(strong),
  .dita-check__text strong {
    color: var(--color-text-primary);
    font-weight: var(--weight-semibold);
  }

  /* ─── Card grids ─── */
  .dita-grid-3,
  .dita-grid-6 {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }
  @media (min-width: 600px) {
    .dita-grid-6 {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 768px) {
    .dita-grid-3 {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .dita-grid-6 {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .dita-card {
    display: flex;
