    animation: twc-flow-draw 460ms ease-out forwards;
    animation-delay: var(--d, 0ms);
  }
  @keyframes twc-flow-fade {
    to { opacity: 1; }
  }
  @keyframes twc-flow-draw {
    to { stroke-dashoffset: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .twc-hero-flow .fx {
      opacity: 1 !important;
      animation: none !important;
    }
    .twc-hero-flow .flow-conn {
      stroke-dashoffset: 0 !important;
      animation: none !important;
    }
  }
</style>

<script>
  function setupTwcHero() {
    const svg = document.getElementById("twc-hero-flow");
    if (!svg) return;
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            svg.classList.add("drawn");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );
    observer.observe(svg);
  }

  document.addEventListener("DOMContentLoaded", setupTwcHero);
  document.addEventListener("astro:page-load", setupTwcHero);
</script>
