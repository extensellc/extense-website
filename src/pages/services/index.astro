---
/*
  /services — main Services page.

  Reframed to the old ex-tense.co structure:
    1. Hero — "Our Services"
    2. Expert Services Across the Content Lifecycle — 7 service cards
       (each -> a /services/<slug> detail page, built next)
    3. Engagement Models — lifecycle thesis + timeline + 3 model cards
       (Project-Based / Staff Augmentation / Managed Services)
    4. CTA-as-closer

  Replaces the prior bespoke "Three ways to engage" build (document-fragment
  cards + signals + lifecycle prose retired; the timeline visual is kept).
  The 3 engagement-model sub-pages are removed in favor of the compact
  section below.
*/

import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/site/Hero.astro";
import CTAModule from "../../components/site/CTAModule.astro";

interface Service {
  icon: "pencil" | "layers" | "gear" | "doc" | "database" | "link" | "code";
  name: string;
  href: string;
  desc: string;
}

const services: Service[] = [
  {
    icon: "pencil",
    name: "Technical Writing & Content Development",
    href: "/services/technical-writing-content-development",
    desc: "Professional authoring using Simplified Technical English (ASD-STE100), topic-based methodology, and minimalist principles. We write API references, user guides, install guides, release notes, and UX copy.",
  },
  {
    icon: "layers",
    name: "Structured Content Strategy",
    href: "/services/structured-content-strategy",
    desc: "Information Architecture (IA), taxonomy design, reuse models (conref, conkeyref, warehouse topics), and content governance frameworks that reduce redundancy by 40–60%.",
  },
  {
    icon: "gear",
    name: "DITA Engineering",
    href: "/services/dita-engineering",
    desc: "Specialization, constraints, SubjectScheme maps, and custom DITA-OT plugin development. We build the information model that fits your product, not the other way around.",
  },
  {
    icon: "doc",
    name: "Publishing Engineering",
    href: "/services/publishing-engineering",
    desc: "Custom DITA-OT PDF plugins (XSL-FO), responsive HTML5 themes, EPUB generation, and batch publishing automation via Jenkins, GitHub Actions, or Azure DevOps pipelines.",
  },
  {
    icon: "database",
    name: "CCMS Services",
    href: "/services/ccms-services",
    desc: "Post-implementation administration, Tier 2/3 helpdesk, schema updates, performance tuning for XML databases with 1M+ objects, onboarding, and orphan topic cleanup.",
  },
  {
    icon: "link",
    name: "System Integration",
    href: "/services/system-integration",
    desc: "Connecting your CCMS to JIRA, Git, Salesforce, Zendesk, PLM, and PIM systems. We build REST API middleware, webhooks, and event-driven connectors.",
  },
  {
    icon: "code",
    name: "XML & Schematron Engineering",
    href: "/services/xml-engineering",
    desc: "XSLT 2.0/3.0 transformations, Schematron business-rule validation, DTD/XSD specialization, and custom checkstyle rules for naming conventions and metadata enforcement.",
  },
];

interface Model {
  name: string;
  instrument: string;
  definition: string;
  bestWhen: string;
}

const models: Model[] = [
  {
    name: "Project-Based",
    instrument: "Statement of Work",
    definition: "Fixed scope, fixed fee, defined endpoint. The default for IA refactors, migration programs, and CCMS implementations.",
    bestWhen: "you have a clear deliverable and procurement wants a fixed price.",
  },
  {
    name: "Staff Augmentation",
    instrument: "Order Form (under your MSA)",
    definition: "Embedded senior specialists working to your plan, on your timelines — time-and-materials, 3–12 month engagements.",
    bestWhen: "you have the strategy and need execution capacity, or hiring is frozen but contracting isn’t.",
  },
  {
    name: "Managed Services",
    instrument: "Service Level Agreement",
    definition: "Your CCMS and publishing pipelines operated for you — administration, governance, Tier 2/3 support. SLA-bounded and recurring.",
    bestWhen: "the architecture is stable and the work has shifted from building to operating.",
  },
];

interface TimelineTrack {
  name: string;
  barLeft: number;
  barWidth: number;
  note: string;
  ongoing?: boolean;
}

const tracks: TimelineTrack[] = [
  {
    name: "Project-Based",
    barLeft: 0,
    barWidth: 48,
    note: "IA refactor · migration · pipeline build",
  },
  {
    name: "Staff Augmentation",
    barLeft: 36,
    barWidth: 38,
    note: "CCMS rollout · author training · client-led extensions",
  },
  {
    name: "Managed Services",
    barLeft: 62,
    barWidth: 38,
    note: "CCMS administration · publishing operation · governance",
    ongoing: true,
  },
];

const axisLabels = [
  { left: 0, text: "Month 0", align: "start" },
  { left: 25, text: "M 6", align: "center" },
  { left: 50, text: "M 12", align: "center" },
  { left: 75, text: "M 18", align: "center" },
  { left: 100, text: "M 24+", align: "end" },
];
---

<BaseLayout
  title="Our Services — Extense LLC"
  description="From authoring to automation, Extense provides expert services across the content lifecycle — technical writing, structured content strategy, DITA engineering, publishing engineering, CCMS services, system integration, and XML engineering — under project-based, staff-augmentation, or managed-services engagement models."
>
  <Hero
    variant="universal"
    title="Our Services"
    subdeck="From authoring to automation, we provide the expertise to optimize your content operations — so your documentation ships on schedule, stays consistent across every channel, and gives your AI clean, structured source to draw from."
  />

  <section class="svc-section svc-expert" aria-labelledby="expert-heading">
    <div class="container-page svc-section__inner">
      <div class="svc-expert__heading-block">
        <h2 id="expert-heading" class="svc-expert__heading">Expert Services Across the Content Lifecycle</h2>
        <p class="svc-expert__intro">
          From the first word written to the last pixel published, our team of information architects, XML engineers, and publishing specialists provide hands-on expertise at every stage.
        </p>
      </div>

      <ul class="svc-expert__grid">
        {services.map((s, i) => (
          <li class="svc-service-card-item" style={`--i: ${i}`}>
            <a href={s.href} class="svc-service-card">
              <span class="svc-service-card__icon" aria-hidden="true">
                {s.icon === "pencil" && (
                  <svg viewBox="0 0 20 20"><path d="M3 17 l1-4 L13 4 l3 3 L7 16 Z" /><line x1="11.5" y1="5.5" x2="14.5" y2="8.5" /></svg>
                )}
                {s.icon === "layers" && (
                  <svg viewBox="0 0 20 20"><path d="M10 2.5 L17.5 7 L10 11.5 L2.5 7 Z" /><path d="M2.5 11 L10 15.5 L17.5 11" /></svg>
                )}
                {s.icon === "gear" && (
                  <svg viewBox="0 0 20 20"><circle cx="10" cy="10" r="3.2" /><path d="M10 2 v2 M10 16 v2 M2 10 h2 M16 10 h2 M4.5 4.5 l1.4 1.4 M14.1 14.1 l1.4 1.4 M15.5 4.5 l-1.4 1.4 M5.9 14.1 l-1.4 1.4" /></svg>
                )}
                {s.icon === "doc" && (
                  <svg viewBox="0 0 20 20"><rect x="4" y="3" width="12" height="14" rx="1" /><line x1="7" y1="7" x2="13" y2="7" /><line x1="7" y1="10" x2="13" y2="10" /><line x1="7" y1="13" x2="11" y2="13" /></svg>
                )}
                {s.icon === "database" && (
                  <svg viewBox="0 0 20 20"><ellipse cx="10" cy="5" rx="6" ry="2.2" /><path d="M4 5 v10 c0 1.2 2.7 2.2 6 2.2 s6-1 6-2.2 V5" /><path d="M4 10 c0 1.2 2.7 2.2 6 2.2 s6-1 6-2.2" /></svg>
                )}
                {s.icon === "link" && (
                  <svg viewBox="0 0 20 20"><path d="M8.5 11.5 a3 3 0 0 1 0-4 l2-2 a3 3 0 0 1 4 4 l-1 1" /><path d="M11.5 8.5 a3 3 0 0 1 0 4 l-2 2 a3 3 0 0 1-4-4 l1-1" /></svg>
                )}
                {s.icon === "code" && (
                  <svg viewBox="0 0 20 20"><polyline points="7,6 3,10 7,14" /><polyline points="13,6 17,10 13,14" /></svg>
                )}
              </span>
              <h3 class="svc-service-card__name">{s.name}</h3>
              <p class="svc-service-card__desc">{s.desc}</p>
              <span class="svc-service-card__cta">
                Details <span class="svc-service-card__arrow" aria-hidden="true">&rarr;</span>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="svc-section svc-engage" aria-labelledby="engage-heading">
    <div class="container-data svc-section__inner">
      <div class="svc-engage__heading-block">
        <h2 id="engage-heading" class="svc-engage__heading">Engagement Models</h2>
        <p class="svc-engage__thesis">
          The right engagement model isn&rsquo;t a property of the client &mdash; it&rsquo;s a property of where the work is in its own lifecycle.
        </p>
      </div>

      <ul class="svc-engage__grid">
        {models.map((m, i) => (
          <li class="svc-model-card" style={`--i: ${i}`}>
            <p class="svc-model-card__instrument">{m.instrument}</p>
            <h3 class="svc-model-card__name">{m.name}</h3>
            <p class="svc-model-card__def">{m.definition}</p>
            <p class="svc-model-card__best">
              <span class="svc-model-card__best-label">Best when</span> {m.bestWhen}
            </p>
          </li>
        ))}
      </ul>

      <figure class="svc-timeline" aria-label="Typical multi-year client engagement journey">
        <figcaption class="svc-timeline__caption">A typical client journey</figcaption>

        <div class="svc-timeline__chart">
          {tracks.map((t) => (
            <div class="svc-track">
              <span class="svc-track__label">{t.name}</span>
              <div class="svc-track__plot">
                <div class="svc-track__line"></div>
                {[0, 25, 50, 75, 100].map((pct) => (
                  <div class="svc-track__tick" style={`left: ${pct}%`}></div>
                ))}
                <div
                  class:list={["svc-track__bar", t.ongoing && "svc-track__bar--ongoing"]}
                  style={`left: ${t.barLeft}%; width: ${t.barWidth}%`}
                ></div>
                {t.ongoing && <div class="svc-track__continues" aria-hidden="true">→</div>}
                <div class="svc-track__note" style={`left: ${t.barLeft}%`}>{t.note}</div>
              </div>
            </div>
          ))}

          <div class="svc-timeline__axis" aria-hidden="true">
            <span></span>
            <div class="svc-timeline__axis-scale">
              {axisLabels.map((l) => (
                <span
                  class:list={[
                    "svc-timeline__axis-label",
                    l.align === "start" && "svc-timeline__axis-label--start",
                    l.align === "end" && "svc-timeline__axis-label--end",
                  ]}
                  style={`left: ${l.left}%`}
                >{l.text}</span>
              ))}
            </div>
          </div>
        </div>

        <p class="svc-timeline__footnote">
          Illustrative. Actual durations and transitions vary per engagement — some clients skip a model, some stay in one indefinitely, some run two in parallel. The pattern is the point, not the timing.
        </p>
      </figure>
    </div>
  </section>

  <CTAModule
    audience="general"
    compact
    accentLine
    body="Tell us about the work — what you need authored, engineered, or operated. We'll recommend the service and engagement model that fit and return a representative scope so you can see exactly what an engagement looks like."
  />
</BaseLayout>

<style>
  .svc-section {
    padding-top: var(--section-pad-default);
    padding-bottom: var(--section-pad-default);
    border-top: var(--border-hairline);
  }

  @media (max-width: 767px) {
    .svc-section {
      padding-top: var(--space-16);
      padding-bottom: var(--space-16);
    }
  }

  /* ─── Expert Services ─── */
  .svc-expert__heading-block {
    max-width: none;
    margin: 0 auto var(--space-12) auto;
    text-align: center;
  }

  .svc-expert__heading {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin: 0;
    text-wrap: balance;
  }

  .svc-expert__intro {
    margin: var(--space-4) auto 0 auto;
    max-width: 80ch;
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    text-wrap: pretty;
  }

  /* 4-up grid (7 cards -> 4 + 3). */
  .svc-expert__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }
  @media (min-width: 600px) {
    .svc-expert__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .svc-expert__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .svc-service-card-item {
    display: flex;
  }

  .svc-service-card {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    border: var(--border-hairline);
    padding: var(--space-6) var(--space-6) var(--space-8);
    color: var(--color-text-primary);
    text-decoration: none;
    transition: border-color var(--duration-base) var(--easing-out),
      translate var(--duration-base) var(--easing-out);
  }
  .svc-service-card:hover,
  .svc-service-card:focus-visible {
    text-decoration: none;
    color: var(--color-text-primary);
    border-color: var(--color-text-secondary);
    translate: 0 -4px;
  }

  .svc-service-card__icon {
    display: inline-flex;
    align-self: flex-start;
    color: var(--color-accent-primary-hover);
    margin-bottom: var(--space-5);
  }
  .svc-service-card__icon svg {
    width: 22px;
    height: 22px;
  }
  .svc-service-card__icon svg circle,
  .svc-service-card__icon svg ellipse,
  .svc-service-card__icon svg line,
  .svc-service-card__icon svg polyline,
  .svc-service-card__icon svg rect,
  .svc-service-card__icon svg path {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
    vector-effect: non-scaling-stroke;
  }

  .svc-service-card__name {
    font-family: var(--font-display);
    font-size: var(--text-display-sm);
    font-weight: var(--weight-medium);
    line-height: var(--leading-snug);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-3) 0;
    text-wrap: balance;
  }

  .svc-service-card__desc {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin: 0 0 var(--space-4) 0;
    text-wrap: pretty;
    flex-grow: 1;
  }

  .svc-service-card__cta {
    font-size: var(--text-body-sm);
    font-weight: var(--weight-medium);
    color: var(--color-link);
    margin-top: auto;
    transition: color var(--duration-base) var(--easing-out);
  }
  .svc-service-card:hover .svc-service-card__cta,
  .svc-service-card:focus-visible .svc-service-card__cta {
    color: var(--color-link-hover);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }
  .svc-service-card__arrow {
    display: inline-block;
    transition: transform var(--duration-base) var(--easing-out);
  }
  .svc-service-card:hover .svc-service-card__arrow {
    transform: translateX(2px);
  }

  /* ─── Engagement Models ─── */
  .svc-engage__heading-block {
    max-width: none;
    margin: 0 auto var(--space-12) auto;
    text-align: center;
  }

  .svc-engage__heading {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin: 0;
    text-wrap: balance;
  }

  .svc-engage__thesis {
    margin: var(--space-4) auto 0 auto;
    max-width: 70ch;
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    text-wrap: pretty;
  }

  .svc-engage__grid {
    list-style: none;
    margin: 0 0 var(--space-16) 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }
  @media (min-width: 768px) {
    .svc-engage__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .svc-model-card {
    border: var(--border-hairline);
    padding: var(--space-8) var(--space-6);
    display: flex;
    flex-direction: column;
  }

  .svc-model-card__instrument {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent-primary-pressed);
    margin: 0 0 var(--space-3) 0;
  }

  .svc-model-card__name {
    font-family: var(--font-display);
    font-size: var(--text-display-md);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-3) 0;
    text-wrap: balance;
  }

  .svc-model-card__def {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin: 0 0 var(--space-5) 0;
    text-wrap: pretty;
    flex-grow: 1;
  }

  .svc-model-card__best {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-text-primary);
    line-height: var(--leading-normal);
    margin: 0;
    padding-top: var(--space-4);
    border-top: var(--border-hairline);
    text-wrap: pretty;
  }
  .svc-model-card__best-label {
    font-weight: var(--weight-semibold);
    color: var(--color-accent-primary-pressed);
  }

  /* ─── Lifecycle timeline (reused from the prior build) ─── */
  .svc-timeline {
    margin: 0;
    padding: 0;
  }

  .svc-timeline__caption {
    font-family: var(--font-body);
    font-size: var(--text-caption);
    letter-spacing: var(--tracking-wide);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-6);
  }

  .svc-timeline__chart {
    padding: var(--space-4) 0 var(--space-6);
  }

  .svc-track {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: var(--space-6);
    align-items: start;
    padding: var(--space-4) 0;
    border-top: var(--border-hairline);
  }

  .svc-track:last-of-type {
    border-bottom: var(--border-hairline);
  }

  @media (max-width: 599px) {
    .svc-track {
      grid-template-columns: 110px 1fr;
      gap: var(--space-3);
    }
  }

  .svc-track__label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    padding-top: 2px;
  }

  .svc-track__plot {
    position: relative;
    min-height: 80px;
  }

  .svc-track__line {
    position: absolute;
    top: 18px;
    left: 0;
    right: 0;
    height: 1px;
    background-color: var(--color-border-subtle);
  }

  .svc-track__tick {
    position: absolute;
    top: 14px;
    width: 1px;
    height: 9px;
    background-color: var(--color-border-subtle);
  }

  .svc-track__bar {
    position: absolute;
    top: 11px;
    height: 14px;
    background-color: #fcd34d;
    border-radius: 1px;
  }

  .svc-track__bar--ongoing {
    background: linear-gradient(
      to right,
      #fcd34d 0%,
      #fcd34d 88%,
      rgb(252 211 77 / 0) 100%
    );
  }

  .svc-track__continues {
    position: absolute;
    top: 7px;
    right: -4px;
    font-family: var(--font-mono);
    font-size: 13px;
    color: #fcd34d;
    line-height: 1;
  }

  .svc-track__note {
    position: absolute;
    top: 32px;
    max-width: 100%;
    padding-right: 4px;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 13.5px;
    color: var(--color-text-secondary);
    line-height: 1.3;
    text-wrap: pretty;
  }

  .svc-timeline__axis {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: var(--space-6);
    padding-top: var(--space-3);
  }

  @media (max-width: 599px) {
    .svc-timeline__axis {
      grid-template-columns: 110px 1fr;
      gap: var(--space-3);
    }
  }

  .svc-timeline__axis-scale {
    position: relative;
    height: 16px;
  }

  .svc-timeline__axis-label {
    position: absolute;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    text-transform: uppercase;
  }

  .svc-timeline__axis-label--start {
    transform: translateX(0);
  }

  .svc-timeline__axis-label--end {
    transform: translateX(-100%);
  }

  .svc-timeline__footnote {
    margin-top: var(--space-8);
    padding-top: var(--space-4);
    border-top: var(--border-hairline);
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    font-style: italic;
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    max-width: 60ch;
  }
</style>
