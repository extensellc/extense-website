    stroke: var(--color-text-primary);
    stroke-width: 1.4;
    stroke-linecap: round;
    stroke-linejoin: round;
    vector-effect: non-scaling-stroke;
  }
  .svc-hero-flow .flow-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: var(--weight-medium);
