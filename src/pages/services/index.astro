<script>
  /*
    Vertical scroll-progress indicator on the signals section.
    Fill height = (viewport-center − section-top) / section-height,
    clamped 0–1. Updates per requestAnimationFrame on scroll/resize.
    Respects prefers-reduced-motion by no-op'ing (CSS sets height: 100%).
  */
  (function () {
    const section = document.querySelector<HTMLElement>('[data-svc-scroll-section]');
    if (!section) return;
    const fill = section.querySelector<HTMLElement>('.svc-scroll-indicator__fill');
    if (!fill) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      return;
    }

    let ticking = false;
    function update() {
      ticking = false;
      const rect = section!.getBoundingClientRect();
      const viewportCenter = window.innerHeight / 2;
      const centerWithinSection = viewportCenter - rect.top;
      const ratio = Math.max(0, Math.min(1, centerWithinSection / rect.height));
      fill!.style.height = `${(ratio * 100).toFixed(2)}%`;
    }

    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
  })();
</script>
