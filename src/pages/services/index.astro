    font-size: 8px;
    fill: var(--color-text-muted);
    letter-spacing: 0.04em;
  }

  .svc-hero-flow .flow-conn {
    stroke: var(--color-accent-primary-hover);
    stroke-width: 1.5;
    fill: none;
    vector-effect: non-scaling-stroke;
    stroke-dasharray: 74;
    stroke-dashoffset: 74;
  }

  /* Reveal: fade-in cascade left-to-right; connectors draw via dashoffset. */
  .svc-hero-flow .fx {
    opacity: 0;
  }
  .svc-hero-flow.drawn .fx {
    animation: svc-flow-fade 360ms ease-out forwards;
    animation-delay: var(--d, 0ms);
  }
  .svc-hero-flow.drawn .flow-conn {
    animation: svc-flow-draw 420ms ease-out forwards;
    animation-delay: var(--d, 0ms);
  }
  @keyframes svc-flow-fade {
    to { opacity: 1; }
  }
  @keyframes svc-flow-draw {
    to { stroke-dashoffset: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .svc-hero-flow .fx {
      opacity: 1 !important;
      animation: none !important;
    }
    .svc-hero-flow .flow-conn {
      stroke-dashoffset: 0 !important;
      animation: none !important;
    }
  }
</style>

<script>
  function setupServicesHero() {
    const svg = document.getElementById("svc-hero-flow");
    if (!svg) return;
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            svg.classList.add("drawn");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );
    observer.observe(svg);
  }

  document.addEventListener("DOMContentLoaded", setupServicesHero);
  document.addEventListener("astro:page-load", setupServicesHero);
</script>
