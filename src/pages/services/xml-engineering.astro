<script>
  function setupXeHero() {
    const svg = document.getElementById("xe-hero-flow");
    if (!svg) return;
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            svg.classList.add("drawn");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );
    observer.observe(svg);
  }

  document.addEventListener("DOMContentLoaded", setupXeHero);
  document.addEventListener("astro:page-load", setupXeHero);
</script>
