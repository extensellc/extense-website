---
/*
  CaseStudyPageLayout — technical-brief layout for case study detail pages.

  Reads as an engineering record, not a marketing page. Two-column document
  grid throughout: a left mono-label rail + a content column. The rail
  carries section labels and decision numbers; the content column carries
  the actual data and prose.

  Structure (every section follows the rail / content pattern):
    1. Breadcrumb (full width above the title block)
    2. Header — case meta + title + frame (full width)
    3. Engagement record (rail: Duration / Team / Engagement / Status)
    4. AnimatedDivider
    5. Rail: "The challenge" / "The approach" — stacked, paragraph each
    6. Rail: "Artifact ledger" — 4-stat strip in content column
    7. Rail: "Stack" — key/value dl in content column
    8. <slot /> — case-specific sections (each follows the rail pattern,
       see the three detail pages for examples)
    9. AnimatedDivider
   10. Rail: "Decisions & trade-offs" intro, then numbered rail-rows where
       the rail is the decision number ("01" / "02" / ...)
   11. Rail: "A note on these numbers" — methodology disclosure
   12. AnimatedDivider
   13. CTAModule

  The .cs-rail-row* classes are defined globally so slot content in the
  detail pages can use the same pattern without duplicating the rules.
*/

import BaseLayout from "./BaseLayout.astro";
import CTAModule from "../components/site/CTAModule.astro";
import AnimatedDivider from "../components/site/AnimatedDivider.astro";

interface ArtifactLedgerItem {
  number: string;
  label: string;
}

interface EngagementMeta {
  duration: string;
  team: string;
  engagement: string;
  status: string;
}

interface StackRow {
  label: string;
  value: string;
}

interface Decision {
  decision: string;
  chosen: string;
  rejected: string;
  why: string;
}

interface Props {
  caseNumber: string;
  caseTotal: string;
  year: string;
  sector: string;
  title: string;
  frame: string;
  challenge: string;
  approach: string;
  artifacts: ArtifactLedgerItem[];
  engagement: EngagementMeta;
  stack: StackRow[];
  decisions: Decision[];
  /** Page meta */
  metaTitle: string;
  metaDescription: string;
}

const {
  caseNumber,
  caseTotal,
  year,
  sector,
  title,
  frame,
  challenge,
  approach,
  artifacts,
  engagement,
  stack,
  decisions,
  metaTitle,
  metaDescription,
} = Astro.props;

const engagementRows: { label: string; value: string }[] = [
  { label: "Duration",   value: engagement.duration },
  { label: "Team",       value: engagement.team },
  { label: "Engagement", value: engagement.engagement },
  { label: "Status",     value: engagement.status },
];
---

<BaseLayout title={metaTitle} description={metaDescription}>
  <section class="cs-header" aria-labelledby="cs-title">
    <div class="container-page cs-header__inner">
      <p class="cs-header__breadcrumb">
        <a href="/company/our-work-and-case-studies" class="cs-header__back">← Our Work &amp; Case Studies</a>
      </p>

      <div class="cs-header__top">
        <div class="cs-header__lead">
          <p class="cs-header__meta">
            <span class="cs-header__meta-item">CASE {caseNumber} / {caseTotal}</span>
            <span class="cs-header__meta-sep" aria-hidden="true">·</span>
            <span class="cs-header__meta-item">{year}</span>
            <span class="cs-header__meta-sep" aria-hidden="true">·</span>
            <span class="cs-header__meta-item">{sector}</span>
          </p>

          <h1 id="cs-title" class="cs-header__title">{title}</h1>
          <p class="cs-header__frame">{frame}</p>
        </div>

        <div class="cs-header__visual">
          <slot name="visual" />
        </div>
      </div>

      <dl class="cs-engagement" aria-label="Engagement record">
        {engagementRows.map((row) => (
          <div class="cs-rail-row cs-rail-row--engagement">
            <dt class="cs-rail-row__label">{row.label}</dt>
            <dd class="cs-rail-row__value">{row.value}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <AnimatedDivider />

  <section class="cs-section" aria-labelledby="ca-heading">
    <div class="container-page cs-section__inner">
      <h2 id="ca-heading" class="cs-section__visually-hidden">Challenge and approach</h2>
      <article class="cs-rail-row cs-rail-row--ca">
        <h3 class="cs-rail-row__label">The challenge</h3>
        <p class="cs-rail-row__paragraph">{challenge}</p>
      </article>
      <article class="cs-rail-row cs-rail-row--ca">
        <h3 class="cs-rail-row__label">The approach</h3>
        <p class="cs-rail-row__paragraph">{approach}</p>
      </article>
    </div>
  </section>

  <section class="cs-section" aria-labelledby="ledger-heading">
    <div class="container-page cs-section__inner">
      <div class="cs-rail-row">
        <p class="cs-rail-row__label" id="ledger-heading">Artifact ledger</p>
        <div class="cs-rail-row__content">
          <ul class="cs-ledger">
            {artifacts.map((a) => (
              <li class="cs-ledger__row">
                <span class="cs-ledger__num">{a.number}</span>
                <span class="cs-ledger__label">{a.label}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="cs-section" aria-labelledby="stack-heading">
    <div class="container-page cs-section__inner">
      <div class="cs-rail-row">
        <p class="cs-rail-row__label" id="stack-heading">Stack</p>
        <div class="cs-rail-row__content">
          <dl class="cs-stack">
            {stack.map((row) => (
              <div class="cs-stack__row">
                <dt class="cs-stack__label">{row.label}</dt>
                <dd class="cs-stack__value">{row.value}</dd>
              </div>
            ))}
          </dl>
        </div>
      </div>
    </div>
  </section>

  <slot />

  <AnimatedDivider />

  <section class="cs-section" aria-labelledby="decisions-heading">
    <div class="container-page cs-section__inner">
      <div class="cs-rail-row cs-rail-row--decisions-intro">
        <h2 id="decisions-heading" class="cs-rail-row__label">Decisions and trade-offs</h2>
        <p class="cs-rail-row__paragraph">
          The choices that shaped the engagement, recorded with the option taken and what was rejected. The reasoning matters more than the outcome.
        </p>
      </div>

      <ol class="cs-decisions">
        {decisions.map((d, i) => (
          <li class="cs-decision cs-rail-row">
            <span class="cs-decision__num" aria-hidden="true">{String(i + 1).padStart(2, "0")}</span>
            <div class="cs-decision__body">
              <p class="cs-decision__title">{d.decision}</p>
              <div class="cs-decision__grid">
                <div class="cs-decision__col">
                  <p class="cs-decision__col-label">Chosen</p>
                  <p class="cs-decision__col-value">{d.chosen}</p>
                </div>
                <div class="cs-decision__col">
                  <p class="cs-decision__col-label">Rejected</p>
                  <p class="cs-decision__col-value">{d.rejected}</p>
                </div>
              </div>
              <p class="cs-decision__why"><span class="cs-decision__why-tag">Why:</span> {d.why}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="cs-section" aria-labelledby="note-heading">
    <div class="container-page cs-section__inner">
      <div class="cs-rail-row">
        <h2 id="note-heading" class="cs-rail-row__label">A note on these numbers</h2>
        <p class="cs-rail-row__paragraph">
          The figures in the artifact ledger are direct counts from the deliverables shipped on this engagement — not ROI projections or aggregated averages. Outcome percentages referenced anywhere on this site reflect industry benchmarks published by OASIS, Gartner, and CIDM for organizations that achieve 40%+ content reuse with structured metadata. Your actual results depend on content volume, language count, update frequency, and current toolchain maturity. Every engagement begins by measuring your baseline so projections are defensible.
        </p>
      </div>
    </div>
  </section>

  <AnimatedDivider />

  <CTAModule
    audience="general"
    body="Submit a 20-page sample. We'll return conversion feasibility, content recovery rate, and engineering effort within two business days. The analysis is the basis for any further engagement, with no obligation to proceed."
  />
</BaseLayout>

<script>
  function setupCsHero() {
    const svgs = document.querySelectorAll(".cs-hero-flow");
    if (!svgs.length) return;
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("drawn");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );
    svgs.forEach((svg) => observer.observe(svg));
  }

  document.addEventListener("DOMContentLoaded", setupCsHero);
  document.addEventListener("astro:page-load", setupCsHero);
</script>

<style is:global>
  /* ─── Rail-row layout primitive (used by layout + slot content) ─── */
  .cs-rail-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
  }

  @media (min-width: 768px) {
    .cs-rail-row {
      grid-template-columns: 220px 1fr;
      gap: var(--space-12);
      align-items: baseline;
    }
  }

  .cs-rail-row__label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.5;
  }

  .cs-rail-row__value {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    line-height: 1.45;
    color: var(--color-text-primary);
    margin: 0;
    text-wrap: pretty;
  }

  .cs-rail-row__paragraph {
    font-family: var(--font-body);
    font-size: var(--text-body);
    line-height: var(--leading-normal);
    color: var(--color-text-secondary);
    margin: 0;
    text-wrap: pretty;
    max-width: 70ch;
  }

  .cs-rail-row__content {
    /* generic slot for grids/lists in the right column; layout is its own */
  }

  /* ─── Shared hero-visual SVG idiom (used by detail pages via slot) ─── */
  .cs-hero-flow {
    width: 100%;
    height: auto;
    max-width: 520px;
    color: var(--color-text-primary);
    overflow: visible;
    display: block;
    shape-rendering: geometricPrecision;
  }
  .cs-hero-flow .chrome {
    font-family: var(--font-mono);
    font-size: 9px;
    fill: var(--color-text-muted);
    letter-spacing: 0.06em;
    user-select: none;
  }
  .cs-hero-flow .chrome--strong {
    fill: var(--color-text-primary);
    font-weight: var(--weight-medium);
  }
  .cs-hero-flow .label--muted {
    fill: var(--color-text-secondary);
  }
  .cs-hero-flow .label--accent {
    fill: var(--color-accent-primary-pressed);
  }
  .cs-hero-flow .corner {
    stroke: var(--color-accent-primary-hover);
    stroke-width: 1.25;
    fill: none;
  }
  .cs-hero-flow .chrome-rule {
    stroke: var(--color-border-subtle);
    stroke-width: 1;
  }
  .cs-hero-flow .build-dot {
    fill: var(--color-accent-primary-hover);
    stroke: none;
  }
  .cs-hero-flow .node {
    fill: var(--color-page-bg);
    stroke: var(--color-text-primary);
    stroke-width: 1.5;
    vector-effect: non-scaling-stroke;
  }
  .cs-hero-flow .node--custom {
    fill: #fef3c7;
    stroke: var(--color-accent-primary);
  }
  .cs-hero-flow .node--soft {
    stroke: var(--color-border-subtle);
    stroke-width: 1;
    stroke-dasharray: 4 4;
  }
  .cs-hero-flow .node-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: var(--weight-medium);
    fill: var(--color-text-primary);
    letter-spacing: 0.02em;
  }
  .cs-hero-flow .node-label--custom {
    fill: var(--color-accent-primary-pressed);
  }
  .cs-hero-flow .node-label--muted {
    fill: var(--color-text-secondary);
  }
  .cs-hero-flow .doc {
    fill: var(--color-page-bg);
    stroke: var(--color-text-primary);
    stroke-width: 1.5;
    vector-effect: non-scaling-stroke;
  }
  .cs-hero-flow .doc--custom {
    stroke: var(--color-accent-primary);
  }
  .cs-hero-flow .doc-band {
    fill: var(--color-surface-band);
    stroke: none;
  }
  .cs-hero-flow .doc-band--custom {
    fill: #fef3c7;
  }
  .cs-hero-flow .doc-label {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: var(--weight-semibold);
    fill: var(--color-text-secondary);
    letter-spacing: 0.06em;
  }
  .cs-hero-flow .doc-label--custom {
    fill: var(--color-accent-primary-pressed);
  }
  .cs-hero-flow .doc-line {
    fill: var(--color-text-muted);
    opacity: 0.45;
  }
  .cs-hero-flow .doc-line--soft {
    fill: var(--color-text-muted);
    opacity: 0.25;
  }
  .cs-hero-flow .flow-conn {
    stroke: var(--color-accent-primary-hover);
    stroke-width: 1.5;
    fill: none;
    vector-effect: non-scaling-stroke;
    stroke-dasharray: 540;
    stroke-dashoffset: 540;
  }
  .cs-hero-flow .conn--soft {
    stroke: var(--color-border-subtle);
    stroke-width: 1;
    stroke-dasharray: 4 4;
    fill: none;
  }
  .cs-hero-flow .toc-num {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: var(--weight-medium);
    fill: var(--color-accent-primary-pressed);
    letter-spacing: 0.04em;
  }
  .cs-hero-flow .toc-label {
    font-family: var(--font-body);
    font-size: 10px;
    fill: var(--color-text-primary);
    letter-spacing: 0;
  }
  .cs-hero-flow .fx {
    opacity: 0;
  }
  .cs-hero-flow.drawn .fx {
    animation: cs-hero-fade 360ms ease-out forwards;
    animation-delay: var(--d, 0ms);
  }
  .cs-hero-flow.drawn .flow-conn {
    animation: cs-hero-draw 620ms ease-out forwards;
    animation-delay: var(--d, 0ms);
  }
  @keyframes cs-hero-fade {
    to { opacity: 1; }
  }
  @keyframes cs-hero-draw {
    to { stroke-dashoffset: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .cs-hero-flow .fx {
      opacity: 1 !important;
      animation: none !important;
    }
    .cs-hero-flow .flow-conn {
      stroke-dashoffset: 0 !important;
      animation: none !important;
    }
  }

  /* Hairline divider between rail rows when stacked vertically.
     (var(--space-10) doesn't exist on the scale and silently computes to 0,
     so use space-6 = 24px each side for a deliberate compact buffer.) */
  .cs-rail-row + .cs-rail-row {
    margin-top: var(--space-6);
    padding-top: var(--space-6);
    border-top: var(--border-hairline);
  }
  @media (max-width: 767px) {
    .cs-rail-row + .cs-rail-row {
      margin-top: var(--space-4);
      padding-top: var(--space-4);
    }
  }
</style>

<style>
  /* ─── Header ─── */
  .cs-header {
    padding-top: var(--space-12);
    padding-bottom: var(--space-8);
  }

  @media (min-width: 768px) {
    .cs-header {
      padding-top: var(--space-20);
      padding-bottom: var(--space-12);
    }
  }

  /* Header top: title block + optional visual side-by-side on desktop */
  .cs-header__top {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    margin-bottom: var(--space-8);
  }

  @media (min-width: 1024px) {
    .cs-header__top {
      flex-direction: row;
      align-items: center;
      gap: var(--space-12);
      margin-bottom: var(--space-12);
    }
  }

  .cs-header__lead {
    flex: 1 1 0;
    min-width: 0;
  }

  .cs-header__visual {
    flex: 0 0 auto;
    width: 100%;
  }

  @media (min-width: 1024px) {
    .cs-header__visual {
      width: 520px;
      max-width: 50%;
    }
  }

  .cs-header__visual:empty {
    display: none;
  }

  .cs-header__breadcrumb {
    margin: 0 0 var(--space-8) 0;
  }

  .cs-header__back {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .cs-header__back:hover,
  .cs-header__back:focus-visible {
    color: var(--color-link);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }

  .cs-header__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: baseline;
    margin: 0 0 var(--space-6) 0;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .cs-header__meta-item {
    color: var(--color-text-muted);
  }

  .cs-header__meta-sep {
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  .cs-header__title {
    font-family: var(--font-display);
    font-size: var(--text-display-xl);
    font-weight: var(--weight-regular);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-6) 0;
    text-wrap: balance;
    max-width: 22ch;
  }

  .cs-header__frame {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    line-height: var(--leading-normal);
    color: var(--color-text-secondary);
    margin: 0;
    text-wrap: pretty;
    max-width: 65ch;
  }

  /* Engagement record — rail-row pattern, but tighter row spacing.
     Reset the auto-hairline between rail-rows since we use one
     enclosing top/bottom rule instead. */
  .cs-engagement {
    margin: 0;
    padding: var(--space-6) 0;
    border-top: var(--border-hairline);
    border-bottom: var(--border-hairline);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .cs-engagement .cs-rail-row + .cs-rail-row {
    margin-top: 0;
    padding-top: 0;
    border-top: 0;
  }

  /* ─── Section spacing ─── */
  .cs-section {
    padding-top: var(--space-8);
    padding-bottom: var(--space-8);
  }

  @media (min-width: 768px) {
    .cs-section {
      padding-top: var(--space-12);
      padding-bottom: var(--space-12);
    }
  }

  .cs-section__visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ─── Artifact ledger — 4-stat strip in the content column ─── */
  .cs-ledger {
    list-style: none;
    margin: 0;
    padding: var(--space-3) 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-8) var(--space-8);
    border-top: var(--border-hairline);
    border-bottom: var(--border-hairline);
  }

  @media (min-width: 768px) {
    .cs-ledger {
      grid-template-columns: repeat(4, 1fr);
      padding: var(--space-5) 0;
    }
  }

  .cs-ledger__row {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .cs-ledger__num {
    font-family: var(--font-display);
    font-size: 40px;
    font-weight: var(--weight-regular);
    line-height: 1;
    color: #fcd34d;
    font-feature-settings: "tnum";
  }

  .cs-ledger__label {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: var(--weight-regular);
    letter-spacing: 0.04em;
    color: var(--color-text-secondary);
    line-height: 1.3;
  }

  /* ─── Stack key/value dl in the content column ─── */
  .cs-stack {
    margin: 0;
    padding: var(--space-3) 0;
    border-top: var(--border-hairline);
    border-bottom: var(--border-hairline);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .cs-stack__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-1);
    padding: var(--space-2) 0;
  }

  @media (min-width: 768px) {
    .cs-stack__row {
      grid-template-columns: 160px 1fr;
      gap: var(--space-6);
      align-items: baseline;
    }
  }

  .cs-stack__label {
    font-family: var(--font-mono);
    font-size: 11.5px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-primary);
    margin: 0;
  }

  .cs-stack__value {
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 1.5;
    color: var(--color-text-secondary);
    margin: 0;
  }

  /* ─── Decisions & trade-offs ─── */
  .cs-decisions {
    list-style: none;
    margin: var(--space-12) 0 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .cs-decision {
    padding: var(--space-8) 0;
    border-top: var(--border-hairline);
  }

  /* Override the global rail-row spacing for decisions since the list
     itself manages padding/border per item. */
  .cs-decision.cs-rail-row + .cs-decision.cs-rail-row {
    margin-top: 0;
    padding-top: var(--space-8);
    border-top: var(--border-hairline);
  }

  .cs-decision:last-child {
    border-bottom: var(--border-hairline);
  }

  .cs-decision__num {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: var(--weight-regular);
    line-height: 1;
    color: #fcd34d;
    font-feature-settings: "tnum";
  }

  .cs-decision__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .cs-decision__title {
    font-family: var(--font-mono);
    font-size: 12.5px;
    font-weight: var(--weight-semibold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-primary);
    margin: 0;
  }

  .cs-decision__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

