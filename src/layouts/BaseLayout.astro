---
/*
  BaseLayout — wraps every page.

  Loads design tokens, global styles, fonts. Renders TopNav + main slot + Footer.

  Per-page props:
    title         <title> tag content. Should be specific to the page.
    description   meta description for SEO + social share.
    canonical     optional override; defaults to current URL.
    ogImage       optional social share image; defaults to a generic Extense card.
    pageClass     optional class on <body> for page-specific styling hooks.
*/

import "../styles/tokens.css";
import "../styles/global.css";

import TopNav from "../components/nav/TopNav.astro";
import Footer from "../components/site/Footer.astro";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  pageClass?: string;
}

const {
  title,
  description,
  canonical = new URL(Astro.url.pathname, Astro.site ?? "https://www.ex-tense.co").toString(),
  ogImage = "/images/og-default.png",
  pageClass,
} = Astro.props;

const siteName = "Extense LLC";
const fullTitle = title.includes(siteName) ? title : `${title} — ${siteName}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Favicon (using inline SVG with the brand mark) -->
    <link
      rel="icon"
      type="image/svg+xml"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 200 200'%3E%3Crect x='60' y='10' width='110' height='110' rx='8' fill='none' stroke='%23f59e0b' stroke-width='8'/%3E%3Crect x='30' y='60' width='100' height='100' rx='8' fill='none' stroke='%23f59e0b' stroke-width='8'/%3E%3C/svg%3E"
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, Astro.site ?? "https://www.ex-tense.co").toString()} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site ?? "https://www.ex-tense.co").toString()} />

    <!-- Fonts: Source Serif 4 (display), Inter (body), JetBrains Mono (code), Montserrat 200 (logo wordmark) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&family=Montserrat:wght@200&family=Source+Serif+4:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap"
    />

    <!-- Robots -->
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#FAF7F2" />

    <!-- Structured data — Organization (matches existing site's JSON-LD) -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Extense LLC",
      "url": "https://www.ex-tense.co",
      "logo": "https://www.ex-tense.co/images/extense-logo.svg",
      "description": "XML content engineering for organizations whose documentation has to be right.",
      "foundingDate": "2012",
      "sameAs": ["https://www.linkedin.com/company/ex-tense"],
      "knowsAbout": ["DITA XML", "CCMS", "S1000D", "Publishing Automation", "Content Strategy", "AI-Ready Content"]
    })} />
  </head>

  <body class={pageClass}>
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <TopNav />

    <main id="main-content">
      <slot />
    </main>

    <Footer />
  </body>
</html>
