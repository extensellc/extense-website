---
/*
  TopNav — shared, sticky to viewport top.

  Spec ref: EXTENSE_DESIGN_BRIEF.md §9 (System / Shared)

  Behavior:
    - Background color-page-bg default; fades to color-surface-elevated
      with hairline-bottom border when scrolled past hero.
    - Active page: weight-semibold + color-link, with aria-current="page".
    - "Contact" emphasis: weight-semibold default (preserves restraint;
      no amber underline / chip).
    - No dropdowns. Each nav item routes to its parent landing page.
    - Mobile: hamburger right; full-height drawer slides from right.
*/

import Logo from "../brand/Logo.astro";

const currentPath = Astro.url.pathname;

interface NavItem {
  label: string;
  href: string;
  matchPaths?: RegExp[];
  emphasis?: boolean;
  children?: NavItem[];
}

const navItems: NavItem[] = [
  { label: "Home", href: "/" },
  {
    label: "Solutions",
    href: "/solutions",
    matchPaths: [/^\/solutions/],
    children: [
      { label: "Technical Docs & Publishing", href: "/solutions/technical-docs-and-publishing" },
      { label: "Content Migration",            href: "/solutions/content-migration" },
      { label: "XML Data Interoperability",    href: "/solutions/xml-data-interoperability" },
      { label: "AI-Ready Content",             href: "/solutions/ai-ready-content" },
    ],
  },
  {
    label: "Services",
    href: "/services",
    matchPaths: [/^\/services/],
    children: [
      { label: "Technical Writing & Content Development", href: "/services/technical-writing-content-development" },
      { label: "Structured Content Strategy",             href: "/services/structured-content-strategy" },
      { label: "DITA Engineering",                        href: "/services/dita-engineering" },
      { label: "Publishing Engineering",                  href: "/services/publishing-engineering" },
      { label: "CCMS Services",                           href: "/services/ccms-services" },
      { label: "System Integration",                      href: "/services/system-integration" },
      { label: "XML & Schematron Engineering",            href: "/services/xml-engineering" },
    ],
  },
  {
    label: "Industries",
    href: "/industries",
    matchPaths: [/^\/industries/],
    children: [
      { label: "Government & Defense", href: "/industries/government-and-defense" },
      { label: "Financial Services",   href: "/industries/financial-services" },
      { label: "Life Sciences",        href: "/industries/life-sciences" },
      { label: "Transportation",       href: "/industries/transportation" },
      { label: "Insurance",            href: "/industries/insurance" },
      { label: "Technology",           href: "/industries/technology" },
    ],
  },
  {
    label: "Resources",
    href: "/resources",
    matchPaths: [/^\/resources/],
    children: [
      { label: "AI Readiness",       href: "/resources/ai-readiness" },
      { label: "Migration Playbook", href: "/resources/migration-playbook" },
      { label: "Automation Guide",   href: "/resources/automation-guide" },
      { label: "FAQ",                href: "/resources/faq" },
    ],
  },
  {
    label: "Company",
    href: "/company",
    matchPaths: [/^\/company/],
    children: [
      { label: "About Us",                 href: "/company/about-us" },
      { label: "Our Process",              href: "/company/our-process" },
      { label: "Our Work & Case Studies",  href: "/company/our-work-and-case-studies" },
      { label: "Careers",                  href: "/company/careers" },
    ],
  },
  { label: "Contact", href: "/contact", emphasis: true },
];

function isActive(item: NavItem): boolean {
  if (item.matchPaths) {
    return item.matchPaths.some((re) => re.test(currentPath));
  }
  // Trailing-slash-tolerant exact match
  return currentPath === item.href || currentPath === `${item.href}/`;
}
---

<header class="topnav" data-topnav>
  <div class="topnav__inner container-page">
    <a href="/" class="topnav__logo" aria-label="Extense LLC — home">
      <Logo height={80} />
    </a>

    <nav class="topnav__nav" aria-label="Main navigation">
      <ul class="topnav__list">
        {navItems.map((item) => {
          const active = isActive(item);
          const hasMenu = !!item.children && item.children.length > 0;
          return (
            <li class:list={["topnav__item", hasMenu && "topnav__item--has-menu"]}>
              <a
                href={item.href}
                class:list={[
                  "topnav__link",
                  active && "is-active",
                  item.emphasis && "is-emphasis",
                ]}
                aria-current={active ? "page" : undefined}
                aria-haspopup={hasMenu ? "true" : undefined}
              >
                {item.label}
              </a>
              {hasMenu && (
                <div class="topnav__submenu" role="menu">
                  <ul class="topnav__submenu-list">
                    {item.children!.map((child) => (
                      <li role="none">
                        <a
                          role="menuitem"
                          href={child.href}
                          class:list={[
                            "topnav__sublink",
                            currentPath === child.href && "is-active",
                          ]}
                        >
                          {child.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </li>
          );
        })}
      </ul>
    </nav>

    <div class="topnav__actions">
    <a href="/contact" class="topnav__cta">Free Assessment</a>

    <button
      type="button"
      class="topnav__hamburger"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="topnav-mobile"
      data-topnav-trigger
    >
      <svg
        viewBox="0 0 24 24"
        width="24"
        height="24"
        fill="none"
        stroke="currentColor"
        stroke-width={1.5}
        stroke-linecap="round"
      >
        <line x1="4" y1="7" x2="20" y2="7"></line>
        <line x1="4" y1="12" x2="20" y2="12"></line>
        <line x1="4" y1="17" x2="20" y2="17"></line>
      </svg>
    </button>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div
    class="topnav__drawer"
    id="topnav-mobile"
    role="dialog"
    aria-modal="true"
    aria-label="Main navigation"
    data-topnav-drawer
    hidden
  >
    <div class="topnav__drawer-inner">
      <div class="topnav__drawer-head">
        <a href="/" class="topnav__drawer-logo" aria-label="Extense LLC — home">
          <Logo height={48} />
        </a>
        <button
          type="button"
          class="topnav__drawer-close"
          aria-label="Close menu"
          data-topnav-close
        >
          <svg
            viewBox="0 0 24 24"
            width="24"
            height="24"
            fill="none"
            stroke="currentColor"
            stroke-width={1.5}
            stroke-linecap="round"
          >
            <line x1="6" y1="6" x2="18" y2="18"></line>
            <line x1="18" y1="6" x2="6" y2="18"></line>
          </svg>
        </button>
      </div>

      <ul class="topnav__drawer-list">
        {navItems.map((item) => {
          const active = isActive(item);
          return (
            <li>
              <a
                href={item.href}
                class:list={["topnav__drawer-link", active && "is-active"]}
                aria-current={active ? "page" : undefined}
              >
                {item.label}
              </a>
              {item.children && item.children.length > 0 && (
                <ul class="topnav__drawer-sublist">
                  {item.children.map((child) => (
                    <li>
                      <a
                        href={child.href}
                        class:list={[
                          "topnav__drawer-link",
                          "topnav__drawer-link--sub",
                          currentPath === child.href && "is-active",
                        ]}
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          );
        })}
      </ul>

      <a href="/contact" class="topnav__drawer-cta">Free Assessment</a>
    </div>
  </div>
</header>

<style>
  .topnav {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    background-color: var(--color-page-bg);
    transition: background-color var(--duration-base) var(--easing-out),
      border-color var(--duration-base) var(--easing-out);
    border-bottom: 1px solid transparent;
  }

  .topnav[data-scrolled="true"] {
    background-color: var(--color-surface-elevated);
    border-bottom-color: var(--color-border-subtle);
  }

  /* TopNav uses wider edge-to-edge padding so the logo can sit further left
     and the nav links can sit further right than the standard container.
     Override container-page padding for the topnav specifically. */
  .topnav__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--space-6);
    height: 76px;
    max-width: none;
    padding-left: var(--space-6);
    padding-right: var(--space-6);
  }
  /* Three zones: logo left, nav centered, actions (CTA + hamburger) right.
     Explicit grid-column keeps logo/actions pinned to the outer tracks even
     when the centre nav is display:none on mobile (otherwise the two
     remaining items would auto-place into columns 1 and 2). */
  .topnav__logo {
    grid-column: 1;
    justify-self: start;
  }
  .topnav__nav {
    grid-column: 2;
    justify-self: center;
  }
  .topnav__actions {
    grid-column: 3;
    justify-self: end;
  }

  @media (min-width: 768px) {
    .topnav__inner {
      height: 104px;
      padding-left: var(--space-8);
      padding-right: var(--space-8);
    }
  }

  @media (min-width: 1280px) {
    .topnav__inner {
      padding-left: var(--space-12);
      padding-right: var(--space-12);
    }
  }

  .topnav__logo {
    display: flex;
    align-items: center;
    color: var(--color-text-primary);
  }
  .topnav__logo:hover,
  .topnav__logo:focus-visible {
    color: var(--color-text-primary);
    text-decoration: none;
  }
  /* Mobile: scale the stacked logo down so it fits the shorter nav cleanly */
  @media (max-width: 767px) {
    .topnav__logo :global(.extense-logo) {
      height: 56px;
    }
  }

  /* Desktop nav */
  .topnav__nav {
    display: none;
  }

  @media (min-width: 1024px) {
    .topnav__nav {
      display: block;
    }
  }

  .topnav__list {
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }

  .topnav__link {
    position: relative;
    font-size: var(--text-body-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-primary);
    text-decoration: none;
    transition: color var(--duration-base) var(--easing-out);
  }

  .topnav__link:hover,
  .topnav__link:focus-visible {
    color: var(--color-link);
    text-decoration: none;
  }

  .topnav__link.is-active {
    font-weight: var(--weight-semibold);
    color: var(--color-link);
  }

  /* "You are here" underline under the active nav item. Pseudo-element bar
     (not text-decoration) so it survives the :hover text-decoration:none rule
     and sits a few px below the label like a tab indicator. */
  .topnav__link.is-active::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -6px;
    height: 2px;
    background-color: var(--color-link);
  }

  .topnav__link.is-emphasis {
    font-weight: var(--weight-semibold);
  }

  /* ─────────────────────────────────────────────────────────────────
     Desktop dropdown menu (Solutions / any nav item with children)

     Pure CSS show/hide via :hover and :focus-within on the parent <li>.
     Sub-items remain in the tab order — focusing into them keeps the
     menu open via :focus-within. No JS needed for keyboard access.
     Click on the parent link still navigates to the parent index page.
     ───────────────────────────────────────────────────────────────── */
  .topnav__item {
    position: relative;
  }

  /* Dropdown panel.

     Document-grade overlay: no drop-shadow, no rounded corners, no gray
     fill. Just a hairline border on top of the page-bg, an amber accent
     stripe at the top to declare it as a brand element, and a list of
     items prefixed by amber monospace 01-04 numbers — same chrome as the
     Content Ops Stack on the homepage. */
  .topnav__submenu {
    position: absolute;
    top: calc(100% + 8px);
    left: -1px;
    /* Each dropdown sizes to fit its widest item (label + padding).
       Capabilities, Solutions, etc. will be wider; Company (FAQs / Careers)
       will be narrower. */
    width: max-content;
    background-color: var(--color-page-bg);
    border: var(--border-hairline);
    border-top: 2px solid var(--color-accent-primary-hover);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition:
      opacity var(--duration-base) var(--easing-out),
      transform var(--duration-base) var(--easing-out),
      visibility 0s linear var(--duration-base);
    z-index: calc(var(--z-sticky) + 1);
  }
  /* A small invisible bridge above the dropdown so a quick mouse cursor
     transition between the parent label and the dropdown panel doesn't
     close the menu. */
  .topnav__submenu::before {
    content: "";
    position: absolute;
    inset: -10px 0 auto 0;
    height: 10px;
  }

  .topnav__item--has-menu:hover .topnav__submenu,
  .topnav__item--has-menu:focus-within .topnav__submenu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    transition:
      opacity var(--duration-base) var(--easing-out),
      transform var(--duration-base) var(--easing-out),
      visibility 0s linear 0s;
  }

  .topnav__submenu-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .topnav__submenu-list > li + li {
    border-top: var(--border-hairline);
  }

  .topnav__sublink {
    display: block;
    padding: var(--space-2) var(--space-4);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    color: var(--color-text-primary);
    text-decoration: none;
    transition: color var(--duration-base) var(--easing-out);
  }
  .topnav__sublink:hover,
  .topnav__sublink:focus-visible {
    color: var(--color-link);
    text-decoration: none;
  }
  .topnav__sublink.is-active {
    color: var(--color-link);
    font-weight: var(--weight-medium);
  }

  /* Right-side actions group: nav + CTA at desktop, hamburger at mobile.
     Grouped on the right (via .topnav__inner space-between) so the nav links
     stay right-aligned, matching the original layout intent. */
  .topnav__actions {
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }

  /* Persistent "Free Assessment" CTA. Hidden on mobile (the drawer carries its
     own); shown alongside the nav at the desktop breakpoint. Amber gradient
     matches the CTAModule primary button. */
  .topnav__cta {
    display: none;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: var(--weight-semibold);
    color: var(--color-text-primary);
    background-color: var(--color-accent-primary);
    background-image: linear-gradient(
      135deg,
      var(--color-logo-gradient-1) 0%,
      var(--color-accent-primary) 100%
    );
    padding: 9px 18px;
    border-radius: var(--radius-sm);
    text-decoration: none;
    white-space: nowrap;
    transition: background-color var(--duration-base) var(--easing-out);
  }
  @media (min-width: 1024px) {
    .topnav__cta {
      display: inline-block;
    }
  }
  .topnav__cta:hover {
    background-image: none;
    background-color: var(--color-accent-primary-hover);
    color: var(--color-text-primary);
    text-decoration: none;
  }
  .topnav__cta:active {
    background-image: none;
    background-color: var(--color-accent-primary-pressed);
    color: var(--color-page-bg);
  }

  /* Hamburger */
  .topnav__hamburger {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    margin-right: calc(var(--space-3) * -1); /* visually align with edge */
    color: var(--color-text-primary);
    border-radius: var(--radius-sm);
    transition: background-color var(--duration-base) var(--easing-out);
  }

  .topnav__hamburger:hover {
    background-color: var(--color-surface-elevated);
  }

  @media (min-width: 1024px) {
    .topnav__hamburger {
      display: none;
    }
  }

  /* Mobile drawer */
  .topnav__drawer {
    position: fixed;
    inset: 0;
    background-color: var(--color-page-bg);
    z-index: var(--z-modal);
    overflow-y: auto;
  }

  .topnav__drawer[hidden] {
    display: none;
  }

  .topnav__drawer-inner {
    padding: var(--space-4) var(--container-padding);
  }

  .topnav__drawer-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
    margin-bottom: var(--space-8);
  }

  .topnav__drawer-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    color: var(--color-text-primary);
    border-radius: var(--radius-sm);
  }

  .topnav__drawer-close:hover {
    background-color: var(--color-surface-elevated);
  }

  .topnav__drawer-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .topnav__drawer-link {
    display: block;
    padding: var(--space-3) 0;
    font-family: var(--font-display);
    font-size: var(--text-display-md);
    font-weight: var(--weight-regular);
    color: var(--color-text-primary);
    text-decoration: none;
    border-bottom: var(--border-hairline);
  }

  .topnav__drawer-link:hover,
  .topnav__drawer-link:focus-visible {
    color: var(--color-link);
    text-decoration: none;
  }

  .topnav__drawer-link.is-active {
    font-weight: var(--weight-semibold);
    color: var(--color-link);
    text-decoration: underline;
    text-decoration-color: var(--color-link);
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
  }
  /* Keep the active underline on hover/focus (the general drawer-link hover
     rule sets text-decoration:none). */
  .topnav__drawer-link.is-active:hover,
  .topnav__drawer-link.is-active:focus-visible {
    text-decoration: underline;
  }

  /* Mobile drawer — sub-items rendered as an inline indented list under
     their parent. Smaller type than the top-level items so the hierarchy
     reads. The parent link still navigates to its index page. */
  .topnav__drawer-sublist {
    list-style: none;
    margin: 0;
    padding: 0 0 var(--space-3) var(--space-4);
    border-bottom: var(--border-hairline);
  }
  .topnav__drawer-sublist > li > .topnav__drawer-link--sub {
    padding: var(--space-2) 0;
    font-family: var(--font-body);
    font-size: var(--text-body);
    font-weight: var(--weight-regular);
    border-bottom: none;
  }

  /* Mobile drawer CTA — full-width primary button at the foot of the drawer. */
  .topnav__drawer-cta {
    display: block;
    margin-top: var(--space-8);
    padding: 14px 28px;
    text-align: center;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: var(--weight-semibold);
    color: var(--color-text-primary);
    background-color: var(--color-accent-primary);
    background-image: linear-gradient(
      135deg,
      var(--color-logo-gradient-1) 0%,
      var(--color-accent-primary) 100%
    );
    border-radius: var(--radius-sm);
    text-decoration: none;
  }
  .topnav__drawer-cta:hover,
  .topnav__drawer-cta:focus-visible {
    background-image: none;
    background-color: var(--color-accent-primary-hover);
    color: var(--color-text-primary);
    text-decoration: none;
  }

  /* Lock scroll on body when drawer is open */
  :global(body.has-drawer-open) {
    overflow: hidden;
  }
</style>

<script>
  // ─────────────────────────────────────────────────────────
  // Sticky-nav background fade on scroll past hero
  // ─────────────────────────────────────────────────────────
  function setupScrollFade() {
    const nav = document.querySelector<HTMLElement>("[data-topnav]");
    if (!nav) return;

    const threshold = 64; // ~hero top padding; sufficient signal for scroll fade
    let ticking = false;

    function update() {
      ticking = false;
      const y = window.scrollY;
      if (y > threshold) {
        nav!.dataset.scrolled = "true";
      } else {
        delete nav!.dataset.scrolled;
      }
    }

    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    }

    window.addEventListener("scroll", onScroll, { passive: true });
    update();
  }

  // ─────────────────────────────────────────────────────────
  // Mobile drawer — focus trap, escape-to-close, scroll lock
  // ─────────────────────────────────────────────────────────
  function setupMobileDrawer() {
    const trigger = document.querySelector<HTMLButtonElement>("[data-topnav-trigger]");
    const drawer = document.querySelector<HTMLElement>("[data-topnav-drawer]");
    const closeBtn = document.querySelector<HTMLButtonElement>("[data-topnav-close]");

    if (!trigger || !drawer || !closeBtn) return;

    let lastFocused: HTMLElement | null = null;

    function open() {
      lastFocused = document.activeElement as HTMLElement;
      drawer!.hidden = false;
      trigger!.setAttribute("aria-expanded", "true");
      document.body.classList.add("has-drawer-open");
      // Move focus into the drawer
      const firstFocusable = drawer!.querySelector<HTMLElement>(
        "a, button, [tabindex]:not([tabindex='-1'])"
      );
      firstFocusable?.focus();
    }

    function close() {
      drawer!.hidden = true;
      trigger!.setAttribute("aria-expanded", "false");
      document.body.classList.remove("has-drawer-open");
      lastFocused?.focus();
    }

    trigger.addEventListener("click", open);
    closeBtn.addEventListener("click", close);

    // Escape to close
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !drawer.hidden) {
        close();
      }
    });

    // Close on link click (so SPA-style navigation feels right;
    // also handles cases where the user clicks an anchor that navigates)
    drawer.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      if (target.tagName === "A") {
        close();
      }
    });
  }

  document.addEventListener("DOMContentLoaded", () => {
    setupScrollFade();
    setupMobileDrawer();
  });

  // Re-setup on view transitions (Astro client-side nav)
  document.addEventListener("astro:page-load", () => {
    setupScrollFade();
    setupMobileDrawer();
  });
</script>
