---
/*
  Pillar badge — CCMS & Publishing.
  Concept: stacked-system — managed components flowing to outputs.
  Phosphor-aligned: 1.5px stroke, single-color via currentColor.
*/

interface Props {
  size?: number;
  class?: string;
}

const { size = 48, class: className } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 48 48"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  <!-- Stacked system (left) — repository / CCMS layers -->
  <rect x="8" y="10" width="20" height="6" rx="1" />
  <rect x="8" y="20" width="20" height="6" rx="1" />
  <rect x="8" y="30" width="20" height="6" rx="1" />

  <!-- Pipeline connector -->
  <line x1="29" y1="24" x2="36" y2="24" />

  <!-- Output node (right) — published artifact -->
  <path d="M36 18 L42 18 L42 30 L36 30 Z" />
  <line x1="38.5" y1="22" x2="40" y2="22" />
  <line x1="38.5" y1="25" x2="40" y2="25" />
</svg>
