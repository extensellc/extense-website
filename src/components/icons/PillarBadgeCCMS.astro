---
/*
  Pillar badge — CCMS & Publishing.
  Concept: stacked-system — managed components flowing to outputs.
  Phosphor-aligned: 1.5px stroke, single-color via currentColor.

  Hover animation: the 3 stacked layers drop into place from above (staggered),
  the pipeline connector extends right, then the output node pulses briefly.
  Respects prefers-reduced-motion (no animation).
*/

interface Props {
  size?: number;
  class?: string;
}

const { size = 48, class: className } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 48 48"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  class:list={["ccms-badge", className]}
  aria-hidden="true"
>
  <!-- Stacked system (left) — repository / CCMS layers -->
  <rect x="8" y="10" width="20" height="6" rx="1" class="ccms-layer ccms-layer-1" />
  <rect x="8" y="20" width="20" height="6" rx="1" class="ccms-layer ccms-layer-2" />
  <rect x="8" y="30" width="20" height="6" rx="1" class="ccms-layer ccms-layer-3" />

  <!-- Pipeline connector -->
  <line x1="29" y1="24" x2="36" y2="24" class="ccms-connector" />

  <!-- Output node (right) — published artifact -->
  <path d="M36 18 L42 18 L42 30 L36 30 Z" class="ccms-output" />
  <line x1="38.5" y1="22" x2="40" y2="22" class="ccms-output-line" />
  <line x1="38.5" y1="25" x2="40" y2="25" class="ccms-output-line" />
</svg>

<style>
  /* Default static state: everything visible. */
  .ccms-layer {
    transform-origin: center;
    transform-box: fill-box;
    transform: translateY(0);
    opacity: 1;
  }

  .ccms-connector {
    stroke-dasharray: 8;
    stroke-dashoffset: 0;
  }

  .ccms-output {
    transform-origin: center;
    transform-box: fill-box;
    transform: scale(1);
  }

  /* Hover replays the pipeline: layers drop in (stagger), connector extends,
     output pulses. */
  :global(.pillar-card__link:hover) .ccms-layer,
  :global(.pillar-card__link:focus-visible) .ccms-layer {
    animation: ccms-drop-in 360ms cubic-bezier(0, 0, 0.2, 1) backwards;
  }
  :global(.pillar-card__link:hover) .ccms-layer-2,
  :global(.pillar-card__link:focus-visible) .ccms-layer-2 {
    animation-delay: 80ms;
  }
  :global(.pillar-card__link:hover) .ccms-layer-3,
  :global(.pillar-card__link:focus-visible) .ccms-layer-3 {
    animation-delay: 160ms;
  }

  :global(.pillar-card__link:hover) .ccms-connector,
  :global(.pillar-card__link:focus-visible) .ccms-connector {
    animation: ccms-draw 240ms cubic-bezier(0, 0, 0.2, 1) backwards;
    animation-delay: 420ms;
  }

  :global(.pillar-card__link:hover) .ccms-output,
  :global(.pillar-card__link:focus-visible) .ccms-output {
    animation: ccms-pulse 360ms cubic-bezier(0.4, 0, 0.2, 1) backwards;
    animation-delay: 620ms;
  }

  @keyframes ccms-drop-in {
    from {
      transform: translateY(-6px);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  @keyframes ccms-draw {
    from {
      stroke-dashoffset: 8;
    }
    to {
      stroke-dashoffset: 0;
    }
  }

  @keyframes ccms-pulse {
    0% {
      transform: scale(1);
    }
    40% {
      transform: scale(1.08);
    }
    100% {
      transform: scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.pillar-card__link:hover) .ccms-layer,
    :global(.pillar-card__link:focus-visible) .ccms-layer,
    :global(.pillar-card__link:hover) .ccms-connector,
    :global(.pillar-card__link:focus-visible) .ccms-connector,
    :global(.pillar-card__link:hover) .ccms-output,
    :global(.pillar-card__link:focus-visible) .ccms-output {
      animation: none;
    }
  }
</style>
