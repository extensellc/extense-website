---
/*
  Pillar badge — AI-Ready Content.
  Concept: network / nodes — content as graph, retrieval pathways.
  Phosphor-aligned: 1.5px stroke, single-color via currentColor.

  Hover animation: connection lines draw in sequence (suggesting retrieval
  pathways being traced), then the center node pulses briefly. Respects
  prefers-reduced-motion (no animation).
*/

interface Props {
  size?: number;
  class?: string;
}

const { size = 48, class: className } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 48 48"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  class:list={["ai-badge", className]}
  aria-hidden="true"
>
  <!-- Connecting lines (drawn first, behind nodes) -->
  <line x1="11" y1="11" x2="24" y2="24" class="ai-link ai-link-1" />
  <line x1="37" y1="11" x2="24" y2="24" class="ai-link ai-link-2" />
  <line x1="11" y1="37" x2="24" y2="24" class="ai-link ai-link-3" />
  <line x1="37" y1="37" x2="24" y2="24" class="ai-link ai-link-4" />
  <line x1="11" y1="11" x2="37" y2="11" class="ai-link ai-link-5" />
  <line x1="11" y1="37" x2="37" y2="37" class="ai-link ai-link-6" />

  <!-- Nodes (drawn last, on top of lines).
       Filled with page-bg so connecting lines appear to terminate at node edges. -->
  <circle cx="11" cy="11" r="3" fill="var(--color-page-bg)" class="ai-node ai-node-tl" />
  <circle cx="37" cy="11" r="3" fill="var(--color-page-bg)" class="ai-node ai-node-tr" />
  <circle cx="24" cy="24" r="4" fill="var(--color-page-bg)" class="ai-node ai-node-center" />
  <circle cx="11" cy="37" r="3" fill="var(--color-page-bg)" class="ai-node ai-node-bl" />
  <circle cx="37" cy="37" r="3" fill="var(--color-page-bg)" class="ai-node ai-node-br" />
</svg>

<style>
  /* Default static state: everything visible. */
  .ai-link {
    /* Approx max length on the diagonals is ~18.4 (sqrt(13^2 + 13^2)); use 30 to be safe */
    stroke-dasharray: 30;
    stroke-dashoffset: 0;
  }

  .ai-node {
    transform-origin: center;
    transform-box: fill-box;
    transform: scale(1);
  }

  /* Hover replays the network: links trace in sequence, then center node pulses. */
  :global(.pillar-card__link:hover) .ai-link,
  :global(.pillar-card__link:focus-visible) .ai-link {
    animation: ai-trace 240ms cubic-bezier(0, 0, 0.2, 1) backwards;
  }
  :global(.pillar-card__link:hover) .ai-link-2,
  :global(.pillar-card__link:focus-visible) .ai-link-2 {
    animation-delay: 60ms;
  }
  :global(.pillar-card__link:hover) .ai-link-3,
  :global(.pillar-card__link:focus-visible) .ai-link-3 {
    animation-delay: 120ms;
  }
  :global(.pillar-card__link:hover) .ai-link-4,
  :global(.pillar-card__link:focus-visible) .ai-link-4 {
    animation-delay: 180ms;
  }
  :global(.pillar-card__link:hover) .ai-link-5,
  :global(.pillar-card__link:focus-visible) .ai-link-5 {
    animation-delay: 240ms;
  }
  :global(.pillar-card__link:hover) .ai-link-6,
  :global(.pillar-card__link:focus-visible) .ai-link-6 {
    animation-delay: 300ms;
  }

  :global(.pillar-card__link:hover) .ai-node,
  :global(.pillar-card__link:focus-visible) .ai-node {
    animation: ai-node-pulse 360ms cubic-bezier(0.4, 0, 0.2, 1) backwards;
    animation-delay: 480ms;
  }
  :global(.pillar-card__link:hover) .ai-node-center,
  :global(.pillar-card__link:focus-visible) .ai-node-center {
    animation: ai-node-pulse 420ms cubic-bezier(0.4, 0, 0.2, 1) backwards;
    animation-delay: 540ms;
  }

  @keyframes ai-trace {
    from {
      stroke-dashoffset: 30;
    }
    to {
      stroke-dashoffset: 0;
    }
  }

  @keyframes ai-node-pulse {
    0% {
      transform: scale(0.6);
      opacity: 0;
    }
    50% {
      transform: scale(1.15);
      opacity: 1;
    }
    100% {
      transform: scale(1);
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.pillar-card__link:hover) .ai-link,
    :global(.pillar-card__link:focus-visible) .ai-link,
    :global(.pillar-card__link:hover) .ai-node,
    :global(.pillar-card__link:focus-visible) .ai-node {
      animation: none;
    }
  }
</style>
