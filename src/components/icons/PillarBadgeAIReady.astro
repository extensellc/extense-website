---
/*
  Pillar badge — AI-Ready Content.
  Concept: network / nodes — content as graph, retrieval pathways.
  Phosphor-aligned: 1.5px stroke, single-color via currentColor.
*/

interface Props {
  size?: number;
  class?: string;
}

const { size = 48, class: className } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 48 48"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  <!-- Connecting lines (drawn first, behind nodes) -->
  <line x1="11" y1="11" x2="24" y2="24" />
  <line x1="37" y1="11" x2="24" y2="24" />
  <line x1="11" y1="37" x2="24" y2="24" />
  <line x1="37" y1="37" x2="24" y2="24" />
  <line x1="11" y1="11" x2="37" y2="11" />
  <line x1="11" y1="37" x2="37" y2="37" />

  <!-- Nodes (drawn last, on top of lines).
       Filled with page-bg so connecting lines appear to terminate at node edges. -->
  <circle cx="11" cy="11" r="3" fill="var(--color-page-bg)" />
  <circle cx="37" cy="11" r="3" fill="var(--color-page-bg)" />
  <circle cx="24" cy="24" r="4" fill="var(--color-page-bg)" />
  <circle cx="11" cy="37" r="3" fill="var(--color-page-bg)" />
  <circle cx="37" cy="37" r="3" fill="var(--color-page-bg)" />
</svg>
