---
/*
  AiReadyPipeline — approach section on /solutions/ai-ready-content.

  Sequenced after the two-pipeline comparison (section 3), before the
  AI use-case chapter-blocks.

  Layout
    - container-data section, border-top hairline
    - Manifesto-style opening at 900 px width (matching Migration and
      Interop pipelines) so the elaboration paragraph spans from the
      center of the AUDIT stage to the center of the VALIDATE stage
      in the 1080 px stages grid below.
    - Horizontal 5-stage pipeline at container-data width:
        AUDIT -> STRUCTURE -> ENRICH -> BUILD -> VALIDATE

  Animation: same as the other pipeline sections. prefers-reduced-motion: static.
*/

interface Stage {
  num: string;
  name: string;
  tool: string;
  detail: string;
}

const stages: Stage[] = [
  {
    num: "01",
    name: "Audit & Score",
    tool: "7-dimension AI-readiness scorecard",
    detail: "Content typing, metadata coverage, addressability, vocabulary control, semantic markup, reuse architecture, pipeline maturity. The corpus is quoted on what is recoverable for retrieval, not on raw topic count.",
  },
  {
    num: "02",
    name: "Structure & Type",
    tool: "DITA 1.3 specialization, controlled topic types, stable section IDs",
    detail: "Word / PDF / FrameMaker / wiki content converted to typed DITA. Every section gets an addressable, version-stable ID so retrieval can cite — not approximate.",
  },
  {
    num: "03",
    name: "Enrich Metadata",
    tool: "Subject scheme, SKOS taxonomy, audience / difficulty / domain / intent",
    detail: "Controlled vocabulary applied at scale. 100 % coverage gate on every topic. Validation rules prevent vocabulary drift on every commit.",
  },
  {
    num: "04",
    name: "Build Pipeline",
    tool: "DITA-OT, chunks.jsonl, glossary-index.json, content-manifest.json",
    detail: "A single build emits semantic chunks alongside the HTML/PDF outputs. Every chunk is metadata-tagged, citation-ready, and tied back to its source section ID.",
  },
  {
    num: "05",
    name: "Integrate & Validate",
    tool: "Pinecone / Weaviate / pgvector, metadata-filtered retrieval, replay tests",
    detail: "Audience and domain filter applied before similarity scoring runs. Precision measured against real user queries before the engagement closes — not promised.",
  },
];
---

<section class="airdy-pipeline" aria-labelledby="airdy-pipeline-heading">
  <div class="container-data airdy-pipeline__inner">
    <div class="airdy-pipeline__manifesto">
      <h2 id="airdy-pipeline-heading" class="airdy-pipeline__heading">
        From Unstructured or Unenriched to AI-Ready in <em>5 Phases</em>
      </h2>
      <p class="airdy-pipeline__intro">
        A deterministic engineering process &mdash; not a consulting engagement with open-ended deliverables. Whether you&rsquo;re starting from Word documents or from DITA that was never properly enriched, each phase has a concrete output and a measurable improvement.
      </p>
    </div>

    <ol class="airdy-pipeline__stages" aria-label="AI-ready content pipeline">
      {stages.map((stage, i) => (
        <li class={`pipeline-stage pipeline-stage--${i + 1}`}>
          <p class="pipeline-stage__num" aria-hidden="true">{stage.num}</p>
          <h3 class="pipeline-stage__name">{stage.name}</h3>
          <p class="pipeline-stage__tool">{stage.tool}</p>
          <p class="pipeline-stage__detail">{stage.detail}</p>
        </li>
      ))}
    </ol>

    <div class="airdy-pipeline__timeline" aria-hidden="true">
      <div class="airdy-pipeline__timeline-track"></div>
      <div class="airdy-pipeline__timeline-marks">
        <span class="tl-mark">Week 1</span>
        <span class="tl-mark tl-mark--mid">4&ndash;8 weeks (small corpus)</span>
        <span class="tl-mark tl-mark--end">AI-Ready &check;</span>
      </div>
    </div>
  </div>
</section>

<style>
  .airdy-pipeline {
    padding-top: var(--section-pad-default);
    padding-bottom: var(--section-pad-default);
    border-top: var(--border-hairline);
  }

  @media (max-width: 767px) {
    .airdy-pipeline {
      padding-top: var(--space-16);
      padding-bottom: var(--space-16);
    }
  }

  /* Manifesto block widened to 900 px (matching Migration and Interop
     pipelines) so the elaboration spans the inner stages. */
  .airdy-pipeline__manifesto {
    max-width: none;
    margin: 0 auto var(--space-20) auto;
    text-align: center;
  }

  @media (max-width: 767px) {
    .airdy-pipeline__manifesto {
      margin-bottom: var(--space-16);
    }
  }

  .airdy-pipeline__heading {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin: 0;
    text-wrap: balance;
  }
  .airdy-pipeline__heading em {
    font-style: italic;
  }

  /* Keep the heading on one line on desktop; wrap (balanced) below. */
  @media (min-width: 1080px) {
    .airdy-pipeline__heading {
      white-space: nowrap;
    }
  }

  .airdy-pipeline__intro {
    margin: var(--space-4) auto 0 auto;
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    font-weight: var(--weight-regular);
    line-height: var(--leading-normal);
    color: var(--color-text-secondary);
    text-wrap: pretty;
  }

  /* Pipeline stages — same vocabulary as TDP/Migration/Interop. */
  .airdy-pipeline__stages {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 960px) {
    .airdy-pipeline__stages {
      grid-template-columns: repeat(5, 1fr);
      gap: var(--space-12);
    }
  }

  .pipeline-stage {
    border-top: 2px solid var(--color-text-primary);
    padding-top: var(--space-4);
    position: relative;
  }

  .pipeline-stage:not(:last-child)::after {
    content: "→";
    position: absolute;
    font-family: var(--font-mono);
    font-size: 24px;
    line-height: 1;
    font-weight: var(--weight-medium);
    color: var(--color-accent-primary-hover);
    bottom: calc(-1 * var(--space-8) - 8px);
    left: 50%;
    transform: translateX(-50%) rotate(90deg);
  }

  @media (min-width: 960px) {
    .pipeline-stage:not(:last-child)::after {
      bottom: auto;
      left: auto;
      right: calc(-1 * var(--space-12) / 2 + 0px);
      top: 38px;
      transform: translate(50%, -50%) rotate(0deg);
    }
  }

  .pipeline-stage__num {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.12em;
    color: var(--color-accent-primary);
    margin: 0 0 var(--space-2) 0;
    line-height: 1;
  }

  .pipeline-stage__name {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: var(--weight-medium);
    line-height: 1.1;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-text-primary);
    margin: 0 0 var(--space-4) 0;
  }

  .pipeline-stage__tool {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: var(--weight-medium);
    line-height: 1.45;
    color: var(--color-text-primary);
    margin: 0 0 var(--space-4) 0;
    text-wrap: pretty;
  }

  .pipeline-stage__detail {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    font-weight: var(--weight-regular);
    line-height: 1.5;
    color: var(--color-text-secondary);
    margin: 0;
    text-wrap: pretty;
  }

  /* Timeline bar beneath the strip — Week 1 → 4–8 weeks → AI-Ready.
     Restrained: a hairline track that warms to amber at the finish. */
  .airdy-pipeline__timeline {
    margin-top: var(--space-16);
  }
  .airdy-pipeline__timeline-track {
    height: 2px;
    width: 100%;
    background: linear-gradient(
      90deg,
      var(--color-border-subtle) 0%,
      var(--color-border-subtle) 68%,
      var(--color-accent-primary) 100%
    );
  }
  .airdy-pipeline__timeline-marks {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
    margin-top: var(--space-3);
  }
  .tl-mark {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .tl-mark--mid {
    text-align: center;
  }
  .tl-mark--end {
    color: var(--color-accent-primary-pressed);
    text-align: right;
  }

  @media (max-width: 767px) {
    .airdy-pipeline__timeline {
      margin-top: var(--space-10);
    }
    .tl-mark {
      font-size: 9px;
      letter-spacing: 0.04em;
    }
  }

  /* Reveal animation — viewport-triggered. */
  .airdy-pipeline.animating .airdy-pipeline__heading,
  .airdy-pipeline.animating .airdy-pipeline__intro,
  .airdy-pipeline.animating .pipeline-stage,
  .airdy-pipeline.animating .airdy-pipeline__timeline {
    opacity: 0;
    transform: translateY(8px);
  }

  .airdy-pipeline.animating.in-view .airdy-pipeline__heading {
    animation: airdy-pipe-fade-in 520ms ease-out forwards;
  }
  .airdy-pipeline.animating.in-view .airdy-pipeline__intro {
    animation: airdy-pipe-fade-in 420ms ease-out forwards;
    animation-delay: 200ms;
  }
  .airdy-pipeline.animating.in-view .pipeline-stage:nth-child(1) { animation: airdy-pipe-fade-in 420ms ease-out forwards; animation-delay: 440ms; }
  .airdy-pipeline.animating.in-view .pipeline-stage:nth-child(2) { animation: airdy-pipe-fade-in 420ms ease-out forwards; animation-delay: 560ms; }
  .airdy-pipeline.animating.in-view .pipeline-stage:nth-child(3) { animation: airdy-pipe-fade-in 420ms ease-out forwards; animation-delay: 680ms; }
  .airdy-pipeline.animating.in-view .pipeline-stage:nth-child(4) { animation: airdy-pipe-fade-in 420ms ease-out forwards; animation-delay: 800ms; }
  .airdy-pipeline.animating.in-view .pipeline-stage:nth-child(5) { animation: airdy-pipe-fade-in 420ms ease-out forwards; animation-delay: 920ms; }
  .airdy-pipeline.animating.in-view .airdy-pipeline__timeline {
    animation: airdy-pipe-fade-in 420ms ease-out forwards;
    animation-delay: 1060ms;
  }

  @keyframes airdy-pipe-fade-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .airdy-pipeline.animating .airdy-pipeline__heading,
    .airdy-pipeline.animating .airdy-pipeline__intro,
    .airdy-pipeline.animating .pipeline-stage,
    .airdy-pipeline.animating .airdy-pipeline__timeline {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }
  }
</style>

<script>
  function setupAiReadyPipeline() {
    const sec = document.querySelector<HTMLElement>(".airdy-pipeline");
    if (!sec) return;
    if (sec.dataset.pipelineRevealInit === "true") return;
    sec.dataset.pipelineRevealInit = "true";

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;
    if (prefersReducedMotion) return;

    sec.classList.add("animating");

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            sec.classList.add("in-view");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );

    observer.observe(sec);
  }

  document.addEventListener("DOMContentLoaded", setupAiReadyPipeline);
  document.addEventListener("astro:page-load", setupAiReadyPipeline);
</script>
