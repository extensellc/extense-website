---
/*
  ContentMigrationPipeline — approach section on
  /solutions/content-migration.

  The technical centerpiece. Sequenced after the problem section,
  before the source chapter-blocks.

  Layout
    - container-data section, border-top hairline
    - Manifesto-style opening at container-prose width, centered:
        eyebrow + display-serif principle + hairline + elaboration
    - Horizontal 5-stage pipeline diagram below at container-data width:
        AUDIT -> MODEL -> CONVERT -> DEDUPLICATE -> VALIDATE
        Each stage has num, name, mono tool list, and body-small detail.
        Amber "->" arrow between stages on desktop; "v" on mobile.

  Animation: viewport-triggered. Manifesto block fades up first, then
  the five stages stagger in. prefers-reduced-motion: static.
*/

interface Stage {
  num: string;
  name: string;
  tool: string;
  detail: string;
}

const stages: Stage[] = [
  {
    num: "01",
    name: "Audit",
    tool: "Custom inventory scripts, structure-density scoring",
    detail: "Wall-to-wall format inventory and recoverability score per asset family. The estate is quoted on what is recoverable, not on page count.",
  },
  {
    num: "02",
    name: "Model",
    tool: "DITA 1.3 + subject scheme, conref strategy",
    detail: "Information architecture for the target project: topic types, metadata vocabulary, reuse strategy. Modeled against the actual content, not boilerplate templates.",
  },
  {
    num: "03",
    name: "Convert",
    tool: "FrameMaker MIF, Word OOXML, RoboHelp HHP/CHM, InDesign IDML, XSLT 3.0, ABBYY FineReader",
    detail: "Format-specific parsers extract maximum structure. Output is DITA 1.3, validated on emission. No human re-keys the body text.",
  },
  {
    num: "04",
    name: "Deduplicate",
    tool: "Paragraph + span hash matching, near-duplicate review queue",
    detail: "Exact matches consolidated automatically. Near-duplicates routed to a reviewer queue with diff. Originals become conref pointers into a topic warehouse.",
  },
  {
    num: "05",
    name: "Validate",
    tool: "Schematron rule sets, DITA-OT validation, provenance metadata",
    detail: "Failed topics route to remediation with diagnostic reports. Final deliverable: a clean, deduplicated DITA project with traceability back to every legacy source.",
  },
];
---

<section class="cm-pipeline" aria-labelledby="cm-pipeline-heading">
  <div class="container-data cm-pipeline__inner">
    <div class="cm-pipeline__manifesto">
      <p class="eyebrow cm-pipeline__eyebrow">The pipeline</p>
      <h2 id="cm-pipeline-heading" class="cm-pipeline__principle">
        The conversion is <em>engineered</em>, not transcribed.
      </h2>
      <hr class="cm-pipeline__rule" />
      <p class="cm-pipeline__elaboration">
        Every migration starts with a wall-to-wall audit. Format inventory, structure-density scoring, recoverability assessment per asset family &mdash; the work is quoted on what&rsquo;s recoverable. Format-specific parsers do the conversion: FrameMaker MIF via custom XSL, Word OOXML via OpenXML, RoboHelp HHP unpacked and topic-split, InDesign IDML mapped to DITA sections, SGML normalized through OmniMark, scanned PDF run through ABBYY FineReader. Paragraph- and span-level hash matching catches the 15&ndash;30% of topics that are exact or near-duplicate of others elsewhere. Schematron rule sets validate the result. Failed topics route to remediation, with provenance metadata back to the legacy source.
      </p>
    </div>

    <ol class="cm-pipeline__stages" aria-label="Content migration pipeline">
      {stages.map((stage, i) => (
        <li class={`pipeline-stage pipeline-stage--${i + 1}`}>
          <p class="pipeline-stage__num" aria-hidden="true">{stage.num}</p>
          <h3 class="pipeline-stage__name">{stage.name}</h3>
          <p class="pipeline-stage__tool">{stage.tool}</p>
          <p class="pipeline-stage__detail">{stage.detail}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .cm-pipeline {
    padding-top: var(--section-pad-default);
    padding-bottom: var(--section-pad-default);
    border-top: var(--border-hairline);
  }

  @media (max-width: 767px) {
    .cm-pipeline {
      padding-top: var(--space-16);
      padding-bottom: var(--space-16);
    }
  }

  /* Manifesto block — widened past the usual container-prose so the
     elaboration paragraph can stretch from the center of the AUDIT
     stage to the center of the VALIDATE stage in the 1080 px stages
     grid below (5 cols of ~178 px each → ~900 px span between the
     outer stage centers). The principle and eyebrow remain centered
     via text-align; text-wrap: balance keeps the principle wrapping
     to two balanced lines at this width. */
  .cm-pipeline__manifesto {
    max-width: 900px;
    margin: 0 auto var(--space-20) auto;
    text-align: center;
  }

  @media (max-width: 767px) {
    .cm-pipeline__manifesto {
      margin-bottom: var(--space-16);
    }
  }

  .cm-pipeline__eyebrow {
    margin: 0 0 var(--space-8) 0;
    color: var(--color-accent-primary);
  }

  .cm-pipeline__principle {
    font-family: var(--font-display);
    font-size: 48px;
    font-weight: var(--weight-regular);
    line-height: 1.1;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin: 0;
    text-wrap: balance;
  }
  .cm-pipeline__principle em {
    font-style: italic;
  }

  @media (max-width: 767px) {
    .cm-pipeline__principle {
      font-size: 32px;
    }
  }

  .cm-pipeline__rule {
    border: 0;
    border-top: var(--border-hairline);
    width: 64px;
    margin: var(--space-8) auto;
  }

  .cm-pipeline__elaboration {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    font-weight: var(--weight-regular);
    line-height: 1.55;
    color: var(--color-text-secondary);
    margin: 0 auto;
    /* Stretch to the full manifesto block width so the paragraph
       lines up halfway under AUDIT and halfway under VALIDATE in
       the stages grid below. */
    max-width: 100%;
    text-wrap: pretty;
    text-align: left;
  }

  /* Pipeline stages — 5-column grid on desktop, stacked on mobile.
     Identical visual vocabulary to TechDocsPipeline so the two pages
     read as parallel diagrams. */
  .cm-pipeline__stages {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 960px) {
    .cm-pipeline__stages {
      grid-template-columns: repeat(5, 1fr);
      gap: var(--space-12);
    }
  }

  .pipeline-stage {
    border-top: 2px solid var(--color-text-primary);
    padding-top: var(--space-4);
    position: relative;
  }

  /* Amber arrow between stages. Mobile: "v" below each stage.
     Desktop: "->" in the gap, vertically aligned to the stage name
     row, with the same +0 px nudge that landed correctly on TDP. */
  .pipeline-stage:not(:last-child)::after {
    content: "→";
    position: absolute;
    font-family: var(--font-mono);
    font-size: 24px;
    line-height: 1;
    font-weight: var(--weight-medium);
    color: var(--color-accent-primary-hover);
    bottom: calc(-1 * var(--space-8) - 8px);
    left: 50%;
    transform: translateX(-50%) rotate(90deg);
  }

  @media (min-width: 960px) {
    .pipeline-stage:not(:last-child)::after {
      bottom: auto;
      left: auto;
      right: calc(-1 * var(--space-12) / 2 + 0px);
      top: 38px;
      transform: translate(50%, -50%) rotate(0deg);
    }
  }

  .pipeline-stage__num {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.12em;
    color: var(--color-accent-primary);
    margin: 0 0 var(--space-2) 0;
    line-height: 1;
  }

  .pipeline-stage__name {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: var(--weight-medium);
    line-height: 1.1;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-text-primary);
    margin: 0 0 var(--space-4) 0;
  }

  .pipeline-stage__tool {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: var(--weight-medium);
    line-height: 1.45;
    color: var(--color-text-primary);
    margin: 0 0 var(--space-4) 0;
    text-wrap: pretty;
  }

  .pipeline-stage__detail {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    font-weight: var(--weight-regular);
    line-height: 1.5;
    color: var(--color-text-secondary);
    margin: 0;
    text-wrap: pretty;
  }

  /* Reveal animation — viewport-triggered. Manifesto block first,
     then stages stagger in left-to-right. */
  .cm-pipeline.animating .cm-pipeline__eyebrow,
  .cm-pipeline.animating .cm-pipeline__principle,
  .cm-pipeline.animating .cm-pipeline__rule,
  .cm-pipeline.animating .cm-pipeline__elaboration,
  .cm-pipeline.animating .pipeline-stage {
    opacity: 0;
    transform: translateY(8px);
  }

  .cm-pipeline.animating.in-view .cm-pipeline__eyebrow {
    animation: cm-pipe-fade-in 420ms ease-out forwards;
  }
  .cm-pipeline.animating.in-view .cm-pipeline__principle {
    animation: cm-pipe-fade-in 520ms ease-out forwards;
    animation-delay: 120ms;
  }
  .cm-pipeline.animating.in-view .cm-pipeline__rule {
    animation: cm-pipe-fade-in 420ms ease-out forwards;
    animation-delay: 320ms;
  }
  .cm-pipeline.animating.in-view .cm-pipeline__elaboration {
    animation: cm-pipe-fade-in 420ms ease-out forwards;
    animation-delay: 420ms;
  }
  .cm-pipeline.animating.in-view .pipeline-stage:nth-child(1) { animation: cm-pipe-fade-in 420ms ease-out forwards; animation-delay: 640ms; }
  .cm-pipeline.animating.in-view .pipeline-stage:nth-child(2) { animation: cm-pipe-fade-in 420ms ease-out forwards; animation-delay: 760ms; }
  .cm-pipeline.animating.in-view .pipeline-stage:nth-child(3) { animation: cm-pipe-fade-in 420ms ease-out forwards; animation-delay: 880ms; }
  .cm-pipeline.animating.in-view .pipeline-stage:nth-child(4) { animation: cm-pipe-fade-in 420ms ease-out forwards; animation-delay: 1000ms; }
  .cm-pipeline.animating.in-view .pipeline-stage:nth-child(5) { animation: cm-pipe-fade-in 420ms ease-out forwards; animation-delay: 1120ms; }

  @keyframes cm-pipe-fade-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cm-pipeline.animating .cm-pipeline__eyebrow,
    .cm-pipeline.animating .cm-pipeline__principle,
    .cm-pipeline.animating .cm-pipeline__rule,
    .cm-pipeline.animating .cm-pipeline__elaboration,
    .cm-pipeline.animating .pipeline-stage {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }
  }
</style>

<script>
  function setupContentMigrationPipeline() {
    const sec = document.querySelector<HTMLElement>(".cm-pipeline");
    if (!sec) return;
    if (sec.dataset.pipelineRevealInit === "true") return;
    sec.dataset.pipelineRevealInit = "true";

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;
    if (prefersReducedMotion) return;

    sec.classList.add("animating");

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            sec.classList.add("in-view");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );

    observer.observe(sec);
  }

  document.addEventListener("DOMContentLoaded", setupContentMigrationPipeline);
  document.addEventListener("astro:page-load", setupContentMigrationPipeline);
</script>
