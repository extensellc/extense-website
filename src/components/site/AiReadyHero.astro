---
/*
  AiReadyHero — hero for /solutions/ai-ready-content.

  Problem-framed (per the old ex-tense.co page): headline + body name the
  cost of unstructured/unenriched content; a 4-metric band carries the
  numbers. The right column shows a "content-grounds-answer" flow diagram:
  a user query retrieved over typed, enriched content produces a grounded,
  cited answer — the answer is only as good as the content beneath it.

  (The precision-gauge SVG that used to live here moved down to the
  "We Engineer" section, where the measured-85% story belongs.)

  Animation: viewport-triggered cascade adds `.drawn` to the SVG; per-
  element `--d` delays assemble it top-to-bottom. prefers-reduced-motion:
  static render.
*/
---

<section class="airdy-hero">
  <div class="airdy-hero__inner">
    <div class="airdy-hero__top">
      <div class="airdy-hero__text">
        <p class="airdy-hero__kicker">
          TYPE<span class="airdy-hero__dot">·</span>CHUNK<span class="airdy-hero__dot">·</span>FILTER<span class="airdy-hero__dot">·</span>MEASURE
        </p>
        <h1 class="airdy-hero__title">
          Your AI Is Only As Good As <em>Your Content.</em>
        </h1>
        <hr class="airdy-hero__rule" />
        <p class="airdy-hero__body">
          You&rsquo;ve invested in LLMs, chatbots, and RAG pipelines. But if your content is unstructured &mdash; or structured but unenriched &mdash; your AI returns wrong answers, your users lose trust, and your investment delivers a fraction of its potential. Both problems have the same fix.
        </p>
      </div>

      <div class="airdy-hero__visual">
        <svg
          class="flow-svg"
          id="airdy-flow"
          viewBox="0 0 320 440"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
          role="presentation"
        >
          <!-- Corner registration marks (amber chrome) -->
          <g class="corner corner--accent fx" style="--d: 0ms">
            <path d="M 10 20 L 10 10 L 20 10" />
            <path d="M 300 10 L 310 10 L 310 20" />
            <path d="M 10 420 L 10 430 L 20 430" />
            <path d="M 300 430 L 310 430 L 310 420" />
          </g>

          <!-- Top chrome -->
          <text class="chrome fx" x="30" y="24" style="--d: 80ms">in :: rag.retrieval</text>

          <!-- Query pill -->
          <g class="fx" style="--d: 160ms">
            <rect class="query-box" x="95" y="44" width="130" height="30" rx="15" />
            <text class="query-text" x="160" y="63" text-anchor="middle">user query</text>
          </g>

          <!-- Arrow query -> content -->
          <g class="flow-arrow fx" style="--d: 280ms">
            <line x1="160" y1="74" x2="160" y2="92" />
            <path d="M 155 87 L 160 93 L 165 87" />
          </g>

          <!-- Content zone label -->
          <text class="chrome chrome--strong fx" x="30" y="110" style="--d: 360ms">TYPED, ENRICHED CONTENT</text>

          <!-- Three typed content blocks -->
          <g class="content-block fx" style="--d: 440ms">
            <rect class="block-box" x="24" y="120" width="80" height="56" />
            <text class="block-tag" x="34" y="138">concept</text>
            <line class="block-line" x1="34" y1="149" x2="92" y2="149" />
            <line class="block-line" x1="34" y1="157" x2="78" y2="157" />
            <rect class="block-chip" x="34" y="162" width="26" height="7" />
          </g>
          <g class="content-block fx" style="--d: 520ms">
            <rect class="block-box" x="120" y="120" width="80" height="56" />
            <text class="block-tag" x="130" y="138">task</text>
            <line class="block-line" x1="130" y1="149" x2="188" y2="149" />
            <line class="block-line" x1="130" y1="157" x2="174" y2="157" />
            <rect class="block-chip" x="130" y="162" width="26" height="7" />
          </g>
          <g class="content-block fx" style="--d: 600ms">
            <rect class="block-box" x="216" y="120" width="80" height="56" />
            <text class="block-tag" x="226" y="138">reference</text>
            <line class="block-line" x1="226" y1="149" x2="284" y2="149" />
            <line class="block-line" x1="226" y1="157" x2="270" y2="157" />
            <rect class="block-chip" x="226" y="162" width="26" height="7" />
          </g>

          <!-- Grounding: blocks converge to a retrieval junction -->
          <g class="grounding fx" style="--d: 680ms">
            <line x1="64" y1="176" x2="160" y2="200" />
            <line x1="160" y1="176" x2="160" y2="200" />
            <line x1="256" y1="176" x2="160" y2="200" />
            <circle class="junction" cx="160" cy="200" r="4" />
          </g>

          <!-- Arrow junction -> answer -->
          <g class="flow-arrow fx" style="--d: 760ms">
            <line x1="160" y1="204" x2="160" y2="234" />
            <path d="M 155 229 L 160 235 L 165 229" />
          </g>

          <!-- Grounded answer card (the brand result) -->
          <g class="fx" style="--d: 860ms">
            <rect class="answer-card" x="40" y="240" width="240" height="140" rx="4" />
            <text class="answer-label" x="58" y="266">GROUNDED ANSWER</text>
            <path class="answer-check" d="M 246 256 l 5 7 l 11 -13" />
            <line class="answer-line" x1="58" y1="286" x2="262" y2="286" />
            <line class="answer-line" x1="58" y1="298" x2="244" y2="298" />
            <line class="answer-line" x1="58" y1="310" x2="212" y2="310" />
            <rect class="cite-chip" x="58" y="328" width="58" height="20" rx="3" />
            <text class="cite-text" x="87" y="342" text-anchor="middle">§ 4.2</text>
            <text class="cite-note" x="128" y="342">traceable to source</text>
          </g>

          <!-- Bottom chrome -->
          <g class="fx" style="--d: 1060ms">
            <line class="chrome-rule" x1="30" y1="400" x2="290" y2="400" />
            <text class="chrome chrome--strong" x="30" y="418">FIG. 06</text>
            <text class="chrome" x="80" y="418">/</text>
            <text class="chrome chrome--strong" x="88" y="418">answer.grounded</text>
            <rect class="build-dot" x="214" y="412" width="6" height="6" />
            <text class="chrome chrome--strong" x="290" y="418" text-anchor="end">GROUNDED OK</text>
          </g>
        </svg>
      </div>
    </div>

    <dl class="airdy-hero__metrics">
      <div class="airdy-metric">
        <dt class="airdy-metric__num">25&ndash;35%</dt>
        <dd class="airdy-metric__label">Chatbot precision on unstructured or unenriched content</dd>
      </div>
      <div class="airdy-metric">
        <dt class="airdy-metric__num">85%+</dt>
        <dd class="airdy-metric__label">Precision after structured content engineering</dd>
      </div>
      <div class="airdy-metric">
        <dt class="airdy-metric__num">3&times;</dt>
        <dd class="airdy-metric__label">Average improvement in AI answer accuracy</dd>
      </div>
      <div class="airdy-metric">
        <dt class="airdy-metric__num">15 yrs</dt>
        <dd class="airdy-metric__label">Enterprise content engineering experience</dd>
      </div>
    </dl>
  </div>
</section>

<style>
  .airdy-hero {
    width: 100%;
  }

  .airdy-hero__inner {
    max-width: var(--container-page, 1240px);
    margin: 0 auto;
    padding: var(--space-32) var(--space-12);
  }

  @media (max-width: 767px) {
    .airdy-hero__inner {
      padding: var(--space-20) var(--space-6);
    }
  }

  .airdy-hero__top {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-16);
    align-items: start;
  }

  @media (min-width: 960px) {
    .airdy-hero__top {
      grid-template-columns: 60% 40%;
      gap: var(--space-12);
    }
  }

  .airdy-hero__text {
    max-width: 640px;
  }

  .airdy-hero__kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-6) 0;
  }
  .airdy-hero__dot {
    color: var(--color-text-muted);
    margin: 0 0.5em;
  }

  .airdy-hero__title {
    font-family: var(--font-display);
    font-weight: var(--weight-regular);
    font-size: 48px;
    line-height: 1.1;
    letter-spacing: -0.012em;
    color: var(--color-text-primary);
    margin: 0 0 var(--space-6) 0;
    text-wrap: balance;
  }
  .airdy-hero__title em {
    font-style: italic;
  }

  @media (max-width: 960px) {
    .airdy-hero__title {
      font-size: 36px;
    }
  }

  .airdy-hero__rule {
    border: 0;
    border-top: var(--border-hairline);
    width: 64px;
    margin: 0 0 var(--space-6) 0;
  }

  .airdy-hero__body {
    font-family: var(--font-body);
    font-weight: var(--weight-regular);
    font-size: 18px;
    line-height: 1.55;
    color: var(--color-text-secondary);
    margin: 0;
    max-width: 560px;
    text-wrap: pretty;
  }

  /* Right: flow SVG */
  .airdy-hero__visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .flow-svg {
    width: 100%;
    max-width: 360px;
    height: auto;
    color: var(--color-text-primary);
    overflow: visible;
    display: block;
    shape-rendering: geometricPrecision;
  }

  /* ── 4-metric band ─────────────────────────────────────────────── */
  .airdy-hero__metrics {
    margin: var(--space-16) 0 0 0;
    padding-top: var(--space-12);
    border-top: var(--border-hairline);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }
  @media (min-width: 600px) {
    .airdy-hero__metrics {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-10);
    }
  }
  @media (min-width: 960px) {
    .airdy-hero__metrics {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-8);
    }
  }

  .airdy-metric {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .airdy-metric__num {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: var(--weight-regular);
    line-height: 1;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    font-variant-numeric: tabular-nums;
  }
  .airdy-metric__label {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin: 0;
    text-wrap: pretty;
  }

  /* ── SVG element styling (shared chrome vocabulary) ────────────── */
  .flow-svg .chrome {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: var(--weight-regular);
    fill: var(--color-text-muted);
    letter-spacing: 0.06em;
    user-select: none;
  }
  .flow-svg .chrome--strong {
    fill: var(--color-text-primary);
    font-weight: var(--weight-medium);
  }
  .flow-svg .corner--accent {
    stroke: var(--color-accent-primary-hover);
    stroke-width: 1.25;
    fill: none;
  }
  .flow-svg .chrome-rule {
    stroke: var(--color-border-subtle);
    stroke-width: 1;
  }
  .flow-svg .build-dot {
    fill: var(--color-accent-primary-hover);
    stroke: none;
  }

  /* Query pill */
  .flow-svg .query-box {
    fill: var(--color-page-bg);
    stroke: var(--color-text-primary);
    stroke-width: 1.5;
    vector-effect: non-scaling-stroke;
  }
  .flow-svg .query-text {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: var(--weight-medium);
    fill: var(--color-text-primary);
    letter-spacing: 0.04em;
  }

  /* Flow arrows (amber) */
  .flow-svg .flow-arrow line,
  .flow-svg .flow-arrow path {
    stroke: var(--color-accent-primary-hover);
    stroke-width: 1.5;
    fill: none;
    vector-effect: non-scaling-stroke;
  }

  /* Content blocks */
  .flow-svg .block-box {
    fill: var(--color-page-bg);
    stroke: var(--color-text-primary);
    stroke-width: 1.25;
    vector-effect: non-scaling-stroke;
  }
  .flow-svg .block-tag {
    font-family: var(--font-mono);
    font-size: 8px;
    font-weight: var(--weight-medium);
    fill: var(--color-text-primary);
    letter-spacing: 0.04em;
  }
  .flow-svg .block-line {
    stroke: var(--color-text-muted);
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
  }
  .flow-svg .block-chip {
    fill: var(--color-accent-primary);
  }

  /* Grounding lines + junction */
  .flow-svg .grounding line {
    stroke: var(--color-accent-primary-hover);
    stroke-width: 1;
    stroke-dasharray: 3 3;
    vector-effect: non-scaling-stroke;
  }
  .flow-svg .junction {
    fill: var(--color-accent-primary-hover);
    stroke: none;
  }

  /* Answer card — the brand result (light-amber wash + amber border) */
  .flow-svg .answer-card {
    fill: #fef3c7;
    stroke: var(--color-accent-primary-hover);
    stroke-width: 1.5;
    vector-effect: non-scaling-stroke;
  }
  .flow-svg .answer-label {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: var(--weight-medium);
    fill: var(--color-accent-primary-pressed);
    letter-spacing: 0.08em;
  }
  .flow-svg .answer-check {
    stroke: var(--color-accent-primary-hover);
    stroke-width: 2;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
    vector-effect: non-scaling-stroke;
  }
  .flow-svg .answer-line {
    stroke: var(--color-text-secondary);
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
  }
  .flow-svg .cite-chip {
    fill: var(--color-page-bg);
    stroke: var(--color-accent-primary-hover);
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
  }
  .flow-svg .cite-text {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: var(--weight-medium);
    fill: var(--color-accent-primary-pressed);
  }
  .flow-svg .cite-note {
    font-family: var(--font-mono);
    font-size: 9px;
    fill: var(--color-text-secondary);
    letter-spacing: 0.02em;
  }

  /* ── Reveal cascade ────────────────────────────────────────────── */
  .flow-svg .fx {
    opacity: 0;
  }
  .flow-svg.drawn .fx {
    animation: flow-fade-in 320ms ease-out forwards;
    animation-delay: var(--d, 0ms);
  }
  @keyframes flow-fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .flow-svg .fx {
      opacity: 1 !important;
      animation: none !important;
    }
  }
</style>

<script>
  function setupAiReadyHero() {
    const svg = document.getElementById("airdy-flow") as SVGElement | null;
    if (!svg) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            svg.classList.add("drawn");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );

    observer.observe(svg);
  }

  document.addEventListener("DOMContentLoaded", setupAiReadyHero);
  document.addEventListener("astro:page-load", setupAiReadyHero);
</script>
