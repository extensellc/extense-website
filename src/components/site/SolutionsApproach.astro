---
/*
  SolutionsApproach — the resolution section on /solutions.

  Sequenced after the diagnosis (SolutionsProblem) and before the four
  solution-area editorial sections. Carries the engineering framing:
  the single principle that the rest of the page operationalizes.

  Layout
    - container-prose width, centered
    - small monospace eyebrow ("The approach")
    - large display-serif principle headline (60 px desktop) with the
      word "system" italicized to underline the central metaphor
    - hairline rule as a typographic breath
    - medium-weight elaboration paragraph below

  Animation
    - Section adds .animating on JS init (no-JS fails open)
    - .in-view added on viewport entry (IntersectionObserver threshold 0.15)
    - Eyebrow, principle, rule, and elaboration fade up in sequence
    - prefers-reduced-motion: static
*/
---

<section class="solutions-approach" aria-labelledby="approach-heading">
  <div class="container-prose solutions-approach__inner">
    <p class="eyebrow solutions-approach__eyebrow">The approach</p>
    <h2 id="approach-heading" class="solutions-approach__principle">
      Documentation is a <em>system</em>, not a deliverable.
    </h2>
    <hr class="solutions-approach__rule" />
    <p class="solutions-approach__elaboration">
      Treat content like code — modeled, versioned, automated, validated — and the volume that overwhelmed authoring becomes a system you can ship.
    </p>
  </div>
</section>

<style>
  .solutions-approach {
    padding-top: var(--section-pad-default);
    padding-bottom: var(--section-pad-default);
    border-top: var(--border-hairline);
  }

  @media (max-width: 767px) {
    .solutions-approach {
      padding-top: var(--space-16);
      padding-bottom: var(--space-16);
    }
  }

  /* container-prose gives a narrower reading column. Center-align all
     content inside so the statement reads as a declaration. */
  .solutions-approach__inner {
    text-align: center;
  }

  .solutions-approach__eyebrow {
    margin: 0 0 var(--space-8) 0;
    color: var(--color-accent-primary);
  }

  /* The principle. Largest typography on the entire page so far —
     intentionally heavier than the section headings elsewhere because
     this is the page's thesis moment. */
  .solutions-approach__principle {
    font-family: var(--font-display);
    font-size: 56px;
    font-weight: var(--weight-regular);
    line-height: 1.08;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin: 0;
    text-wrap: balance;
  }

  @media (max-width: 767px) {
    .solutions-approach__principle {
      font-size: 36px;
    }
  }

  .solutions-approach__principle em {
    font-style: italic;
    /* Use the existing display-serif italic face loaded in BaseLayout. */
  }

  /* Hairline rule between the principle and the elaboration — same
     short-rule pattern the hero uses between title and subdeck. */
  .solutions-approach__rule {
    border: 0;
    border-top: var(--border-hairline);
    width: 64px;
    margin: var(--space-8) auto;
  }

  .solutions-approach__elaboration {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    font-weight: var(--weight-regular);
    line-height: 1.55;
    color: var(--color-text-secondary);
    margin: 0 auto;
    max-width: 56ch;
    text-wrap: pretty;
  }

  /* ─────────────────────────────────────────────────────────────────
     Reveal animation — viewport-triggered. JS adds .animating immediately
     so no-JS users see the section in its default visible state, then
     .in-view when scrolled to. Elements fade up in sequence.
     ───────────────────────────────────────────────────────────────── */
  .solutions-approach.animating .solutions-approach__eyebrow,
  .solutions-approach.animating .solutions-approach__principle,
  .solutions-approach.animating .solutions-approach__rule,
  .solutions-approach.animating .solutions-approach__elaboration {
    opacity: 0;
    transform: translateY(8px);
  }

  .solutions-approach.animating.in-view .solutions-approach__eyebrow {
    animation: approach-fade-in 420ms ease-out forwards;
    animation-delay: 0ms;
  }
  .solutions-approach.animating.in-view .solutions-approach__principle {
    animation: approach-fade-in 520ms ease-out forwards;
    animation-delay: 120ms;
  }
  .solutions-approach.animating.in-view .solutions-approach__rule {
    animation: approach-fade-in 420ms ease-out forwards;
    animation-delay: 320ms;
  }
  .solutions-approach.animating.in-view .solutions-approach__elaboration {
    animation: approach-fade-in 420ms ease-out forwards;
    animation-delay: 420ms;
  }

  @keyframes approach-fade-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .solutions-approach.animating .solutions-approach__eyebrow,
    .solutions-approach.animating .solutions-approach__principle,
    .solutions-approach.animating .solutions-approach__rule,
    .solutions-approach.animating .solutions-approach__elaboration {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }
  }
</style>

<script>
  // ─────────────────────────────────────────────────────────
  // SolutionsApproach — viewport-triggered reveal
  // ─────────────────────────────────────────────────────────
  function setupSolutionsApproach() {
    const sec = document.querySelector<HTMLElement>(".solutions-approach");
    if (!sec) return;
    if (sec.dataset.approachRevealInit === "true") return;
    sec.dataset.approachRevealInit = "true";

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;
    if (prefersReducedMotion) return;

    sec.classList.add("animating");

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            sec.classList.add("in-view");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );

    observer.observe(sec);
  }

  document.addEventListener("DOMContentLoaded", setupSolutionsApproach);
  document.addEventListener("astro:page-load", setupSolutionsApproach);
</script>
