---
/*
  SolutionsProblem — "Solving the Content Problem at Scale" section on /solutions.

  (Filename retained for the existing index.astro import; the section was
  repurposed from the new-site "The problem at scale" diagnosis into the
  old-site framing block: intro copy + the four-step engagement strip.)

  Sequenced after the hero, before the solution cards (old-site order).

  Layout
    - heading + intro at container-prose width (narrow)
    - Assess -> Architect -> Implement -> Optimize, four hairline step cards
      in a row connected by amber arrows; stacks on mobile (arrows rotate down)

  Animation
    - Section adds .animating on JS init (no-JS fails open); .in-view on
      viewport entry. Heading fades up, then the steps stagger left-to-right.
    - prefers-reduced-motion: static.
*/

interface Step {
  id: string;
  name: string;
  desc: string;
}

const steps: Step[] = [
  {
    id: "assess",
    name: "Assess",
    desc: "Audit the existing content estate — formats, volume, and the recoverable, reusable assets buried in legacy documents.",
  },
  {
    id: "architect",
    name: "Architect",
    desc: "Design the information model — the schema, taxonomy, and reuse strategy everything downstream depends on.",
  },
  {
    id: "implement",
    name: "Implement",
    desc: "Deploy the toolchain and migrate — conversion at scale, CCMS configuration, and the CI/CD that publishes it.",
  },
  {
    id: "optimize",
    name: "Optimize",
    desc: "Measure, iterate, and scale — usage metrics and feedback that tighten the system release over release.",
  },
];
---

<section class="solutions-problem section-band" aria-labelledby="solving-heading">
  <div class="container-data solutions-problem__inner">
    <div class="solutions-problem__heading-block">
      <h2 id="solving-heading" class="solutions-problem__heading">
        Solving the Content Problem at Scale
      </h2>
      <p class="solutions-problem__subdeck">
        Every organization has content. The question is whether that content is
        an asset or a liability. Our solutions turn unstructured, siloed
        information into reusable, standards-based, automatically publishable
        knowledge.
      </p>
    </div>

    <div class="solving-steps" role="list">
      {steps.map((step, i) => (
        <>
          <div class="solving-step" role="listitem">
            <div class="solving-step__head">
              <span class="solving-step__icon" aria-hidden="true">
                {step.id === "assess" && (
                  <svg viewBox="0 0 24 24" fill="none">
                    <circle cx="10.5" cy="10.5" r="6.5" />
                    <line x1="15.5" y1="15.5" x2="20.5" y2="20.5" />
                  </svg>
                )}
                {step.id === "architect" && (
                  <svg viewBox="0 0 24 24" fill="none">
                    <rect x="9" y="3" width="6" height="4" />
                    <rect x="3" y="15" width="6" height="4" />
                    <rect x="15" y="15" width="6" height="4" />
                    <path d="M12 7 V11 M6 11 H18 M6 11 V15 M18 11 V15" />
                  </svg>
                )}
                {step.id === "implement" && (
                  <svg viewBox="0 0 24 24" fill="none">
                    <rect x="2" y="9" width="6" height="6" />
                    <path d="M8 12 H20" />
                    <path d="M16 8 L20 12 L16 16" />
                  </svg>
                )}
                {step.id === "optimize" && (
                  <svg viewBox="0 0 24 24" fill="none">
                    <line x1="3" y1="20" x2="21" y2="20" />
                    <rect x="5" y="13" width="3.5" height="7" />
                    <rect x="10.5" y="9" width="3.5" height="11" />
                    <rect x="16" y="5" width="3.5" height="15" />
                  </svg>
                )}
              </span>
              <span class="solving-step__num">{String(i + 1).padStart(2, "0")}</span>
            </div>
            <span class="solving-step__name">{step.name}</span>
            <span class="solving-step__desc">{step.desc}</span>
          </div>
          {i < steps.length - 1 && (
            <span class="solving-steps__arrow" aria-hidden="true">→</span>
          )}
        </>
      ))}
    </div>
  </div>
</section>

<style>
  .solutions-problem {
    padding-top: var(--section-pad-default);
    padding-bottom: var(--section-pad-default);
    border-top: var(--border-hairline);
  }

  @media (max-width: 767px) {
    .solutions-problem {
      padding-top: var(--space-16);
      padding-bottom: var(--space-16);
    }
  }

  .solutions-problem__heading-block {
    max-width: var(--container-prose, 720px);
    margin-bottom: var(--space-12);
  }

  .solutions-problem__heading {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin: 0;
    text-wrap: balance;
  }

  .solutions-problem__subdeck {
    margin-top: var(--space-4);
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    max-width: 64ch;
    text-wrap: pretty;
  }

  /* Four-step strip: Assess -> Architect -> Implement -> Optimize.
     Hairline step cards in a row, amber arrows between. Stacks on mobile. */
  .solving-steps {
    display: flex;
    align-items: stretch;
    gap: var(--space-4);
  }

  .solving-step {
    flex: 1 1 0;
    min-width: 0;
    border: var(--border-hairline);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    background-color: var(--color-page-bg);
  }

  .solving-step__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-1);
  }

  .solving-step__icon svg {
    display: block;
    width: 28px;
    height: 28px;
    stroke: var(--color-text-primary);
    stroke-width: 1.5;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .solving-step__num {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.08em;
    color: var(--color-accent-primary);
  }

  .solving-step__name {
    font-family: var(--font-display);
    font-size: var(--text-display-sm);
    font-weight: var(--weight-regular);
    color: var(--color-text-primary);
    line-height: var(--leading-snug);
  }

  .solving-step__desc {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    text-wrap: pretty;
  }

  .solving-steps__arrow {
    flex: 0 0 auto;
    align-self: center;
    color: var(--color-accent-primary-hover);
    font-size: 18px;
    line-height: 1;
  }

  @media (max-width: 767px) {
    .solving-steps {
      flex-direction: column;
      gap: var(--space-3);
    }
    .solving-steps__arrow {
      align-self: center;
      transform: rotate(90deg);
    }
  }

  /* ── Reveal: heading fades up, then the steps stagger left-to-right. ── */
  .solutions-problem.animating .solutions-problem__heading-block,
  .solutions-problem.animating .solving-steps > * {
    opacity: 0;
    transform: translateY(8px);
  }
  .solutions-problem.animating.in-view .solutions-problem__heading-block {
    animation: problem-fade-in 480ms ease-out forwards;
  }
  .solutions-problem.animating.in-view .solving-steps > * {
    animation: problem-fade-in 420ms ease-out forwards;
  }
  .solutions-problem.animating.in-view .solving-steps > *:nth-child(1) { animation-delay: 200ms; }
  .solutions-problem.animating.in-view .solving-steps > *:nth-child(2) { animation-delay: 280ms; }
  .solutions-problem.animating.in-view .solving-steps > *:nth-child(3) { animation-delay: 360ms; }
  .solutions-problem.animating.in-view .solving-steps > *:nth-child(4) { animation-delay: 440ms; }
  .solutions-problem.animating.in-view .solving-steps > *:nth-child(5) { animation-delay: 520ms; }
  .solutions-problem.animating.in-view .solving-steps > *:nth-child(6) { animation-delay: 600ms; }
  .solutions-problem.animating.in-view .solving-steps > *:nth-child(7) { animation-delay: 680ms; }

  @keyframes problem-fade-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  /* Keep the mobile arrow rotation through the reveal. */
  @media (max-width: 767px) {
    @keyframes problem-fade-in {
      to {
        opacity: 1;
        transform: translateY(0) rotate(90deg);
      }
    }
    /* Steps themselves don't rotate — scope the rotated keyframe to arrows. */
    .solutions-problem.animating.in-view .solving-step {
      animation-name: problem-fade-in-plain;
    }
    @keyframes problem-fade-in-plain {
      to { opacity: 1; transform: translateY(0); }
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .solutions-problem.animating .solutions-problem__heading-block,
    .solutions-problem.animating .solving-steps > * {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }
    @media (max-width: 767px) {
      .solutions-problem.animating .solving-steps__arrow {
        transform: rotate(90deg) !important;
      }
    }
  }
</style>

<script>
  // SolutionsProblem — section-level reveal on viewport entry.
  function setupSolutionsProblem() {
    const sec = document.querySelector<HTMLElement>(".solutions-problem");
    if (!sec) return;
    if (sec.dataset.problemRevealInit === "true") return;
    sec.dataset.problemRevealInit = "true";

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;
    if (prefersReducedMotion) return;

    sec.classList.add("animating");

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            sec.classList.add("in-view");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );
    observer.observe(sec);
  }

  document.addEventListener("DOMContentLoaded", setupSolutionsProblem);
  document.addEventListener("astro:page-load", setupSolutionsProblem);
</script>
