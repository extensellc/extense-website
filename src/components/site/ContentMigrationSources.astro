---
/*
  ContentMigrationSources — five editorial chapter-blocks on
  /solutions/content-migration.

  Sequenced after the pipeline section. Each block is one source-format
  family Extense converts from — plus a fifth block for topic
  deduplication, the cross-cutting engineering capability:

    01  FrameMaker & InDesign.
    02  Word, RoboHelp & Confluence.
    03  Unstructured XML, SGML & HTML.
    04  PDF & scanned print.
    05  Topic deduplication.

  Per-block structure (mirrors TechDocsOutputs)
    - amber monospace number prefix (left column, narrow)
    - display-serif name + italic subtitle + body + pull-quote hook
      (right column, wide)
    - hairline rule at the top of each block; last block also gets a
      hairline at the bottom so the section ends cleanly
    - no "Explore" link affordance: these blocks are the destination

  Pull-quote
    - italic display serif
    - 2 px amber left bar via ::before, scales in on reveal

  Animation: per-block IntersectionObserver, same pattern as
  TechDocsOutputs. prefers-reduced-motion: static.
*/

interface SourceArea {
  num: string;
  name: string;
  subtitle: string;
  body: string;
  hook: string;
}

const sources: SourceArea[] = [
  {
    num: "01",
    name: "FrameMaker & InDesign",
    subtitle: "Adobe page-layout estates.",
    body: "FrameMaker MIF parsed via custom XSL. InDesign IDML extracted topic-by-topic, with frame hierarchy mapped to DITA section structure. Cross-references, conditional text, and variable definitions migrated as conref keys and DITAVAL filters.",
    hook: "What does a 4,000-page FrameMaker book turn into, when the page-layout heuristics finally agree?",
  },
  {
    num: "02",
    name: "Word, RoboHelp & Confluence",
    subtitle: "Office and help-authoring estates.",
    body: "Word OOXML parsed via OpenXML with paragraph-style mappings to DITA element vocabularies. RoboHelp HHP and CHM unpacked and topic-split. Confluence space exports converted via the REST API with macro mappings to conref keys. Heading-style consistency rebuilt where the source forgot it.",
    hook: "Where do all the inconsistent heading styles go?",
  },
  {
    num: "03",
    name: "Unstructured XML, SGML & HTML",
    subtitle: "XML estates that lost their DTD.",
    body: "DocBook, IBMIDDoc, MIL-STD-2361, and bespoke XML schemas converted via element-by-element XSLT 3.0 transforms. SGML normalized through OmniMark or SGML→XML round-tripping. HTML estates — intranet exports, knowledge bases — parsed into DITA topics with link-graph preservation.",
    hook: "When the original DTD is lost, what tells you what the elements meant?",
  },
  {
    num: "04",
    name: "PDF & scanned print",
    subtitle: "The estate that never had structure.",
    body: "Born-digital PDFs parsed via PDF.js or pdfminer, with tagged-PDF structure extraction where present. Scanned PDFs OCR’d through ABBYY FineReader with layout reconstruction. Output is a structured DITA shell — imperfect, but a measurable starting point that hand-keying cannot match for cost.",
    hook: "Is the parts catalog locked in a 1998 PDF still authoritative? Then why is it unsearchable?",
  },
  {
    num: "05",
    name: "Topic deduplication",
    subtitle: "The compounding payoff.",
    body: "Paragraph and span hashes computed across the entire converted estate. Exact matches consolidated automatically; near-duplicates (typically 92%+ similarity) routed to a reviewer queue with diff. Consolidated content becomes a topic warehouse; originals carry conref pointers to it. Typical result: 15–30% of topics retired in the first pass, full provenance retained.",
    hook: "Why discover the 30% redundancy after migration, when you can collapse it during?",
  },
];
---

<section class="cm-sources" aria-labelledby="cm-sources-heading">
  <div class="container-data cm-sources__inner">
    <div class="cm-sources__heading-block">
      <h2 id="cm-sources-heading" class="cm-sources__heading">
        Five fronts, <em>one target.</em>
      </h2>
      <p class="cm-sources__subdeck">
        Four legacy format families, plus the engineering capability that compounds the savings. Each is a separate parser, transform, or hash-matching pass in the same engineered conversion.
      </p>
    </div>

    <ol class="cm-sources__list">
      {sources.map((area) => (
        <li class="source-area">
          <div class="source-area__num" aria-hidden="true">{area.num}</div>
          <div class="source-area__content">
            <h3 class="source-area__name">{area.name}.</h3>
            <p class="source-area__subtitle">{area.subtitle}</p>
            <p class="source-area__body">{area.body}</p>
            <p class="source-area__hook">{area.hook}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .cm-sources {
    padding-top: var(--section-pad-default);
    padding-bottom: var(--section-pad-default);
    border-top: var(--border-hairline);
  }

  @media (max-width: 767px) {
    .cm-sources {
      padding-top: var(--space-16);
      padding-bottom: var(--space-16);
    }
  }

  .cm-sources__heading-block {
    max-width: var(--container-prose, 720px);
    margin-bottom: var(--space-16);
  }

  .cm-sources__heading {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin: 0;
    text-wrap: balance;
  }
  .cm-sources__heading em {
    font-style: italic;
  }

  .cm-sources__subdeck {
    margin-top: var(--space-4);
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    max-width: 64ch;
    text-wrap: pretty;
  }

  /* List of areas — flat list, no bullets. Each area separated by a
     hairline at its top. Last area also gets a hairline at the bottom
     so the section ends cleanly. */
  .cm-sources__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .source-area {
    border-top: var(--border-hairline);
    padding-top: var(--space-12);
    padding-bottom: var(--space-12);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }
  .source-area:last-child {
    border-bottom: var(--border-hairline);
  }

  @media (min-width: 768px) {
    .source-area {
      grid-template-columns: 96px 1fr;
      gap: var(--space-8);
      padding-top: var(--space-16);
      padding-bottom: var(--space-16);
    }
  }

  .source-area__num {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.08em;
    color: var(--color-accent-primary);
    line-height: 1;
    padding-top: 8px;
  }

  .source-area__content {
    max-width: 72ch;
  }

  .source-area__name {
    font-family: var(--font-display);
    font-size: var(--text-display-md);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-2) 0;
    text-wrap: balance;
  }

  .source-area__subtitle {
    font-family: var(--font-display);
    font-size: 18px;
    font-style: italic;
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-6) 0;
    text-wrap: pretty;
  }

  .source-area__body {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    line-height: 1.55;
    margin: 0 0 var(--space-8) 0;
    text-wrap: pretty;
  }

  /* Pull-quote hook: italic with a 2 px amber bar on the left. */
  .source-area__hook {
    position: relative;
    margin: 0;
    padding-left: var(--space-6);
    font-family: var(--font-display);
    font-size: 22px;
    font-style: italic;
    font-weight: var(--weight-regular);
    line-height: 1.4;
    color: var(--color-text-primary);
    text-wrap: pretty;
    max-width: 60ch;
  }
  .source-area__hook::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background-color: var(--color-accent-primary-hover);
    transform-origin: top center;
  }

  /* Reveal animation — per-block, same pattern as TechDocsOutputs. */
  .cm-sources.animating .cm-sources__heading-block {
    opacity: 0;
    transform: translateY(8px);
  }
  .cm-sources.animating .source-area__num,
  .cm-sources.animating .source-area__name,
  .cm-sources.animating .source-area__subtitle,
  .cm-sources.animating .source-area__body,
  .cm-sources.animating .source-area__hook {
    opacity: 0;
    transform: translateY(8px);
  }
  .cm-sources.animating .source-area__hook::before {
    transform: scaleY(0);
  }

  .cm-sources.animating.in-view .cm-sources__heading-block {
    animation: cm-sources-fade-in 480ms ease-out forwards;
  }

  .cm-sources.animating .source-area.in-view .source-area__num {
    animation: cm-sources-fade-in 420ms ease-out forwards;
  }
  .cm-sources.animating .source-area.in-view .source-area__name {
    animation: cm-sources-fade-in 420ms ease-out forwards;
    animation-delay: 80ms;
  }
  .cm-sources.animating .source-area.in-view .source-area__subtitle {
    animation: cm-sources-fade-in 420ms ease-out forwards;
    animation-delay: 140ms;
  }
  .cm-sources.animating .source-area.in-view .source-area__body {
    animation: cm-sources-fade-in 420ms ease-out forwards;
    animation-delay: 220ms;
  }
  .cm-sources.animating .source-area.in-view .source-area__hook {
    animation: cm-sources-fade-in 420ms ease-out forwards;
    animation-delay: 320ms;
  }
  .cm-sources.animating .source-area.in-view .source-area__hook::before {
    animation: cm-sources-bar-grow 520ms ease-out forwards;
    animation-delay: 320ms;
  }

  @keyframes cm-sources-fade-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes cm-sources-bar-grow {
    to {
      transform: scaleY(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cm-sources.animating .cm-sources__heading-block,
    .cm-sources.animating .source-area__num,
    .cm-sources.animating .source-area__name,
    .cm-sources.animating .source-area__subtitle,
    .cm-sources.animating .source-area__body,
    .cm-sources.animating .source-area__hook {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }
    .cm-sources.animating .source-area__hook::before {
      transform: scaleY(1) !important;
      animation: none !important;
    }
  }
</style>

<script>
  function setupContentMigrationSources() {
    const sec = document.querySelector<HTMLElement>(".cm-sources");
    if (!sec) return;
    if (sec.dataset.sourcesRevealInit === "true") return;
    sec.dataset.sourcesRevealInit = "true";

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;
    if (prefersReducedMotion) return;

    sec.classList.add("animating");

    const sectionObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            sec.classList.add("in-view");
            sectionObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );
    sectionObserver.observe(sec);

    const areaObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("in-view");
            areaObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.25 }
    );
    const areas = sec.querySelectorAll<HTMLElement>(".source-area");
    areas.forEach((area) => areaObserver.observe(area));
  }

  document.addEventListener("DOMContentLoaded", setupContentMigrationSources);
  document.addEventListener("astro:page-load", setupContentMigrationSources);
</script>
