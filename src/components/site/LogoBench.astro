---
/*
  LogoBench — client logo display.

  Spec ref: EXTENSE_DESIGN_BRIEF.md §9 (Visualization)

  Variants:
    .full        — 12 logos mixed federal/commercial (/). Marquee carousel.
    .federal     — 3 logos (public-sector pages). Static grid.
    .commercial  — 8 logos (private-sector). Static grid.
    .industry    — 1–2 logos (industry pages). Static grid.

  Treatment: monochrome single-color (color-text-secondary), no original brand colors.
  Optical-balance alignment, not strict pixel-grid.

  The .full variant on the homepage renders as an auto-scrolling horizontal
  marquee. The logos cycle infinitely. Pauses on hover. Honors
  prefers-reduced-motion (animation removed; static rendering).

  Phase 4 follow-up: replace text-fallback labels with actual logo SVGs in
  public/images/clients/ when sourced. Component supports both src and label.
*/

interface Logo {
  label: string;
  src?: string;
  href?: string;
  /**
   * Per-logo max height in px (desktop). Used to visually balance logos
   * of different intrinsic aspect ratios in the marquee. Seals and
   * pictorial marks need more height than horizontal wordmarks.
   * Mobile renders at ~75% of this value.
   */
  maxH?: number;
}

interface Props {
  variant: "full" | "federal" | "commercial" | "industry";
  logos?: Logo[];
  eyebrow?: string;
}

/* Per-logo heights tuned for optical balance — pictorial seals get more
   height than horizontal wordmarks so each reads at comparable visual weight.
   Heights chosen against the marquee row baseline. */
const defaultLogos: Record<Props["variant"], Logo[]> = {
  full: [
    { label: "IRS", src: "/images/clients/irs.png", maxH: 80 },
    { label: "U.S. House of Representatives", src: "/images/clients/us-house.png", maxH: 80 },
    { label: "U.S. District Courts", src: "/images/clients/us-district-courts.png", maxH: 75 },
    { label: "Paralyzed Veterans of America", src: "/images/clients/paralyzed-veterans.png", maxH: 70 },
    { label: "Toyota", src: "/images/clients/toyota.png", maxH: 65 },
    { label: "FedEx", src: "/images/clients/fedex.png", maxH: 70 },
    { label: "Morgan Stanley", src: "/images/clients/morgan-stanley.png", maxH: 50 },
    { label: "Great American Insurance Group", src: "/images/clients/great-american-insurance.jpg", maxH: 65 },
    { label: "Guidewire", src: "/images/clients/guidewire.png", maxH: 55 },
    { label: "Thermo Fisher", src: "/images/clients/thermo-fisher.png", maxH: 60 },
    { label: "AMD", src: "/images/clients/amd.png", maxH: 45 },
    { label: "HPE", src: "/images/clients/hpe.png", maxH: 40 },
  ],
  federal: [
    { label: "IRS", src: "/images/clients/irs.png", maxH: 80 },
    { label: "U.S. House of Representatives", src: "/images/clients/us-house.png", maxH: 80 },
    { label: "U.S. District Courts", src: "/images/clients/us-district-courts.png", maxH: 75 },
    { label: "Paralyzed Veterans of America", src: "/images/clients/paralyzed-veterans.png", maxH: 70 },
  ],
  commercial: [
    { label: "Toyota", src: "/images/clients/toyota.png", maxH: 65 },
    { label: "FedEx", src: "/images/clients/fedex.png", maxH: 70 },
    { label: "Morgan Stanley", src: "/images/clients/morgan-stanley.png", maxH: 50 },
    { label: "Great American Insurance Group", src: "/images/clients/great-american-insurance.jpg", maxH: 65 },
    { label: "Thermo Fisher", src: "/images/clients/thermo-fisher.png", maxH: 60 },
    { label: "AMD", src: "/images/clients/amd.png", maxH: 45 },
    { label: "HPE", src: "/images/clients/hpe.png", maxH: 40 },
    { label: "Guidewire", src: "/images/clients/guidewire.png", maxH: 55 },
  ],
  industry: [],
};

const { variant, logos = defaultLogos[variant], eyebrow } = Astro.props;

const isCarousel = variant === "full";
// For the carousel, duplicate the logo list so the marquee can loop seamlessly.
// The animation translates -50% (one full set width), at which point the second
// set has scrolled into the position where the first set started — no visible jump.
const renderLogos = isCarousel ? [...logos, ...logos] : logos;
---

<section class:list={["logo-bench", `logo-bench--${variant}`]} aria-label="Client logo bench">
  <div class="logo-bench__inner">
    {eyebrow && (
      <div class="container-page">
        <p class="eyebrow logo-bench__eyebrow">{eyebrow}</p>
      </div>
    )}

    {isCarousel ? (
      <div class="logo-bench__marquee" aria-roledescription="carousel">
        <ul class="logo-bench__track" aria-hidden="false">
          {renderLogos.map((logo, idx) => (
            <li
              class="logo-bench__item logo-bench__item--marquee"
              aria-hidden={idx >= logos.length ? "true" : undefined}
            >
              {logo.href ? (
                <a href={logo.href} class="logo-bench__cell" style={logo.maxH ? `--logo-h: ${logo.maxH}px;` : undefined}>
                  {logo.src ? (
                    <img src={logo.src} alt={logo.label} loading="lazy" />
                  ) : (
                    <span class="logo-bench__text">{logo.label}</span>
                  )}
                </a>
              ) : (
                <span class="logo-bench__cell" style={logo.maxH ? `--logo-h: ${logo.maxH}px;` : undefined}>
                  {logo.src ? (
                    <img src={logo.src} alt={logo.label} loading="lazy" />
                  ) : (
                    <span class="logo-bench__text">{logo.label}</span>
                  )}
                </span>
              )}
            </li>
          ))}
        </ul>
      </div>
    ) : (
      <div class="container-page">
        <ul class="logo-bench__grid">
          {logos.map((logo) => (
            <li class="logo-bench__item">
              {logo.href ? (
                <a href={logo.href} class="logo-bench__cell" style={logo.maxH ? `--logo-h: ${logo.maxH}px;` : undefined}>
                  {logo.src ? (
                    <img src={logo.src} alt={logo.label} loading="lazy" />
                  ) : (
                    <span class="logo-bench__text">{logo.label}</span>
                  )}
                </a>
              ) : (
                <span class="logo-bench__cell" style={logo.maxH ? `--logo-h: ${logo.maxH}px;` : undefined}>
                  {logo.src ? (
                    <img src={logo.src} alt={logo.label} loading="lazy" />
                  ) : (
                    <span class="logo-bench__text">{logo.label}</span>
                  )}
                </span>
              )}
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
</section>

<style>
  .logo-bench {
    /* No background — sits within the parent page surface. */
  }

  .logo-bench__eyebrow {
    text-align: center;
    margin-bottom: var(--space-8);
    /* translateY shifts the eyebrow up visually without affecting layout flow,
       so the marquee position below stays exactly where it was. */
    transform: translateY(-56px);
  }

  /* ─────────────────────────────────────────────────────────
     MARQUEE — .full variant only (homepage TRUSTED BY)
     ───────────────────────────────────────────────────────── */
  .logo-bench__marquee {
    overflow: hidden;
    width: 100%;
    /* Edge fade so the marquee looks like it's flowing in/out of the section */
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
  }

  .logo-bench__track {
    display: flex;
    align-items: center;
    gap: var(--space-12);
    list-style: none;
    margin: 0;
    padding: 0;
    width: max-content;
    animation: logo-marquee 50s linear infinite;
  }

  .logo-bench__marquee:hover .logo-bench__track,
  .logo-bench__marquee:focus-within .logo-bench__track {
    animation-play-state: paused;
  }

  @keyframes logo-marquee {
    from {
      transform: translateX(0);
    }
    to {
      /* Translate by exactly one full set of logos; because the second set is an
         exact copy following the first, the marquee loops seamlessly. */
      transform: translateX(-50%);
    }
  }

  /* .logo-bench--full is added to beat .logo-bench__item { width: 100% }
     which appears later in this stylesheet and wins on equal specificity. */
  .logo-bench--full .logo-bench__item--marquee {
    width: auto;
    flex-shrink: 0;
    flex-grow: 0;
    flex-basis: auto;
    min-width: 240px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  @media (min-width: 768px) {
    .logo-bench--full .logo-bench__item--marquee {
      min-width: 300px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-bench__track {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
      width: 100%;
      padding-left: var(--container-padding);
      padding-right: var(--container-padding);
    }
    .logo-bench__marquee {
      -webkit-mask-image: none;
      mask-image: none;
    }
  }

  /* ─────────────────────────────────────────────────────────
     STATIC GRID — federal / commercial / industry variants
     ───────────────────────────────────────────────────────── */
  .logo-bench__grid {
    display: grid;
    align-items: center;
    justify-items: center;
    gap: var(--space-6);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* .federal — 3 logos */
  .logo-bench--federal .logo-bench__grid {
    grid-template-columns: 1fr;
  }
  @media (min-width: 600px) {
    .logo-bench--federal .logo-bench__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-12);
    }
  }

  /* .commercial — 8 logos: 4×2 */
  .logo-bench--commercial .logo-bench__grid {
    grid-template-columns: repeat(2, 1fr);
  }
  @media (min-width: 768px) {
    .logo-bench--commercial .logo-bench__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-12);
    }
  }

  /* .industry — 1–2 logos */
  .logo-bench--industry .logo-bench__grid {
    grid-template-columns: repeat(auto-fit, minmax(120px, max-content));
    justify-content: center;
    gap: var(--space-12);
  }

  /* ─────────────────────────────────────────────────────────
     CELL — shared across all variants
     ───────────────────────────────────────────────────────── */
  .logo-bench__item {
    width: 100%;
  }

  .logo-bench__cell {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 104px;
    padding: 0 var(--space-3);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--duration-base) var(--easing-out),
      opacity var(--duration-base) var(--easing-out);
    opacity: 0.85;
  }

  @media (max-width: 767px) {
    .logo-bench__cell {
      height: 80px;
    }
  }

  .logo-bench__cell:hover,
  .logo-bench__cell:focus-visible {
    opacity: 1;
    color: var(--color-text-primary);
    text-decoration: none;
  }

  /* Each logo gets its own --logo-h (set per-item via inline style) so the
     marquee row stays a constant height while individual logos render at the
     proportional height that gives them comparable visual weight. */
  .logo-bench__cell img {
    max-height: var(--logo-h, 32px);
    max-width: 100%;
    width: auto;
    object-fit: contain;
    filter: none;
  }

  /* Mobile renders each logo at ~75% of its desktop max-height for fit. */
  @media (max-width: 767px) {
    .logo-bench__cell img {
      max-height: calc(var(--logo-h, 32px) * 0.75);
    }
  }

  /* Text fallback for missing logo SVGs */
  .logo-bench__text {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: inherit;
    text-align: center;
    line-height: 1.2;
    text-wrap: balance;
    white-space: nowrap;
  }
</style>
