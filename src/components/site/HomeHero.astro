---
/*
  HomeHero — homepage-specific hero, used only on /.

  Two-column layout (60/40 desktop, single column mobile):
    LEFT  — kicker, H1 statement, hairline rule, sub-deck, client list
    RIGHT — animated DITA topic-tree visualization with subtle idle motion

  Adapted from Chat's extense-hero-v2 mockup. Adjustments from that mock:
    - Removed CTA buttons (See engagements / Methodology)
    - Removed the founded/certifications meta line (lives in /about)
    - Brand-color accent on the SVG visual (amber gradient on the root
      <map> node; amber on corner registration marks and the VALID dot)

  The DITA tree draws itself in once on viewport-enter, then idles —
  a random node pulses every ~5s, and an annotation strip below the
  figure rotates through DITA fragments matched to the pulsing node.

  Respects prefers-reduced-motion: tree renders static, no idle pulse.
*/
---

<section class="home-hero">
  <div class="home-hero__inner">
    <div class="home-hero__text">
      <p class="home-hero__kicker">
        DITA<span class="home-hero__dot">·</span>DocBook<span class="home-hero__dot">·</span>S1000D<span class="home-hero__dot">·</span>NIEM
      </p>
      <h1 class="home-hero__title">
        Content engineering for organizations whose documentation <em>needs</em> to be right.
      </h1>
      <hr class="home-hero__rule" />
      <p class="home-hero__subdeck">
        Information architecture through automated CI/CD publishing — built for documentation that must be auditable, multilingual, and version-correct the moment it ships.
      </p>
      <p class="home-hero__clients">
        <span class="home-hero__clients-label">Clients —</span>
        IRS<span class="home-hero__sep">·</span>
        U.S.&nbsp;House&nbsp;of&nbsp;Representatives<span class="home-hero__sep">·</span>
        Toyota<span class="home-hero__sep">·</span>
        FedEx<span class="home-hero__sep">·</span>
        Morgan&nbsp;Stanley<span class="home-hero__sep">·</span>
        AMD
      </p>
    </div>

    <div class="home-hero__visual">
      <svg
        class="dita-svg"
        id="hero-dita-tree"
        viewBox="0 0 380 320"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        role="presentation"
      >
        <defs>
          <linearGradient
            id="hero-amber-gradient"
            x1="0%"
            y1="0%"
            x2="100%"
            y2="100%"
          >
            <stop offset="0%" stop-color="var(--color-logo-gradient-1)" />
            <stop offset="50%" stop-color="var(--color-logo-gradient-2)" />
            <stop offset="100%" stop-color="var(--color-logo-gradient-3)" />
          </linearGradient>
        </defs>

        <!-- Corner registration marks (amber accent) -->
        <g class="corner corner--accent" style="--d: 0ms">
          <path d="M 10 20 L 10 10 L 20 10" />
          <path d="M 360 10 L 370 10 L 370 20" />
          <path d="M 10 300 L 10 310 L 20 310" />
          <path d="M 360 310 L 370 310 L 370 300" />
        </g>

        <!-- Ruler tick marks along the inner viewBox edges. Three per edge,
             evenly spaced. Reinforces the "engineering blueprint" aesthetic
             that the corner brackets start. -->
        <g class="tick-marks" style="--d: 40ms">
          <!-- top edge: ticks pointing down -->
          <line x1="110" y1="10" x2="110" y2="14" />
          <line x1="190" y1="10" x2="190" y2="14" />
          <line x1="270" y1="10" x2="270" y2="14" />
          <!-- bottom edge: ticks pointing up -->
          <line x1="110" y1="310" x2="110" y2="306" />
          <line x1="190" y1="310" x2="190" y2="306" />
          <line x1="270" y1="310" x2="270" y2="306" />
          <!-- left edge: ticks pointing right -->
          <line x1="10" y1="85"  x2="14" y2="85" />
          <line x1="10" y1="160" x2="14" y2="160" />
          <line x1="10" y1="235" x2="14" y2="235" />
          <!-- right edge: ticks pointing left -->
          <line x1="370" y1="85"  x2="366" y2="85" />
          <line x1="370" y1="160" x2="366" y2="160" />
          <line x1="370" y1="235" x2="366" y2="235" />
        </g>

        <!-- Top namespace declaration -->
        <text class="chrome" x="30" y="18" style="--d: 80ms">xmlns:dita="http://docs.oasis-open.org/dita/v1.3"</text>

        <!-- L1 root: map (amber gradient stroke, ties to logo).
             data-branch lists which leaf-traces pass through this node
             (all four). data-tier orders elements within a trace. -->
        <rect class="node node--root" x="162" y="38" width="56" height="22"
              data-branch="0 1 2 3" data-tier="0" style="--d: 240ms" />
        <text class="label label--root" x="190" y="49" style="--d: 240ms">&lt;map&gt;</text>

        <!-- L1 → L2 edges. Each branch is one continuous bent path from the map
             bottom all the way down to a topic top, with mitered corners.
             No T-junctions => no junction artifacts at any render scale. -->
        <path class="edge" d="M 190 60 L 190 78 L 95 78 L 95 96"
              data-branch="0 1" data-tier="1" style="--d: 400ms" />
        <path class="edge" d="M 190 60 L 190 78 L 285 78 L 285 96"
              data-branch="2 3" data-tier="1" style="--d: 400ms" />

        <!-- L2 topics -->
        <rect class="node" x="63" y="96" width="64" height="22"
              data-branch="0 1" data-tier="2" style="--d: 560ms" />
        <text class="label" x="95" y="107" style="--d: 560ms">&lt;topic&gt;</text>
        <rect class="node" x="253" y="96" width="64" height="22"
              data-branch="2 3" data-tier="2" style="--d: 560ms" />
        <text class="label" x="285" y="107" style="--d: 560ms">&lt;topic&gt;</text>

        <!-- L2 → L3 edges. Each branch is one continuous bent path. -->
        <path class="edge" d="M 95 118 L 95 138 L 60 138 L 60 160"
              data-branch="0" data-tier="3" style="--d: 720ms" />
        <path class="edge" d="M 95 118 L 95 138 L 130 138 L 130 160"
              data-branch="1" data-tier="3" style="--d: 720ms" />
        <path class="edge" d="M 285 118 L 285 138 L 250 138 L 250 160"
              data-branch="2" data-tier="3" style="--d: 720ms" />
        <path class="edge" d="M 285 118 L 285 138 L 320 138 L 320 160"
              data-branch="3" data-tier="3" style="--d: 720ms" />

        <!-- L3 section/xref -->
        <rect class="node" x="30"  y="160" width="60" height="20"
              data-branch="0" data-tier="4" style="--d: 880ms" />
        <text class="label" x="60" y="170" style="--d: 880ms">&lt;section&gt;</text>
        <rect class="node" x="100" y="160" width="60" height="20"
              data-branch="1" data-tier="4" style="--d: 880ms" />
        <text class="label" x="130" y="170" style="--d: 880ms">&lt;xref&gt;</text>
        <rect class="node" x="220" y="160" width="60" height="20"
              data-branch="2" data-tier="4" style="--d: 880ms" />
        <text class="label" x="250" y="170" style="--d: 880ms">&lt;section&gt;</text>
        <rect class="node" x="290" y="160" width="60" height="20"
              data-branch="3" data-tier="4" style="--d: 880ms" />
        <text class="label" x="320" y="170" style="--d: 880ms">&lt;xref&gt;</text>

        <!-- L3 → L4 edges (straight verticals to leaf rects) -->
        <path class="edge" d="M 60 180 L 60 215"
              data-branch="0" data-tier="5" style="--d: 1040ms" />
        <path class="edge" d="M 130 180 L 130 215"
              data-branch="1" data-tier="5" style="--d: 1040ms" />
        <path class="edge" d="M 250 180 L 250 215"
              data-branch="2" data-tier="5" style="--d: 1040ms" />
        <path class="edge" d="M 320 180 L 320 215"
              data-branch="3" data-tier="5" style="--d: 1040ms" />

        <!-- L4 leaves -->
        <rect class="node leaf" x="53"  y="215" width="14" height="7"
              data-branch="0" data-tier="6" style="--d: 1160ms" />
        <rect class="node leaf" x="123" y="215" width="14" height="7"
              data-branch="1" data-tier="6" style="--d: 1160ms" />
        <rect class="node leaf" x="243" y="215" width="14" height="7"
              data-branch="2" data-tier="6" style="--d: 1160ms" />
        <rect class="node leaf" x="313" y="215" width="14" height="7"
              data-branch="3" data-tier="6" style="--d: 1160ms" />

        <!-- Title block hairline -->
        <line class="chrome-rule" x1="30" y1="252" x2="350" y2="252" style="--d: 1260ms" />

        <!-- Title block text -->
        <text class="chrome chrome--strong" x="30" y="269" style="--d: 1300ms">FIG. 01</text>
        <text class="chrome" x="80" y="269" style="--d: 1300ms">/</text>
        <text class="chrome chrome--strong" x="88" y="269" style="--d: 1300ms">map.ditamap</text>

        <!-- VALID status: amber dot + label -->
        <rect class="valid-dot" x="305" y="263" width="6" height="6" style="--d: 1300ms" />
        <text class="chrome chrome--strong" x="350" y="269" text-anchor="end" style="--d: 1300ms">VALID</text>

        <!-- Annotation strip -->
        <text class="chrome" x="30" y="290" style="--d: 1380ms">
          <tspan class="annotation-prefix">▸</tspan><tspan id="hero-annotation-text" dx="6" class="chrome--strong">&lt;map title="api-reference.ditamap"&gt;</tspan>
        </text>
      </svg>
    </div>
  </div>
</section>

<style>
  .home-hero {
    width: 100%;
  }

  .home-hero__inner {
    max-width: var(--container-page, 1240px);
    margin: 0 auto;
    padding: var(--space-32) var(--space-12);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-16);
    align-items: center;
  }

  @media (min-width: 960px) {
    .home-hero__inner {
      grid-template-columns: 60% 40%;
      gap: var(--space-12);
      padding: var(--space-32) var(--space-12);
    }
  }

  @media (max-width: 767px) {
    .home-hero__inner {
      padding: var(--space-20) var(--space-6);
      gap: var(--space-16);
    }
  }

  /* ───────── Left: text column ───────── */
  .home-hero__text {
    max-width: 640px;
  }

  .home-hero__kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-6) 0;
  }

  .home-hero__dot {
    color: var(--color-text-muted);
    margin: 0 0.5em;
  }

  .home-hero__title {
    font-family: var(--font-display);
    font-weight: var(--weight-regular);
    font-size: 48px;
    line-height: 1.1;
    letter-spacing: -0.012em;
    color: var(--color-text-primary);
    margin: 0 0 var(--space-6) 0;
    text-wrap: balance;
  }

  @media (max-width: 960px) {
    .home-hero__title {
      font-size: 36px;
    }
  }

  .home-hero__rule {
    border: 0;
    border-top: var(--border-hairline);
    width: 64px;
    margin: 0 0 var(--space-6) 0;
  }

  .home-hero__subdeck {
    font-family: var(--font-body);
    font-weight: var(--weight-regular);
    font-size: 18px;
    line-height: 1.55;
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-8) 0;
    max-width: 560px;
    text-wrap: pretty;
  }

  .home-hero__clients {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-primary);
    margin: 0;
    line-height: 1.9;
  }

  .home-hero__clients-label {
    color: var(--color-text-muted);
    margin-right: 12px;
    font-weight: var(--weight-regular);
  }

  .home-hero__sep {
    color: var(--color-text-muted);
    margin: 0 8px;
    font-weight: var(--weight-regular);
  }

  /* ───────── Right: SVG visual ───────── */
  .home-hero__visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .dita-svg {
    width: 100%;
    max-width: 456px; /* +20% from 380px per request */
    height: auto;
    color: var(--color-text-primary);
    overflow: visible;
    display: block;
    shape-rendering: geometricPrecision;
  }

  .dita-svg .node {
    fill: var(--color-page-bg);
    stroke: currentColor;
    stroke-width: 1.5;
    vector-effect: non-scaling-stroke;
    transform-box: fill-box;
    transform-origin: center;
  }

  /* Root <map> node — amber gradient stroke ties it to the logo */
  .dita-svg .node--root {
    stroke: url(#hero-amber-gradient);
    stroke-width: 1.75;
  }

  .dita-svg .edge {
    stroke: currentColor;
    stroke-width: 1.5;
    fill: none;
    /* butt (default), not square — square caps extend half-stroke-width past the
       endpoint, which leaves visible whisker stubs at every T-junction once the
       bent connectors are split into separate straight segments. */
    stroke-linecap: butt;
    stroke-linejoin: miter;
    vector-effect: non-scaling-stroke;
  }

  .dita-svg .label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: var(--weight-medium);
    fill: currentColor;
    text-anchor: middle;
    dominant-baseline: central;
    letter-spacing: 0.01em;
    user-select: none;
  }

  .dita-svg .chrome {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: var(--weight-regular);
    fill: var(--color-text-muted);
    letter-spacing: 0.06em;
    user-select: none;
  }

  .dita-svg .chrome--strong {
    fill: var(--color-text-primary);
    font-weight: var(--weight-medium);
  }

  /* Amber accents on document chrome */
  .dita-svg .corner--accent {
    stroke: var(--color-accent-primary-hover);
    stroke-width: 1.25;
    fill: none;
  }

  /* Ruler ticks — same amber as corners, thinner so they read as secondary. */
  .dita-svg .tick-marks {
    stroke: var(--color-accent-primary-hover);
    stroke-width: 0.75;
    fill: none;
    opacity: 0.7;
  }

  /* Leaves are content blobs, not structural nodes — fill with the stroke
     color at low opacity so they read as solid ink dots, distinct from the
     outlined-only L1/L2/L3 rects above. */
  .dita-svg .leaf {
    fill: currentColor;
    fill-opacity: 0.15;
    stroke-width: 1;
  }

  .dita-svg .chrome-rule {
    stroke: var(--color-border-subtle);
    stroke-width: 1;
  }

  .dita-svg .valid-dot {
    fill: var(--color-accent-primary-hover);
    stroke: none;
  }

  .dita-svg .annotation-prefix {
    fill: var(--color-text-muted);
  }

  /* Initial hidden state */
  .dita-svg .node,
  .dita-svg .label,
  .dita-svg .chrome,
  .dita-svg .chrome-rule,
  .dita-svg .corner,
  .dita-svg .tick-marks,
  .dita-svg .valid-dot,
  .dita-svg .annotation-prefix {
    opacity: 0;
  }

  .dita-svg .edge {
    opacity: 0;
  }

  /* Reveal cascade — triggered when .dita-svg gets the .drawn class */
  .dita-svg.drawn .corner,
  .dita-svg.drawn .tick-marks,
  .dita-svg.drawn .chrome,
  .dita-svg.drawn .chrome-rule,
  .dita-svg.drawn .valid-dot,
  .dita-svg.drawn .annotation-prefix {
    animation: hero-fade-in 280ms ease-out forwards;
    animation-delay: var(--d, 0ms);
  }

  .dita-svg.drawn .node {
    animation: hero-fade-in 220ms cubic-bezier(0.4, 0, 0.2, 1) forwards;
    animation-delay: var(--d, 0ms);
  }

  .dita-svg.drawn .label {
    animation: hero-fade-in 200ms ease-out forwards;
    animation-delay: calc(var(--d, 0ms) + 90ms);
  }

  .dita-svg.drawn .edge {
    animation: hero-fade-in 280ms ease-out forwards;
    animation-delay: var(--d, 0ms);
  }

  @keyframes hero-fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  /* Branch trace — every ~5s, a "data pulse" cascades from the map node
     down a random root-to-leaf path. Each element on the chosen branch
     gets the .tracing class briefly, with staggered start times computed
     in JS so the highlight reads as a wave traveling down the tree. */
  @keyframes hero-trace-node {
    0% {
      stroke: currentColor;
      stroke-width: 1.5;
    }
    25% {
      stroke: var(--color-accent-primary-hover);
      stroke-width: 2.25;
    }
    100% {
      stroke: currentColor;
      stroke-width: 1.5;
    }
  }

  @keyframes hero-trace-edge {
    0% {
      stroke: currentColor;
      stroke-width: 1.5;
    }
    25% {
      stroke: var(--color-accent-primary-hover);
      stroke-width: 2.25;
    }
    100% {
      stroke: currentColor;
      stroke-width: 1.5;
    }
  }

  /* Map root has an amber gradient stroke already; tint shift wouldn't read.
     Pulse it by scaling instead, as the "ignition" frame of each trace. */
  @keyframes hero-trace-root {
    0%   { transform: scale(1); }
    35%  { transform: scale(1.06); }
    100% { transform: scale(1); }
  }

  .dita-svg .node.tracing {
    animation: hero-trace-node 700ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .dita-svg .edge.tracing {
    animation: hero-trace-edge 700ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .dita-svg .node--root.tracing {
    animation: hero-trace-root 700ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  #hero-annotation-text {
    transition: opacity 180ms ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .dita-svg .node,
    .dita-svg .label,
    .dita-svg .edge,
    .dita-svg .chrome,
    .dita-svg .chrome-rule,
    .dita-svg .corner,
    .dita-svg .tick-marks,
    .dita-svg .valid-dot,
    .dita-svg .annotation-prefix {
      opacity: 1 !important;
      animation: none !important;
    }

    .dita-svg .node.tracing,
    .dita-svg .edge.tracing {
      animation: none !important;
    }

    #hero-annotation-text {
      transition: none !important;
    }
  }
</style>

<script>
  // ─────────────────────────────────────────────────────────
  // HomeHero — viewport-triggered draw-in + idle branch trace
  // ─────────────────────────────────────────────────────────
  function setupHomeHero() {
    const svg = document.getElementById("hero-dita-tree") as SVGElement | null;
    if (!svg) return;

    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const annotationEl = document.getElementById("hero-annotation-text");

    function getAnnotationFor(node: Element): string {
      const x = parseFloat(node.getAttribute("x") || "0");
      const y = parseFloat(node.getAttribute("y") || "0");

      if (y < 80) return '<map title="api-reference.ditamap">';
      if (y < 130 && x < 150) return '<topic id="overview" outputclass="reference">';
      if (y < 130) return '<topic id="endpoints" outputclass="reference">';
      if (y < 200 && x < 80) return '<section id="introduction">';
      if (y < 200 && x < 200) return '<xref href="../auth/oauth2.dita"/>';
      if (y < 200 && x < 290) return '<section id="response-codes">';
      if (y < 200) return '<xref href="../errors/codes.dita"/>';
      if (x < 80) return "<p>Block-level paragraph element.</p>";
      if (x < 200) return '<image href="sequence.svg" placement="break"/>';
      if (x < 290) return '<codeblock outputclass="language-bash">';
      return '<note type="warning">Authentication required.</note>';
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            svg.classList.add("drawn");
            observer.unobserve(entry.target);
            if (!prefersReducedMotion) {
              window.setTimeout(startIdleTrace, 1700);
            }
          }
        });
      },
      { threshold: 0.15 }
    );

    observer.observe(svg);

    /*
     * Idle trace — every ~5s, pick a random leaf (branch 0..3) and cascade
     * an amber "data pulse" down the path from map -> topic -> section/xref
     * -> leaf. data-branch lists which traces an element belongs to;
     * data-tier sorts the elements along the path so the stagger reads as
     * a wave traveling down the tree.
     */
    function startIdleTrace(): void {
      const branchCount = 4;
      let lastBranch = -1;
      const STEP_MS = 130;
      const HIGHLIGHT_MS = 700;

      function pickBranch(): number {
        let i: number;
        do {
          i = Math.floor(Math.random() * branchCount);
        } while (i === lastBranch);
        lastBranch = i;
        return i;
      }

      function traceOnce(): void {
        const branchIdx = pickBranch();
        const els = Array.from(
          svg!.querySelectorAll<SVGElement>(`[data-branch~="${branchIdx}"]`)
        ).sort(
          (a, b) =>
            parseInt(a.dataset.tier || "0", 10) -
            parseInt(b.dataset.tier || "0", 10)
        );

        els.forEach((el, i) => {
          const delay = i * STEP_MS;
          window.setTimeout(() => el.classList.add("tracing"), delay);
          window.setTimeout(
            () => el.classList.remove("tracing"),
            delay + HIGHLIGHT_MS
          );
        });

        // Update annotation strip with the leaf's DITA fragment when
        // the pulse reaches the leaf.
        const leaf = els[els.length - 1];
        if (annotationEl && leaf) {
          const leafDelay = (els.length - 1) * STEP_MS;
          window.setTimeout(() => {
            annotationEl.style.opacity = "0";
            window.setTimeout(() => {
              annotationEl.textContent = getAnnotationFor(leaf);
              annotationEl.style.opacity = "1";
            }, 160);
          }, leafDelay);
        }

        const totalTraceMs = (els.length - 1) * STEP_MS + HIGHLIGHT_MS;
        const next = totalTraceMs + 3200 + Math.random() * 1200;
        window.setTimeout(traceOnce, next);
      }

      traceOnce();
    }
  }

  document.addEventListener("DOMContentLoaded", setupHomeHero);
  document.addEventListener("astro:page-load", setupHomeHero);
</script>
