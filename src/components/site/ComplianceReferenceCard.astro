---
/*
  ComplianceReferenceCard — animated visual for the /industries hero.

  A small bordered document-fragment card (same brand language as the
  SOW/Order Form/SLA panels) that cycles through the six regulated
  verticals every 3 seconds with a smooth crossfade. Each card view shows
  one vertical's compliance reference: Vertical · Standard · Artifact ·
  Auditor · Cadence.

  Counter (01/06 → 06/06) updates with each cycle. Pause-on-hover lets
  visitors freeze on a vertical they care about. Prefers-reduced-motion:
  no auto-cycle, first vertical shown statically.

  Hidden on viewports below 1024px (desktop-only enhancement).
*/

interface VerticalCard {
  vertical: string;
  standard: string;
  artifact: string;
  auditor: string;
  cadence: string;
  /** One-line italic "what we do here" note shown below the fields */
  note: string;
}

interface Props {
  cards: VerticalCard[];
  /** Cycle interval in milliseconds */
  intervalMs?: number;
}

const { cards, intervalMs = 3000 } = Astro.props;
---

<aside class="cref" id="cref" data-interval={intervalMs} aria-label="Compliance reference, cycling through six regulated verticals">
  <div class="cref__panel">
    <header class="cref__header">
      <p class="cref__doc-ref">Compliance Reference</p>
      <p class="cref__counter" id="cref-counter" aria-live="polite">
        <span class="cref__counter-current">01</span>
        <span class="cref__counter-sep">/</span>
        <span class="cref__counter-total">{String(cards.length).padStart(2, '0')}</span>
      </p>
    </header>
    <hr class="cref__rule" />
    <div class="cref__stack">
      {cards.map((card, i) => (
        <article
          class:list={["cref__view", i === 0 && "is-active"]}
          data-view-index={i}
          aria-hidden={i !== 0 ? "true" : undefined}
        >
          <ul class="cref__fields">
            <li class="cref__field">
              <span class="cref__label">Vertical</span>
              <span class="cref__value cref__value--vertical">{card.vertical}</span>
            </li>
            <li class="cref__field">
              <span class="cref__label">Standard</span>
              <span class="cref__value">{card.standard}</span>
            </li>
            <li class="cref__field">
              <span class="cref__label">Artifact</span>
              <span class="cref__value">{card.artifact}</span>
            </li>
            <li class="cref__field">
              <span class="cref__label">Auditor</span>
              <span class="cref__value">{card.auditor}</span>
            </li>
            <li class="cref__field">
              <span class="cref__label">Cadence</span>
              <span class="cref__value">{card.cadence}</span>
            </li>
          </ul>
          <p class="cref__note">{card.note}</p>
        </article>
      ))}
    </div>
    <hr class="cref__rule" />
    <footer class="cref__footer">
      <span>Form: REF v1.0</span>
      <span class="cref__hover-hint">Hover to pause</span>
    </footer>
  </div>
</aside>

<style>
  /* Hidden by default; shown only at desktop */
  .cref {
    display: none;
  }

  @media (min-width: 1024px) {
    .cref {
      display: block;
      width: 320px;
      flex-shrink: 0;
    }
  }

  .cref__panel {
    position: relative;
    border: var(--border-hairline);
    background-color: var(--color-page-bg);
    padding: var(--space-4) var(--space-6) var(--space-3);
  }

  .cref__panel::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 2px;
    background-color: #fcd34d;
    pointer-events: none;
  }

  .cref__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-3);
  }

  .cref__doc-ref {
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    text-transform: uppercase;
    margin: 0;
  }

  .cref__counter {
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.06em;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    margin: 0;
    font-feature-settings: "tnum";
  }

  .cref__counter-current {
    color: var(--color-link);
    font-weight: var(--weight-semibold);
  }

  .cref__counter-sep {
    color: var(--color-text-muted);
    margin: 0 2px;
  }

  .cref__rule {
    border: 0;
    border-top: var(--border-hairline);
    margin: var(--space-3) 0;
  }

  /* ─── Stack (all views overlap; only is-active is visible) ─── */
  .cref__stack {
    position: relative;
    /* min-height set on the wrapper itself so the stack reserves space */
    min-height: 220px;
  }

  .cref__view {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    opacity: 0;
    transition: opacity 400ms cubic-bezier(0, 0, 0.2, 1);
    pointer-events: none;
  }

  .cref__view.is-active {
    opacity: 1;
    pointer-events: auto;
  }

  .cref__fields {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .cref__field {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: var(--space-3);
    align-items: baseline;
  }

  .cref__label {
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    text-transform: uppercase;
  }

  .cref__value {
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.35;
    color: var(--color-text-primary);
    text-wrap: pretty;
  }

  .cref__value--vertical {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: var(--weight-regular);
    color: var(--color-text-primary);
    line-height: 1.2;
  }

  .cref__note {
    margin: var(--space-4) 0 0 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 13px;
    line-height: 1.4;
    color: var(--color-text-secondary);
    text-wrap: pretty;
  }

  .cref__footer {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .cref__hover-hint {
    font-style: italic;
    text-transform: none;
    letter-spacing: 0.04em;
  }

  /* Reduced motion: don't auto-cycle, no transitions */
  @media (prefers-reduced-motion: reduce) {
    .cref__view {
      transition: none;
    }
  }
</style>

<script>
(function () {
  const cref = document.getElementById('cref');
  if (!cref) return;

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reduced) return; // keep first view static

  const intervalMs = parseInt(cref.getAttribute('data-interval') || '3000', 10);
  const views = cref.querySelectorAll('.cref__view');
  if (views.length <= 1) return;

  const counterCurrent = cref.querySelector('.cref__counter-current') as HTMLElement | null;
  let current = 0;
  let timer: number | null = null;
  let paused = false;

  function show(idx: number) {
    views.forEach((v, i) => {
      const active = i === idx;
      v.classList.toggle('is-active', active);
      v.setAttribute('aria-hidden', active ? 'false' : 'true');
    });
    if (counterCurrent) {
      counterCurrent.textContent = String(idx + 1).padStart(2, '0');
    }
  }

  function tick() {
    if (paused) return;
    current = (current + 1) % views.length;
    show(current);
  }

  function start() {
    stop();
    timer = window.setInterval(tick, intervalMs);
  }

  function stop() {
    if (timer !== null) {
      window.clearInterval(timer);
      timer = null;
    }
  }

  cref.addEventListener('mouseenter', () => { paused = true; });
  cref.addEventListener('mouseleave', () => { paused = false; });
  cref.addEventListener('focusin', () => { paused = true; });
  cref.addEventListener('focusout', () => { paused = false; });

  // Pause when tab not visible (saves CPU)
  document.addEventListener('visibilitychange', () => {
    if (document.hidden) stop();
    else start();
  });

  start();
})();
</script>
