---
/*
  ComplianceReferenceCard — animated visual for the /industries hero.

  Two bordered document-fragment cards side by side (same brand language
  as the SOW/Order Form/SLA panels) that cycle through the six regulated
  verticals every 3 seconds with a smooth crossfade. The two panels are
  offset by half the cycle length so they always display different
  verticals — at any moment two distinct cards are visible, all six rotate
  through over time.

  Each card view shows one vertical's compliance reference:
  Vertical · Standard · Artifact · Auditor · Cadence.

  Counter (01/06 → 06/06) on each panel updates with each cycle.
  Pause-on-hover lets visitors freeze on a vertical they care about.
  Prefers-reduced-motion: no auto-cycle, both panels show their starting
  views statically.

  Hidden on viewports below 1024px (desktop-only enhancement).
*/

interface VerticalCard {
  vertical: string;
  standard: string;
  artifact: string;
  auditor: string;
  cadence: string;
  /** One-line italic "what we do here" note shown below the fields */
  note: string;
}

interface Props {
  cards: VerticalCard[];
  /** Cycle interval in milliseconds */
  intervalMs?: number;
}

const { cards, intervalMs = 3000 } = Astro.props;
const offset = Math.floor(cards.length / 2);
const panelStarts = [0, offset];
---

<aside class="cref" id="cref" data-interval={intervalMs} aria-label="Compliance reference, two views cycling through six regulated verticals">
  <div class="cref__row">
    {panelStarts.map((startIdx, panelIdx) => (
      <div class="cref__panel" data-panel-start={startIdx}>
        <header class="cref__header">
          <p class="cref__doc-ref">Compliance Reference</p>
          <p class="cref__counter" aria-live="polite">
            <span class="cref__counter-current">{String(startIdx + 1).padStart(2, '0')}</span>
            <span class="cref__counter-sep">/</span>
            <span class="cref__counter-total">{String(cards.length).padStart(2, '0')}</span>
          </p>
        </header>
        <hr class="cref__rule" />
        <div class="cref__stack">
          {cards.map((card, i) => (
            <article
              class:list={["cref__view", i === startIdx && "is-active"]}
              data-view-index={i}
              aria-hidden={i !== startIdx ? "true" : "false"}
            >
              <ul class="cref__fields">
                <li class="cref__field">
                  <span class="cref__label">Vertical</span>
                  <span class="cref__value cref__value--vertical">{card.vertical}</span>
                </li>
                <li class="cref__field">
                  <span class="cref__label">Standard</span>
                  <span class="cref__value">{card.standard}</span>
                </li>
                <li class="cref__field">
                  <span class="cref__label">Artifact</span>
                  <span class="cref__value">{card.artifact}</span>
                </li>
                <li class="cref__field">
                  <span class="cref__label">Auditor</span>
                  <span class="cref__value">{card.auditor}</span>
                </li>
                <li class="cref__field">
                  <span class="cref__label">Cadence</span>
                  <span class="cref__value">{card.cadence}</span>
                </li>
              </ul>
              <p class="cref__note">{card.note}</p>
            </article>
          ))}
        </div>
        <hr class="cref__rule" />
        <footer class="cref__footer">
          <span>Form: REF v1.0</span>
          {panelIdx === 1 && <span class="cref__hover-hint">Hover to pause</span>}
        </footer>
      </div>
    ))}
  </div>
</aside>

<style>
  /* Hidden by default; shown only at desktop */
  .cref {
    display: none;
  }

  @media (min-width: 1024px) {
    .cref {
      display: block;
      flex-shrink: 0;
    }
  }

  .cref__row {
    display: flex;
    gap: var(--space-4);
  }

  .cref__panel {
    position: relative;
    width: 280px;
    flex: 0 0 280px;
    border: var(--border-hairline);
    background-color: var(--color-page-bg);
    padding: var(--space-4) var(--space-5) var(--space-3);
  }

  .cref__panel::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 2px;
    background-color: #fcd34d;
    pointer-events: none;
  }

  .cref__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-3);
  }

  .cref__doc-ref {
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    text-transform: uppercase;
    margin: 0;
  }

  .cref__counter {
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.06em;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    margin: 0;
    font-feature-settings: "tnum";
  }

  .cref__counter-current {
    color: var(--color-link);
    font-weight: var(--weight-semibold);
  }

  .cref__counter-sep {
    color: var(--color-text-muted);
    margin: 0 2px;
  }

  .cref__rule {
    border: 0;
    border-top: var(--border-hairline);
    margin: var(--space-3) 0;
  }

  /* ─── Stack (all views overlap; only is-active is visible) ─── */
  .cref__stack {
    position: relative;
    min-height: 220px;
  }

  .cref__view {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    opacity: 0;
    transition: opacity 400ms cubic-bezier(0, 0, 0.2, 1);
    pointer-events: none;
  }

  .cref__view.is-active {
    opacity: 1;
    pointer-events: auto;
  }

  .cref__fields {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .cref__field {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: var(--space-2);
    align-items: baseline;
  }

  .cref__label {
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    text-transform: uppercase;
  }

  .cref__value {
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.35;
    color: var(--color-text-primary);
    text-wrap: pretty;
  }

  .cref__value--vertical {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: var(--weight-regular);
    color: var(--color-text-primary);
    line-height: 1.2;
  }

  .cref__note {
    margin: var(--space-4) 0 0 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 13px;
    line-height: 1.4;
    color: var(--color-text-secondary);
    text-wrap: pretty;
  }

  .cref__footer {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .cref__hover-hint {
    font-style: italic;
    text-transform: none;
    letter-spacing: 0.04em;
  }

  /* Reduced motion: don't auto-cycle, no transitions */
  @media (prefers-reduced-motion: reduce) {
    .cref__view {
      transition: none;
    }
  }
</style>

<script>
(function () {
  const cref = document.getElementById('cref');
  if (!cref) return;

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reduced) return; // keep starting views static

  const intervalMs = parseInt(cref.getAttribute('data-interval') || '3000', 10);
  const panels = cref.querySelectorAll('.cref__panel');
  if (panels.length === 0) return;

  // Per-panel state: current view index
  const state = Array.from(panels).map((panel) => {
    const start = parseInt(panel.getAttribute('data-panel-start') || '0', 10);
    return { current: start };
  });

  let timer: number | null = null;
  let paused = false;

  function show(panelIdx: number, viewIdx: number) {
    const panel = panels[panelIdx];
    const views = panel.querySelectorAll('.cref__view');
    if (views.length === 0) return;
    const total = views.length;
    const idx = ((viewIdx % total) + total) % total;
    views.forEach((v, i) => {
      const active = i === idx;
      v.classList.toggle('is-active', active);
      v.setAttribute('aria-hidden', active ? 'false' : 'true');
    });
    const counter = panel.querySelector('.cref__counter-current') as HTMLElement | null;
    if (counter) {
      counter.textContent = String(idx + 1).padStart(2, '0');
    }
  }

  function tick() {
    if (paused) return;
    state.forEach((s, idx) => {
      s.current = s.current + 1;
      show(idx, s.current);
    });
  }

  function start() {
    stop();
    timer = window.setInterval(tick, intervalMs);
  }

  function stop() {
    if (timer !== null) {
      window.clearInterval(timer);
      timer = null;
    }
  }

  cref.addEventListener('mouseenter', () => { paused = true; });
  cref.addEventListener('mouseleave', () => { paused = false; });
  cref.addEventListener('focusin', () => { paused = true; });
  cref.addEventListener('focusout', () => { paused = false; });

  document.addEventListener('visibilitychange', () => {
    if (document.hidden) stop();
    else start();
  });

  start();
})();
</script>
