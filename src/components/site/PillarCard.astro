---
/*
  PillarCard — capability pillar wayfinding card, used in 4-up rows on
  /, /capabilities, top of pillar pages.

  Spec ref: EXTENSE_DESIGN_BRIEF.md §9 (Cards)

  Structure:
    Pillar badge (48px, single-color color-text-primary) → space-4 →
    name (text-display-sm font-body weight-semibold) → space-2 →
    scope sentence (text-body-sm color-text-secondary) → space-4 →
    "Read more →" link (text-body-sm weight-medium color-link)

  No card box; whitespace separation only.
  Whole card wrapped in <a> (single keyboard target). Stretched-link pattern.
*/

import PillarBadgeIA from "../icons/PillarBadgeIA.astro";
import PillarBadgeMigration from "../icons/PillarBadgeMigration.astro";
import PillarBadgeCCMS from "../icons/PillarBadgeCCMS.astro";
import PillarBadgeAIReady from "../icons/PillarBadgeAIReady.astro";

interface Props {
  pillar: "ia" | "migration" | "ccms" | "ai-ready";
  name: string;
  scope: string;
  href: string;
  linkLabel?: string;
}

const { pillar, name, scope, href, linkLabel = "Read more" } = Astro.props;

const badges = {
  ia: PillarBadgeIA,
  migration: PillarBadgeMigration,
  ccms: PillarBadgeCCMS,
  "ai-ready": PillarBadgeAIReady,
};

const BadgeIcon = badges[pillar];
---

<article class="pillar-card">
  <a href={href} class="pillar-card__link">
    <span class="pillar-card__badge" aria-hidden="true">
      <BadgeIcon />
    </span>
    <h3 class="pillar-card__name">{name}</h3>
    <p class="pillar-card__scope">{scope}</p>
    <span class="pillar-card__cta">
      {linkLabel} <span class="pillar-card__arrow" aria-hidden="true">→</span>
    </span>
  </a>
</article>

<style>
  .pillar-card {
    /* No card box. Whitespace separation only. */
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .pillar-card__link {
    /* Whole card is a link. Stretched-link via ::after to avoid nested-link
       issues. The visible CTA is decorative; the link wraps the card. */
    display: flex;
    flex-direction: column;
    color: var(--color-text-primary);
    text-decoration: none;
    transition: opacity var(--duration-base) var(--easing-out);
  }

  .pillar-card__link:hover,
  .pillar-card__link:focus-visible {
    text-decoration: none;
    color: var(--color-text-primary);
  }

  .pillar-card__badge {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    color: var(--color-text-primary);
    margin-bottom: var(--space-4);
    transition: opacity var(--duration-base) var(--easing-out);
  }

  .pillar-card__link:hover .pillar-card__badge {
    opacity: 0.85;
  }

  .pillar-card__name {
    font-family: var(--font-body);
    font-size: var(--text-display-sm);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-normal);
    color: var(--color-text-primary);
    margin-bottom: var(--space-2);
  }

  .pillar-card__scope {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    text-wrap: pretty;
    margin-bottom: var(--space-4);
  }

  .pillar-card__cta {
    font-size: var(--text-body-sm);
    font-weight: var(--weight-medium);
    color: var(--color-link);
    margin-top: auto;
    transition: color var(--duration-base) var(--easing-out);
  }

  .pillar-card__link:hover .pillar-card__cta,
  .pillar-card__link:focus-visible .pillar-card__cta {
    color: var(--color-link-hover);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }

  .pillar-card__arrow {
    display: inline-block;
    transition: transform var(--duration-base) var(--easing-out);
  }

  .pillar-card__link:hover .pillar-card__arrow {
    transform: translateX(2px);
  }
</style>
