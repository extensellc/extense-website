---
/*
  XmlDataInteropProblem — diagnosis section on
  /solutions/xml-data-interoperability.

  Sequenced after the hero + siblings row, before the pipeline (approach)
  section. Names three failure modes that turn disconnected systems
  into open-ended audit and translation problems.

  Layout: same vocabulary as TechDocsProblem and ContentMigrationProblem.
    - container-data section
    - heading + subdeck on the left at container-prose width
    - three diagnostic items in a 3-column grid on desktop, stacked
      on mobile, each separated by a hairline at the top of the card
    - no border-top on the section itself: the siblings row above
      already carries a border-bottom

  Animation: viewport-triggered fade-up, heading then three items in
  sequence at 200/320/440 ms delays. prefers-reduced-motion: static.
*/
---

<section class="interop-problem" aria-labelledby="interop-problem-heading">
  <div class="container-data interop-problem__inner">
    <div class="interop-problem__heading-block">
      <h2 id="interop-problem-heading" class="interop-problem__heading">
        Why systems disagree on the facts.
      </h2>
      <p class="interop-problem__subdeck">
        Three failure modes turn an integration project into an open-ended audit problem. Each one is visible the first time two systems try to answer the same question.
      </p>
    </div>

    <ol class="interop-problem__grid">
      <li class="problem-item">
        <h3 class="problem-item__heading">
          The same fact in five places.
        </h3>
        <p class="problem-item__body">
          The product description lives in PIM, the technical specs in CCMS, the marketing copy in CMS, the training material in LMS, and the parts manual in a shared drive. Nobody is wrong individually. They just don&rsquo;t agree.
        </p>
      </li>
      <li class="problem-item">
        <h3 class="problem-item__heading">
          APIs don&rsquo;t bridge semantics.
        </h3>
        <p class="problem-item__body">
          A REST endpoint serves &ldquo;product.&rdquo; A GraphQL query serves &ldquo;product.&rdquo; A SOAP feed serves &ldquo;product.&rdquo; Each system&rsquo;s product has a different shape, a different vocabulary, and a different audit trail. The HTTP transport is interoperable; the data isn&rsquo;t.
        </p>
      </li>
      <li class="problem-item">
        <h3 class="problem-item__heading">
          Translation memory loses the link.
        </h3>
        <p class="problem-item__body">
          The same warning translated through five disconnected TM vendors gets five slightly different translations. Without a canonical source feeding all five, there&rsquo;s no way to know which is current &mdash; and the regulator only audits one of them.
        </p>
      </li>
    </ol>
  </div>
</section>

<style>
  .interop-problem {
    padding-top: var(--section-pad-default);
    padding-bottom: var(--section-pad-default);
    /* No border-top: the siblings row above already carries a
       border-bottom; doubling would render as a 2 px line. */
  }

  @media (max-width: 767px) {
    .interop-problem {
      padding-top: var(--space-16);
      padding-bottom: var(--space-16);
    }
  }

  .interop-problem__heading-block {
    max-width: var(--container-prose, 720px);
    margin-bottom: var(--space-12);
  }

  .interop-problem__heading {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin: 0;
    text-wrap: balance;
  }

  .interop-problem__subdeck {
    margin-top: var(--space-4);
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    max-width: 64ch;
    text-wrap: pretty;
  }

  .interop-problem__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 1024px) {
    .interop-problem__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-8);
    }
  }

  .problem-item {
    border-top: var(--border-hairline);
    padding-top: var(--space-6);
  }

  .problem-item__heading {
    font-family: var(--font-display);
    font-size: var(--text-display-sm);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-3) 0;
    text-wrap: balance;
  }

  .problem-item__body {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin: 0;
    text-wrap: pretty;
  }

  /* Reveal animation — viewport-triggered, same pattern as
     TechDocsProblem and ContentMigrationProblem. */
  .interop-problem.animating .interop-problem__heading-block {
    opacity: 0;
    transform: translateY(8px);
  }
  .interop-problem.animating .problem-item {
    opacity: 0;
    transform: translateY(8px);
  }
  .interop-problem.animating .problem-item:nth-child(1) { --reveal-delay: 200ms; }
  .interop-problem.animating .problem-item:nth-child(2) { --reveal-delay: 320ms; }
  .interop-problem.animating .problem-item:nth-child(3) { --reveal-delay: 440ms; }

  .interop-problem.animating.in-view .interop-problem__heading-block {
    animation: interop-problem-fade-in 480ms ease-out forwards;
  }
  .interop-problem.animating.in-view .problem-item {
    animation: interop-problem-fade-in 420ms ease-out forwards;
    animation-delay: var(--reveal-delay, 0ms);
  }

  @keyframes interop-problem-fade-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .interop-problem.animating .interop-problem__heading-block,
    .interop-problem.animating .problem-item {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }
  }
</style>

<script>
  function setupXmlDataInteropProblem() {
    const sec = document.querySelector<HTMLElement>(".interop-problem");
    if (!sec) return;
    if (sec.dataset.problemRevealInit === "true") return;
    sec.dataset.problemRevealInit = "true";

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;
    if (prefersReducedMotion) return;

    sec.classList.add("animating");

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            sec.classList.add("in-view");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );

    observer.observe(sec);
  }

  document.addEventListener("DOMContentLoaded", setupXmlDataInteropProblem);
  document.addEventListener("astro:page-load", setupXmlDataInteropProblem);
</script>
