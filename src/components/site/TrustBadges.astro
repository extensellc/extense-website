---
/*
  TrustBadges — homepage credentials strip.

  Four procurement-relevant trust signals:
    13+              Years in Business
    11+              Major Clients Served
    DITA · S1000D    Content Standards
    508              Section Compliant

  Placement: between the outcome StatBlock (60/72/85) and the LogoBench.
  Narrative order: outcomes -> credentials -> who trusts us -> pivot.

  Design: hairline top + bottom borders, four-column row on desktop, 2x2
  on tablet, single column on mobile. No solid color fill (vs the original
  navy banner) — fits the redesign's restrained palette. Display serif
  for the primary line, mono caps for the descriptor, so the numbers
  read as credentials, not outcomes (those are bigger and amber-adjacent
  in the StatBlock above).

  The DITA · S1000D badge uses a smaller primary font (primarySmall flag)
  because the combined-standard string is too wide for the column at the
  default 44px display size.
*/

interface Badge {
  primary: string;
  label: string;
  /** Render the primary line at a smaller font size so longer strings fit
      the column without wrapping (e.g., the combined-standards badge). */
  primarySmall?: boolean;
}

const badges: Badge[] = [
  { primary: "13+",            label: "Years in Business" },
  { primary: "11+",            label: "Major Clients Served" },
  { primary: "DITA · S1000D",  label: "Content Standards", primarySmall: true },
  { primary: "508",            label: "Section Compliant" },
];
---

<section class="trust-badges" aria-label="Credentials">
  <div class="container-data trust-badges__inner">
    <ul class="trust-badges__row">
      {badges.map((b) => (
        <li class="trust-badges__item">
          <span
            class:list={[
              "trust-badges__primary",
              b.primarySmall && "trust-badges__primary--small",
            ]}
          >{b.primary}</span>
          <span class="trust-badges__label">{b.label}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .trust-badges {
    border-top: var(--border-hairline);
    border-bottom: var(--border-hairline);
    padding-top: var(--space-12);
    padding-bottom: var(--space-12);
  }

  .trust-badges__row {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    text-align: center;
  }

  @media (min-width: 600px) {
    .trust-badges__row {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-12);
    }
  }

  @media (min-width: 1024px) {
    .trust-badges__row {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-8);
    }
  }

  .trust-badges__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
  }

  .trust-badges__primary {
    font-family: var(--font-display);
    font-size: 44px;
    font-weight: var(--weight-regular);
    line-height: 1;
    color: var(--color-text-primary);
    letter-spacing: var(--tracking-tight);
    /* Reserve a uniform 44px-tall box for every primary line so that
       badges with a smaller font (see --small below) don't lift their
       labels above the labels in adjacent columns. Text bottom-aligns
       within the box so the visual baseline stays consistent across
       the row regardless of font size. */
    min-height: 44px;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  /* Smaller primary line for badges with longer strings (e.g., the combined
     DITA · S1000D standards badge). Keeps the same display-serif voice but
     fits the column width without wrapping. Inherits the 44px min-height
     from .trust-badges__primary above so its label aligns with the others. */
  .trust-badges__primary--small {
    font-size: 28px;
  }

  .trust-badges__label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
  }
</style>
