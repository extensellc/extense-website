---
/*
  ContentOpsStack — homepage process-flow section.

  Spec ref: integration of the original ex-tense.co "Extense Content Ops Stack"
  + "Content Engineering Lifecycle" into the redesign, between the Pillars
  (capabilities) and Stats (outcomes) sections. Narrative slot: "how we
  deliver" between "what we do" and "the results".

  Five phases: Strategy -> Engineering -> Automation -> Delivery -> Analyze.
  The Analyze phase closes the feedback loop back to Strategy.

  Visual treatment (redesign aesthetic, not the original colored tiles):
    - 5-up grid: 1 col mobile, 2 cols tablet, 5 desktop.
    - Hairline border on every side. Page-bg fill. No solid color tiles.
    - Phase number "01..05" rendered in amber monospace (matches FIG. 01 chrome
      in the hero SVG) — this is the cue that the cards form a sequence.
    - Small inline SVG glyph above each title. Strokes match the rest of the site.
*/
---

<section class="home-section home-section--ops-stack" aria-labelledby="ops-stack-heading">
  <div class="container-data home-section__inner">
    <div class="home-section__heading-block">
      <h2 id="ops-stack-heading" class="home-section__heading">
        The content ops stack.
      </h2>
      <p class="home-section__subdeck">
        Five integrated layers. One seamless content operation.
      </p>
    </div>

    <div class="ops-stack__trace" aria-hidden="true"></div>

    <ol class="ops-stack__grid">
      <li class="ops-stack__card">
        <div class="ops-stack__head">
          <svg class="ops-stack__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <line x1="3" y1="6" x2="21" y2="6" />
            <line x1="8" y1="12" x2="21" y2="12" />
            <line x1="13" y1="18" x2="21" y2="18" />
          </svg>
          <span class="ops-stack__num">01</span>
        </div>
        <h3 class="ops-stack__label">Strategy</h3>
        <p class="ops-stack__desc">Information Architecture, Taxonomy, Content Governance</p>
      </li>

      <li class="ops-stack__card">
        <div class="ops-stack__head">
          <svg class="ops-stack__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M9 6 L4 12 L9 18 M15 6 L20 12 L15 18" />
          </svg>
          <span class="ops-stack__num">02</span>
        </div>
        <h3 class="ops-stack__label">Engineering</h3>
        <p class="ops-stack__desc">DITA, XSLT, Schematron, CCMS Configuration</p>
      </li>

      <li class="ops-stack__card">
        <div class="ops-stack__head">
          <svg class="ops-stack__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M20 12 A8 8 0 0 1 6.5 17.5" />
            <path d="M4 12 A8 8 0 0 1 17.5 6.5" />
            <!-- Filled triangle arrowheads. Base midpoint sits on each arc's
                 terminus; tip extends 3 units further along the tangent so the
                 arc visually flows into the arrow. -->
            <path class="ops-stack__arrow-tip" d="M3.5 14.5 L8 16 L5 19 Z" />
            <path class="ops-stack__arrow-tip" d="M20.5 9.5 L16 8 L19 5 Z" />
          </svg>
          <span class="ops-stack__num">03</span>
        </div>
        <h3 class="ops-stack__label">Automation</h3>
        <p class="ops-stack__desc">CI/CD Pipelines, Build Scripts, Validation Gates</p>
      </li>

      <li class="ops-stack__card">
        <div class="ops-stack__head">
          <svg class="ops-stack__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <rect x="3.5" y="4" width="11" height="14" />
            <path d="M11 11 L20.5 11 M20.5 11 L17.5 8 M20.5 11 L17.5 14" />
          </svg>
          <span class="ops-stack__num">04</span>
        </div>
        <h3 class="ops-stack__label">Delivery</h3>
        <p class="ops-stack__desc">PDF, HTML5, Portal, API, Mobile</p>
      </li>

      <li class="ops-stack__card">
        <div class="ops-stack__head">
          <svg class="ops-stack__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <line x1="3" y1="20" x2="21" y2="20" />
            <rect x="5" y="14" width="3" height="6" />
            <rect x="10.5" y="9" width="3" height="11" />
            <rect x="16" y="5" width="3" height="15" />
          </svg>
          <span class="ops-stack__num">05</span>
        </div>
        <h3 class="ops-stack__label">Analyze</h3>
        <p class="ops-stack__desc">Usage Metrics, Content Performance, Feedback Loop</p>
      </li>
    </ol>
  </div>
</section>

<style>
  /* Section-level spacing. Astro scopes <style> blocks per-component, so
     index.astro's `.home-section { padding: ... }` and
     `.home-section__heading-block { margin-bottom: ... }` rules do not reach
     elements rendered inside this component. We mirror those defaults here
     so this section feels identical to .home-section--pillars and the rest. */
  .home-section--ops-stack {
    padding-top: var(--section-pad-default);
    padding-bottom: var(--section-pad-default);
    /* Hairline section divider above. Matches the dividers above .stats and
       .pivot in index.astro. */
    border-top: var(--border-hairline);
  }

  @media (max-width: 767px) {
    .home-section--ops-stack {
      padding-top: var(--space-16);
      padding-bottom: var(--space-16);
    }
  }

  .home-section--ops-stack .home-section__heading-block {
    margin-bottom: var(--space-8);
  }

  /* Match the heading-to-subdeck gap used in other sections (.pillars etc.).
     The global .home-section__subdeck { margin-top: --space-4 } rule lives in
     index.astro and does not reach this section because of Astro scoping. */
  .home-section--ops-stack .home-section__subdeck {
    margin-top: var(--space-4);
  }

  .ops-stack__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 600px) {
    .ops-stack__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-6);
    }
  }

  @media (min-width: 1024px) {
    .ops-stack__grid {
      grid-template-columns: repeat(5, 1fr);
      gap: var(--space-4);
    }
  }

  .ops-stack__card {
    background-color: var(--color-page-bg);
    border: var(--border-hairline);
    padding: var(--space-6) var(--space-6) var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .ops-stack__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-2);
  }

  .ops-stack__icon {
    width: 24px;
    height: 24px;
    stroke: var(--color-text-primary);
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
    fill: none;
    flex-shrink: 0;
  }

  /* Filled triangle arrowheads on the Automation icon. Inherited fill: none
     from .ops-stack__icon would otherwise hide them. */
  .ops-stack__icon .ops-stack__arrow-tip {
    fill: var(--color-text-primary);
    stroke: none;
  }

  /* Number plate — monospace, amber. Matches the FIG. 01 chrome in the hero SVG. */
  .ops-stack__num {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: var(--weight-medium);
    color: var(--color-accent-primary);
    letter-spacing: 0.08em;
  }

  .ops-stack__label {
    font-family: var(--font-display);
    font-size: var(--text-display-sm);
    font-weight: var(--weight-regular);
    color: var(--color-text-primary);
    margin: 0;
    line-height: var(--leading-snug);
  }

  .ops-stack__desc {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin: 0;
    text-wrap: pretty;
  }

  /* ─────────────────────────────────────────────────────────────────
     Reveal animation — viewport-triggered.

     A horizontal amber "trace" scales from left to right across the top
     of the row. As it passes each card's center, that card reveals:
       - card box fades + slides up
       - phase number scale-pulses in
       - icon strokes draw in via stroke-dasharray
     The trace stays visible afterward as an amber accent rule.

     Pattern (same as hero DITA tree):
       Initial state lives under .animating  (added by JS so no-JS fails open)
       Reveal triggered by .animating.drawn  (added by IntersectionObserver)
     prefers-reduced-motion turns it all off.
     ───────────────────────────────────────────────────────────────── */

  .ops-stack__trace {
    height: 1.5px;
    margin-bottom: var(--space-8);
    background-color: var(--color-accent-primary-hover);
    transform-origin: left center;
    transform: scaleX(1); /* default visible — no-JS fallback */
  }

  /* Hidden initial states applied only when JS has marked the section
     for animation. Without JS the section reads normally. */
  .home-section--ops-stack.animating .ops-stack__trace {
    transform: scaleX(0);
  }
  .home-section--ops-stack.animating .ops-stack__card {
    opacity: 0;
    transform: translateY(8px);
  }
  .home-section--ops-stack.animating .ops-stack__num {
    opacity: 0;
    transform: scale(0.8);
    display: inline-block; /* so scale takes effect on the span */
  }
  .home-section--ops-stack.animating .ops-stack__icon > * {
    /* Generous dash length covers every shape in every icon. */
    stroke-dasharray: 80;
    stroke-dashoffset: 80;
  }

  /* Per-card stagger. Linear trace means times line up with the trace
     position over each card's horizontal center. 1400 ms total trace
     duration, 5 cards, centers at 10%/30%/50%/70%/90%. */
  .home-section--ops-stack.animating .ops-stack__card:nth-child(1) { --reveal-delay: 140ms; }
  .home-section--ops-stack.animating .ops-stack__card:nth-child(2) { --reveal-delay: 420ms; }
  .home-section--ops-stack.animating .ops-stack__card:nth-child(3) { --reveal-delay: 700ms; }
  .home-section--ops-stack.animating .ops-stack__card:nth-child(4) { --reveal-delay: 980ms; }
  .home-section--ops-stack.animating .ops-stack__card:nth-child(5) { --reveal-delay: 1260ms; }

  /* Drawn — turn on animations. */
  .home-section--ops-stack.animating.drawn .ops-stack__trace {
    transform: scaleX(1);
    transition: transform 1400ms linear;
  }

  .home-section--ops-stack.animating.drawn .ops-stack__card {
    animation: ops-card-reveal 420ms ease-out forwards;
    animation-delay: var(--reveal-delay, 0ms);
  }

  .home-section--ops-stack.animating.drawn .ops-stack__num {
    animation: ops-num-pulse 540ms ease-out forwards;
    animation-delay: var(--reveal-delay, 0ms);
  }

  .home-section--ops-stack.animating.drawn .ops-stack__icon > * {
    animation: ops-icon-draw 540ms ease-out forwards;
    animation-delay: calc(var(--reveal-delay, 0ms) + 100ms);
  }

  @keyframes ops-card-reveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes ops-num-pulse {
    0%   { opacity: 0; transform: scale(0.8); }
    55%  { opacity: 1; transform: scale(1.15); }
    100% { opacity: 1; transform: scale(1); }
  }

  @keyframes ops-icon-draw {
    to { stroke-dashoffset: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-section--ops-stack.animating .ops-stack__trace,
    .home-section--ops-stack.animating .ops-stack__card,
    .home-section--ops-stack.animating .ops-stack__num,
    .home-section--ops-stack.animating .ops-stack__icon > * {
      opacity: 1 !important;
      transform: none !important;
      stroke-dashoffset: 0 !important;
      animation: none !important;
      transition: none !important;
    }
  }
</style>

<script>
  // ─────────────────────────────────────────────────────────
  // ContentOpsStack — viewport-triggered reveal cascade
  // ─────────────────────────────────────────────────────────
  function setupOpsStackReveal() {
    const section = document.querySelector<HTMLElement>(".home-section--ops-stack");
    if (!section) return;

    // If JS has already run on this section (e.g. astro:page-load on
    // back-forward navigation), don't re-trigger the entry.
    if (section.dataset.opsRevealInit === "true") return;
    section.dataset.opsRevealInit = "true";

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;

    if (prefersReducedMotion) {
      // Skip the animating + drawn dance entirely. Cards stay in their
      // default (visible) state with no hidden phase.
      return;
    }

    // Switch to the animating state — hides cards/trace/icons until drawn.
    section.classList.add("animating");

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            section.classList.add("drawn");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );

    observer.observe(section);
  }

  document.addEventListener("DOMContentLoaded", setupOpsStackReveal);
  document.addEventListener("astro:page-load", setupOpsStackReveal);
</script>
