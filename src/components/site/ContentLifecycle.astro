---
/*
  ContentLifecycle — homepage "how content flows" section.

  The five lifecycle stages as a horizontal timeline: a continuous hairline rail
  with an amber node at each stage, numbered 01–05, each with name + a short
  descriptor. Content from the old ex-tense.co "Content Engineering Lifecycle".

  Distinct from ContentOpsStack (a bordered card grid): this is a node-and-rail
  timeline. On scroll, an amber fill sweeps the rail left-to-right, lighting each
  node and revealing its text in sequence — the "Analyze → Model" loop is implied
  by the closing descriptor.

  prefers-reduced-motion renders the clean hairline timeline, no sweep.
  Heading typography defined locally (Astro scopes index.astro's rules).
*/

interface Stage {
  name: string;
  desc: string;
}

const stages: Stage[] = [
  { name: "Model", desc: "Define schema, taxonomy, and the reuse model." },
  { name: "Author", desc: "Structured XML authoring against the model." },
  { name: "Manage", desc: "Version control, branching, and review in the CCMS." },
  { name: "Publish", desc: "Automated output — PDF, HTML5, and portals." },
  { name: "Analyze", desc: "Usage metrics that feed back into the model." },
];
---

<section
  class="home-section home-section--lifecycle"
  aria-labelledby="lifecycle-heading"
>
  <div class="container-data home-section__inner">
    <div class="home-section__heading-block">
      <h2 id="lifecycle-heading" class="home-section__heading">
        The Content Engineering Lifecycle
      </h2>
      <p class="home-section__subdeck">
        We don't just write words. We engineer information systems.
      </p>
    </div>

    <div class="lifecycle" role="list">
      {stages.map((stage, i) => (
        <div class="lifecycle__stage" role="listitem" style={`--i:${i}`}>
          <div class="lifecycle__head" aria-hidden="true">
            <span class="lifecycle__node"></span>
            {i < stages.length - 1 && (
              <span class="lifecycle__connector">
                <span class="lifecycle__connector-fill"></span>
              </span>
            )}
          </div>
          <span class="lifecycle__num">{String(i + 1).padStart(2, "0")}</span>
          <span class="lifecycle__name">{stage.name}</span>
          <span class="lifecycle__desc">{stage.desc}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Section + heading typography mirrored from index.astro (Astro scoping). */
  .home-section--lifecycle {
    padding-top: var(--section-pad-default);
    padding-bottom: var(--section-pad-default);
    border-top: var(--border-hairline);
  }
  @media (max-width: 767px) {
    .home-section--lifecycle {
      padding-top: var(--space-16);
      padding-bottom: var(--space-16);
    }
  }

  .home-section--lifecycle .home-section__heading-block {
    max-width: var(--container-prose);
    margin-bottom: var(--space-12);
  }
  .home-section--lifecycle .home-section__heading {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    text-wrap: balance;
  }
  .home-section--lifecycle .home-section__subdeck {
    margin-top: var(--space-4);
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    max-width: 60ch;
    text-wrap: pretty;
  }

  /* Timeline */
  .lifecycle {
    display: flex;
    align-items: flex-start;
  }
  .lifecycle__stage {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-right: var(--space-4);
  }

  /* Node + connecting rail */
  .lifecycle__head {
    display: flex;
    align-items: center;
    height: 11px;
    margin-bottom: var(--space-4);
  }
  .lifecycle__node {
    flex: 0 0 auto;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    box-sizing: border-box;
    background: var(--color-page-bg);
    border: 1.5px solid var(--color-text-secondary);
  }
  .lifecycle__connector {
    flex: 1 1 auto;
    height: 1.5px;
    margin-left: var(--space-2);
    background: var(--color-border-subtle);
    position: relative;
    overflow: hidden;
  }
  .lifecycle__connector-fill {
    position: absolute;
    inset: 0;
    background: var(--color-accent-primary-hover);
    transform: scaleX(0);
    transform-origin: left center;
  }

  .lifecycle__num {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.08em;
    color: var(--color-accent-primary);
  }
  .lifecycle__name {
    font-family: var(--font-display);
    font-size: var(--text-display-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-primary);
    line-height: var(--leading-snug);
  }
  .lifecycle__desc {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    text-wrap: pretty;
  }

  /* Mobile: stack vertically; drop the horizontal rail. */
  @media (max-width: 639px) {
    .lifecycle {
      flex-direction: column;
      gap: var(--space-8);
    }
    .lifecycle__stage {
      padding-right: 0;
    }
    .lifecycle__connector {
      display: none;
    }
    .lifecycle__head {
      margin-bottom: var(--space-2);
    }
  }

  /* ── Scroll sweep: amber fills the rail left-to-right, nodes light, text
     reveals in sequence (staggered by --i). ── */
  .home-section--lifecycle.is-animating .lifecycle__num,
  .home-section--lifecycle.is-animating .lifecycle__name,
  .home-section--lifecycle.is-animating .lifecycle__desc {
    opacity: 0;
    transform: translateY(6px);
  }
  .home-section--lifecycle.is-animating.drawn .lifecycle__node {
    animation: lc-node 320ms ease-out forwards;
    animation-delay: calc(var(--i) * 220ms);
  }
  .home-section--lifecycle.is-animating.drawn .lifecycle__connector-fill {
    animation: lc-fill 260ms ease-out forwards;
    animation-delay: calc(var(--i) * 220ms + 110ms);
  }
  .home-section--lifecycle.is-animating.drawn .lifecycle__num,
  .home-section--lifecycle.is-animating.drawn .lifecycle__name,
  .home-section--lifecycle.is-animating.drawn .lifecycle__desc {
    animation: lc-text 380ms ease-out forwards;
    animation-delay: calc(var(--i) * 220ms);
  }

  @keyframes lc-node {
    to {
      border-color: var(--color-accent-primary-hover);
      background: var(--color-accent-primary-hover);
    }
  }
  @keyframes lc-fill {
    to {
      transform: scaleX(1);
    }
  }
  @keyframes lc-text {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-section--lifecycle.is-animating .lifecycle__num,
    .home-section--lifecycle.is-animating .lifecycle__name,
    .home-section--lifecycle.is-animating .lifecycle__desc {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }
  }
</style>

<script>
  // ContentLifecycle — timeline sweep on viewport entry.
  function setupLifecycle() {
    const section = document.querySelector<HTMLElement>(
      ".home-section--lifecycle"
    );
    if (!section) return;
    if (section.dataset.lcInit === "true") return;
    section.dataset.lcInit = "true";

    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;
    if (prefersReduced) return;

    section.classList.add("is-animating");

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            section.classList.add("drawn");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.3 }
    );
    observer.observe(section);
  }

  document.addEventListener("DOMContentLoaded", setupLifecycle);
  document.addEventListener("astro:page-load", setupLifecycle);
</script>
