---
/*
  XmlDataInteropClosing — short prose section on
  /solutions/xml-data-interoperability.

  Sequenced after the five integration-pattern chapter-blocks,
  before the CTA. Unlike TDP and Migration (which land a homepage-
  canonical percentage as the punchline), Interop closes with a
  qualitative payoff — no metric, no stat block. The brief reserves
  the 60/72/85/45/90 metrics for other pillars.

  Layout (mirrors TechDocsLocalization and ContentMigrationROI)
    - container-prose width (~720 px), left-aligned
    - eyebrow + heading + three short body paragraphs
    - no diagram, no card, no number stat treatment
    - hairline border-top divides from the chapter-blocks above;
      hairline border-bottom + 58 px padding-top/bottom match the
      symmetric treatment we tuned on TDP/Migration

  Animation: viewport-triggered fade-up of eyebrow / heading /
  paragraphs in sequence. The :nth-of-type indices are shifted by 1
  because the eyebrow is the first <p>, so the first body paragraph
  is <p>:nth-of-type(2). prefers-reduced-motion: static.
*/
---

<section class="interop-closing" aria-labelledby="interop-closing-heading">
  <div class="container-prose interop-closing__inner">
    <p class="eyebrow interop-closing__eyebrow">The payoff</p>
    <h2 id="interop-closing-heading" class="interop-closing__heading">
      When the schema is the contract.
    </h2>
    <p class="interop-closing__body">
      When the schema is what every downstream system agrees on, a lot of integration work disappears. The audit trail unifies &mdash; every change has a single provenance record, not five. The translation memory unifies &mdash; the same paragraph is translated once, and every consumer reads the same string. The search index unifies &mdash; the support chatbot, the customer portal, and the regulator&rsquo;s PDF reader all retrieve the same paragraph.
    </p>
    <p class="interop-closing__body">
      Every system bolted on after that inherits the corrections, the versioning, and the provenance of the canonical layer. There is no second integration project. The next portal, the next chatbot, the next analytics dashboard reads the schema &mdash; and the schema already has the answers.
    </p>
    <p class="interop-closing__body interop-closing__body--punch">
      The point of the schema isn&rsquo;t the schema. It&rsquo;s that the next audit, the next system you bolt on, the next regulator doesn&rsquo;t require renegotiating what the words mean.
    </p>
  </div>
</section>

<style>
  .interop-closing {
    /* Symmetric top/bottom padding (58 px) so the hairlines bracket
       the content with equal breathing room — same treatment we
       tuned on TDP and Migration. */
    padding-top: 58px;
    padding-bottom: 58px;
    border-top: var(--border-hairline);
    border-bottom: var(--border-hairline);
  }

  .interop-closing__eyebrow {
    margin: 0 0 var(--space-6) 0;
    color: var(--color-accent-primary);
  }

  .interop-closing__heading {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-8) 0;
    text-wrap: balance;
  }

  .interop-closing__body {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    font-weight: var(--weight-regular);
    line-height: var(--leading-normal);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-6) 0;
    max-width: 60ch;
    text-wrap: pretty;
  }
  .interop-closing__body:last-child {
    margin-bottom: 0;
  }

  /* The closing punchline paragraph reads slightly heavier — same
     body type, but in primary color so the qualitative payoff lands
     without becoming a stat block or stepping on the single-
     semantic-accent rule. */
  .interop-closing__body--punch {
    color: var(--color-text-primary);
  }

  /* Reveal animation — viewport-triggered, eyebrow / heading / each
     paragraph stagger in. :nth-of-type indices are shifted by 1
     because the eyebrow is the first <p>; the first body paragraph
     is <p>:nth-of-type(2). */
  .interop-closing.animating .interop-closing__eyebrow,
  .interop-closing.animating .interop-closing__heading,
  .interop-closing.animating .interop-closing__body {
    opacity: 0;
    transform: translateY(8px);
  }

  .interop-closing.animating.in-view .interop-closing__eyebrow {
    animation: interop-closing-fade-in 420ms ease-out forwards;
  }
  .interop-closing.animating.in-view .interop-closing__heading {
    animation: interop-closing-fade-in 520ms ease-out forwards;
    animation-delay: 120ms;
  }
  .interop-closing.animating.in-view .interop-closing__body:nth-of-type(2) {
    animation: interop-closing-fade-in 420ms ease-out forwards;
    animation-delay: 280ms;
  }
  .interop-closing.animating.in-view .interop-closing__body:nth-of-type(3) {
    animation: interop-closing-fade-in 420ms ease-out forwards;
    animation-delay: 400ms;
  }
  .interop-closing.animating.in-view .interop-closing__body:nth-of-type(4) {
    animation: interop-closing-fade-in 420ms ease-out forwards;
    animation-delay: 520ms;
  }

  @keyframes interop-closing-fade-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .interop-closing.animating .interop-closing__eyebrow,
    .interop-closing.animating .interop-closing__heading,
    .interop-closing.animating .interop-closing__body {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }
  }
</style>

<script>
  function setupXmlDataInteropClosing() {
    const sec = document.querySelector<HTMLElement>(".interop-closing");
    if (!sec) return;
    if (sec.dataset.closingRevealInit === "true") return;
    sec.dataset.closingRevealInit = "true";

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;
    if (prefersReducedMotion) return;

    sec.classList.add("animating");

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            sec.classList.add("in-view");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );

    observer.observe(sec);
  }

  document.addEventListener("DOMContentLoaded", setupXmlDataInteropClosing);
  document.addEventListener("astro:page-load", setupXmlDataInteropClosing);
</script>
