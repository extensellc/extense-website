---
/*
  ControlChain — Financial Services vertical visualization.

  Centerpiece for /industries/financial-services. Five horizontally-flowing
  document-fragment cards representing the chain of evidence that auditors
  trace when testing a SOX 404 documentation control: authorship → approval
  → version control → audit & attestation → external disclosure.

  Each card uses the same brand-distinctive document-grade language as the
  SOW/Order Form/SLA panels and the Insurance VariantPolicyForm — bordered
  panel with #fcd34d left bar, mono labels, hairline construction.

  Cards connected by hairline arrows (rendered via ::after on each non-last
  stage). Below the chain, a single-line callout in italic display serif
  lands the failure-mode consequence.

  Build-in animation triggered once on scroll into view: cards cascade
  left-to-right with stagger; callout fades in last.
*/

interface ControlStage {
  /** Stage number, e.g. "01" */
  number: string;
  /** Stage name (mono uppercase) */
  name: string;
  /** What happens at this stage */
  description: string;
  /** Evidence artifact produced */
  artifact: string;
}

interface Props {
  eyebrow: string;
  heading: string;
  lead: string;
  stages: ControlStage[];
  callout: string;
  footnote: string;
}

const { eyebrow, heading, lead, stages, callout, footnote } = Astro.props;

// Animation timing helpers
const STAGE_BASE_DELAY = 200;  // ms
const STAGE_STAGGER    = 120;  // ms per stage
---

<section class="cc-section" aria-labelledby="cc-heading">
  <div class="container-data cc-section__inner">
    <p class="eyebrow cc-section__eyebrow">{eyebrow}</p>
    <h2 id="cc-heading" class="cc-section__heading">{heading}</h2>
    <p class="cc-section__lead">{lead}</p>

    <figure class="cc" id="cc" aria-label="Documentation control chain">
      <ol class="cc__row">
        {stages.map((stage, i) => (
          <li
            class="cc__stage"
            data-stage-index={i}
            style={`transition-delay: ${STAGE_BASE_DELAY + i * STAGE_STAGGER}ms`}
          >
            <article class="cc__card">
              <p class="cc__num">{stage.number}</p>
              <h3 class="cc__name">{stage.name}</h3>
              <p class="cc__desc">{stage.description}</p>
              <hr class="cc__rule" />
              <p class="cc__artifact-label">Artifact</p>
              <p class="cc__artifact">{stage.artifact}</p>
            </article>
          </li>
        ))}
      </ol>

      <div class="cc__callout" role="note">
        <p class="cc__callout-text">{callout}</p>
      </div>

      <figcaption class="cc__footnote">{footnote}</figcaption>
    </figure>
  </div>
</section>

<style>
  .cc-section {
    padding-top: var(--section-pad-default);
    padding-bottom: var(--section-pad-default);
    border-top: var(--border-hairline);
  }

  @media (max-width: 767px) {
    .cc-section {
      padding-top: var(--space-16);
      padding-bottom: var(--space-16);
    }
  }

  .cc-section__eyebrow {
    margin: 0 0 var(--space-3) 0;
    color: var(--color-accent-primary);
  }

  .cc-section__heading {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin-bottom: var(--space-6);
    text-wrap: balance;
  }

  .cc-section__lead {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-12);
    text-wrap: pretty;
    max-width: 75ch;
  }

  /* ─── The chain row ─── */
  .cc {
    margin: 0;
    padding: 0;
  }

  .cc__row {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  @media (min-width: 900px) {
    .cc__row {
      flex-direction: row;
      gap: var(--space-8);
      align-items: stretch;
    }
  }

  .cc__stage {
    flex: 1 1 0;
    position: relative;
    display: flex;
    /* Build-in: hidden until is-built; per-card delay set inline */
    opacity: 0;
    transform: translateY(4px);
    transition:
      opacity 320ms cubic-bezier(0, 0, 0.2, 1),
      transform 320ms cubic-bezier(0, 0, 0.2, 1);
  }

  /* Right-pointing arrow between cards on desktop, in the gap */
  @media (min-width: 900px) {
    .cc__stage:not(:last-child)::after {
      content: "→";
      position: absolute;
      top: 50%;
      right: calc(var(--space-8) * -0.5 - 4px);
      transform: translateY(-50%);
      font-family: var(--font-mono);
      font-size: 14px;
      color: var(--color-text-muted);
      pointer-events: none;
    }
  }

  /* ─── Card (document-fragment treatment) ─── */
  .cc__card {
    position: relative;
    border: var(--border-hairline);
    background-color: var(--color-page-bg);
    padding: var(--space-6) var(--space-4) var(--space-4);
    width: 100%;
    display: flex;
    flex-direction: column;
  }

  .cc__card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 2px;
    background-color: #fcd34d;
    pointer-events: none;
  }

  .cc__num {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-3) 0;
  }

  .cc__name {
    font-family: var(--font-mono);
    font-size: var(--text-body-sm);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-primary);
    line-height: 1.25;
    margin: 0 0 var(--space-3) 0;
  }

  .cc__desc {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 14px;
    color: var(--color-text-secondary);
    line-height: 1.4;
    margin: 0 0 var(--space-4) 0;
    text-wrap: pretty;
    flex-grow: 1;
  }

  .cc__rule {
    border: 0;
    border-top: var(--border-hairline);
    margin: 0 0 var(--space-3) 0;
  }

  .cc__artifact-label {
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    text-transform: uppercase;
    margin: 0 0 4px 0;
  }

  .cc__artifact {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-text-primary);
    line-height: 1.4;
    margin: 0;
    text-wrap: pretty;
  }

  /* ─── Callout below the chain ─── */
  .cc__callout {
    margin-top: var(--space-12);
    padding: var(--space-4) var(--space-6);
    border-left: 2px solid #fcd34d;
    background-color: rgb(253 224 71 / 0.06);
    /* Build-in: appears last */
    opacity: 0;
    transform: translateY(4px);
    transition:
      opacity 320ms cubic-bezier(0, 0, 0.2, 1),
      transform 320ms cubic-bezier(0, 0, 0.2, 1);
  }

  .cc__callout-text {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 18px;
    line-height: var(--leading-snug);
    color: var(--color-text-primary);
    margin: 0;
    text-wrap: balance;
  }

  .cc__footnote {
    margin-top: var(--space-8);
    padding-top: var(--space-4);
    border-top: var(--border-hairline);
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    font-style: italic;
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    max-width: 75ch;
  }

  /* ─── Build-in animation: cascade once is-built is added ─── */
  .cc.is-built .cc__stage {
    opacity: 1;
    transform: translateY(0);
    /* Per-stage transition-delay set inline in template */
  }

  .cc.is-built .cc__callout {
    opacity: 1;
    transform: translateY(0);
    /* Callout fires after the last stage — base 200ms + 5 stages * 120ms = 800ms */
    transition-delay: 1000ms;
  }

  /* Reduced motion: show everything at rest, no transitions */
  @media (prefers-reduced-motion: reduce) {
    .cc__stage,
    .cc__callout {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
(function () {
  const cc = document.getElementById('cc');
  if (!cc) return;

  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    cc.classList.add('is-built');
    return;
  }

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        cc.classList.add('is-built');
        observer.disconnect();
      }
    });
  }, {
    threshold: 0.15,
    rootMargin: '0px 0px -10% 0px',
  });

  observer.observe(cc);
})();
</script>
