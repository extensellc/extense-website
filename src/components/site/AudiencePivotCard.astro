---
/*
  AudiencePivotCard — used as a pair on the / homepage and on /industries.

  Spec ref: EXTENSE_DESIGN_BRIEF.md §9 (Cards)

  Two interaction modes:

    Direct-link mode (default) — the whole card is a link to `href`. Used
    when the card pivots to a single destination (e.g., Public Sector card
    pointing to /industries/government-and-defense).

    Disclosure mode — pass an `industries` array. The card becomes a <div>
    (not a link); the CTA at the bottom is a <details>/<summary>
    disclosure that expands to a list of industries. Used when the card
    pivots to multiple destinations (e.g., Private Sector card listing the
    four private-sector industries).

  Visual treatment:
    - Hairline border on right and bottom
    - 4px accent left border (color depends on variant)
    - radius-none, color-page-bg background, padding space-8 all sides
    - Eyebrow → heading → description → CTA (link or disclosure)

  Variants:
    Both variants share the brand amber left border (--color-accent-primary)
    so the pair reads as one "where to next" pivot. Eyebrows keep their
    distinct color (navy / warm gray) so the audiences remain visually
    labeled.
*/

interface IndustryItem {
  label: string;
  href: string;
}

interface Props {
  variant: "public-sector" | "private-sector";
  eyebrow: string;
  heading: string;
  description: string;
  /** Required in direct-link mode; ignored in disclosure mode */
  href?: string;
  /** CTA label (e.g., "View Agencies", "View Industries") */
  linkLabel?: string;
  /** If provided, renders disclosure mode with these items in the dropdown */
  industries?: IndustryItem[];
}

const {
  variant,
  eyebrow,
  heading,
  description,
  href,
  linkLabel,
  industries,
} = Astro.props;

const isDisclosure = !!industries && industries.length > 0;
const ctaLabel = linkLabel ?? `View ${variant === "public-sector" ? "Public Sector" : "Private Sector"}`;
---

{isDisclosure ? (
  <article class:list={["pivot-card", `pivot-card--${variant}`, "pivot-card--disclosure"]}>
    <div class="pivot-card__body">
      <p class="eyebrow pivot-card__eyebrow">{eyebrow}</p>
      <h3 class="pivot-card__heading">{heading}</h3>
      <p class="pivot-card__description">{description}</p>
      <details class="pivot-card__disclosure">
        <summary class="pivot-card__cta">
          {ctaLabel} <span class="pivot-card__caret" aria-hidden="true">→</span>
        </summary>
        <ul class="pivot-card__industry-list">
          {industries!.map((it) => (
            <li>
              <a href={it.href} class="pivot-card__industry-link">
                {it.label}
                <span class="pivot-card__industry-arrow" aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ul>
      </details>
    </div>
  </article>
) : (
  <article class:list={["pivot-card", `pivot-card--${variant}`]}>
    <a href={href} class="pivot-card__link">
      <p class="eyebrow pivot-card__eyebrow">{eyebrow}</p>
      <h3 class="pivot-card__heading">{heading}</h3>
      <p class="pivot-card__description">{description}</p>
      <span class="pivot-card__cta">
        {ctaLabel} <span class="pivot-card__arrow" aria-hidden="true">→</span>
      </span>
    </a>
  </article>
)}

<style>
  .pivot-card {
    background-color: var(--color-page-bg);
    border-top: var(--border-hairline);
    border-right: var(--border-hairline);
    border-bottom: var(--border-hairline);
    border-left-width: 4px;
    border-left-style: solid;
    border-radius: var(--radius-none);
    transition: background-color var(--duration-base) var(--easing-out);
  }

  .pivot-card:hover {
    background-color: var(--color-surface-elevated);
  }

  .pivot-card--public-sector,
  .pivot-card--private-sector {
    border-left-color: var(--color-accent-primary);
  }

  .pivot-card__link,
  .pivot-card__body {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: var(--space-8);
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .pivot-card__link:hover,
  .pivot-card__link:focus-visible {
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .pivot-card--public-sector .pivot-card__eyebrow {
    color: var(--color-gravitas-navy);
  }

  .pivot-card--private-sector .pivot-card__eyebrow {
    color: var(--color-text-secondary);
  }

  .pivot-card__eyebrow {
    margin-bottom: var(--space-3);
  }

  .pivot-card__heading {
    font-family: var(--font-display);
    font-size: var(--text-display-md);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    color: var(--color-text-primary);
    margin-bottom: var(--space-3);
    text-wrap: balance;
  }

  .pivot-card__description {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-6);
    text-wrap: pretty;
    flex-grow: 1;
  }

  .pivot-card__cta {
    font-size: var(--text-body-sm);
    font-weight: var(--weight-medium);
    color: var(--color-link);
    margin-top: auto;
    transition: color var(--duration-base) var(--easing-out);
  }

  .pivot-card__link:hover .pivot-card__cta,
  .pivot-card__link:focus-visible .pivot-card__cta {
    color: var(--color-link-hover);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }

  .pivot-card__arrow {
    display: inline-block;
    transition: transform var(--duration-base) var(--easing-out);
  }

  .pivot-card__link:hover .pivot-card__arrow {
    transform: translateX(2px);
  }

  /* ─── Disclosure mode ─── */
  .pivot-card__disclosure {
    margin-top: auto;
  }

  .pivot-card__disclosure > summary {
    list-style: none;
    cursor: pointer;
    padding: var(--space-1) 0;
    font-size: var(--text-body-sm);
    font-weight: var(--weight-medium);
    color: var(--color-link);
    transition: color var(--duration-base) var(--easing-out);
  }
  .pivot-card__disclosure > summary::-webkit-details-marker { display: none; }

  .pivot-card__disclosure > summary:hover,
  .pivot-card__disclosure > summary:focus-visible {
    color: var(--color-link-hover);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
    outline: none;
  }

  .pivot-card__caret {
    display: inline-block;
    transition: transform var(--duration-base) var(--easing-out);
  }
  .pivot-card__disclosure[open] .pivot-card__caret {
    transform: rotate(90deg);
  }

  .pivot-card__industry-list {
    list-style: none;
    margin: var(--space-4) 0 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .pivot-card__industry-list > li {
    border-top: var(--border-hairline);
  }

  .pivot-card__industry-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding: var(--space-3) 0;
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    font-weight: var(--weight-regular);
    color: var(--color-text-primary);
    text-decoration: none;
    transition: color var(--duration-base) var(--easing-out);
  }

  .pivot-card__industry-link:hover,
  .pivot-card__industry-link:focus-visible {
    color: var(--color-link-hover);
    text-decoration: none;
  }

  .pivot-card__industry-arrow {
    color: var(--color-link);
    transition: transform var(--duration-base) var(--easing-out);
  }

  .pivot-card__industry-link:hover .pivot-card__industry-arrow {
    transform: translateX(2px);
  }
</style>
