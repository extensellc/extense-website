---
/*
  VariantPolicyForm — Insurance vertical visualization.

  Centerpiece for /industries/insurance. A bordered policy-form artifact
  showing how a multi-state base form profiles per state DOI requirements
  via DITA conditional-content. Each section row carries a profile-count
  tag (right-aligned) and a row of state-name pills illustrating which
  jurisdictions drive variants for that section.

  Same brand-distinctive document-grade treatment as the SOW / Order Form /
  SLA panels on the Services pages — bordered panel, #fcd34d left bar,
  mono labels — but a single non-paginated artifact.

  Build-in animation triggered once when the component scrolls into view:
  panel border + title fade in, sections reveal top-to-bottom with stagger,
  state pills cascade left-to-right within each section.
*/

interface SectionVariant {
  /** Section label, e.g. "§3. COVERAGE LIMITS" */
  label: string;
  /** Profile-count tag shown right-aligned, e.g. "50 STATE PROFILES" */
  profileTag: string;
  /** Section body description */
  description: string;
  /** State-name pills (uppercase abbreviations); optional */
  statePills?: string[];
  /** Overflow count, e.g. 40 → "+40" */
  overflow?: number;
}

interface Props {
  eyebrow: string;
  heading: string;
  lead: string;
  documentRef: string;
  formLabel: string;
  documentTitle: string;
  documentSubtitle: string;
  sections: SectionVariant[];
  bottomNote: string;
  footnote: string;
}

const {
  eyebrow,
  heading,
  lead,
  documentRef,
  formLabel,
  documentTitle,
  documentSubtitle,
  sections,
  bottomNote,
  footnote,
} = Astro.props;

// Animation timing helpers (ms)
const SECTIONS_BASE_DELAY = 500;
const SECTION_STAGGER     = 100;
const PILL_BASE_DELAY     = 700;
const PILL_STAGGER        = 30;
---

<section class="vpf-section" aria-labelledby="vpf-heading">
  <div class="container-data vpf-section__inner">
    <p class="eyebrow vpf-section__eyebrow">{eyebrow}</p>
    <h2 id="vpf-heading" class="vpf-section__heading">{heading}</h2>
    <p class="vpf-section__lead">{lead}</p>

    <figure class="vpf" id="vpf" aria-label={`${documentTitle} — variant cardinality view`}>
      <article class="vpf__panel">
        <header class="vpf__head">
          <p class="vpf__doc-ref">{documentRef}</p>
          <p class="vpf__form-label">{formLabel}</p>
        </header>
        <h3 class="vpf__title">{documentTitle}</h3>
        <p class="vpf__subtitle">{documentSubtitle}</p>
        <hr class="vpf__rule" />

        <ol class="vpf__sections">
          {sections.map((s, i) => (
            <li class="vpf__section" data-section-index={i}>
              <div class="vpf__section-row">
                <span class="vpf__section-label">{s.label}</span>
                <span class="vpf__profile-tag">[ {s.profileTag} ]</span>
              </div>
              <p class="vpf__section-description">{s.description}</p>
              {s.statePills && s.statePills.length > 0 && (
                <ul class="vpf__pills">
                  {s.statePills.map((pill, pIdx) => (
                    <li
                      class="vpf__pill"
                      style={`transition-delay: ${PILL_BASE_DELAY + i * SECTION_STAGGER + pIdx * PILL_STAGGER}ms`}
                    >{pill}</li>
                  ))}
                  {s.overflow && s.overflow > 0 && (
                    <li
                      class="vpf__pill vpf__pill--overflow"
                      style={`transition-delay: ${PILL_BASE_DELAY + i * SECTION_STAGGER + s.statePills.length * PILL_STAGGER}ms`}
                    >+{s.overflow}</li>
                  )}
                </ul>
              )}
            </li>
          ))}
        </ol>

        <hr class="vpf__rule" />
        <p class="vpf__bottom-note">{bottomNote}</p>
      </article>

      <figcaption class="vpf__footnote">{footnote}</figcaption>
    </figure>
  </div>
</section>

<style define:vars={{
  sectionsBaseDelay: SECTIONS_BASE_DELAY + 'ms',
  sectionStagger: SECTION_STAGGER + 'ms'
}}>
  .vpf-section {
    padding-top: var(--section-pad-default);
    padding-bottom: var(--section-pad-default);
    border-top: var(--border-hairline);
  }

  @media (max-width: 767px) {
    .vpf-section {
      padding-top: var(--space-16);
      padding-bottom: var(--space-16);
    }
  }

  .vpf-section__eyebrow {
    margin: 0 0 var(--space-3) 0;
    color: var(--color-accent-primary);
  }

  .vpf-section__heading {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin-bottom: var(--space-6);
    text-wrap: balance;
  }

  .vpf-section__lead {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-12);
    text-wrap: pretty;
    max-width: 70ch;
  }

  /* ─── The artifact panel ─── */
  .vpf {
    margin: 0;
    padding: 0;
  }

  .vpf__panel {
    position: relative;
    border: var(--border-hairline);
    background-color: var(--color-page-bg);
    padding: var(--space-8) var(--space-8) var(--space-6);
    /* Build-in: panel fades in slightly */
    opacity: 0;
    transform: translateY(4px);
    transition:
      opacity 320ms cubic-bezier(0, 0, 0.2, 1),
      transform 320ms cubic-bezier(0, 0, 0.2, 1);
  }

  .vpf__panel::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 2px;
    background-color: #fcd34d;
    pointer-events: none;
  }

  .vpf__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-bottom: var(--space-6);
  }

  .vpf__doc-ref,
  .vpf__form-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    text-transform: uppercase;
    margin: 0;
  }

  .vpf__title {
    font-family: var(--font-display);
    font-weight: var(--weight-regular);
    font-size: 30px;
    line-height: 1.15;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin-bottom: var(--space-2);
  }

  .vpf__subtitle {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 16px;
    color: var(--color-text-secondary);
    line-height: var(--leading-snug);
    margin-bottom: var(--space-6);
    text-wrap: balance;
  }

  .vpf__rule {
    border: 0;
    border-top: var(--border-hairline);
    margin: 0 0 var(--space-6) 0;
  }

  .vpf__sections {
    list-style: none;
    margin: 0 0 var(--space-6) 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .vpf__section {
    padding: var(--space-6) 0;
    border-top: var(--border-hairline);
    /* Build-in: each section fades in with stagger */
    opacity: 0;
    transform: translateY(-3px);
    transition:
      opacity 240ms cubic-bezier(0, 0, 0.2, 1),
      transform 240ms cubic-bezier(0, 0, 0.2, 1);
  }
  .vpf__section:first-of-type {
    border-top: none;
    padding-top: 0;
  }
  .vpf__section:last-of-type {
    padding-bottom: 0;
  }

  .vpf__section-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-bottom: var(--space-2);
  }

  .vpf__section-label {
    font-family: var(--font-mono);
    font-size: var(--text-body-sm);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-primary);
  }

  .vpf__profile-tag {
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-link);
    background-color: rgb(253 224 71 / 0.18);
    padding: 3px 8px;
    border-radius: 2px;
    white-space: nowrap;
  }

  .vpf__section-description {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin: 0 0 var(--space-3) 0;
    text-wrap: pretty;
    max-width: 70ch;
  }

  /* State pills */
  .vpf__pills {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .vpf__pill {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    background-color: var(--color-page-bg);
    border: 1px solid var(--color-border-subtle);
    padding: 2px 6px;
    border-radius: 2px;
    /* Build-in: each pill fades in with per-pill stagger via inline delay */
    opacity: 0;
    transform: translateY(-2px);
    transition:
      opacity 200ms cubic-bezier(0, 0, 0.2, 1),
      transform 200ms cubic-bezier(0, 0, 0.2, 1);
  }

  .vpf__pill--overflow {
    color: var(--color-text-muted);
    border-style: dashed;
  }

  .vpf__bottom-note {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    font-style: italic;
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin: 0;
    text-wrap: pretty;
  }

  .vpf__footnote {
    margin-top: var(--space-8);
    padding-top: var(--space-4);
    border-top: var(--border-hairline);
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    font-style: italic;
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    max-width: 70ch;
  }

  /* ─── Build-in animation: cascade once is-built is added ─── */
  .vpf.is-built .vpf__panel {
    opacity: 1;
    transform: translateY(0);
  }

  .vpf.is-built .vpf__section {
    opacity: 1;
    transform: translateY(0);
  }
  .vpf.is-built .vpf__section[data-section-index="0"] { transition-delay: var(--sectionsBaseDelay); }
  .vpf.is-built .vpf__section[data-section-index="1"] { transition-delay: calc(var(--sectionsBaseDelay) + var(--sectionStagger)); }
  .vpf.is-built .vpf__section[data-section-index="2"] { transition-delay: calc(var(--sectionsBaseDelay) + var(--sectionStagger) * 2); }
  .vpf.is-built .vpf__section[data-section-index="3"] { transition-delay: calc(var(--sectionsBaseDelay) + var(--sectionStagger) * 3); }
  .vpf.is-built .vpf__section[data-section-index="4"] { transition-delay: calc(var(--sectionsBaseDelay) + var(--sectionStagger) * 4); }
  .vpf.is-built .vpf__section[data-section-index="5"] { transition-delay: calc(var(--sectionsBaseDelay) + var(--sectionStagger) * 5); }

  .vpf.is-built .vpf__pill {
    opacity: 1;
    transform: translateY(0);
    /* Per-pill transition-delay set inline in template */
  }

  /* Reduced motion: show everything at rest, no transitions */
  @media (prefers-reduced-motion: reduce) {
    .vpf__panel,
    .vpf__section,
    .vpf__pill {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
(function () {
  const vpf = document.getElementById('vpf');
  if (!vpf) return;

  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    vpf.classList.add('is-built');
    return;
  }

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        vpf.classList.add('is-built');
        observer.disconnect();
      }
    });
  }, {
    threshold: 0.15,
    rootMargin: '0px 0px -10% 0px',
  });

  observer.observe(vpf);
})();
</script>
