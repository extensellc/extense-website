---
/*
  Footer — shared, all pages.

  Vertical stack:
    1. Six link columns mirroring the top-nav structure:
       Solutions | Services | Industries | Resources | Company | Legal.
       Each heading is a link to its section index (where one exists).
       Legal heading is plain text — there's no /legal index page.
    2. Centered single-line copyright on its own hairline-separated row.
    3. Full-width animated ShimmerLogo (deep glossy black background).

  Footer is structural navigation + brand presence. No newsletter, no
  marketing CTAs, no tagline text — the shimmer carries the brand moment.
  Tight typographic register: small uppercase headings, body-sm links,
  compressed vertical rhythm.

  Mobile: columns reflow to 2-up; copyright stays centered. Shimmer
  remains full-width at the bottom.
*/

import ShimmerLogo from "../brand/ShimmerLogo.astro";

const year = new Date().getFullYear();

interface FooterLink {
  label: string;
  href: string;
  external?: boolean;
}

interface FooterColumn {
  heading: string;
  /** Section-index URL. Omit for sections without an index (e.g. Legal). */
  headingHref?: string;
  links: FooterLink[];
}

const columns: FooterColumn[] = [
  {
    heading: "Solutions",
    headingHref: "/solutions",
    links: [
      { label: "Technical Docs & Publishing", href: "/solutions/technical-docs-and-publishing" },
      { label: "Content Migration",            href: "/solutions/content-migration" },
      { label: "XML Data Interoperability",    href: "/solutions/xml-data-interoperability" },
      { label: "AI-Ready Content",             href: "/solutions/ai-ready-content" },
    ],
  },
  {
    heading: "Services",
    headingHref: "/services",
    links: [
      { label: "Project-Based",      href: "/services/project-based" },
      { label: "Staff Augmentation", href: "/services/staff-augmentation" },
      { label: "Managed Services",   href: "/services/managed-services" },
    ],
  },
  {
    heading: "Industries",
    headingHref: "/industries",
    links: [
      { label: "Government & Defense", href: "/industries/government-and-defense" },
      { label: "Financial Services",   href: "/industries/financial-services" },
      { label: "Life Sciences",        href: "/industries/life-sciences" },
      { label: "Transportation",       href: "/industries/transportation" },
      { label: "Insurance",            href: "/industries/insurance" },
      { label: "Technology",           href: "/industries/technology" },
    ],
  },
  {
    heading: "Resources",
    headingHref: "/resources",
    links: [
      { label: "AI Readiness",       href: "/resources/ai-readiness" },
      { label: "Migration Playbook", href: "/resources/migration-playbook" },
      { label: "Automation Guide",   href: "/resources/automation-guide" },
      { label: "FAQ",                href: "/resources/faq" },
    ],
  },
  {
    heading: "Company",
    headingHref: "/company",
    links: [
      { label: "About Us",                 href: "/company/about-us" },
      { label: "Our Process",              href: "/company/our-process" },
      { label: "Our Work & Case Studies",  href: "/company/our-work-and-case-studies" },
      { label: "Careers",                  href: "/company/careers" },
      { label: "LinkedIn",                 href: "https://www.linkedin.com/company/ex-tense", external: true },
    ],
  },
  {
    heading: "Legal",
    links: [
      { label: "Privacy", href: "/privacy" },
      { label: "Terms",   href: "/terms" },
    ],
  },
];
---

<footer class="footer" aria-label="Site footer">
  <div class="footer__upper container-page">
    <div class="footer__columns">
      {columns.map((col) => (
        <div class="footer__column">
          <h4 class="footer__heading">
            {col.headingHref ? (
              <a href={col.headingHref} class="footer__heading-link">{col.heading}</a>
            ) : (
              col.heading
            )}
          </h4>
          <ul class="footer__links">
            {col.links.map((link) => (
              <li>
                {link.external ? (
                  <a
                    href={link.href}
                    class="footer__link"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {link.label}
                  </a>
                ) : (
                  <a href={link.href} class="footer__link">{link.label}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="footer__utility">
      <p class="footer__copyright">© {year} Extense LLC. All rights reserved.</p>
    </div>
  </div>

  <div class="footer__shimmer">
    <ShimmerLogo />
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-surface-elevated);
    border-top: var(--border-hairline);
    color: var(--color-text-primary);
    margin-top: auto;
    display: flex;
    flex-direction: column;
  }

  /* Tight vertical rhythm — less breathing room than before. */
  .footer__upper {
    padding-top: var(--space-12);
    padding-bottom: var(--space-6);
  }

  /* Six link columns on desktop, reflowing on smaller widths.
     Compact gaps so the column packing feels dense. */
  .footer__columns {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6) var(--space-4);
    margin-bottom: var(--space-8);
  }

  @media (min-width: 640px) {
    .footer__columns {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .footer__columns {
      /* Size each column to its content so the visible gap between any
         two columns is exactly the `gap` value — not "gap + each column's
         leftover internal whitespace" (which made COMPANY↔LEGAL look
         further apart than INDUSTRIES↔RESOURCES under fixed 1fr widths). */
      grid-template-columns: repeat(6, max-content);
      gap: var(--space-8);
      justify-content: center;
      /* Slight optical nudge left of true-center (~2mm). The track
         centers within (full width − margin-right), so a 16px margin
         on the right shifts the visible track ~8px to the left. */
      margin-right: var(--space-4);
    }
  }

  .footer__column {
    /* Centered contents — masks the uneven column heights and the
       label wraps that come with the 7-column packing. */
    text-align: center;
    min-width: 0;
  }

  /* Heading — always an <h4>. If the section has an index page, an
     inner <a class="footer__heading-link"> wraps the text. Typography
     and bottom margin live on the h4 so both variants align identically. */
  .footer__heading {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-3) 0;
  }

  .footer__heading-link {
    color: inherit;
    text-decoration: none;
    transition: color var(--duration-base) var(--easing-out);
  }

  .footer__heading-link:hover,
  .footer__heading-link:focus-visible {
    color: var(--color-link);
  }

  .footer__links {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer__link {
    display: inline-block;
    font-size: 11px;
    font-weight: var(--weight-regular);
    line-height: 1.4;
    color: #555555;
    text-decoration: none;
    transition: color var(--duration-base) var(--easing-out);
  }

  .footer__link:hover,
  .footer__link:focus-visible {
    color: var(--color-link);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }

  /* Utility row — centered single-line copyright on its own hairline row. */
  .footer__utility {
    padding-top: var(--space-4);
    border-top: var(--border-hairline);
    text-align: center;
  }

  .footer__copyright {
    font-size: var(--text-caption);
    color: var(--color-text-muted);
    margin: 0;
  }

  /* Shimmer band — full-width, sits below the utility row. */
  .footer__shimmer {
    width: 100%;
  }
</style>
