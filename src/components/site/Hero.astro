---
/*
  Hero — used on every primary page.

  Spec ref: EXTENSE_DESIGN_BRIEF.md §9 (Hero)

  One component, three copy-mode variants. Structure is identical across variants;
  only copy register varies. The variant prop is a class hook for any page-specific
  styling tweaks (e.g., gravitas-navy treatment on /public-sector if needed).

  Variants:
    .universal   — /, /about, /capabilities, /insights, /contact
    .identifying — /public-sector (declarative federal-procurement)
    .outcome     — /private-sector (outcome-led with concrete numbers)

  Locked rules:
    - No CTA in hero. Conversion mechanism lives at the close of each page.
    - No transformation language anywhere. (No "we transform", "empower", "enable" verbs.)
    - /private-sector hero must use real numbers, not abstractions.
    - /about hero uses Phase 1 canonical positioning sentence verbatim.
*/

interface Props {
  title: string;
  subdeck?: string;
  variant?: "universal" | "identifying" | "outcome";
  /**
   * If true, includes a small badge row above the H1 (e.g., for /
   * homepage with certification pills). Phase 4 design has shipped this
   * out of the hero per locked decisions, but the slot remains available
   * for future use.
   */
  badges?: string[];
  /**
   * Eyebrow above H1 (small label). Used on some interior pages.
   */
  eyebrow?: string;
  /**
   * Optional max-width for the subdeck paragraph (any CSS length, e.g.
   * "580px"). Lets a page tighten the subdeck's wrap without affecting the
   * shared default. Omit to use the natural content-column width.
   */
  subdeckMaxWidth?: string;
  /**
   * Center the hero text (title + subdeck) across the full page width.
   * For text-only heroes (no side visual) that would otherwise leave the
   * right half empty — e.g. /resources/faq.
   */
  centered?: boolean;
}

const { title, subdeck, variant = "universal", badges, eyebrow, subdeckMaxWidth, centered = false } = Astro.props;
const hasSideContent = Astro.slots.has('default');
const hasBg = Astro.slots.has('background');
---

<section class:list={["hero", `hero--${variant}`, hasSideContent && "hero--has-side", centered && "hero--centered", hasBg && "hero--has-bg"]}>
  {hasBg && (
    <div class="hero__bg" aria-hidden="true"><slot name="background" /></div>
  )}
  <div class="container-page hero__inner">
    <div class="hero__content">
      {eyebrow && <p class="eyebrow hero__eyebrow">{eyebrow}</p>}

      {badges && badges.length > 0 && (
        <ul class="hero__badges" aria-label="Firm certifications">
          {badges.map((b) => <li>{b}</li>)}
        </ul>
      )}

      <h1 class="hero__title">{title}</h1>

      {subdeck && <p class="hero__subdeck" style={subdeckMaxWidth ? `max-width: ${subdeckMaxWidth};` : undefined}><Fragment set:html={subdeck} /></p>}
    </div>

    {hasSideContent && (
      <div class="hero__side">
        <slot />
      </div>
    )}
  </div>
</section>

<style>
  .hero {
    padding-top: var(--space-16);
    padding-bottom: var(--space-16);
  }

  @media (min-width: 768px) {
    .hero {
      padding-top: var(--space-32);
      padding-bottom: var(--space-24);
    }
  }

  .hero__inner {
    /* container-page provides max-width + padding */
  }

  .hero__content {
    /* Content lives within container-prose width inside the page-width container.
       Left-aligned, not centered — Phase 3 wireframe spec. */
    max-width: var(--container-prose);
  }

  .hero__eyebrow {
    margin-bottom: var(--space-4);
  }

  .hero__badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }

  .hero__badges li {
    font-size: var(--text-caption);
    font-weight: var(--weight-medium);
    color: var(--color-text-secondary);
    padding: var(--space-1) var(--space-3);
    border: var(--border-hairline);
    border-radius: var(--radius-pill);
    background-color: var(--color-page-bg);
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: var(--text-display-xl);
    /* Phase 4 calibration: test weight-regular vs. weight-medium under rendered output.
       Default per spec is weight-regular; bump to weight-medium if it reads soft on warm bg. */
    font-weight: var(--weight-regular);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    text-wrap: balance;
  }

  .hero__subdeck {
    margin-top: var(--space-6);
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    font-weight: var(--weight-regular);
    line-height: var(--leading-normal);
    color: var(--color-text-secondary);
    text-wrap: pretty;
  }

  /* Centered text-only hero (e.g. /resources/faq) — fills the full page
     width instead of leaving the right half empty. */
  .hero--centered .hero__content {
    max-width: none;
    text-align: center;
  }
  .hero--centered .hero__subdeck {
    margin-left: auto;
    margin-right: auto;
  }

  /* Optional moving/background slot — rendered behind the hero content.
     The page supplies the visual via slot="background". */
  .hero--has-bg {
    position: relative;
    overflow: hidden;
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .hero--has-bg .hero__inner {
    position: relative;
    z-index: 1;
  }

  /* Variant-specific class hooks — currently no visual deviation,
     but the hooks exist for any per-audience tweaks discovered in Phase 4. */
  .hero--identifying .hero__eyebrow {
    color: var(--color-gravitas-navy);
  }

  /* ─── Optional side-content slot ───
     When the hero has slot content, the inner becomes a horizontal flex
     layout at desktop widths. The side content renders to the right of
     the hero text. */
  @media (min-width: 1024px) {
    .hero--has-side .hero__inner {
      display: flex;
      align-items: center;
      gap: var(--space-12);
    }

    .hero--has-side .hero__content {
      flex: 1 1 auto;
    }

    .hero__side {
      flex: 0 0 auto;
      margin-left: auto;
    }
  }
</style>
