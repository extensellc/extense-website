---
/*
  SolutionsAreas — "Our Solutions" section on /solutions.

  The four solution areas as a 2x2 card grid (was a stacked editorial list).
  Each card: amber number, name, body (old-site card copy), Explore link.
  Hairline cards, no drop shadow (brand card pattern). Equal-height cards via
  the grid; the body flex-grows so the Explore link bottom-aligns across a row.

  Animation: cards fade/rise in, staggered, when the section enters the
  viewport. prefers-reduced-motion: static.

  Heading typography defined locally (Astro scopes index.astro's rules).
*/

interface Area {
  num: string;
  name: string;
  body: string;
  href: string;
}

const areas: Area[] = [
  {
    num: "01",
    name: "Technical Documentation & Publishing",
    body: "Modernize your authoring and publishing workflows. We build single-source pipelines that produce pixel-perfect PDF, responsive HTML5, EPUB, and context-sensitive help from the same DITA map — eliminating the \"copy-paste-reformat\" cycle that costs enterprises thousands of hours per year.",
    href: "/solutions/technical-docs-and-publishing",
  },
  {
    num: "02",
    name: "Content Migration & Modernization",
    body: "Legacy Word, FrameMaker, and InDesign content doesn't have to be rewritten by hand. Our migration engine combines automated conversion scripts with expert manual refinement to convert unstructured documents into clean, validated DITA XML — typically at 10x the speed of manual conversion.",
    href: "/solutions/content-migration",
  },
  {
    num: "03",
    name: "XML Data Interoperability",
    body: "Your content must flow between systems: CCMS to PIM, ERP to Portal, CMS to Translation Memory. We design XSLT/XQuery transformation layers, REST/GraphQL APIs, and OData connectors that make your XML data a first-class citizen in your enterprise architecture.",
    href: "/solutions/xml-data-interoperability",
  },
  {
    num: "04",
    name: "AI-Ready Content",
    body: "Your content is becoming an AI retrieval source — whether it was engineered for that or not. We structure it for RAG pipelines: semantic chunking, retrieval metadata, and embedding-ready markup, validated so answers stay grounded in the source — the difference between 85% retrieval precision and a system that confidently hallucinates.",
    href: "/solutions/ai-ready-content",
  },
];
---

<section class="solutions-areas" aria-labelledby="areas-heading">
  <div class="container-data solutions-areas__inner">
    <div class="solutions-areas__heading-block">
      <h2 id="areas-heading" class="solutions-areas__heading">Our Solutions</h2>
      <p class="solutions-areas__subdeck">
        Four areas where engineered content replaces a hand-authored,
        copy-and-rebuild cycle.
      </p>
    </div>

    <ol class="solutions-areas__grid">
      {areas.map((area) => (
        <li class="solution-card">
          <span class="solution-card__num" aria-hidden="true">{area.num}</span>
          <h3 class="solution-card__name">{area.name}</h3>
          <p class="solution-card__body">{area.body}</p>
          <a
            href={area.href}
            class="solution-card__link"
            aria-label={`Explore ${area.name}`}
          >
            Explore <span class="solution-card__arrow" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .solutions-areas {
    padding-top: var(--section-pad-default);
    /* Extra bottom space so the CTA's amber accent line clears the cards. */
    padding-bottom: var(--space-16);
    border-top: var(--border-hairline);
  }
  @media (max-width: 767px) {
    .solutions-areas {
      padding-top: var(--space-16);
      padding-bottom: var(--space-12);
    }
  }

  .solutions-areas__heading-block {
    max-width: var(--container-prose, 720px);
    margin-bottom: var(--space-12);
  }
  .solutions-areas__heading {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin: 0;
    text-wrap: balance;
  }
  .solutions-areas__subdeck {
    margin-top: var(--space-4);
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    max-width: 64ch;
    text-wrap: pretty;
  }

  /* 2x2 card grid (single column on mobile). */
  .solutions-areas__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }
  @media (min-width: 768px) {
    .solutions-areas__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .solution-card {
    border: var(--border-hairline);
    padding: var(--space-8) var(--space-6);
    display: flex;
    flex-direction: column;
  }

  .solution-card__num {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.08em;
    color: var(--color-accent-primary);
    margin-bottom: var(--space-4);
  }

  .solution-card__name {
    font-family: var(--font-display);
    font-size: var(--text-display-md);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-4) 0;
    text-wrap: balance;
  }

  .solution-card__body {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin: 0 0 var(--space-6) 0;
    text-wrap: pretty;
    flex-grow: 1;
  }

  .solution-card__link {
    font-family: var(--font-body);
    font-size: var(--text-body);
    font-weight: var(--weight-medium);
    color: var(--color-link);
    text-decoration: none;
    margin-top: auto;
    transition: color var(--duration-base) var(--easing-out);
  }
  .solution-card__link:hover,
  .solution-card__link:focus-visible {
    color: var(--color-link-hover);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }
  .solution-card__arrow {
    display: inline-block;
    transition: transform var(--duration-base) var(--easing-out);
  }
  .solution-card__link:hover .solution-card__arrow {
    transform: translateX(2px);
  }

  /* ── Reveal: cards fade/rise, staggered, on section entry. ── */
  .solutions-areas.animating .solutions-areas__heading-block,
  .solutions-areas.animating .solution-card {
    opacity: 0;
    transform: translateY(8px);
  }
  .solutions-areas.animating.in-view .solutions-areas__heading-block {
    animation: areas-fade-in 480ms ease-out forwards;
  }
  .solutions-areas.animating.in-view .solution-card {
    animation: areas-fade-in 460ms ease-out forwards;
  }
  .solutions-areas.animating.in-view .solution-card:nth-child(1) { animation-delay: 120ms; }
  .solutions-areas.animating.in-view .solution-card:nth-child(2) { animation-delay: 220ms; }
  .solutions-areas.animating.in-view .solution-card:nth-child(3) { animation-delay: 320ms; }
  .solutions-areas.animating.in-view .solution-card:nth-child(4) { animation-delay: 420ms; }

  @keyframes areas-fade-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .solutions-areas.animating .solutions-areas__heading-block,
    .solutions-areas.animating .solution-card {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }
  }
</style>

<script>
  // SolutionsAreas — section-level staggered card reveal on viewport entry.
  function setupSolutionsAreas() {
    const sec = document.querySelector<HTMLElement>(".solutions-areas");
    if (!sec) return;
    if (sec.dataset.areasRevealInit === "true") return;
    sec.dataset.areasRevealInit = "true";

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;
    if (prefersReducedMotion) return;

    sec.classList.add("animating");

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            sec.classList.add("in-view");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );
    observer.observe(sec);
  }

  document.addEventListener("DOMContentLoaded", setupSolutionsAreas);
  document.addEventListener("astro:page-load", setupSolutionsAreas);
</script>
