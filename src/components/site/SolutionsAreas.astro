---
/*
  SolutionsAreas — the four editorial chapter-blocks on /solutions.

  Sequenced after the approach principle. Each block is one solution
  area, presented as an editorial section rather than a card:

    01  Technical Docs & Publishing.
    02  Content Migration.
    03  XML Data Interoperability.
    04  AI-Ready Content.

  Per-block structure
    - amber monospace number prefix (left column, narrow)
    - display-serif name + body + pull-quote hook + Explore link
      (right column, wide)
    - hairline rule at the top of each block
    - on the last block, hairline rule at the bottom too

  Pull-quote
    - italic display serif
    - 2 px amber left bar via ::before
    - bar scales in (top-to-bottom) when the block enters the viewport

  Animation
    - Each block has its own IntersectionObserver. When it scrolls into
      view, it adds .in-view to itself; CSS fades up the contents and
      grows the pull-quote bar.
    - Each block is independent — they don't all animate at once.
    - prefers-reduced-motion: static.
*/

interface Area {
  num: string;
  name: string;
  body: string;
  hook: string;
  href: string;
}

const areas: Area[] = [
  {
    num: "01",
    name: "Technical Docs & Publishing",
    body: "One source, every output channel. We replace the copy-and-reformat cycle with a single DITA-driven pipeline that produces pixel-perfect PDF, responsive HTML5, EPUB, and context-sensitive help — automatically, on every merge.",
    hook: "What happens to your translation costs when the same paragraph stops being authored five different ways?",
    href: "/solutions/technical-docs-and-publishing",
  },
  {
    num: "02",
    name: "Content Migration",
    body: "Recovery operation. Legacy estates — FrameMaker, Word, unstructured XML, scanned PDF — converted to clean, reusable DITA. The conversion is engineered, not hand-rekeyed, so the work finishes.",
    hook: "Why does manual conversion never end — and what does a conversion pipeline that does?",
    href: "/solutions/content-migration",
  },
  {
    num: "03",
    name: "XML Data Interoperability",
    body: "Structured content as a portable data layer. CCMS to PIM, ERP to portal, CMS to translation memory — your content fact is one fact, not five copies in five systems. XSLT/XQuery transformation layers, REST/GraphQL APIs, and OData connectors make the same source authoritative everywhere it's consumed.",
    hook: "When four systems need the same fact, who's the source of truth?",
    href: "/solutions/xml-data-interoperability",
  },
  {
    num: "04",
    name: "AI-Ready Content",
    body: "The translation layer between authoritative documentation and the LLMs that consume it. Chunking strategy, metadata schemas, and retrieval architecture that turn 85% RAG precision into a measurable property of the content itself, not a hope.",
    hook: "Why is your RAG hallucinating on a topic you've already documented?",
    href: "/solutions/ai-ready-content",
  },
];
---

<section class="solutions-areas" aria-labelledby="areas-heading">
  <div class="container-data solutions-areas__inner">
    <div class="solutions-areas__heading-block">
      <h2 id="areas-heading" class="solutions-areas__heading">
        Where the principle becomes <em>practice</em>.
      </h2>
      <p class="solutions-areas__subdeck">
        Four areas where modeled, validated content replaces a hand-authored, copy-and-rebuild cycle.
      </p>
    </div>

    <ol class="solutions-areas__list">
      {areas.map((area) => (
        <li class="solution-area">
          <div class="solution-area__num" aria-hidden="true">{area.num}</div>
          <div class="solution-area__content">
            <h3 class="solution-area__name">{area.name}.</h3>
            <p class="solution-area__body">{area.body}</p>
            <p class="solution-area__hook">{area.hook}</p>
            <a href={area.href} class="solution-area__link">
              Explore {area.name}
              <span class="solution-area__arrow" aria-hidden="true">→</span>
            </a>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .solutions-areas {
    padding-top: var(--section-pad-default);
    /* Reduced bottom padding so the gap to the CTA below doesn't read
       as dead space — the CTA's own padding-top (--space-32) already
       provides substantial breathing room. */
    padding-bottom: var(--space-4);
    border-top: var(--border-hairline);
  }

  @media (max-width: 767px) {
    .solutions-areas {
      padding-top: var(--space-16);
      padding-bottom: var(--space-6);
    }
  }

  .solutions-areas__heading-block {
    max-width: var(--container-prose, 720px);
    margin-bottom: var(--space-16);
  }

  .solutions-areas__heading {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin: 0;
    text-wrap: balance;
  }

  .solutions-areas__heading em {
    font-style: italic;
  }

  .solutions-areas__subdeck {
    margin-top: var(--space-4);
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    max-width: 64ch;
    text-wrap: pretty;
  }

  /* List of areas — flat list, no bullets. Each area separated by a
     hairline at its top. Last area also gets a hairline at the bottom
     so the section ends cleanly. */
  .solutions-areas__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .solution-area {
    border-top: var(--border-hairline);
    padding-top: var(--space-12);
    padding-bottom: var(--space-12);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }
  .solution-area:last-child {
    border-bottom: var(--border-hairline);
  }

  @media (min-width: 768px) {
    .solution-area {
      /* Narrow left col for the number, wide right col for the content. */
      grid-template-columns: 96px 1fr;
      gap: var(--space-8);
      padding-top: var(--space-16);
      padding-bottom: var(--space-16);
    }
  }

  .solution-area__num {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.08em;
    color: var(--color-accent-primary);
    line-height: 1;
    /* Pull up to align visually with the top of the name */
    padding-top: 8px;
  }

  .solution-area__content {
    max-width: 72ch;
  }

  .solution-area__name {
    font-family: var(--font-display);
    font-size: var(--text-display-md);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-6) 0;
    text-wrap: balance;
  }

  .solution-area__body {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    line-height: 1.55;
    margin: 0 0 var(--space-8) 0;
    text-wrap: pretty;
  }

  /* Pull-quote hook: italic with a 2 px amber bar on the left. The bar
     is a ::before pseudo so it can animate independently of the text. */
  .solution-area__hook {
    position: relative;
    margin: 0 0 var(--space-8) 0;
    padding-left: var(--space-6);
    font-family: var(--font-display);
    font-size: 22px;
    font-style: italic;
    font-weight: var(--weight-regular);
    line-height: 1.4;
    color: var(--color-text-primary);
    text-wrap: pretty;
    max-width: 60ch;
  }
  .solution-area__hook::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background-color: var(--color-accent-primary-hover);
    transform-origin: top center;
  }

  .solution-area__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: var(--text-body);
    font-weight: var(--weight-medium);
    color: var(--color-link);
    text-decoration: none;
    transition: color var(--duration-base) var(--easing-out);
  }
  .solution-area__link:hover,
  .solution-area__link:focus-visible {
    color: var(--color-link-hover);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }
  .solution-area__arrow {
    display: inline-block;
    transition: transform var(--duration-base) var(--easing-out);
  }
  .solution-area__link:hover .solution-area__arrow {
    transform: translateX(2px);
  }

  /* ─────────────────────────────────────────────────────────────────
     Reveal animation — per-block.

     Each .solution-area has its own .in-view trigger. JS adds
     .animating on init (no-JS fails open). When an individual area
     scrolls into view, its in-view class fades up the elements and
     scales the pull-quote bar in.
     ───────────────────────────────────────────────────────────────── */
  .solutions-areas.animating .solutions-areas__heading-block {
    opacity: 0;
    transform: translateY(8px);
  }
  .solutions-areas.animating .solution-area__num,
  .solutions-areas.animating .solution-area__name,
  .solutions-areas.animating .solution-area__body,
  .solutions-areas.animating .solution-area__hook,
  .solutions-areas.animating .solution-area__link {
    opacity: 0;
    transform: translateY(8px);
  }
  .solutions-areas.animating .solution-area__hook::before {
    transform: scaleY(0);
  }

  /* Heading reveals when the whole section first enters view. */
  .solutions-areas.animating.in-view .solutions-areas__heading-block {
    animation: areas-fade-in 480ms ease-out forwards;
  }

  /* Per-area reveal: each area uses its own .in-view, set independently
     by the observer. Inside each, items fade up in sequence; the
     pull-quote bar scales in alongside the hook. */
  .solutions-areas.animating .solution-area.in-view .solution-area__num {
    animation: areas-fade-in 420ms ease-out forwards;
  }
  .solutions-areas.animating .solution-area.in-view .solution-area__name {
    animation: areas-fade-in 420ms ease-out forwards;
    animation-delay: 80ms;
  }
  .solutions-areas.animating .solution-area.in-view .solution-area__body {
    animation: areas-fade-in 420ms ease-out forwards;
    animation-delay: 160ms;
  }
  .solutions-areas.animating .solution-area.in-view .solution-area__hook {
    animation: areas-fade-in 420ms ease-out forwards;
    animation-delay: 240ms;
  }
  .solutions-areas.animating .solution-area.in-view .solution-area__hook::before {
    animation: areas-bar-grow 520ms ease-out forwards;
    animation-delay: 240ms;
  }
  .solutions-areas.animating .solution-area.in-view .solution-area__link {
    animation: areas-fade-in 420ms ease-out forwards;
    animation-delay: 380ms;
  }

  @keyframes areas-fade-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes areas-bar-grow {
    to {
      transform: scaleY(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .solutions-areas.animating .solutions-areas__heading-block,
    .solutions-areas.animating .solution-area__num,
    .solutions-areas.animating .solution-area__name,
    .solutions-areas.animating .solution-area__body,
    .solutions-areas.animating .solution-area__hook,
    .solutions-areas.animating .solution-area__link {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }
    .solutions-areas.animating .solution-area__hook::before {
      transform: scaleY(1) !important;
      animation: none !important;
    }
  }
</style>

<script>
  // ─────────────────────────────────────────────────────────
  // SolutionsAreas — per-block viewport-triggered reveal
  //
  // Two observers:
  //   1. One for the section's heading block (reveals when the section
  //      first enters view)
  //   2. One per .solution-area (each reveals when it scrolls in)
  // ─────────────────────────────────────────────────────────
  function setupSolutionsAreas() {
    const sec = document.querySelector<HTMLElement>(".solutions-areas");
    if (!sec) return;
    if (sec.dataset.areasRevealInit === "true") return;
    sec.dataset.areasRevealInit = "true";

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;
    if (prefersReducedMotion) return;

    sec.classList.add("animating");

    // Section-level observer — reveals the heading block on first entry.
    const sectionObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            sec.classList.add("in-view");
            sectionObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );
    sectionObserver.observe(sec);

    // Per-area observer — each block reveals independently as the user
    // scrolls through the section.
    const areaObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("in-view");
            areaObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.25 }
    );
    const areas = sec.querySelectorAll<HTMLElement>(".solution-area");
    areas.forEach((area) => areaObserver.observe(area));
  }

  document.addEventListener("DOMContentLoaded", setupSolutionsAreas);
  document.addEventListener("astro:page-load", setupSolutionsAreas);
</script>
