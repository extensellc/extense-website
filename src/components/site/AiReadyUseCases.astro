---
/*
  AiReadyUseCases — "Every AI Use Case Needs the Same Foundation" on
  /solutions/ai-ready-content.

  Rebuilt from 5 editorial chapter-blocks to the OLD ex-tense.co 7-row
  comparison table (Use Case | What It Needs from Content | Without
  Structure | With Extense Structure). [OLD] copy verbatim.

  Render: hairline comparison table on desktop (mono header, the
  "With Extense" column carries a light-amber wash + accent header text,
  the "without" cells read muted). Stacks to per-use-case cards < 768px,
  where a 4-column table is unreadable. The old page used red/green
  semantic color throughout; we translate to the locked single-amber
  palette — wash on the positive column only.

  border-top hairline divides from the two-pipeline comparison above.
  Animation: viewport-triggered staggered fade-up (rows on desktop, cards
  on mobile). prefers-reduced-motion: static.
*/

interface UseCaseRow {
  useCase: string;
  needs: string;
  without: string;
  withExtense: string;
}

const rows: UseCaseRow[] = [
  {
    useCase: "Chatbot / RAG",
    needs: "Typed chunks, metadata filters, section IDs for citation",
    without: "25–35% precision. Hallucinations fill gaps.",
    withExtense: "85%+ precision. Cited, traceable answers.",
  },
  {
    useCase: "Semantic Search",
    needs: "audience, difficulty, domain metadata per topic",
    without: "Relevance improves slightly. Filtering impossible.",
    withExtense: "Role-scoped results. Right level, right domain.",
  },
  {
    useCase: "AI-Assisted Translation",
    needs: "Semantic elements (<step>, <warning>, <shortdesc>)",
    without: "NMT treats everything as prose. Quality inconsistent.",
    withExtense: 'Element-aware NMT. Safety phrasing rules fire on <note type="warning">.',
  },
  {
    useCase: "LLM Fine-Tuning",
    needs: "Clean, typed, deduplicated training examples",
    without: "Noisy training data. Model learns contradictions.",
    withExtense: "High-signal corpus. Model learns your voice, not an average.",
  },
  {
    useCase: "Personalization",
    needs: "audience + difficulty metadata on every topic",
    without: "Same content for everyone. Personalization is theoretical.",
    withExtense: "Dynamic delivery by role, level, product line.",
  },
  {
    useCase: "Compliance Auditing",
    needs: "Schema-enforced structure to audit against",
    without: "AI can flag keywords but not structural gaps.",
    withExtense: "AI detects missing <prereq>, untagged warnings, coverage gaps.",
  },
  {
    useCase: "AI-Assisted Authoring",
    needs: "Typed templates + controlled vocabulary constraints",
    without: "AI generates off-topic, inconsistent drafts.",
    withExtense: "AI fills typed templates. Output is consistently on-structure.",
  },
];
---

<section class="airdy-foundation" aria-labelledby="airdy-foundation-heading">
  <div class="container-data airdy-foundation__inner">
    <div class="airdy-foundation__heading-block">
      <h2 id="airdy-foundation-heading" class="airdy-foundation__heading">
        Every AI Use Case Needs the Same Foundation
      </h2>
      <p class="airdy-foundation__subdeck">
        It&rsquo;s not just chatbots. Every AI initiative your organization runs draws from the same content well.<br />
        Structure it once &mdash; every system benefits.
      </p>
    </div>

    <!-- Desktop: comparison table -->
    <table class="foundation-table">
      <colgroup>
        <col class="foundation-table__col-usecase" />
        <col class="foundation-table__col-needs" />
        <col class="foundation-table__col-without" />
        <col class="foundation-table__col-with" />
      </colgroup>
      <thead>
        <tr>
          <th scope="col">AI Use Case</th>
          <th scope="col">What It Needs from Content</th>
          <th scope="col">Without Structure</th>
          <th scope="col" class="is-accent">With Extense Structure</th>
        </tr>
      </thead>
      <tbody>
        {rows.map((row, i) => (
          <tr class="foundation-row" style={`--i: ${i}`}>
            <th scope="row" class="cell-usecase">{row.useCase}</th>
            <td class="cell-needs">{row.needs}</td>
            <td class="cell-without">{row.without}</td>
            <td class="cell-with">{row.withExtense}</td>
          </tr>
        ))}
      </tbody>
    </table>

    <!-- Mobile: per-use-case cards -->
    <ul class="foundation-cards">
      {rows.map((row, i) => (
        <li class="foundation-card" style={`--i: ${i}`}>
          <p class="foundation-card__name">{row.useCase}</p>
          <div class="foundation-card__row">
            <span class="foundation-card__label">Needs</span>
            <span class="foundation-card__val">{row.needs}</span>
          </div>
          <div class="foundation-card__row">
            <span class="foundation-card__label">Without structure</span>
            <span class="foundation-card__val foundation-card__val--muted">{row.without}</span>
          </div>
          <div class="foundation-card__row foundation-card__row--with">
            <span class="foundation-card__label">With Extense</span>
            <span class="foundation-card__val">{row.withExtense}</span>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  /* Locked light-amber wash (EXTENSE_DESIGN_BRIEF — badges/panels). Not
     tokenized; scoped here for the positive-outcome column/row. */
  .airdy-foundation {
    --wash-amber: #fef3c7;
    padding-top: var(--section-pad-default);
    padding-bottom: var(--section-pad-default);
    border-top: var(--border-hairline);
  }

  @media (max-width: 767px) {
    .airdy-foundation {
      padding-top: var(--space-16);
      padding-bottom: var(--space-16);
    }
  }

  /* Centered heading; full width so the sub-deck sits on 1–2 lines. */
  .airdy-foundation__heading-block {
    max-width: none;
    margin: 0 auto var(--space-12) auto;
    text-align: center;
  }

  .airdy-foundation__heading {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin: 0;
    text-wrap: balance;
  }

  .airdy-foundation__subdeck {
    margin: var(--space-4) auto 0 auto;
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    text-wrap: pretty;
  }

  /* ── Desktop table ─────────────────────────────────────────────── */
  .foundation-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }

  .foundation-table__col-usecase { width: 17%; }
  .foundation-table__col-needs { width: 25%; }
  .foundation-table__col-without { width: 28%; }
  .foundation-table__col-with { width: 30%; }

  .foundation-table thead th {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-align: left;
    vertical-align: bottom;
    color: var(--color-text-secondary);
    padding: 0 var(--space-6) var(--space-5) var(--space-6);
    border-bottom: 2px solid var(--color-text-primary);
  }
  .foundation-table thead th.is-accent {
    color: var(--color-accent-primary-pressed);
    background-color: var(--wash-amber);
  }

  .foundation-table tbody th,
  .foundation-table tbody td {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    font-weight: var(--weight-regular);
    line-height: var(--leading-normal);
    color: var(--color-text-secondary);
    text-align: left;
    vertical-align: top;
    padding: 28px var(--space-6);
    border-bottom: var(--border-hairline);
    text-wrap: pretty;
  }

  /* Use-case name — mono, primary, the row's "key". Element + tbody in the
     selector so it out-specifies the base `tbody th` color (Astro scopes
     each compound, so type selectors decide ties in the class column). */
  .foundation-table tbody th.cell-usecase {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.02em;
    color: var(--color-text-primary);
  }

  /* "Without" reads muted; "With Extense" carries the wash + primary text. */
  .foundation-table tbody td.cell-without {
    color: var(--color-text-muted);
  }
  .foundation-table tbody td.cell-with {
    background-color: var(--wash-amber);
    color: var(--color-text-primary);
  }

  @media (max-width: 767px) {
    .foundation-table { display: none; }
  }

  /* ── Mobile cards ──────────────────────────────────────────────── */
  .foundation-cards {
    display: none;
  }

  @media (max-width: 767px) {
    .foundation-cards {
      display: flex;
      flex-direction: column;
      gap: var(--space-5);
      list-style: none;
      margin: 0;
      padding: 0;
    }
  }

  .foundation-card {
    border: var(--border-hairline);
    padding: var(--space-6);
  }

  .foundation-card__name {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.02em;
    color: var(--color-text-primary);
    margin: 0 0 var(--space-4) 0;
    padding-bottom: var(--space-3);
    border-bottom: var(--border-hairline);
  }

  .foundation-card__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-1);
    padding: var(--space-3) 0;
  }
  .foundation-card__row + .foundation-card__row {
    border-top: var(--border-hairline);
  }
  .foundation-card__row--with {
    background-color: var(--wash-amber);
    margin: var(--space-2) calc(-1 * var(--space-6)) calc(-1 * var(--space-6));
    padding: var(--space-3) var(--space-6) var(--space-4);
    border-top: var(--border-hairline);
  }

  .foundation-card__label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }
  .foundation-card__row--with .foundation-card__label {
    color: var(--color-accent-primary-pressed);
  }

  .foundation-card__val {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    line-height: var(--leading-normal);
    color: var(--color-text-primary);
    text-wrap: pretty;
  }
  .foundation-card__val--muted {
    color: var(--color-text-muted);
  }

  /* ── Reveal animation ──────────────────────────────────────────── */
  .airdy-foundation.animating .airdy-foundation__heading-block,
  .airdy-foundation.animating .foundation-row,
  .airdy-foundation.animating .foundation-card {
    opacity: 0;
    transform: translateY(8px);
  }

  .airdy-foundation.animating.in-view .airdy-foundation__heading-block {
    animation: airdy-foundation-fade-in 480ms ease-out forwards;
  }
  .airdy-foundation.animating.in-view .foundation-row,
  .airdy-foundation.animating.in-view .foundation-card {
    animation: airdy-foundation-fade-in 420ms ease-out forwards;
    animation-delay: calc(var(--i) * 70ms + 220ms);
  }

  @keyframes airdy-foundation-fade-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .airdy-foundation.animating .airdy-foundation__heading-block,
    .airdy-foundation.animating .foundation-row,
    .airdy-foundation.animating .foundation-card {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }
  }
</style>

<script>
  function setupAiReadyFoundation() {
    const sec = document.querySelector<HTMLElement>(".airdy-foundation");
    if (!sec) return;
    if (sec.dataset.foundationRevealInit === "true") return;
    sec.dataset.foundationRevealInit = "true";

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;
    if (prefersReducedMotion) return;

    sec.classList.add("animating");

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            sec.classList.add("in-view");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1 }
    );

    observer.observe(sec);
  }

  document.addEventListener("DOMContentLoaded", setupAiReadyFoundation);
  document.addEventListener("astro:page-load", setupAiReadyFoundation);
</script>
