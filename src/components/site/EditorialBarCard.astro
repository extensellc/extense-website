---
/*
  EditorialBarCard — hero side panel for /resources.

  States the editorial bar that every publication in this section meets.
  Animates on page load: header in immediately, then lead, then each
  principle staggers in with the hairline rule between them drawing
  left-to-right (scaleX from 0 to 1). Footer ("The signature") slides in
  last. The whole sequence completes in ~1.4 seconds — slow enough to
  feel deliberate, fast enough not to test patience.

  No IntersectionObserver — card is hero-positioned, so we trigger on
  DOMContentLoaded. Reduced motion: show all content immediately.

  Hidden below 1024px.
*/

interface Principle {
  number: string;
  position: string;
  contrast: string;
}

interface Props {
  imprint: string;
  date: string;
  lead: string;
  principles: Principle[];
}

const { imprint, date, lead, principles } = Astro.props;
---

<aside class="ebc" id="ebc" aria-label="Editorial bar for Extense Publications">
  <div class="ebc__panel">
    <header class="ebc__header">
      <p class="ebc__doc-ref">Editorial Bar</p>
      <p class="ebc__counter">
        <span class="ebc__imprint">{imprint}</span>
        <span class="ebc__sep">/</span>
        <span class="ebc__date">{date}</span>
      </p>
    </header>
    <hr class="ebc__rule ebc__rule--top" />

    <p class="ebc__lead">{lead}</p>

    <ol class="ebc__list">
      {principles.map((p, i) => (
        <>
          {i > 0 && <hr class="ebc__rule ebc__rule--between" data-rule-index={i - 1} />}
          <li class="ebc__principle" data-principle-index={i}>
            <span class="ebc__num">{p.number}</span>
            <div class="ebc__body">
              <p class="ebc__position">{p.position}</p>
              <p class="ebc__contrast">{p.contrast}</p>
            </div>
          </li>
        </>
      ))}
    </ol>

    <hr class="ebc__rule ebc__rule--bottom" />
    <footer class="ebc__footer">
      <span>Form: EDITORIAL v1.0</span>
      <span class="ebc__hint">The signature</span>
    </footer>
  </div>
</aside>

<style>
  .ebc {
    display: none;
  }

  @media (min-width: 1024px) {
    .ebc {
      display: block;
      width: 360px;
      flex-shrink: 0;
    }
  }

  .ebc__panel {
    position: relative;
    border: var(--border-hairline);
    background-color: var(--color-page-bg);
    padding: var(--space-4) var(--space-6) var(--space-3);
  }

  .ebc__panel::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 2px;
    background-color: #fcd34d;
    pointer-events: none;
  }

  .ebc__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-3);
  }

  .ebc__doc-ref {
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    text-transform: uppercase;
    margin: 0;
  }

  .ebc__counter {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-1);
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.06em;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    margin: 0;
    font-feature-settings: "tnum";
  }

  .ebc__imprint {
    color: var(--color-link);
    font-weight: var(--weight-semibold);
  }

  .ebc__sep {
    color: var(--color-text-muted);
    margin: 0 2px;
  }

  .ebc__date {
    color: var(--color-text-muted);
  }

  .ebc__rule {
    border: 0;
    border-top: var(--border-hairline);
    margin: var(--space-3) 0;
    transform-origin: left center;
    transform: scaleX(0);
    transition: transform 400ms cubic-bezier(0.2, 0, 0.2, 1);
  }

  .ebc__lead {
    font-family: var(--font-body);
    font-size: 12.5px;
    line-height: 1.4;
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-4) 0;
    text-wrap: pretty;
    opacity: 0;
    transform: translateY(4px);
    transition:
      opacity 280ms cubic-bezier(0, 0, 0.2, 1),
      transform 280ms cubic-bezier(0, 0, 0.2, 1);
  }

  .ebc__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .ebc__principle {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: var(--space-3);
    padding: var(--space-2) 0;
    align-items: baseline;
    opacity: 0;
    transform: translateY(4px);
    transition:
      opacity 320ms cubic-bezier(0, 0, 0.2, 1),
      transform 320ms cubic-bezier(0, 0, 0.2, 1);
  }

  .ebc__num {
    font-family: var(--font-mono);
    font-size: 11.5px;
    font-weight: var(--weight-semibold);
    color: #fcd34d;
    font-feature-settings: "tnum";
    line-height: 1.3;
  }

  .ebc__body {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .ebc__position {
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.35;
    color: var(--color-text-primary);
    font-weight: var(--weight-medium);
    margin: 0;
  }

  .ebc__contrast {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 12px;
    line-height: 1.35;
    color: var(--color-text-muted);
    margin: 0;
  }

  .ebc__footer {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    opacity: 0;
    transform: translateY(4px);
    transition:
      opacity 320ms cubic-bezier(0, 0, 0.2, 1),
      transform 320ms cubic-bezier(0, 0, 0.2, 1);
  }

  .ebc__hint {
    font-style: italic;
    text-transform: none;
    letter-spacing: 0.04em;
  }

  /* ─── Build-in sequence (added when .is-built lands on .ebc) ─── */
  .ebc.is-built .ebc__rule--top              { transform: scaleX(1); transition-delay: 50ms; }
  .ebc.is-built .ebc__lead                   { opacity: 1; transform: translateY(0); transition-delay: 200ms; }
  .ebc.is-built .ebc__principle[data-principle-index="0"] { opacity: 1; transform: translateY(0); transition-delay: 400ms; }
  .ebc.is-built .ebc__rule--between[data-rule-index="0"]  { transform: scaleX(1); transition-delay: 600ms; }
  .ebc.is-built .ebc__principle[data-principle-index="1"] { opacity: 1; transform: translateY(0); transition-delay: 700ms; }
  .ebc.is-built .ebc__rule--between[data-rule-index="1"]  { transform: scaleX(1); transition-delay: 900ms; }
  .ebc.is-built .ebc__principle[data-principle-index="2"] { opacity: 1; transform: translateY(0); transition-delay: 1000ms; }
  .ebc.is-built .ebc__rule--bottom           { transform: scaleX(1); transition-delay: 1200ms; }
  .ebc.is-built .ebc__footer                 { opacity: 1; transform: translateY(0); transition-delay: 1300ms; }

  /* Reduced motion: show everything immediately, no transitions */
  @media (prefers-reduced-motion: reduce) {
    .ebc__rule,
    .ebc__lead,
    .ebc__principle,
    .ebc__footer {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  (function () {
    const card = document.getElementById('ebc');
    if (!card) return;

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) {
      card.classList.add('is-built');
      return;
    }

    // Trigger after one frame so the staged initial state paints before
    // transitions begin. setTimeout (not RAF) for robustness — RAF
    // doesn't fire reliably in backgrounded tabs or headless renderers.
    function trigger() {
      setTimeout(() => {
        card.classList.add('is-built');
      }, 32);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', trigger);
    } else {
      trigger();
    }
  })();
</script>
