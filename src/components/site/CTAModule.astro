---
/*
  CTAModule — Sample Content Assessment conversion zone.

  Spec ref: EXTENSE_DESIGN_BRIEF.md §9 (Conversion)

  - Section background --color-surface-elevated, full-width edge-to-edge
  - container-page interior, content centered in container-prose
  - Heading + body + primary button
  - Locked label: "Sample Content Assessment" — heading and button identical
    across all contexts. Body adapts per page.
  - Routes to /contact with audience toggle preset based on referring page.

  Audience routing: passes audience as URL query param (?audience=public-sector |
  private-sector | general). /contact reads this and presets the AudienceToggle.
*/

interface Props {
  /**
   * Pre-set the /contact AudienceToggle based on the page this CTA appears on.
   * Defaults to "general" — appropriate for /, /about, /capabilities, /insights.
   * Pillar pages use "general"; audience pages and their descendants pass their
   * audience explicitly.
   */
  audience?: "public-sector" | "private-sector" | "general";
  heading?: string;
  body: string;
  buttonLabel?: string;
}

const {
  audience = "general",
  heading = "Sample Content Assessment",
  body,
  buttonLabel = "Submit a sample →",
} = Astro.props;

const href = `/contact?audience=${audience}`;
---

<section class="cta-module" aria-label="Sample Content Assessment">
  <div class="container-page cta-module__inner">
    <div class="cta-module__content">
      <h2 class="cta-module__heading">{heading}</h2>
      <p class="cta-module__body">{body}</p>
      <a href={href} class="cta-module__button">
        {buttonLabel}
      </a>
    </div>
  </div>
</section>

<style>
  .cta-module {
    background-color: var(--color-surface-elevated);
    width: 100%;
    padding-top: var(--space-32);
    padding-bottom: var(--space-32);
  }

  @media (max-width: 767px) {
    .cta-module {
      padding-top: var(--space-20);
      padding-bottom: var(--space-20);
    }
  }

  .cta-module__inner {
    /* container-page provides max-width + padding */
  }

  .cta-module__content {
    max-width: var(--container-prose);
    margin: 0 auto;
  }

  .cta-module__heading {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: var(--weight-regular);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin-bottom: var(--space-6);
    text-wrap: balance;
  }

  .cta-module__body {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-8);
    text-wrap: pretty;
  }

  .cta-module__button {
    display: inline-block;
    font-family: var(--font-body);
    font-size: var(--text-body);
    font-weight: var(--weight-semibold);
    color: var(--color-text-primary);
    background-color: var(--color-accent-primary);
    background-image: linear-gradient(
      135deg,
      var(--color-logo-gradient-1) 0%,
      var(--color-accent-primary) 100%
    );
    padding: var(--space-4) var(--space-8);
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background-color var(--duration-base) var(--easing-out),
      transform var(--duration-base) var(--easing-out);
    border: none;
    cursor: pointer;
  }

  .cta-module__button:hover {
    background-image: none;
    background-color: var(--color-accent-primary-hover);
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .cta-module__button:active {
    background-image: none;
    background-color: var(--color-accent-primary-pressed);
    color: var(--color-page-bg);
  }

  @media (max-width: 767px) {
    .cta-module__button {
      display: block;
      width: 100%;
      text-align: center;
    }
  }
</style>
