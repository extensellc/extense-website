---
/*
  ShimmerLogo — animated brand mark for the footer.

  Adapted from the brand-kit extense-logo-shimmer.html. Two SVG layers
  (dim + bright) with a CSS-mask sweep creating a 5-second shimmer.
  Honors prefers-reduced-motion (mask removed; full logo visible static).

  Uses the horizontal lockup (viewBox 1020x180) — squares left, "EXTENSE"
  wordmark right. Renders on a deep glossy black gradient background.

  The wordmark is white here (it's on the dark shimmer background) regardless
  of light/dark theme — this component is its own visual context.
*/

interface Props {
  /** Optional max-width in px for the logo container. */
  maxWidth?: number;
}

const { maxWidth = 720 } = Astro.props;

const gradientIdDim = `shimmer-amber-dim-${Math.random().toString(36).slice(2, 8)}`;
const gradientIdBright = `shimmer-amber-bright-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="shimmer" role="img" aria-label="Extense LLC">
  <div class="shimmer__logo" style={`--shimmer-max-width: ${maxWidth}px;`}>
    <!-- Dim base layer: full logo at low opacity, always visible -->
    <svg
      class="shimmer__svg shimmer__svg--dim"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 1020 180"
      preserveAspectRatio="xMidYMid meet"
      aria-hidden="true"
    >
      <defs>
        <linearGradient id={gradientIdDim} x1="15" y1="10" x2="155" y2="160" gradientUnits="userSpaceOnUse">
          <stop offset="0%" stop-color="#fcd34d" />
          <stop offset="50%" stop-color="#fde047" />
          <stop offset="100%" stop-color="#f59e0b" />
        </linearGradient>
      </defs>
      <rect x="45" y="10" width="110" height="110" rx="4" fill="none" stroke={`url(#${gradientIdDim})`} stroke-width="5" />
      <rect x="15" y="60" width="100" height="100" rx="4" fill="none" stroke={`url(#${gradientIdDim})`} stroke-width="5" />
      <text
        x="205"
        y="137"
        font-family="'Montserrat', 'Helvetica Neue', Arial, sans-serif"
        font-size="150"
        font-weight="200"
        letter-spacing="20"
        fill="#ffffff"
      >EXTENSE</text>
    </svg>

    <!-- Bright layer: full logo masked by a diagonal sliver that sweeps right→left -->
    <svg
      class="shimmer__svg shimmer__svg--bright"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 1020 180"
      preserveAspectRatio="xMidYMid meet"
      aria-hidden="true"
    >
      <defs>
        <linearGradient id={gradientIdBright} x1="15" y1="10" x2="155" y2="160" gradientUnits="userSpaceOnUse">
          <stop offset="0%" stop-color="#fcd34d" />
          <stop offset="50%" stop-color="#fde047" />
          <stop offset="100%" stop-color="#f59e0b" />
        </linearGradient>
      </defs>
      <rect x="45" y="10" width="110" height="110" rx="4" fill="none" stroke={`url(#${gradientIdBright})`} stroke-width="5" />
      <rect x="15" y="60" width="100" height="100" rx="4" fill="none" stroke={`url(#${gradientIdBright})`} stroke-width="5" />
      <text
        x="205"
        y="137"
        font-family="'Montserrat', 'Helvetica Neue', Arial, sans-serif"
        font-size="150"
        font-weight="200"
        letter-spacing="20"
        fill="#ffffff"
      >EXTENSE</text>
    </svg>
  </div>
</div>

<style>
  .shimmer {
    /* Deep glossy black background per brand kit */
    background: linear-gradient(to bottom right, #000000, #0a0e1a);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-12) var(--space-8);
    min-height: 100%;
    overflow: hidden;
  }

  .shimmer__logo {
    position: relative;
    width: 100%;
    max-width: var(--shimmer-max-width, 720px);
    aspect-ratio: 1020 / 180;
  }

  .shimmer__svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  .shimmer__svg--dim {
    opacity: 0.28;
  }

  .shimmer__svg--bright {
    -webkit-mask-image: linear-gradient(
      102deg,
      transparent 35%,
      black 47%,
      black 53%,
      transparent 65%
    );
    mask-image: linear-gradient(
      102deg,
      transparent 35%,
      black 47%,
      black 53%,
      transparent 65%
    );
    -webkit-mask-size: 300% 100%;
    mask-size: 300% 100%;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: 100% 0;
    mask-position: 100% 0;
    animation: shimmer 5s cubic-bezier(0.42, 0, 0.58, 1) infinite;
  }

  @keyframes shimmer {
    0% {
      -webkit-mask-position: 100% 0;
      mask-position: 100% 0;
    }
    70%,
    100% {
      -webkit-mask-position: 0% 0;
      mask-position: 0% 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .shimmer__svg--bright {
      animation: none;
      -webkit-mask-image: none;
      mask-image: none;
    }
    .shimmer__svg--dim {
      opacity: 1;
    }
  }
</style>
