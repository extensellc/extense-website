---
/*
  Logo — Extense canonical brand mark.

  Stacked layout (matches the canonical extense-logo.svg in the brand kit):
  two overlapping amber-gradient squares on top, "EXTENSE" wordmark centered
  underneath in Montserrat ExtraLight.

  Usage:
    <Logo height={48} />                 -> default, dark wordmark on light bg
    <Logo height={48} variant="dark" />  -> light wordmark on dark bg (footer/shimmer)
    <Logo height={48} monochrome />      -> single-color rendering, inherits currentColor
                                            (footer / proof contexts where the logo should
                                            match surrounding text color)

  Accessibility: SVG has aria-label "Extense LLC" and role="img".
  The wordmark depends on Montserrat (200 weight) — loaded by BaseLayout.

  Source-of-truth dimensions: viewBox 200x225 (matches the brand-kit SVG).

  Safari (locked): Brand colors are hardcoded as hex values directly on
  the SVG attributes, NOT routed through CSS custom properties. Safari /
  WebKit has multiple long-standing bugs with var(...) inside SVG
  presentation attributes — including stop-color on <stop> elements and
  fill on <text> elements — that cause the gradient and wordmark to
  render as none, leaving the entire logo invisible on macOS and iOS.
  CSS-rule routing via class selectors works for <text> but is
  unreliable for <stop>. The brand gradient is locked anyway (#fcd34d /
  #fde047 / #f59e0b per the design brief §14), so hardcoding here is the
  correct trade-off. The same pattern is already in place in
  ShimmerLogo.astro.
*/

interface Props {
  height?: number;
  variant?: "default" | "dark";
  monochrome?: boolean;
  class?: string;
}

const {
  height = 48,
  variant = "default",
  monochrome = false,
  class: className,
} = Astro.props;

// Resolved at build time — Safari-safe because the SVG fill attribute
// gets a literal hex value, never a var().
const wordmarkFill = monochrome
  ? "currentColor"
  : variant === "dark"
    ? "#faf7f2"
    : "#1A1817";

// Safari (locked): set explicit width AND height on the <svg> attribute.
// When only `height` is set and `width` is left to CSS `width: auto`,
// Safari sometimes computes width as 0 instead of inferring it from the
// viewBox aspect ratio (200:225). Result: SVG occupies 0px wide and is
// effectively invisible. Computing the width here guarantees both
// browsers render at the correct size.
const aspectRatio = 200 / 225;
const width = Math.round(height * aspectRatio);

const gradientId = `extense-logo-amber-${Math.random().toString(36).slice(2, 8)}`;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 200 225"
  width={width}
  height={height}
  role="img"
  aria-label="Extense LLC"
  class:list={["extense-logo", className]}
  data-monochrome={monochrome ? "true" : undefined}
>
  <defs>
    <linearGradient id={gradientId} x1="30" y1="10" x2="170" y2="160" gradientUnits="userSpaceOnUse">
      <stop offset="0%" stop-color="#fcd34d" />
      <stop offset="50%" stop-color="#fde047" />
      <stop offset="100%" stop-color="#f59e0b" />
    </linearGradient>
  </defs>
  <!-- Outer square (top-right) -->
  <rect
    x="60" y="10" width="110" height="110" rx="4"
    fill="none"
    stroke={monochrome ? "currentColor" : `url(#${gradientId})`}
    stroke-width="5"
  />
  <!-- Inner square (bottom-left, overlapping) -->
  <rect
    x="30" y="60" width="100" height="100" rx="4"
    fill="none"
    stroke={monochrome ? "currentColor" : `url(#${gradientId})`}
    stroke-width="5"
  />
  <!-- EXTENSE wordmark, centered below the squares -->
  <text
    x="100" y="210"
    text-anchor="middle"
    font-family="'Montserrat', 'Helvetica Neue', Arial, sans-serif"
    font-size="30"
    font-weight="600"
    letter-spacing="6"
    fill={wordmarkFill}
  >EXTENSE</text>
</svg>

<style>
  .extense-logo {
    display: block;
    width: auto;
  }
</style>
