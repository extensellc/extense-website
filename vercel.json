{
  "headers": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "extense-website.vercel.app" }],
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "extense.co" }],
      "destination": "https://www.extense.co/$1",
      "permanent": true
    },
    {
      "source": "/resources/case-studies",
      "destination": "/company/our-work-and-case-studies",
      "permanent": true
    },
    {
      "source": "/resources/case-studies/:slug",
      "destination": "/company/our-work-and-case-studies/:slug",
      "permanent": true
    },
    {
      "source": "/company/about-us",
      "destination": "/company",
      "permanent": true
    }
  ]
}
